MATCH (a:Event {name: '우면산 하류부 토석류(공군부대 연결구역)'}), (b:Damage {name: '공군부대 연결구역 인명피해(2011 우면산)'}) MERGE (a)-[r:CAUSES]->(b) SET r += {directCause: '토석류 매몰', scale: '사망 7명', specialNote: '공군부대 연결 구역 사망자수는 총 사망자 16명 중 7명', evidence: '산사태 및 토석류의 이동경로가 공군부대와 연결되어 있는 구역에서의 사망자수는 총 사망자 16명 중 7명이다.', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0077'};
MATCH (a:Event {name: '2011년 우면산 산사태'}), (b:Damage {name: '2011년 우면산 산사태 총 인명피해'}) MERGE (a)-[r:CAUSES]->(b) SET r += {directCause: '산사태·토석류', scale: '총 사망 16명', evidence: '총 사망자 16명 중 7명이다.', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0078'};
MATCH (a:Facility {name: '공군부대(우면산 정상부)'}), (b:Event {name: '우면산 하류부 토석류(공군부대 연결구역)'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {effectiveness: 'Low', mechanism: '영내 침투수↓ 영외유출수↑이나 총량 일정, 하류부 산사태/토석류 악화 영향 무시 가능', specialNote: '정량 평가 매우 어려움', evidence: '공군부대 영내침투수와 영외유출수의 총량은 공군부대 유무에 관계없이 일정한 값이다... 공군부대 영내 배출수로 인한 하류부 산사태/토석류 악화 영향은 무시할 수 있다고 판단된다.', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0079'};
MATCH (a:ResponseAction {name: '공군부대 주위 관리(2010 교훈 활용)'}), (b:Damage {name: '공군부대 연결구역 인명피해(2011 우면산)'}) MERGE (a)-[r:MITIGATES]->(b) SET r += {effectiveness: 'High', reason: '2010년 곤파스 이후 산사태 경험 교훈 삼아 관리 시 인명·재산피해 감소 가능', evidence: '2010년 태풍 곤파스 이후 공군부대 영내를 비롯하여 우면산 일대 곳곳에서 발생한 산사태 경험을 교훈삼아 공군부대 주위를 관리하였으면 인명 피해는 물론 재산 피해도 많이 줄일 수 있었을 것', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0080'};
MATCH (a:Facility {name: '형촌마을 생태공원 저수지'}), (b:Resilience {name: '생태저수지 사방댐 효과'}) MERGE (a)-[r:HAS_RESILIENCE]->(b) SET r += {effectiveness: 'High', mechanism: '토석류를 내부·유입부에 퇴적시키는 사방댐 역할, 둑 월류 없이 하류 전파 차단', specialNote: 'FLO-2D 모의 결과 현장 사진과 일치', evidence: '유역에서 발생한 토석이 저수지 둑을 월류하여 하류로 전파되지 않음을 모의를 통해 확인... 생태저수지는 토석류를 그 내부와 유입부에 퇴적시키는 사방댐의 역할을 했음을 알 수 있다.', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0081'};
MATCH (a:Resilience {name: '생태저수지 사방댐 효과'}), (b:Damage {name: '형촌마을 토석류 피해'}) MERGE (a)-[r:OFFSETS]->(b) SET r += {effectiveness: 'High', mechanism: '토석류 퇴적·하류 전파 차단으로 마을 피해 경감', evidence: '형촌마을 유역에 위치한 생태공원의 저수지가 토석류로 인한 마을 피해에 미친 영향에 대해 중점적으로 검토하였다... 토석류를 그 내부와 유입부에 퇴적시키는 사방댐의 역할', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0082'};
MATCH (a:Event {name: '여수로 유입부 유송잡물 막힘'}), (b:Event {name: '생태공원 저수지 제체 붕괴'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {mechanism: '여수로 막힘으로 홍수류가 여수로 부근으로 집중→제체 붕괴', directCause: '유송잡물 여수로 막힘', specialNote: '충격·월류에 의한 붕괴 아님', evidence: '저수지는 토석류의 충격 및 월류에 의해서 붕괴된 것이 아니라, 여수로 유입부가 유송잡물에 의해서 막힘으로써 홍수류가 여수로 부근...', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0083'};
MATCH (a:Event {name: '2011년 우면산 토석류'}), (b:Event {name: '형촌마을 생태공원 저수지 토석류 유입·퇴적'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {mechanism: '토석류가 형촌마을 유역 생태공원 저수지로 유입', directCause: '상류 토석류 발생', timing: '산사태 직후', evidence: '우면산 래미안 유역에서 발생한 토석류의 실제 발생 현상을 시뮬레이션... 형촌마을 유역에 위치한 생태공원의 저수지가 토석류로 인한 마을 피해에 미친 영향', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0084'};
MATCH (a:Facility {name: '형촌마을 생태공원 저수지'}), (b:Resilience {name: '생태저수지 토석류 가둠 완충능력'}) MERGE (a)-[r:HAS_RESILIENCE]->(b) SET r += {role: '토석류 차단·완충', effectiveness: 'Med', specialNote: '둑이 붕괴되지 않은 모의에서 토석이 월류하여 하류로 전파되지 않음', evidence: '생태저수지는 토석류를 그 내부와 유입부에 퇴적시키는 사방댐의 역할을 했음을 알 수 있다', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0085'};
MATCH (a:Resilience {name: '생태저수지 토석류 가둠 완충능력'}), (b:Damage {name: '형촌마을 하류부 토석류 피해'}) MERGE (a)-[r:OFFSETS]->(b) SET r += {effectiveness: 'Med', mechanism: '상류 토석류를 가둬 하류 마을 피해 억지', reason: '토석이 저수지 둑을 월류하여 하류로 전파되지 않음', evidence: '유역에서 발생한 토석이 저수지 둑을 월류하여 하류로 전파되지 않음을 모의를 통해 확인... 더 큰 피해 발생을 억지하는 역할', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0086'};
MATCH (a:Event {name: '여수로 유입부 유송잡물 막힘'}), (b:Event {name: '형촌마을 생태공원 저수지 제체 붕괴'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {directCause: '여수로 유입부 막힘으로 홍수류가 여수로 부근에서 월류', mechanism: '월류수가 제체를 침식', probability: 'High', evidence: '저수지는 토석류의 충격 및 월류에 의해서 붕괴된 것이 아니라, 여수로 유입부가 유송잡물에 의해서 막힘으로써 홍수류가 여수로 부근에서 월류하여 제체를 침식시킴으로 인해 붕괴된 것으로 파악된다', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0087'};
MATCH (a:Event {name: '형촌마을 생태공원 저수지 제체 붕괴'}), (b:Damage {name: '형촌마을 하류부 가구 침수피해'}) MERGE (a)-[r:CAUSES]->(b) SET r += {directCause: '저수지 둑 붕괴로 저류수 방류', probability: 'High', scale: '많은 가구', evidence: '형촌마을의 생태 저수지는 둑의 붕괴로 하류부의 많은 가구를 침수시켰으나', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0088'};
MATCH (a:Damage {name: '형촌마을 생태공원 저수지 퇴적'}), (b:Context {name: '생태저수지 퇴적 규모(퇴적심도 1~3m, 퇴사량 2,400㎥)'}) MERGE (a)-[r:QUANTIFIED_BY]->(b) SET r += {role: '퇴적 규모 정량', evidence: '저수지내 퇴적규모는 퇴적심도 약 1~3m 이고, 퇴사량은 약 2,400㎥ 으로 파악된다', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0089'};
MATCH (a:ManmadeHazard {name: '서초터널 발파'}), (b:Event {name: '2011년 우면산 산사태'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'Low', mechanism: '발파 지반진동에 의한 사면 잔류변위 유발', effectiveness: '미미', specialNote: '조사 결과 발파 지반진동이 설계허용치 만족, 사면 안전율 변화 거의 없음 → 산사태와 관련 없다고 판단', evidence: '터널발파로 인한 지반진동의 수준이 설계허용치를 만족... 터널발파는 산사태와 관련이 없다고 판단된다', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0090'};
MATCH (a:ManmadeHazard {name: '서초터널 발파'}), (b:Facility {name: '우면산 사면(터널 직상부·인접)'}) MERGE (a)-[r:AFFECTS]->(b) SET r += {scale: '최대 3.6mm(표토 잔류변위), 토층-암반 경계면 최대 0.1mm', effectiveness: 'Low', mechanism: '발파 지반진동에 의한 사면 잔류변위', specialNote: '무시할 만큼 미소, 사면 안전율 변화 거의 없음', evidence: '터널 직상부 및 인접한 사면에서 잔류변위가 표토에서 최대 3.6mm로 나타났으며, 토층-암반 경계면에서는 최대 0.1mm', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0091'};
MATCH (a:ResponseAction {name: '서초터널 발파 지반진동 영향 검토'}), (b:Context {name: '전원마을 발파영향 해석결과'}) MERGE (a)-[r:QUANTIFIED_BY]->(b) SET r += {role: '전원마을 지점 해석결과', evidence: '<표 5> 전원마을 0.011 / 0.087 / 1.6 / 1.75 / 1.75', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0092'};
MATCH (a:ResponseAction {name: '서초터널 발파 지반진동 영향 검토'}), (b:Context {name: '보덕사 발파영향 해석결과'}) MERGE (a)-[r:QUANTIFIED_BY]->(b) SET r += {role: '보덕사 지점 해석결과', evidence: '<표 5> 보덕사 0.032(기초)0.037(옥상) / 0.147(기초)0.270(옥상) / 3.6 / 1.31 / 1.31', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0093'};
MATCH (a:ResponseAction {name: '서초터널 발파 지반진동 영향 검토'}), (b:Context {name: '정상부 발파영향 해석결과'}) MERGE (a)-[r:QUANTIFIED_BY]->(b) SET r += {role: '정상부 지점 해석결과', evidence: '<표 5> 정상부 0.013 / 0.022 / 0.2 / 1.52 / 1.51', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0094'};
MATCH (a:ResponseAction {name: '서초터널 발파 지반진동 영향 검토'}), (b:Context {name: '송동마을 발파영향 해석결과'}) MERGE (a)-[r:QUANTIFIED_BY]->(b) SET r += {role: '송동마을 지점 해석결과', evidence: '<표 5> 송동마을 0.017 / 0.147 / 0.2 / 1.71 / 1.71', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0095'};
MATCH (a:ResponseAction {name: '서초터널 발파 지반진동 영향 검토'}), (b:Context {name: '전원마을 계곡부 발파영향 해석결과'}) MERGE (a)-[r:QUANTIFIED_BY]->(b) SET r += {role: '전원마을 계곡부 지점 해석결과', evidence: '<표 5> 전원마을 계곡부 0.013 / 0.124 / 0.1 / 1.52 / 1.52', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0096'};
MATCH (a:RiskFactor {name: '대비 부족(산사태 안전대책 미시행)'}), (b:Event {name: '2011년 우면산 산사태'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'High', reason: '항구적 산사태 안전대책 부재', mechanism: '대비 부족으로 피해 확대', evidence: '집중강우와 이에 대한 대비가 부족했던 이유로 발생... 2010년 산사태 이후 발생한 산사태에 대한 붕괴 복구 대책은 일부 붕괴 발생지역에 국한된 대책으로서 항구적인 산사태 안전 대책으로는 절대 미흡했다', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0097'};
MATCH (a:Context {name: '2011년 우면산 산사태 직전 강우강도'}), (b:Context {name: '서초 관측소 강우 빈도(2011)'}) MERGE (a)-[r:UNDER_CONDITION]->(b) SET r += {role: '강우 빈도 기준', evidence: '서초 관측소 1시간 87.0mm(20년 빈도), 6시간 212.0mm(20년 빈도), 12시간 257.0mm(20년 빈도), 24시간 325.0mm(15년 빈도)', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0098'};
MATCH (a:Context {name: '2011년 우면산 산사태 직전 강우강도'}), (b:Context {name: '남현 관측소 강우 빈도(2011)'}) MERGE (a)-[r:UNDER_CONDITION]->(b) SET r += {role: '강우 빈도 기준', evidence: '남현 관측소 1시간 114.0mm(120년 빈도), 6시간 279.5mm(120년 빈도), 12시간 333.0mm(100년 빈도), 24시간 387.0mm(40년 빈도)', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0099'};
MATCH (a:Event {name: '덕우암 지구 산사태'}), (b:Event {name: '2011년 우면산 산사태'}) MERGE (a)-[r:CONCURRENT_WITH]->(b) SET r += {specialNote: '유역 전체에 전방위적으로 발생한 산사태군의 일부', reason: '해석적 예측 가능', evidence: '2011년 덕우암 지구의 산사태는, 공군부대 경계부에서 발생한 것을 포함하여 모두 해석적으로 예측 가능하였으며, 산사태가 유역 전체에 전방위적으로 발생한 점', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0100'};
MATCH (a:ResponseAction {name: '우면산 일대 산사태·토석류 위험도 평가'}), (b:Event {name: '2011년 우면산 산사태'}) MERGE (a)-[r:MODIFIES_RISK_OF]->(b) SET r += {role: '위험지역 식별', effectiveness: 'High', specialNote: '31개 유역 모두 위험/매우 위험 평가 → 사전 안전대책 시 인명손실 예방 및 재산피해 대폭 감소 가능', evidence: '우면산 일대 13개 지구 31개 유역에 대한 산사태 및 토석류 위험도 평가 결과... 31개 유역 모두 위험 또는 매우 위험 지역으로 평가', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0101'};
MATCH (a:Region {name: '우면산 일대 13개 지구 31개 유역'}), (b:Damage {name: '2011년 우면산 산사태 인명·재산 피해'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {role: '위험지역', reason: '31개 유역 전부 위험/매우 위험 평가', evidence: '산사태 및 토석류 안전대책이 즉시 강구되었다면... 인명 손실 예방과 함께 재산 피해도 대폭 감소시킬 수 있었다', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0102'};
MATCH (a:RiskFactor {name: '사방공사·산사태 안전대책 미시행'}), (b:Damage {name: '2011년 우면산 산사태 인명·재산 피해'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'High', reason: '사전 안전대책 부재', mechanism: '안전대책 미시행으로 인명·재산 피해 가중', evidence: '2010년 산사태 피해 이후 덕우암 지구와 공군부대를 포함한 우면산 전 지역에 대한 산사태 및 토석류 안전대책이 즉시 강구되었다면... 인명 손실 예방과 함께 재산 피해도 대폭 감소시킬 수 있었다', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0103'};
MATCH (a:Event {name: '공군부대 영내·외곽 산사태'}), (b:Damage {name: '공군부대 연결구역 하류부 인명피해'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {role: '피해 가중', mechanism: '산사태·토석류 이동경로가 공군부대와 연결된 구역에서 하류부 인명·재산 피해 가중', specialNote: '정량화는 어려움', evidence: '공군부대 영내 및 외곽에서 발생한 산사태는 하류부의 인명 및 재산피해를 가중시켰다... 이동경로가 공군부대와 연결되어 있는 구역에서의 사망자 수는 총 16인 중 7인이다', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0104'};
MATCH (a:Event {name: '공군부대 영내·외곽 산사태'}), (b:Event {name: '우면산 하류부 토석류(공군부대 연결구역)'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {mechanism: '공군부대 산사태 토석이 하류부로 가세', directCause: '공군부대 산사태 및 세굴 토석', specialNote: '정량적 평가 매우 어려움', evidence: '내려간 토석 모두가 가세하여 일어난 것... 규모를 파악할 수 없는 중류부 발생 산사태와 세굴에 의한 토석의 발생을 고려할 때, 하류부에서의 인명 및 재산 피해', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0105'};
MATCH (a:Damage {name: '2011년 우면산 산사태 인명피해'}), (b:Context {name: '공군부대 연결구역 사망자 비중(16인 중 7인)'}) MERGE (a)-[r:QUANTIFIED_BY]->(b) SET r += {role: '공군부대 연결구역 사망자 비중', evidence: '이동경로가 공군부대와 연결되어 있는 구역에서의 사망자 수는 총 16인 중 7인이다', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0106'};
MATCH (a:RiskFactor {name: '임상(수목)·인공시설물·터널발파 영향'}), (b:Event {name: '2011년 우면산 산사태'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'Low', effectiveness: '미미', specialNote: '2차 보완조사 결론상 영향 미미로 판단', evidence: '2011년 우면산 산사태 및 토석류 발생에 대한 임상, 인공시설물, 터널발파 등의 영향은 미미한 것으로 판단된다', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0107'};
MATCH (a:RiskFactor {name: '공군부대 절개면'}), (b:Event {name: '공군부대 영내·외곽 산사태'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'Med', mechanism: '절개면이 산사태 시발점 역할', reason: '공군부대 설치 후 산사태 취약지점', specialNote: '전문가 의견', evidence: '공군부대의 절개면이 시발점이 되어 산사태 원인을 제공하였다는 것은 적절한 지적임', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0108'};
MATCH (a:Event {name: '공군부대 영내 2군데 산사태'}), (b:Event {name: '래미안 유역 산사태·토석류'}) MERGE (a)-[r:TRIGGERS_SECONDARY]->(b) SET r += {probability: 'Med', mechanism: '공군부대 영내 산사태가 래미안 산사태 촉진', specialNote: '전문가 의견 — 공학적 검토 부재 지적', evidence: '공군부대 영내 2군데 산사태의 래미안 산사태를 촉진시킨 영향의 공학적 검토가 없음', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0109'};
MATCH (a:RiskFactor {name: '공군부대 주변도로 배수시설 불충분'}), (b:Event {name: '2011년 우면산 산사태'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'Med', mechanism: '배수 불량으로 유출수·침출수 증가', reason: '공군부대 배수로 정비 미실시', specialNote: '전문가/유가족 의견', evidence: '공군부대 주변도로의 배수시설 불충분이 산사태 원인이라는 공군 보고서의 언급이 없음 / 공군부대에서 배수로 정비를 제대로 하지 않은 것도 산사태 발생의 원인일 것임', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0110'};
MATCH (a:RiskFactor {name: '절개지형 등산로(보행길 확장·배수로 미설치)'}), (b:Event {name: '2011년 우면산 산사태'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'Med', mechanism: '등산로 확장·배수로 미설치로 산사태 취약화', specialNote: '전문가 의견', evidence: '절개지 형태의 등산로 역시 산사태 발생 위험을 증가시켰다고 판단됨 / 보행길 조성을 위해 등산로를 확장하고 배수로를 설치하지 않아 산사태에 취약해졌음', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0111'};
MATCH (a:RiskFactor {name: '철탑·산책로 등 인공시설물'}), (b:Event {name: '2011년 우면산 산사태'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'Low', specialNote: '전문가 의견 — 검토 누락 지적', evidence: '우면산에 철탑과 산책로에 의한 산사태 영향은 중요하나 검토가 빠졌음', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0112'};
MATCH (a:RiskFactor {name: '벌목 통나무·전원마을 상수리나무 미제거'}), (b:Event {name: '2011년 우면산 산사태'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'Med', mechanism: '유목이 배수로 막힘 효과 유발, 토석류 가세', specialNote: '유가족 민원 미조치', evidence: '벌목한 통나무를 치우지 않고 계속 쌓아놓은 것도 산사태 발생에 영향을 미쳤을 것임 / 전원마을 상수리나무 제거 등의 민원을 수차례 제기', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0113'};
MATCH (a:RiskFactor {name: '유목에 의한 배수로 막힘'}), (b:Event {name: '2011년 우면산 산사태'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'Med', mechanism: '유목이 배수로를 막아 홍수류 월류 및 토석류 가중', specialNote: '전문가 의견 — 침구해석에서 미고려', evidence: '산사태 원인 분석시 강우에 의한 침구해석 이외에 토석류, 유목에 의한 배수로 막힘 효과... 등을 고려하지 않음', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0114'};
MATCH (a:RiskFactor {name: '점토층 용출수·피압수'}), (b:Event {name: '2011년 우면산 산사태'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'Low', mechanism: '점토층 용출수·피압수가 사면 안정에 영향', specialNote: '전문가 의견 — 분석시 미고려', evidence: '점토층의 용출수 및 피압수 특성, 계곡 및 능선의 배수 특성 등을 고려하지 않음', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0115'};
MATCH (a:RiskFactor {name: '발파로 인한 상부 토사 전단강도 장기 약화'}), (b:Event {name: '2011년 우면산 산사태'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'Low', mechanism: '발파로 상부 토사 전단강도 장기 약화', specialNote: 'Malone교수 의견 — 고려 필요', evidence: 'Malone교수 의견대로 발파로 인한 상부 토사 전단강도의 장기적 약화가 고려되어야 함', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0116'};
MATCH (a:Event {name: '서초터널 발파 민원·진동'}), (b:Damage {name: '보덕사 발파진동 보상'}) MERGE (a)-[r:CAUSES]->(b) SET r += {directCause: '터널발파 폭발음·진동', amount: 36000000, unit: '원', specialNote: '시공회사가 보덕사에 3,600만원 보상금 지급', evidence: '시공회사에서 보덕사에 3,600만원의 보상금을 지급했다는 내용... 터널발파 폭발음과 진동으로 생활에 지장을 받고 있다고 민원을 제기', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0117'};
MATCH (a:ResponseActor {name: '행정기관(산림청·서초구청·경찰서·서울시)'}), (b:ResponseAction {name: '주민 정보전파·긴급대처'}) MERGE (a)-[r:FAILS]->(b) SET r += {phase: 'response', reason: '산사태 직전·직후 주민 정보 전파 및 대처 미흡', effectiveness: 'Low', specialNote: '신속 대처 시 인명피해 감소 가능했음', evidence: '산사태가 발생하기 직전과 직후에 산림청, 서초구청, 경찰서, 서울시에서 신속하게 주민에게 관련정보를 알리고 대처했다면 인명피해가 감소할 수 있었는데 행정기관의 대처가 미흡했음', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0118'};
MATCH (a:RiskFactor {name: '행정기관 대처 미흡'}), (b:Damage {name: '2011년 우면산 산사태 인명피해'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'Med', reason: '신속 대처·민원 조치 부재', mechanism: '정보전파 지연으로 대피 실패', evidence: '서초구에서 조치하지 않아서 사망사고 발생 등 피해를 가중시킴 / 행정기관의 대처가 미흡했음', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0119'};
MATCH (a:ResponseAction {name: '대한토목학회 2차 원인 보완조사'}), (b:Event {name: '2011년 우면산 산사태'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {role: '사후 원인 규명', phase: 'recovery', evidence: '2011년 실시한 우면산 산사태 원인조사 누락지에 대한 추가조사와 미흡지에 대한 보완조사를 통해 객관적인 원인 분석을 실시', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0120'};
MATCH (a:ResponseActor {name: '대한토목학회'}), (b:ResponseAction {name: '대한토목학회 2차 원인 보완조사'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '조사 수행', phase: 'recovery', evidence: '본 과업에서는 2011년 실시한 우면산 산사태 원인조사 누락지에 대한 추가조사와 미흡지에 대한 보완조사', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0121'};
MATCH (a:Event {name: '산사태 발생시간 분석'}), (b:Context {name: '산사태 발생시간 강우빈도 쟁점(09시 vs 07:40~08:40)'}) MERGE (a)-[r:OCCURS_AT]->(b) SET r += {role: '발생시간 쟁점', specialNote: '기준시간을 07:40~08:40로 보면 강우빈도가 120년→20년 내외로 대폭 축소', evidence: '119 신고접수시간, CCTV 영상, 유가족 증언... 우면산 산사태는 09시가 아니라 07:40~08:40 사이에 발생하였고, 이 경우에 강우빈도는 120년 빈도에서 20년 내외 빈도로 대폭 축소', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0122'};
MATCH (a:ResponseAction {name: '대한토목학회 2차 원인 보완조사'}), (b:Context {name: '산사태 발생 추정(07:40경~11시경, 150개소 사면붕괴)'}) MERGE (a)-[r:QUANTIFIED_BY]->(b) SET r += {role: '발생시간·붕괴 규모 추정', evidence: '현장촬영영상, 119접수시간 등을 종합적으로 고려하면 산사태는 07:40분경부터 11시경까지 150개소의 사면붕괴가 발생한 것으로 추정됨', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0123'};
MATCH (a:Event {name: '2001년 우면산 강우'}), (b:Event {name: '2011년 우면산 산사태'}) MERGE (a)-[r:CONCURRENT_WITH]->(b) SET r += {role: '비교 사례', specialNote: '2001년 더 큰 강우에도 산사태 미발생 → 2011년 산사태는 인공시설물 영향으로 추정(유가족 의견)', evidence: '2011년보다 2001년에 비가 더 많이 왔는데 2001년에 산사태가 발생하지 않았고, 2011년에 산사태가 발생한 것은 그동안 설치된 인위적인 인공시설물 때문으로 추정됨', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0124'};
MATCH (a:Event {name: '2011년 우면산 산사태'}), (b:Damage {name: '우면산 산사태 인명피해'}) MERGE (a)-[r:CAUSES]->(b) SET r += {directCause: '산사태로 인한 인명사고', scale: '18명', mechanism: '산사태 발생지의 인명피해', evidence: '산사태 인명피해 18명에 대하여 개별적인 산사태 발생원인과 인명사고의 연관성을 분석하였어야', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0125'};
MATCH (a:RiskFactor {name: '공군부대 절개면'}), (b:Event {name: '2011년 우면산 산사태'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'High', mechanism: '절개면이 산사태 시발점이 되어 원인 제공', reason: '공군부대 설계보고서에서 책임 자인', evidence: '공군부대의 절개면이 시발점이 되어 산사태 원인을 제공하였다는 것은 적절한 지적임', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0126'};
MATCH (a:Facility {name: '공군부대'}), (b:Event {name: '2011년 우면산 산사태'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'High', reason: '설치 이후 줄곧 산사태 취약지점', mechanism: '취약지점 형성', evidence: '공군부대는 설치된 이후로 줄 곳 산사태 취약지점이었다고 보아야 할 것임', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0127'};
MATCH (a:Event {name: '공군부대 인근 산사태'}), (b:Damage {name: '공군부대 연결 구역 하류 인명피해'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {directCause: '상부 산사태가 하류 인명피해 가중', mechanism: '공군부대 인근 산사태가 하류로 연결되며 인명피해 가중', scale: '사망자 16명', probability: 'High', evidence: '공군부대 연결 구역 사망자수 16명 / 공군부대 인근 산사태가 하류 인명피해 가중', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0128'};
MATCH (a:RiskFactor {name: '발파로 인한 상부 토사 전단강도 약화'}), (b:Event {name: '2011년 우면산 산사태'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'Low', mechanism: '장기적 지반 전단강도 약화', specialNote: '외국전문가들도 단기적으로는 터널발파와 산사태 직접 연관 없다는 의견', evidence: 'Malone교수 의견대로 발파로 인한 상부 토사 전단강도의 장기적 약화가 고려되어야 함', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0129'};
MATCH (a:Facility {name: '철탑(송전탑)'}), (b:Event {name: '2011년 우면산 산사태'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'Med', mechanism: '인공시설물의 산사태 영향', specialNote: '중요하나 검토가 빠졌다는 지적', evidence: '우면산에 철탑과 산책로에 의한 산사태 영향은 중요하나 검토가 빠졌음', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0130'};
MATCH (a:RiskFactor {name: '절개지 형태의 등산로'}), (b:Event {name: '2011년 우면산 산사태'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'Med', mechanism: '등산로 확장 및 배수로 미설치로 산사태 취약화', reason: '보행길 조성', evidence: '절개지 형태의 등산로 역시 산사태 발생 위험을 증가시켰다고 판단됨 / 보행길 조성을 위해 등산로를 확장하고 배수로를 설치하지 않아 산사태에 취약해졌음', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0131'};
MATCH (a:RiskFactor {name: '서초구 둘레길(자연배수로 횡단)'}), (b:Event {name: '2011년 우면산 산사태'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'Med', mechanism: '자연배수로 횡단 둘레길 조성으로 산사태 원인 제공', specialNote: '토목학회는 기존 등산로 1.2km 정비라고 반박', evidence: '서초구에서 우면산 자연배수로를 횡단하는 방향으로 둘레길을 조성하여 산사태 원인을 제고하였음', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0132'};
MATCH (a:Facility {name: '형촌마을 생태저수지'}), (b:Event {name: '2011년 우면산 토석류'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'Med', mechanism: '저수지 붕괴 시 하류부 토사 끌고 가는 역할 가능', specialNote: '저수지 규모 축소가 산사태 원인 증거라는 주장과 사방댐 신설 때문이라는 반박 대립', evidence: '저수지가 터지면 하류부에 있는 많은 토사를 끌고 가는 역할을 할 수 있다고 판단됨 / 생태저수지의 규모를 축소한 것은 저수지가 산사태 원인이라는 증거', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0133'};
MATCH (a:Facility {name: '형촌마을 생태저수지'}), (b:Event {name: '2011년 우면산 토석류'}) MERGE (a)-[r:AFFECTS]->(b) SET r += {role: '유속 감소 구간', mechanism: '유속이 감소하는 구간으로 토석 가둠', specialNote: '일부 붕괴로 토사 일부가 하류 배사 가능', effectiveness: 'Low', evidence: '생태저수지는 유속이 감소하는 구간이며 / 저수지 일부 붕괴로 인하여 토사 일부가 하류로 배사될 수 있음', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0134'};
MATCH (a:Event {name: '초단기 집중강우(2011.07.27)'}), (b:Event {name: '2011년 우면산 산사태'}) MERGE (a)-[r:TRIGGERS_SECONDARY]->(b) SET r += {directCause: '계류부 사면의 급격한 세굴', mechanism: '초단기 집중강우가 계류부 사면 세굴 및 산사태 유발', probability: 'High', evidence: '11년은 과거에 비해 초단기 집중강우(10분당 10㎜ 이상)가 07:21~08:40까지 80분 동안 지속적으로 내려, 계류부 사면의 급격한 세굴 및 산사태를 유발한 것으로 판단됨', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0135'};
MATCH (a:Event {name: '초단기 집중강우(2011.07.27)'}), (b:Event {name: '계류부 사면 세굴'}) MERGE (a)-[r:CAUSES]->(b) SET r += {directCause: '급격한 세굴', mechanism: '계류부 사면 급격한 세굴', evidence: '계류부 사면의 급격한 세굴 및 산사태를 유발한 것으로 판단됨', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0136'};
MATCH (a:Context {name: '2011.07.27 우면산 강우'}), (b:Event {name: '2011년 우면산 산사태'}) MERGE (a)-[r:UNDER_CONDITION]->(b) SET r += {role: '강우 조건', specialNote: '1시간 최대강우량 우면산 전역 20-120년 빈도 산출', evidence: '우면산 전역의 1시간 최대 강우량을 20-120년 빈도라고 산출 / 11년 일강우량(230㎜)은 11.7.27 07:40까지의 강우량 / 실제 강우가 7.26 16:29부터 내린 점', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0137'};
MATCH (a:RiskFactor {name: '강우 함수비 변화에 의한 지반 전단강도 약화'}), (b:Event {name: '2011년 우면산 산사태'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'High', mechanism: '함수비 증가로 지반 전단강도 약화', reason: '강우 침투', evidence: '시간 보다는 \'강우에 의해서 변화된 함수비에 의한 지반 전단강도 약화\'를 분석해야 함', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0138'};
MATCH (a:Event {name: '공군부대 하단부 세굴'}), (b:Event {name: '2011년 우면산 산사태'}) MERGE (a)-[r:CONCURRENT_WITH]->(b) SET r += {role: '산사태 동반 현상', mechanism: '공개된 공군부대 하단부에 기반암 노출 세굴 발생', evidence: '공개된 공군부대 하단부에 기반암이 노출될 정도로 세굴이 일어났음', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0139'};
MATCH (a:RiskFactor {name: '산지쪽 집수정 막힘'}), (b:Event {name: '2011년 우면산 산사태'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'Med', mechanism: '집수정 막힘으로 배수 불량', reason: '산지쪽 집수정 막힘', evidence: '산지쪽 집수정을 막혔지만 래미안쪽 집수정은 제대로 기능하여 배수가 되었음', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0140'};
MATCH (a:Resilience {name: '래미안쪽 집수정'}), (b:Damage {name: '우면산 산사태 인명피해'}) MERGE (a)-[r:OFFSETS]->(b) SET r += {effectiveness: 'Med', mechanism: '정상 배수로 피해 완충', evidence: '래미안쪽 집수정은 제대로 기능하여 배수가 되었음', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0141'};
MATCH (a:Resilience {name: '형촌마을 생태저수지 상부 사방댐'}), (b:Event {name: '2011년 우면산 토석류'}) MERGE (a)-[r:OFFSETS]->(b) SET r += {effectiveness: 'Med', mechanism: '사방댐 신설로 토석 차단', phase: 'recovery', evidence: '13년 복구공사에서 생태저수지 규모를 줄인 것은 저수지 상부에 사방댐(2개소)를 신설하면서 수로를 설치했기 때문임', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0142'};
MATCH (a:ManmadeHazard {name: '우면산터널 발파'}), (b:Event {name: '2011년 우면산 산사태'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'Low', mechanism: '발파 진동에 의한 지반 영향', effectiveness: 'Low', specialNote: '10년 경과로 영향 미미 판단', evidence: '우면산터널 발파는 01.09월 완료되어 10년 정도 경과되었음', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0143'};
MATCH (a:ResponseAction {name: '대한토목학회 우면산 산사태 2차 원인조사'}), (b:Event {name: '2011년 우면산 산사태'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {role: '원인조사', phase: 'post_event', effectiveness: 'Med', specialNote: '발생현장 데이터 부재로 해석중심 보고서', evidence: '대한토목학회의 우면산 산사태 2차 보고서 / 침투해석 등 토목학회 보고서에서 할 건 다 했음. 발생현장 데이터가 없어 해석중심 보고서임', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0144'};
