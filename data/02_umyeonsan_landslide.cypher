MATCH (a:ResponseAction {name: '강우빈도해석'}), (b:Event {name: '2011년 우면산 산사태'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {role: '원인 규명 분석', specialNote: '서초 5~20년빈도, 남현 7~120년빈도', evidence: '강우 빈도해석 결과로 서초관측소의 경우 ... 5~20년 빈도의 강우량이 발생한 반면 남현관측소의 경우 7~120년 빈도의 강우량이 발생하였다; 서울관측소 시강우 자료(1961~2011년)로써 PWM 매개변수 산정방법 및 Gumbel 확률분포형을 적용', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0022'};
MATCH (a:RiskFactor {name: '원거리 우량관측소(서울관측소 108)'}), (b:Event {name: '2011년 우면산 산사태'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'Low', role: '분석 한계 요인', reason: '근접 AWS(서초·남현) 관측년수 부족으로 빈도해석 직접 불가', specialNote: '강우 원인 규명의 불확실성 요인', evidence: '서울 관측소(108) 지점은 우면산의 강우를 분석하기에 원거리에 위치하고 있어 근접한 기상청 산하 AWS 자료를 활용하였다; 두 관측소 모두 관측년수가 빈도해석을 실시하기엔 부족하여', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0023'};
MATCH (a:Region {name: '우면산 산사태 발생지(12개 지역)'}), (b:Region {name: '서울특별시 서초구'}) MERGE (a)-[r:LOCATED_IN]->(b) SET r += {role: '행정구역 포함', evidence: '2011.7.27 서울특별시 서초구 우면산 지역에 산사태가 발생하여', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0024'};
MATCH (a:Population {name: '우면산 인근 주민'}), (b:Damage {name: '우면산 산사태 인명피해(사망 16명)'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {role: '피해 대상 인구', mechanism: '산지 인접 거주로 토석류 직접 노출', evidence: '2011.7.27 ... 산사태가 발생하여 시민의 생명과 재산피해가 발생하였음', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0025'};
MATCH (a:Region {name: '우면산 일원'}), (b:Context {name: '경기육괴 단층대'}) MERGE (a)-[r:LOCATED_IN]->(b) SET r += {role: '지질구조적 위치', specialNote: '2차 단열 발달 예상 지역', evidence: '우면산 일원은 한반도 지체구조상 경기육괴에 속하며 경기도 일원에 분포하는 대규모의 단층대의 말단부 및 인접하여 위치함으로 인하여 2차 단열의 발달이 예상되는 지역이다.', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0026'};
MATCH (a:RiskFactor {name: '흑운모호상편마암 모암(우면산)'}), (b:Event {name: '2011년 우면산 산사태'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {mechanism: '표토 모암(호상편마암)이 산사태 및 토석류에 취약', probability: 'High', reason: '인근 지역(청계산·구룡산·관악산) 대비 발생 위험도 높음', evidence: '우면산이 인근 지역(청계산, 구룡산, 관악산)에 비해 산사태 및 토석류 발생 위험도가 높은 원인은 표토의 모암(호상 편마암)이 산사태 및 토석류에 취약하기 때문인 것으로 판단된다.', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0027'};
MATCH (a:RiskFactor {name: '제4기 붕적층(우면산)'}), (b:Event {name: '2011년 우면산 산사태'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {mechanism: '두꺼운 붕적층이 사면 불안정 조성', probability: 'Med', evidence: '제4기 붕적층은 우면산 전역에 걸쳐 2~13m의 층후를 보이며 불규칙하게 분포하며 대부분 흑운모호상편마암의 쇄설성 암편으로 구성... 붕적층은 최소 3번의 퇴적이력을 나타내며', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0028'};
MATCH (a:RiskFactor {name: '엽리·절리·단층작용(우면산 지질구조)'}), (b:RiskFactor {name: '제4기 붕적층(우면산)'}) MERGE (a)-[r:DERIVES_FROM]->(b) SET r += {mechanism: '지질구조작용이 두꺼운 붕적층 생성의 주된 원인', directCause: '엽리 발달·절리·단층작용', evidence: '얇은 두께의 엽리 발달과 함께 엽리면을 따라 생성된 절리 그리고 단층작용은 우면산일원에 불규칙하게 두꺼운 층후의 붕적층을 생성시킨 주된 원인으로 판단된다.', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0029'};
MATCH (a:RiskFactor {name: '붕적층-기반암 사이 점토층(우면산)'}), (b:Event {name: '2011년 우면산 산사태'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {mechanism: '점토층이 물 집적·불투수 경계 형성', probability: 'Med', evidence: '붕적층과 기반암 사이에 협재하는 점토층은 붕적층을 통과한 물과 미립의 점토광물들이 집적된 것이다.', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0030'};
MATCH (a:Context {name: '우면산 자연사면 지질위험도'}), (b:Event {name: '2011년 우면산 산사태'}) MERGE (a)-[r:UNDER_CONDITION]->(b) SET r += {role: '지질재해도 평가 기준', specialNote: '지질학적·지형적 요소 종합', evidence: '우면산일원의 지질위험도는 흑운모호상편마암이 분포하며 급사면을 이루고 있는 지역에서 자연사면 지질위험도 60~80점으로 심한 불안정(Strongly instability)한 II등급을 나타낸다.', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0031'};
MATCH (a:Resilience {name: '참나무류 식생(우면산 정상부)'}), (b:Event {name: '2011년 우면산 산사태'}) MERGE (a)-[r:OFFSETS]->(b) SET r += {effectiveness: 'Low', mechanism: '역학적 뿌리 보강 효과', specialNote: 'TRIGRS 모형 해석상 수목 영향력 미미', evidence: '사면 붕괴의 시작점은 주로 우면산 정상 부근이며, 이 지역은 주로 뿌리가 깊고 넓게 발달하는 참나무류가 많이 분포... 2011년 우면산 산사태 발생에 미친 수목의 영향력을 미미한 것으로 판단된다.', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0032'};
MATCH (a:RiskFactor {name: '극한 강우조건(2011 우면산)'}), (b:Event {name: '2011년 우면산 산사태'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {mechanism: '극한 강우 시 식생의 수문학적 영향력(강우차단·증산) 미미해짐', probability: 'High', evidence: '지속시간이 짧고 강우강도가 매우 큰 극한 강우조건하에서는 식생의 수문학적인 영향력이 미미해진다고 알려져 있다.', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0033'};
MATCH (a:Facility {name: '등산로(우면산)'}), (b:Event {name: '2011년 우면산 산사태'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {mechanism: '답압으로 난투수층(불투수층) 형성→강우 시 표면유출 증가·침식 활발', probability: 'Med', specialNote: '정량 연구 거의 없음', evidence: '등산로의 경우, 등산객의 잦은 통행에 의한 답압으로 난투수층(혹은 불투수층)이 형성될 수 있다. 이로 인하여 강우 시 표면 유출을 많이 발생하여 침식 작용이 활발히 일어날 수 있는 가능성은 커질 것', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0034'};
MATCH (a:Facility {name: '약수터(먹는물공동시설, 우면산)'}), (b:Resilience {name: '약수터 배수 효과(우면산)'}) MERGE (a)-[r:HAS_RESILIENCE]->(b) SET r += {effectiveness: 'Low', mechanism: '강우 시 지표유출수를 신속히 하류로 배제하여 지하침투 감소→산사태 위험도 낮춤', evidence: '우면산에 산재하는 약수터의 경우는 배수로가 체계적으로 정비되어 있어서 강우시 지표유출수를 신속하게 하류로 배제하여, 지하침투를 감소시켰을 것이다. 따라서, 이러한 약수터가 오히려 산사태 발생 위험도를 낮추었을 것', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0035'};
MATCH (a:Region {name: '우면산 전체 유역'}), (b:Context {name: '우면산 산사태·토석류 위험도 분석(2011)'}) MERGE (a)-[r:UNDER_CONDITION]->(b) SET r += {role: '위험도 분석 대상', specialNote: '2011년 호우 기준 전역 산사태 위험도 높음, 위험지역이 발생부와 잘 일치', evidence: '우면산의 산사태 및 토석류 위험도 평가를 위해 크고 작은 31개의 유역으로 분류하여 위험도 분석을 실시... 우면산 전체 유역이 산사태 위험도가 높은 것을 알 수 있으며, 위험지역이 발생부와도 잘 일치', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0036'};
MATCH (a:Facility {name: '신동아APT 유역'}), (b:Event {name: '2011년 우면산 산사태'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {riskGrade: '산사태 위험지역', probability: 'High', specialNote: '산림청 산사태 위험지 관리 시스템 6개 위험유역 중 하나', evidence: '31개 유역 중 신동아APT, 임광APT, 래미안APT, 송동마을 및 서울시인재개발원 지역 등의 6개 유역이 산사태 위험지역으로 분류', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0037'};
MATCH (a:Facility {name: '임광APT 유역'}), (b:Event {name: '2011년 우면산 산사태'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {riskGrade: '산사태 위험지역', probability: 'High', specialNote: '6개 위험유역 중 하나', evidence: '신동아APT, 임광APT, 래미안APT, 송동마을 및 서울시인재개발원 지역 등의 6개 유역이 산사태 위험지역으로 분류', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0038'};
MATCH (a:Facility {name: '래미안APT 유역'}), (b:Event {name: '2011년 우면산 산사태'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {riskGrade: '산사태 위험지역', probability: 'High', specialNote: '6개 위험유역 중 하나', evidence: '신동아APT, 임광APT, 래미안APT, 송동마을 및 서울시인재개발원 지역 등의 6개 유역이 산사태 위험지역으로 분류', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0039'};
MATCH (a:Facility {name: '송동마을 유역'}), (b:Event {name: '2011년 우면산 산사태'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {riskGrade: '산사태 위험지역', probability: 'High', specialNote: '6개 위험유역 중 하나, 토석류 위험도 100%', evidence: '신동아APT, 임광APT, 래미안APT, 송동마을 및 서울시인재개발원 지역 등의 6개 유역이 산사태 위험지역으로 분류', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0040'};
MATCH (a:Facility {name: '서울시인재개발원 지역 유역'}), (b:Event {name: '2011년 우면산 산사태'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {riskGrade: '산사태 위험지역', probability: 'High', specialNote: '6개 위험유역 중 하나', evidence: '신동아APT, 임광APT, 래미안APT, 송동마을 및 서울시인재개발원 지역 등의 6개 유역이 산사태 위험지역으로 분류', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0041'};
MATCH (a:ResponseAction {name: '산사태 경보·주의보 적기 발령·전파'}), (b:Damage {name: '2011년 우면산 산사태 인명·재산피해'}) MERGE (a)-[r:MITIGATES]->(b) SET r += {effectiveness: 'High', reason: '적기 신속 전파 시 인명·재산피해 감소했을 것', timing: '사전 경보', evidence: '이에 따른 산사태 경보 및 주의보 발령이 적기에 인근 주민들에게 신속히 전파되었다면 산사태 및 토석류로 인한 인명 및 재산피해는 감소했을 것으로 판단된다.', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0042'};
MATCH (a:Facility {name: '관문사-2 소유역'}), (b:Event {name: '2011년 우면산 토석류'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'High', intensity: '토석류 위험도 97%', riskGrade: '매우위험', evidence: '<표 3> 관문사-2 97%', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0043'};
