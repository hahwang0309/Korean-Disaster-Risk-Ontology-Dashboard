MATCH (a:Facility {name: '뒷골 소유역'}), (b:Event {name: '2011년 우면산 토석류'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'High', intensity: '토석류 위험도 100%', riskGrade: '매우위험', evidence: '<표 3> 뒷골 100%', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0046'};
