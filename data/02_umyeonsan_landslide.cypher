MATCH (a:Event {name: '공군부대 석축 부분파괴(간극수압 상승)'}), (b:Event {name: '공군부대 내부 산사태'}) MERGE (a)-[r:TRIGGERS_SECONDARY]->(b) SET r += {probability: 'Med', mechanism: '강우 침투로 간극수압 상승, 안전율 저하', evidence: '공군부대 실시설계보고서에 강우가 침투하여 간급수압이 높아져 석축이 부분파괴되었다고 함.', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0168'};
MATCH (a:Event {name: '공군부대 하단부 세굴(기반암 노출)'}), (b:Facility {name: '우면산 공군부대 하단부'}) MERGE (a)-[r:OCCURS_AT]->(b) SET r += {role: '발생위치', evidence: '공개된 공군부대 하단부에 기반암이 노출될 정도로 세굴이 일어났음.', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0169'};
MATCH (a:RiskFactor {name: '절개지'}), (b:Event {name: '2011년 우면산 산사태'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'High', reason: '교과서와 국내 사례상 절개지가 세굴보다 더 중요한 산사태 원인', mechanism: '사면 안정성 저하', evidence: '교과서와 국내 사례를 봐도 산사태에는 세굴 보다는 절개지가 더 중요한 원인임.', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0170'};
MATCH (a:RiskFactor {name: '등산로(배수로 부재)'}), (b:Event {name: '2011년 우면산 산사태'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'Med', mechanism: '등산로가 물길 형성·세굴 통로 역할로 산사태 발생에 영향', specialNote: '등산로·군부대 진입로에서 20,30미터씩 흘러내린 빗물흔적 / 정량적 분석은 곤란', evidence: '철탑에서 산사태가 시작되고 산책로도 배수로가 없어서 (배수)통로 역할을 함. / 등산로를 따라 물길이 형성되는 등 등산로가 산사태 발생에 영향을 미친 것으로 추정', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0171'};
MATCH (a:RiskFactor {name: '도로(배수체계 변경)'}), (b:Event {name: '2011년 우면산 산사태'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'Med', mechanism: '배수체계 변경을 통한 세굴', specialNote: '국내사례상 도로·텃밭·과수원 등에 의해 산사태 발생', evidence: '도로는 배수체계 변경으로 통한 세굴의 영향을 철탑은 침투영향을 고려해야 함. / 국내사례를 보면 도로, 텃밭, 과수원 등에 의해 산사태가 발생함.', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0172'};
MATCH (a:RiskFactor {name: '철탑(침투영향)'}), (b:Event {name: '2011년 우면산 산사태'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'Low', mechanism: '침투영향', specialNote: '철탑은 스팟이기 때문에 산사태 촉발 원인이기는 어려움', evidence: '도로는 개연성이 있으나 철탑은 스팟이기 때문에 산사태 촉발 원인이기는 어려움. / 철탑은 침투영향을 고려해야 함.', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0173'};
MATCH (a:RiskFactor {name: '전원마을 주말농장(텃밭)'}), (b:Event {name: '2011년 우면산 산사태'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'Low', mechanism: '텃밭·과수원 등 토지이용 변화', specialNote: '추정 의견', evidence: '전원마을에 주말농장이 있음. 이도 산사태에 영향을 주었을 것임.', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0174'};
MATCH (a:Facility {name: '생태저수지'}), (b:Resilience {name: '생태저수지 토석류 저장 완충능력'}) MERGE (a)-[r:HAS_RESILIENCE]->(b) SET r += {role: '토석류 저장 완충', effectiveness: 'Med', evidence: '우면산 산사태 당시의 생태저수지는 토석류 저장의 긍정적인 영향 및 하류 배수의 부정적인 영향을 함께 미쳤음. / 생태저수지가 토사를 막아 더 큰 재앙을 막았다는 말도 있음.', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0175'};
MATCH (a:Resilience {name: '생태저수지 토석류 저장 완충능력'}), (b:Damage {name: '우면산 토석류 하류 피해'}) MERGE (a)-[r:OFFSETS]->(b) SET r += {effectiveness: 'Med', mechanism: '토석류 저장으로 하류 피해 경감', specialNote: '긍정적 영향', evidence: '상부의 토석(2,400㎥)을 가둔 것을 확인할 수 있었음. / 생태저수지가 토사를 막아 더 큰 재앙을 막았다는 말도 있음.', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0176'};
MATCH (a:RiskFactor {name: '생태저수지 규모 축소(하류 배수 악화)'}), (b:Damage {name: '우면산 토석류 하류 피해'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'Low', mechanism: '하류 배수 악화', specialNote: '생태저수지 축소가 산사태 원인이라는 증거는 아님', evidence: '우면산 산사태 당시의 생태저수지는 토석류 저장의 긍정적인 영향 및 하류 배수의 부정적인 영향을 함께 미쳤음.', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0177'};
MATCH (a:Facility {name: '사방댐(2개소)'}), (b:Facility {name: '생태저수지'}) MERGE (a)-[r:OCCURS_AT]->(b) SET r += {role: '복구시설 신설', phase: 'recovery', evidence: '13년 복구공사에서 생태저수지 규모를 줄인 것은 저수지 상부에 사방댐(2개소)를 신설하면서 수로를 설치했기 때문임.', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0178'};
MATCH (a:ManmadeHazard {name: '터널발파(인근 터널)'}), (b:Event {name: '2011년 우면산 산사태'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'Low', mechanism: '장기적 발파로 인한 토양특성 저하 가능성', specialNote: '수치 해석상 영향 없다고 보이나, 검증 데이터 부재로 영향 없다고 단정 불가', evidence: '터널 발파의 영향은 없다고 보이나... 터널발파의 영향이 없다고 단정할 수 없다는 주장도 있었음.', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0179'};
MATCH (a:RiskFactor {name: '암반-흙 경계부 점토 협재(CL 토질)'}), (b:Event {name: '2011년 우면산 산사태'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'Med', mechanism: '점토 협재부에 강우 침투 시 전단강도 약화', specialNote: '보덕사같이 CL이면 위험, 흙 2~3m·CL·연암 발파 시 전단강도 낮아짐', evidence: '암반과 흙의 경계부 점토가 협재되어 있으면 강우가 침투하면 위험해짐. / 흙이 2,3미터이고 CL이라고 하고 기반암이 연암이라고 하면 발파하면 전단강도가 낮아짐.', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0180'};
MATCH (a:Event {name: '임광/신동아 아파트 산사태'}), (b:Context {name: '08:15경·강우빈도 10년(서초 이수초교 관측소)'}) MERGE (a)-[r:OCCURS_AT]->(b) SET r += {role: '발생추정시간 및 강우빈도', evidence: '임광/신동아 아파트 / 08:15경 / 10년 / 서초(이수초교)', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0181'};
MATCH (a:Event {name: '래미안 아파트 산사태'}), (b:Context {name: '08:30경·강우빈도 12년(서초 교대 관측소)'}) MERGE (a)-[r:OCCURS_AT]->(b) SET r += {role: '발생추정시간 및 강우빈도', evidence: '래미안 아파트 / 08:30경 / 12년 / 서초(교대) / 래미안 아파트는 08:31에 피해 발생', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0182'};
MATCH (a:Event {name: '전원마을 산사태'}), (b:Context {name: '07:40~07:58경·강우빈도 5년이하~20년'}) MERGE (a)-[r:OCCURS_AT]->(b) SET r += {role: '발생추정시간 및 강우빈도', evidence: '전원마을 / 07:40-07:58경 / 5년이하-20년 / 유가족 임방춘·이혜경, 교수 조원철 진술', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0183'};
MATCH (a:Event {name: '양재자동차학원 산사태'}), (b:Context {name: '07:50경·강우빈도 5년(서초구청 관측소)'}) MERGE (a)-[r:OCCURS_AT]->(b) SET r += {role: '발생추정시간 및 강우빈도', evidence: '양재자동차학원 / 07:50경 / 5년 / 서초구청 / 고인과 통화중 07:50에 갑자기 끊김', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0184'};
MATCH (a:Event {name: '형촌마을·송동마을·보덕사 산사태'}), (b:Context {name: '07:40~08:40경·강우빈도 5년이하~107년'}) MERGE (a)-[r:OCCURS_AT]->(b) SET r += {role: '발생추정시간 및 강우빈도', evidence: '형촌마을 송동마을 보덕사 / 07:40-8:40경 / 5년이하-45년 / 5년이하-107년', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0185'};
MATCH (a:Event {name: '윗성뒤마을 산사태'}), (b:Context {name: '07:50경·강우빈도 5년이하(윗성뒤마을)'}) MERGE (a)-[r:OCCURS_AT]->(b) SET r += {role: '발생추정시간 및 강우빈도', evidence: '유가족(함창수) 증언에 따라 윗성뒤마을에 산사태가 07:50에 발생했다면 강우빈도는 5년 이하에 해당됨', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0186'};
MATCH (a:Event {name: '남부순환로 물·토사 유출'}), (b:Context {name: '남부순환로 06:50경'}) MERGE (a)-[r:OCCURS_AT]->(b) SET r += {role: '발생시점', evidence: '남부순환로(서초경찰서 경사 박제영) : 06:50경 물과 토사 쏟아짐. 07:45부터 교통 통제', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0187'};
MATCH (a:Event {name: '남부순환로 토사 유출'}), (b:Event {name: '남부순환로 교통 통제'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {mechanism: '도로 토사 유입으로 교통 통제', timing: '07:45부터', evidence: '남부순환로 : 06:50경 물과 토사 쏟아짐. 07:45부터 교통 통제', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0188'};
MATCH (a:Event {name: '초단기 집중강우 누적급증'}), (b:Event {name: '2011년 우면산 산사태'}) MERGE (a)-[r:TRIGGERS_SECONDARY]->(b) SET r += {probability: 'High', mechanism: '누적강우량 급증 시점에 지역별 산사태 발생', timing: '07:40~08:40', evidence: '초단기 집중강우(10분 10㎜ 이상)가 내려 누적강우량이 급증한 07:40～08:40 사이에 산사태가 발생하였을 것으로 추정', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0189'};
MATCH (a:ResponseActor {name: '서울연구원'}), (b:ResponseAction {name: '학계·전문가 및 시민 의견수렴 절차'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', role: '원인조사 보완·의견수렴', evidence: '서울연구원은 학계․전문가 및 시민 의견 수렴(주민설명회 2012.9.21, 공청회 2012.11.23, 전문가 자문 및 유가족 의견수렴 등), 대한토목학회 답변서(2013.2.1) 검토, 학계․전문가 토론회(1차 5.8, 2차 7.12) 등의 절차를 통해 대한토목학회 조사보고서에 대해 종합적으로 분석하였음.', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0190'};
MATCH (a:ResponseActor {name: '대한토목학회 조사단'}), (b:ResponseAction {name: '대한토목학회 우면산 산사태 원인조사'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', role: '원인조사', effectiveness: 'Med', specialNote: '대표시간 09시 적용한 강우분석, 일부 항목 규명 미흡', evidence: '대한토목학회는 우면산 전역의 산사태 발생(150개소)을 고려한 강우분석을 위해 대표시간을 적용한 것 / 우면산 민관합동 TF에서는 대한토목학회에 권한과 책임을 전적으로 부여', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0191'};
MATCH (a:RiskFactor {name: '대한토목학회 강우빈도 120년 산정(대표시간 09시)'}), (b:ResponseAction {name: '대한토목학회 우면산 산사태 원인조사'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'Low', reason: '대표시간 적용으로 강우빈도 과대 산정(천재 이미지 형성)', specialNote: '지역별 발생시간 기준 시 10년 빈도, 방법론적 한계 지적', effectiveness: 'Low', evidence: '강우빈도 120년이라는 말이 천재라는 이미지를 강하게 만든 요인이 됨. / 산사태가 날 만큼 비가 충분히 왔다는게 10년 빈도 정도이나 특별한 설명도 없이 보고서에서 120년 빈도로 강조한 것은 타당하지 않음.', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0192'};
MATCH (a:ResponseAction {name: '레이더 영상 강우분석기법'}), (b:Resilience {name: '산악지역 강우분석 역량'}) MERGE (a)-[r:BUILDS]->(b) SET r += {effectiveness: 'Low', role: '산정상부 강우 저평가 보완', specialNote: '상대적 경향성 판단만 가능, 정량분석 활용 불가', evidence: '레이더 영상을 활용한 강우분석기법은 수증기 밀도 추정 등에 기술적인 한계가 있으므로 상대적인 경향성 판단은 가능하되 정량적 분석에는 활용될 수 없다는 지적이 있었음.', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0193'};
MATCH (a:ResponseAction {name: '위험사면 상시 모니터링·현장조사 기법 제도화'}), (b:Resilience {name: '산사태 원인조사·모니터링 역량'}) MERGE (a)-[r:BUILDS]->(b) SET r += {effectiveness: 'High', role: '산사태 원인조사 한계 개선', phase: 'prevention', evidence: '이를 개선하기 위해서는 위험사면에 대한 상시 모니터링 기술과 산사태 발생 직후 응급복구와 병행될 수 있는 현장조사 기법의 개발이 필요함. 그리고 이를 제도화하여 현실성 있게 시행될 수 있도록 하는 여건 조성도 필요할 것으로 보임.', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0194'};
MATCH (a:RiskFactor {name: '산사태 직전·직후 계측자료 부재'}), (b:ResponseAction {name: '대한토목학회 우면산 산사태 원인조사'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'Med', reason: '계측자료 부재로 명확한 원인 규명 한계, 향후 재발 시 동일 한계', specialNote: '전문가 합치 의견 미도출', evidence: '대한토목학회 조사결과에 대해 정량적으로 개선사항을 제시하기 어려운 이유는 산사태발생 직전과 직후의 계측자료가 없다는 것임.', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0195'};
MATCH (a:RiskFactor {name: '초단기 집중강우 80분 지속(2011)'}), (b:Event {name: '2011년 우면산 산사태'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'High', reason: '2011년보다 큰 과거 강우에도 산사태 미발생, 80분 연속 초단기 집중강우가 2011년 특성', mechanism: '단기 집중으로 함수비 급증', evidence: '2011년에는 과거와는 다르게 10분 당 10밀리 이상 강우가 80분 연속으로 왔다는 특성이 있음.', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0196'};
