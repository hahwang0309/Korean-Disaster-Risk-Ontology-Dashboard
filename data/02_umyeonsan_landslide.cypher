MATCH (a:NaturalHazard {name: '2011년 우면산 집중호우'}), (b:Event {name: '2011년 우면산 산사태'}) MERGE (a)-[r:TRIGGERS]->(b) SET r += {probability: 'High', mechanism: '단기 집중호우 및 장기 누적강우로 사면 포화·강도저하 유발', directCause: '강우', specialNote: '많은 단기 및 장기 강우가 산사태·토석류 발생의 중요한 원인으로 판단', evidence: '2011.7.27 서울특별시 서초구 우면산 지역에 산사태가 발생하여 시민의 생명과 재산피해가 발생하였음; 이와 같이 많은 단기 및 장기 강우가 산사태 및 토석류 발생에 중요한 원인이었을 것으로 판단된다.', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0001'};
MATCH (a:Event {name: '2011년 우면산 산사태'}), (b:Event {name: '2011년 우면산 토석류'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {probability: 'High', mechanism: '사면붕괴 토사가 계곡부·사면을 따라 흐르며 토석류로 전이', directCause: '사면붕괴', specialNote: '사면붕괴 150개소 및 토석류 33개소 발생', evidence: '2011년 태풍 메아리(6월22일~6월27일) 및 계절적 강우의 영향으로 사면붕괴 150개소 및 토석류 33개소가 발생하였다. 남쪽 사면의 토석류는 대부분 계곡부를 따라 흐르는 수로형 토석류의 형태를 보였으며, 북쪽 사면의 토석류는 수로를 벗어나 사면을 따라 빠른 속도로 흐르는 사면형 토석류의 특성을 보였다.', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0002'};
MATCH (a:Event {name: '2011년 우면산 토석류'}), (b:Damage {name: '우면산 산사태 인명피해(사망 16명)'}) MERGE (a)-[r:CAUSES]->(b) SET r += {probability: 'High', mechanism: '토석류가 주택·인명을 매몰', directCause: '토석류', evidence: '\'11. 07. 27 : 우면산 산사태 발생(총 12개 지역, 사망 16명)', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0003'};
MATCH (a:Event {name: '2011년 우면산 토석류'}), (b:Damage {name: '우면산 토석류 주택 파손피해'}) MERGE (a)-[r:CAUSES]->(b) SET r += {probability: 'High', mechanism: '토석류가 주택을 파손', directCause: '토석류', evidence: '우면산 토석류에 의한 파손 세대수를 그림 2에 ... 나타내었다.', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0004'};
MATCH (a:NaturalHazard {name: '2011년 태풍 메아리(MEARI)'}), (b:Event {name: '2011년 우면산 산사태'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'Med', mechanism: '태풍 강우와 계절적 강우가 토양을 사전 포화시켜 사면 불안정 증대', specialNote: '태풍 메아리 및 계절적 강우의 영향', evidence: '2011년 태풍 메아리(6월22일~6월27일) 및 계절적 강우의 영향으로 사면붕괴 150개소 및 토석류 33개소가 발생하였다.', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0005'};
MATCH (a:RiskFactor {name: '장기 누적강우(선행강우)'}), (b:Event {name: '2011년 우면산 산사태'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'High', mechanism: '장기 누적강우로 토양이 사전 포화되어 사면 붕괴 임계 도달', specialNote: '장기 강우가 산사태·토석류 발생의 중요한 원인', evidence: '산사태 및 토석류 발생이전의 장기적인 강우의 영향을 파악하기 위하여 ... 2011년 강우는 1일 누적뿐만 아니라 2일, 30일, 60일, 90일 누적 강우가 모두 2000년 이후 가장 많았던 것으로 나타났다.', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0006'};
MATCH (a:RiskFactor {name: '단기 집중강우'}), (b:Event {name: '2011년 우면산 산사태'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'High', mechanism: '단시간 집중호우로 사면 안정 임계 초과', specialNote: '단기 강우가 산사태·토석류 발생의 중요한 원인', evidence: '이와 같이 많은 단기 및 장기 강우가 산사태 및 토석류 발생에 중요한 원인이었을 것으로 판단된다.', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0007'};
MATCH (a:Event {name: '2011년 우면산 산사태'}), (b:Context {name: '2011-07-27 09시 이전(산사태 발생시각)'}) MERGE (a)-[r:OCCURS_AT]->(b) SET r += {role: '발생일시', evidence: '서초 및 남현관측소의 강우 자료는 산사태 발생시각인 27일 09시 이전까지의 자료를 활용하였으며', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0008'};
MATCH (a:Event {name: '2011년 우면산 산사태'}), (b:Region {name: '우면산 산사태 발생지(12개 지역)'}) MERGE (a)-[r:AFFECTS]->(b) SET r += {role: '노출 지역', scale: '총 12개소, 69만㎡', evidence: '조사대상 : 2011년 우면산 산사태 발생지 전역(총 12개소, 69만㎡)', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0009'};
MATCH (a:RiskFactor {name: '급경사 산지 지형(우면산)'}), (b:Event {name: '2011년 우면산 토석류'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'Med', mechanism: '급경사 지형에서 사면붕괴 토사가 빠르게 토석류로 발달', specialNote: '남쪽 계곡부 수로형, 북쪽 사면형 토석류', evidence: '발생부 및 토석류 이동경로를 지역별로 구분하면 남쪽과 북쪽 지역에서 대부분의 사면붕괴 및 토석류가 발생하였다.', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0010'};
MATCH (a:ResponseActor {name: '서울특별시'}), (b:ResponseAction {name: '우면산 산사태 1차 원인조사'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', timing: '2011-07 ~ 2011-11', role: '1차 원인조사 시행', evidence: '이후 서울시에서는 2011.7~11월까지 1차 원인조사를 실시하였으나 ... 1차 조사에서는 ... 4개소 ... 에 대해서만 조사를 실시하였으나', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0011'};
MATCH (a:ResponseActor {name: '한국지반공학회'}), (b:ResponseAction {name: '우면산 산사태 1차 원인조사'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', timing: '2011-07-29 ~ 2011-11-25', role: '1차 원인조사 수행', evidence: '\'11. 07. 29 : 1차 원인조사(한국지반공학회, \'11. 07. 29 ~ 11. 25)', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0012'};
MATCH (a:ResponseActor {name: '서울연구원'}), (b:ResponseAction {name: '우면산 산사태 원인 추가·보완 조사(2차 원인조사)'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', timing: '2012-05-31 ~ 2014-02-21', role: '2차 원인조사 수행', evidence: '\'12. 05. 31 : 2차 원인조사 착수(서울연구원, 대한토목학회); 과업기간 : 2012. 5. 31. ~ 2014. 2. 21.', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0013'};
MATCH (a:ResponseActor {name: '대한토목학회'}), (b:ResponseAction {name: '우면산 산사태 원인 추가·보완 조사(2차 원인조사)'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', role: '공학적 조사·분석 수행', timing: '2012-05-31 착수', evidence: '수행기관 : 서울연구원(학계·전문가 자문 및 의견수렴), 대한토목학회(공학적 조사 및 분석)', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0014'};
MATCH (a:ResponseAction {name: '우면산 산사태 원인 추가·보완 조사(2차 원인조사)'}), (b:Event {name: '2011년 우면산 산사태'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {reason: '1차 조사결과에 대한 피해주민·학계·전문가·시민사회의 이의제기', role: '재조사', specialNote: '이수곤·박창근 교수 등 학계·전문가, 유가족 재조사 요구', evidence: '1차 원인조사를 실시하였으나 이에 대해 피해주민, 학계·전문가 및 시민사회의 이의제기가 있어 추가 및 보완 조사를 실시한 것임; 학계·전문가(이수곤, 박창근 교수 등), 유가족 재조사 요구', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0015'};
