MATCH (a:Event {name: '송동마을 산사태'}), (b:Context {name: '송동마을·보덕사·윗성뒤마을 산사태 강우빈도 5년이하~107년'}) MERGE (a)-[r:UNDER_CONDITION]->(b) SET r += {specialNote: '지역별 산사태 발생 추정시간대 강우빈도(송동마을·보덕사·윗성뒤마을 공통)', evidence: '송동마을 보덕사 윗성뒤마을 07:40~8:40경 5년이하~107년', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0220'};
MATCH (a:Event {name: '보덕사 산사태'}), (b:Damage {name: '보덕사 붕괴 및 인명 고립피해'}) MERGE (a)-[r:CAUSES]->(b) SET r += {directCause: '산사태로 사찰 건물 붕괴', probability: 'High', evidence: '보덕사 10:17 절이 무너져서 사람이 갇혀있음', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0221'};
MATCH (a:Event {name: '윗성뒤마을 산사태'}), (b:Damage {name: '윗성뒤마을 인명 매몰피해'}) MERGE (a)-[r:CAUSES]->(b) SET r += {directCause: '산사태로 인한 인명 매몰', probability: 'High', evidence: '윗성뒤마을 10:31 어머니가 매몰됐다고 들었는데 연락이 안 됨', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0222'};
MATCH (a:Event {name: '전원마을 산사태'}), (b:Damage {name: '전원마을 급류 인명피해(2명 실종)'}) MERGE (a)-[r:CAUSES]->(b) SET r += {directCause: '급류에 휩쓸림', probability: 'High', evidence: '산쪽에서 흘러나온 급류에 2명이 휩쓸려 떠내려 감', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0223'};
MATCH (a:Event {name: '공군부대 내부 산사태'}), (b:Event {name: '공군부대 하류부 사면파괴'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {mechanism: '부대 내부 산사태로 저류된 물이 흙둑을 넘어 월류(overflow)하거나 흙둑을 침투하여 사면파괴 유발(추정)', directCause: '저류수 월류·침투', probability: 'Med', specialNote: '정량화 어려움, 검토 미흡 지적', evidence: '공군부대 영내 및 외곽에서 발생한 산사태가 하류부의 인명 및 재산피해를 가중시켰다고 판단되나... 저류된 물이 흙둑을 넘어 부대 밖으로 월류(overflow) 하였는지, 흙둑을 침투하여 사면파괴를 유발했는지', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0224'};
MATCH (a:RiskFactor {name: '공군부대 저류수'}), (b:Event {name: '공군부대 하류부 사면파괴'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {mechanism: '저류수 월류·침투로 하류 사면파괴 가능성 증가', probability: 'Med', specialNote: '토목학회 조사에서 월류·침투·배수 여부 분석 미실시', evidence: '부대 내부 산사태로 인해 저류된 물이 흙둑을 넘어 부대 밖으로 월류(overflow) 하였는지, 흙둑을 침투하여 사면파괴를 유발했는지', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0225'};
MATCH (a:RiskFactor {name: '공군부대 영외 배출수'}), (b:Event {name: '2011년 우면산 산사태'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {effectiveness: 'Low', probability: 'Low', specialNote: '영향 미미로 평가', evidence: '공군부대 영외 배출수의 영향은 미미함.', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0226'};
MATCH (a:RiskFactor {name: '터널발파'}), (b:Event {name: '2011년 우면산 산사태'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {effectiveness: 'Low', probability: 'Low', specialNote: '토목학회: 터널발파 영향 미미. 다만 장기적 토양특성 저하 분석 미실시로 영향 없다고 단정 불가 주장도 있음', reason: '산사태 발생지점이 터널 종단을 따라 편향되어 있지 않음', evidence: '발파로 인한 사면의 잔류변위가 무시할 만큼 미소한 수준이고... 터널발파의 영향은 미미함.', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0227'};
MATCH (a:RiskFactor {name: '등산로'}), (b:Event {name: '2011년 우면산 산사태'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'Med', specialNote: '토목학회: 영향 미미 판단 / 현장조사 전문가: 등산로를 따라 물길이 형성되는 등 산사태 발생에 영향을 미친 것으로 추정 지적. 신속 복구로 정량적 분석 곤란', mechanism: '등산로를 따라 물길 형성', evidence: '등산로를 따라 물길이 형성되는 등 등산로가 산사태 발생에 영향을 미친 것으로 추정된다는 지적이 있었음.', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0228'};
MATCH (a:Facility {name: '생태저수지'}), (b:Resilience {name: '생태저수지의 토석류 저장 완충역량'}) MERGE (a)-[r:HAS_RESILIENCE]->(b) SET r += {role: '토석류 저장(완충)', effectiveness: 'Med', specialNote: '상류에서 발생한 토석류를 가두어 피해 발생을 억지', evidence: '상류에서 발생한 토석류를 가두어 피해 발생을 억지하기도 했음.', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0229'};
MATCH (a:Resilience {name: '생태저수지의 토석류 저장 완충역량'}), (b:Damage {name: '우면산 산사태 하류부 침수피해'}) MERGE (a)-[r:OFFSETS]->(b) SET r += {effectiveness: 'Med', mechanism: '상류 토석류를 가두어 하류 피해 억지', evidence: '상류에서 발생한 토석류를 가두어 피해 발생을 억지하기도 했음.', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0230'};
MATCH (a:Event {name: '생태저수지 둑 붕괴'}), (b:Damage {name: '우면산 산사태 하류부 침수피해'}) MERGE (a)-[r:CAUSES]->(b) SET r += {directCause: '생태저수지 둑 붕괴', probability: 'High', mechanism: '둑 붕괴로 하류부 침수 유발', evidence: '생태저수지는 둑의 붕괴로 하류부의 침수를 유발하였으나', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0231'};
MATCH (a:ResponseAction {name: '위험사면 상시 모니터링 기술 개발'}), (b:Event {name: '2011년 우면산 산사태'}) MERGE (a)-[r:MODIFIES_RISK_OF]->(b) SET r += {phase: 'prevention', effectiveness: 'Med', reason: '산사태 발생 직전·직후 계측자료 부재 개선', specialNote: '재발방지 제언', evidence: '위험사면에 대한 상시 모니터링 기술과 산사태 발생 직후 응급복구와 병행될 수 있는 현장조사 기법의 개발이 필요함.', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0232'};
MATCH (a:ResponseAction {name: '산사태 원인조사 방법론 연구개발'}), (b:Event {name: '2011년 우면산 산사태'}) MERGE (a)-[r:MODIFIES_RISK_OF]->(b) SET r += {phase: 'prevention', effectiveness: 'Med', reason: '현 산사태 원인조사 방법론은 정밀 적용에 한계', specialNote: '재발방지 제언', evidence: '레이더 영상 분석기법, 수목 및 배수구 단위 사면안정 해석을 위한 정밀 분석기법... 방법론이 정립될 수 있도록 연구개발을 추진해야 할 것', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0233'};
MATCH (a:ResponseActor {name: '대한토목학회'}), (b:ResponseAction {name: '대한토목학회 우면산 산사태 원인조사'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '원인조사', timing: '2012-12-03', specialNote: '우면산 전역 대표시간 09시 적용, 강우강도 최대 20~120년 빈도 분석', evidence: '대한토목학회에서는 당초 우면산 전역의 산사태를 모두 고려하기 위해 대표시간 09시를 적용하고... 분석(2012.12.3)하였으나', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0234'};
MATCH (a:ResponseActor {name: '서울시립대 문영일 교수'}), (b:ResponseAction {name: '지역별 산사태 발생시간 고려 강우빈도 재해석'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '강우빈도 재해석 의견 제시', timing: '2013-08-26', specialNote: '지역별 산사태 발생시간을 고려한 강우 기준시간에 따른 빈도해석이 합리적이라는 의견서', evidence: '대한토목학회 강우량 분석 연구진(서울시립대 문영일 교수)의 의견서(2013.8.26)에서도... 지역별 산사태 발생시간을 고려한 강우 기준시간에 따른 빈도해석으로 하는 것이 합리적이라고 하였음.', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0235'};
MATCH (a:Event {name: '2011년 우면산 산사태'}), (b:Population {name: '우면산 인근 주민'}) MERGE (a)-[r:AFFECTS]->(b) SET r += {role: '노출 인구', specialNote: '산사태·토석류·급류로 주민 매몰·고립·휩쓸림', evidence: '어머니가 매몰됐다고 들었는데 연락이 안 됨 / 절이 무너져서 사람이 갇혀있음 / 산쪽에서 흘러나온 급류에 2명이 휩쓸려 떠내려 감', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0236'};
MATCH (a:Population {name: '우면산 인근 주민'}), (b:Damage {name: '우면산 산사태 인명피해'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {role: '노출', specialNote: '하류부에 인구·시설이 노출되어 인명·재산피해 가중', evidence: '산사태가 하류부의 인명 및 재산피해를 가중시켰다고 판단되나', sourceDoc: '우면산 산사태 원인 보완조사 요약본(서울시 2014)', tripleId: 'T0237'};
