MATCH (a:Event {name: '세월호 특별법 허위사실·오보 확산'}), (b:Event {name: '인터넷 허위정보 2·3차 확산'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {probability: 'High', mechanism: '오보 정정 후에도 인터넷에서 2·3차 잘못된 정보가 재생성·확산', spreadRisk: 'High', evidence: '오보를 통해 퍼져 나간 잘못된 정보는 인터넷 등에서 2차 생성되는데 ... 대표적인 사안마다 2차, 3차 과정 문제까지도', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1130'};
MATCH (a:Resilience {name: '대한변협 공익법률지원단 협업 시스템'}), (b:Damage {name: '세월호 피해자·유가족 2차 피해'}) MERGE (a)-[r:OFFSETS]->(b) SET r += {role: '허위사실 선제 대응 역량', effectiveness: 'Med', evidence: '진상조사팀과 현장대응팀에서 활동한 자료들이 정리되어 전달되다 보니 언론 보도가 정확한 정보였는지를 판단할 수 있었고, 유언비어에 선제적 대응이 가능할 수가 있었다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1131'};
