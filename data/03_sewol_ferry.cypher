MATCH (a:ResponseActor {name: '어버이연합'}), (b:ResponseAction {name: '세월호 특별법 반대 허위 광고 게재'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', timing: '2014', specialNote: '허위사실 광고', evidence: '어버이연합 간부를 7월 29일에 서울중앙지검에 고발했다. 광고 게재 행위가 공직선거법 제93조를 위반한 것이라고 판단한 것이다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1133'};
MATCH (a:ResponseAction {name: '세월호 특별법 반대 허위 광고 게재'}), (b:Event {name: '세월호 특별법 허위사실·오보 확산'}) MERGE (a)-[r:TRIGGERS_SECONDARY]->(b) SET r += {probability: 'High', mechanism: '허위 광고가 특별법 13가지 특혜 허위사실 논란 촉발', spreadRisk: 'High', evidence: '\'세월호 특별법입니까 평생 노숙 보장 특별법입니까?\' 라는 소제목으로 ... 13가지 항목의 특혜를 주는 것처럼 광고는 게재되어 있다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1134'};
MATCH (a:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}), (b:Other {name: '4·16 세월호 참사 진상규명 및 안전사회 건설 등을 위한 특별법'}) MERGE (a)-[r:GUIDED_BY]->(b) SET r += {role: '근거 법령', timing: '여야 합의 통과 후', evidence: '특별법이 통과되기 전까지는 주로 현장 법률 자문·상담 ... 통과 이후에는 주로 대정부 협상 및 사고 관련 정책 및 법 제도 개선에 대해서 활동', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1135'};
MATCH (a:Population {name: '세월호 사고 피해자 및 유가족'}), (b:Region {name: '경기도 안산시'}) MERGE (a)-[r:LOCATED_IN]->(b) SET r += {role: '피해자 소재', evidence: '경기도 안산시 단원고에 재학 중인 학생 및 희생자 또는 생존자의 직계 비속 및 형제자매', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1136'};
MATCH (a:Event {name: '세월호 참사 진도 실종자 수색'}), (b:Event {name: '세월호 침몰사고'}) MERGE (a)-[r:CONCURRENT_WITH]->(b) SET r += {specialNote: '수색 현장에서 실종자 수색 진행', evidence: '진도 실종자 수색 현장에도 세월호특위 위원인 배의철 변호사가 연말까지 상주하였다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1137'};
MATCH (a:Event {name: '해경 초기 구조작업 실패'}), (b:Damage {name: '세월호 참사 인명피해'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {mechanism: '초동 구조 부실로 피해 확대', specialNote: '참사당일부터 이틀뒤까지 구조작업 문제', evidence: '해경의 구조작업에 문제가 있다는 점 ... 초기 구조 활동의 문제점', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1138'};
MATCH (a:ResponseActor {name: '해양경찰청'}), (b:Event {name: '세월호 침몰사고'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {reason: '참사 당시 출동', specialNote: '경비정 123정·헬기 구조 동영상 촬영', evidence: '세월호 참사 당시 출동한 해경 경비정 123정과 헬기가 촬영한 구조 동영상', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1139'};
MATCH (a:Event {name: '경찰의 세월호 피해자 인권침해(2차 가해)'}), (b:Damage {name: '세월호 피해자·유가족 2차 피해'}) MERGE (a)-[r:CAUSES]->(b) SET r += {mechanism: '피해자에 대한 2차 가해', specialNote: '참사 후 인권침해', evidence: '단원경찰서 소속 사복경찰이 희생자 가족들을 차량으로 미행 ... 강제 연행된 여성 참가자에 대한 속옷 탈의를 강요', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1140'};
MATCH (a:ResponseActor {name: '경찰'}), (b:ResponseAction {name: '세월호 피해자 인권보호'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '비민주적·반법치적 행태, 불법적 관행 미시정', specialNote: '2차 가해 유발', evidence: '경찰의 비민주적이고 반법치적인 행태 ... 과거 불법적 관행을 고치지 않고 있는 것', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1141'};
MATCH (a:ResponseActor {name: '해양경찰청'}), (b:ResponseAction {name: '세월호 피해자 보호'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '피해자를 명예훼손으로 고소하여 2차 가해', timing: '2014-06-27', specialNote: '생존 피해자 위축·트라우마 가중', evidence: '해경이 피해자를 명예훼손으로 고소한 것 ... 심한 트라우마를 겪고 있는 피해자 전체에게 2차 피해를 입히고 있다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1142'};
MATCH (a:Event {name: '해경의 피해자 명예훼손 고소(2차 가해)'}), (b:Damage {name: '세월호 피해자·유가족 2차 피해'}) MERGE (a)-[r:CAUSES]->(b) SET r += {mechanism: '증언 앞둔 생존자 위축, 트라우마 가중', specialNote: '2차 피해', evidence: '증언을 앞둔 생존 피해자들을 위축시킬 우려 ... 2차 피해를 입히고 있다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1143'};
MATCH (a:ResponseActor {name: '대한변호사협회'}), (b:ResponseAction {name: '세월호 가족대책위 법률지원 MOU 체결'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', timing: '2014-05-16', role: '피해자 법률지원 협약', evidence: '대한변협은 ... 가족대책위와 업무협약을 체결하고 ... 법률적 지원 대리, 관련 정책 및 제도 개선을 포함한 대책 마련', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1144'};
MATCH (a:ResponseActor {name: '대한변협 공익법률지원단'}), (b:ResponseAction {name: '세월호 공익법률지원단 운영'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'preparedness', timing: '2014-05-03, 2014-05-31', role: '지원 역량 강화 워크숍', evidence: '100여명의 변호사가 참여해 ... 보험·국가배상 등 법률적 문제, 정신적 상담 사례, 2차 피해예방 및 대응책 등에 대한 강의', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1145'};
MATCH (a:ResponseActor {name: '대한변호사협회'}), (b:ResponseAction {name: '안산 합동분향소 법률상담 텐트 운영'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', timing: '2014-05-27~', role: '현장 법률상담 거점 운영', evidence: '5월 17일부터 안산 분향소에 법률상담소를 설치해 계속 운영 ... 24시간 이내 무상으로 답변이 제공', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1146'};
MATCH (a:ResponseActor {name: '대한변호사협회'}), (b:ResponseAction {name: '경찰 인권침해 중단 촉구 성명 발표'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', timing: '2014-05-27', role: '경찰 2차 가해 규탄 성명', evidence: '경찰의 세월호 참사 관련 인권침해 행위 중단 촉구 성명 ... 사과와 시정을 촉구', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1147'};
MATCH (a:ResponseAction {name: '경찰 인권침해 중단 촉구 성명 발표'}), (b:Event {name: '경찰의 세월호 피해자 인권침해(2차 가해)'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {role: '2차 가해 대응', specialNote: '재발방지 대책 요청', evidence: '강제연행 재발방지 대책을 마련할 것을 요청', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1148'};
MATCH (a:ResponseActor {name: '대한변호사협회'}), (b:ResponseAction {name: '해경 2차 가해 중단 촉구 성명 발표'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', timing: '2014-06-27', role: '해경 2차 가해 규탄 성명', evidence: '해경의 세월호 참사 피해자에 대한 2차 가해 중단 촉구 성명 ... 고소 취소와 2차 가해 중지를 강력 촉구', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1149'};
MATCH (a:ResponseAction {name: '해경 2차 가해 중단 촉구 성명 발표'}), (b:Event {name: '해경의 피해자 명예훼손 고소(2차 가해)'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {role: '2차 가해 대응', evidence: '고소 취소와 2차 가해 중지를 강력 촉구', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1150'};
MATCH (a:ResponseActor {name: '대한변호사협회'}), (b:ResponseAction {name: '한부모가정 보험금 지급방식 간담회'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', timing: '2014-05-30', role: '보험금 분쟁 대비 간담회', evidence: '비양육친의 보험금 청구가 문제되자 변협은 금융위원회, 금융감독원 ... 간담회를 개최하여 향후 발생할 수 있는 법적 분쟁에 대비한 방침을 설정', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1151'};
MATCH (a:ResponseActor {name: '세월호 특위 진상조사단'}), (b:ResponseAction {name: '안산 침수휴대폰 복구센터 운영(포렌식)'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', timing: '2014-05~2014-06', role: '피해학생 휴대폰 포렌식 복구', evidence: '희생자 침수 휴대폰 90여 개 자체 복구(포렌식) ... 영상을 비롯한 정보를 복구해 가족들에게 인계 ... 진상조사의 증거로써 확보', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1152'};
MATCH (a:ResponseActor {name: '세월호 특위 진상조사단'}), (b:ResponseAction {name: '진도·제주 VTS 증거보전'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', timing: '2014-06-13', role: 'VTS 교신기록 증거보전', evidence: '제주해상교통관제센터(제주 VTS)에서 ... 세월호 침몰사고 당시 제주VTS와 나눈 교신 기록을 검증하기 위한 증거보전 절차', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1153'};
MATCH (a:ResponseActor {name: '세월호 특위 진상조사단'}), (b:ResponseAction {name: '해경 구조 동영상·해수부 상황보고서 증거보전 신청'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', timing: '2014-06-23', role: '해경 구조 동영상 증거보전', evidence: '해양경찰청을 방문, 세월호 참사 당시 출동한 해경 경비정 123정과 헬기가 촬영한 구조 동영상 등 증거들에 대해 보전신청', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1154'};
MATCH (a:ResponseActor {name: '세월호 특위 진상조사단'}), (b:ResponseAction {name: '세월호 CCTV DVR 64개 증거보전·자체복구'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', timing: '2014-07~2014-08', role: '선내 CCTV DVR 복구', evidence: '세월호 CCTV 64개의 DVR에 대한 증거보전 신청 후 ... 2개월간 바다속에 잠겨 있던 DVR을 복구하는데 성공 ... 증거보전비용 8천여만원', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1155'};
MATCH (a:ResponseActor {name: '세월호 특위 진상조사단'}), (b:ResponseAction {name: '단원고 유가족·생존학생 개별 면담·진술청취카드 작성'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', timing: '2014-06-03~2014-06-09', role: '유가족·생존학생 진술청취', evidence: '단원고 유가족 전원과 생존학생을 반별로 ... 진술청취카드를 작성 ... 사고 및 구조당시의 상황과 대처 현황을 파악, 진상조사의 방향을 결정', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1156'};
MATCH (a:ResponseActor {name: '세월호 특위 언론대응팀'}), (b:ResponseAction {name: '방송통신심의위원회 민원 신청'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', timing: '2014-06-09', role: '구조작업 문제 미보도 언론 민원', evidence: '해경의 구조작업에 문제가 있다는 점을 제대로 보도하지 않은 KBS, MBC 뉴스에 대하여 민원을 신청 ... 방송법 제100조 제1항에 따라 \'권고\' 조치', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1157'};
MATCH (a:ResponseActor {name: '세월호 특위 현장대응지원단'}), (b:ResponseAction {name: '국회·광화문 유가족 지원'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', timing: '2014-06~', role: '시위현장 인권탄압 감시', evidence: '현장대응지원단은 국회, 광화문 등의 시위 현장에서 인권탄압여부를 감시하고, 각종 협상과 법률자문 등의 지원활동을 계속', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1158'};
MATCH (a:ResponseActor {name: '대한변호사협회'}), (b:ResponseAction {name: '허위사실 유포·악성댓글 고소·고발'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', timing: '2014-06~2014-08', role: '허위사실·악성댓글 법적 대응', evidence: '유가족을 비방하는 글이 확산되면서 ... 70여건의 고소·고발을 진행', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1159'};
MATCH (a:Event {name: '유가족 비방·허위사실 유포(2차 가해)'}), (b:Damage {name: '세월호 피해자·유가족 2차 피해'}) MERGE (a)-[r:CAUSES]->(b) SET r += {mechanism: '유가족 명예훼손·모욕', specialNote: '2차 가해', evidence: '유가족을 비방하는 글이 확산 ... 허위사실 유포와 모욕', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1160'};
MATCH (a:ResponseActor {name: '대한변호사협회'}), (b:ResponseAction {name: '광주 선원 등 재판 피해자 지원'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', timing: '2014-06~', role: '재판 피해자 지원·모니터링', evidence: '세월호 선원 등 재판 ... 실제 법정에서 피해자를 위해 변론 ... 청해진해운 재판과 해경 재판, 유병언 비리사건 재판도 수시 모니터링', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1161'};
MATCH (a:ResponseAction {name: '세월호 특별법 제정 추진'}), (b:Event {name: '세월호 침몰사고'}) MERGE (a)-[r:PREVENTS]->(b) SET r += {role: '재난방지·안전사회 건설', effectiveness: 'Med', mechanism: '재난방지 및 대응책 수립 제도화', evidence: '재난방지 및 대응책 수립 ... 안전사회 건설 등을 위한 특별법', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1162'};
MATCH (a:ResponseActor {name: '대한변호사협회'}), (b:ResponseAction {name: '4·16 특별법 제정촉구 성명 발표'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', timing: '2014-07-16', role: '특별법 제정 촉구 성명', evidence: '4·16특별법제정촉구 성명발표 ... 국회는 진실규명과 재발(방지)', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1163'};
MATCH (a:ResponseActor {name: '김앤장 사회공헌위원회'}), (b:ResponseAction {name: '세월호참사 피해 지원 성금 기탁'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', timing: '2014-07-14', role: '피해 지원 성금 기탁', evidence: '목영준 김앤장사회공헌위원회 위원장이 ... 대한변협 협회장에게 세월호참사피해 지원 성금을 전달', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1164'};
MATCH (a:ResponseActor {name: '대한변호사협회'}), (b:ResponseAction {name: '국조특위 모니터링 및 가족대책위 지원'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', timing: '2014-06~2014-07', role: '국정조사 모니터링·가족대책위 지원', evidence: '세월호 침몰사고 진상규명을 위한 국정조사 특별위원회 ... 변협 세월호 특위 위원이 국조특위 위원으로 참여하면서 동시에 가족대책위의 모니터링 활동을 지원', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1165'};
MATCH (a:ResponseActor {name: '국회 세월호 국정조사 특별위원회'}), (b:Event {name: '세월호 침몰사고'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {role: '진상규명 국정조사', timing: '2014-07-07', evidence: '세월호 침몰사고의 진상 규명을 위한 국정조사특별위원회 전체회의', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1166'};
MATCH (a:Event {name: '세월호 침몰사고'}), (b:Event {name: '선장·선원 승객 방기 탈출(2014.4.16)'}) MERGE (a)-[r:TRIGGERS_SECONDARY]->(b) SET r += {mechanism: '침몰 후 선장·선원이 승객을 버리고 먼저 탈출', reason: '선원의 구조의무 방기', timing: '침몰 진행 중', probability: 'High', evidence: '선장과 선원들은 승객을 버리고 먼저 탈출하였으며', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1167'};
MATCH (a:RiskFactor {name: '공권력·행정조직의 무능·무책임'}), (b:Damage {name: '세월호 참사 인명피해'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {mechanism: '무능·무책임한 대응이 피해 확대', reason: '공권력과 행정조직의 무능·무책임', probability: 'High', evidence: '도대체 그 사고 배후에는 어떠한 거악과 비리가 축적되어 있고, 공권력과 행정조직은 얼마나 무능하고 무책임했던 것인지?', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1168'};
MATCH (a:ResponseActor {name: '대한변협 공익법률지원단'}), (b:ResponseAction {name: '세월호 피해자 법률지원 활동'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', role: '피해자 법률지원', scale: '514명 자원', evidence: '세월호 공익법률지원단에 자원했던 514명의 변호인단', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1169'};
MATCH (a:ResponseActor {name: '4·16 세월호참사 특별조사위원회'}), (b:ResponseAction {name: '재난 예방 및 대응방안 마련'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'prevention', role: '진상규명·재난 예방·대응방안 마련', specialNote: '활동 성패에 따라 안전사회 구축 좌우', evidence: '특별조사위원회가 벌일 진상조사, 재난 예방과 대응방안 마련, 피해자 지원 등 활동 ... 4·16 세월호 참사의 직접적 원인은 물론, 배후의 모든 악과 비리, 무능과 무지 ... 진실을 밝혀내야', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1170'};
MATCH (a:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}), (b:ResponseAction {name: '세월호 업무용 노트북 증거보전·자체복구'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', role: '증거보전·증거복구', timing: '2014-07-25', evidence: '세월호 업무용 노트북의 증거보전 신청 이후 세월호 특위 자체적으로 침수된 노트북을 복구, 국정원 지적사항을 발견하고 여러 의문점을 제시', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1171'};
MATCH (a:ManmadeHazard {name: '4·16 세월호 참사'}), (b:Event {name: '세월호 침몰사고'}) MERGE (a)-[r:TRIGGERS]->(b) SET r += {mechanism: '여객선 침몰 발현', scale: '대형', probability: 'High', evidence: '4·16 세월호 참사를 돌이켜 보면 ... 거대한 배가 침몰하였고', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1172'};
