MATCH (a:Population {name: '단원고 2학년 학생 등 승객'}), (b:Event {name: '세월호 대형참사'}) MERGE (a)-[r:AFFECTS]->(b) SET r += {role: '주된 피해 노출 집단', scale: '대규모', evidence: '피해자가 300명을 넘어설 것으로 예상되고, 더군다나 그들의 대부분은 수학여행 중이었던 단원고 2학년 학생들', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0535'};
