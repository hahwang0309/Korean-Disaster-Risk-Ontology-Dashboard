MATCH (a:Event {name: '조속입법 TF 해체'}), (b:Damage {name: '특별법 본회의 통과 무산'}) MERGE (a)-[r:CAUSES]->(b) SET r += {role: '회기 내 특별법 통과 무산', mechanism: '협상체 소멸로 입법 동력 상실', probability: 'High', evidence: '홍일표 의원은 조속입법 TF의 해체를 선언하였다. 이로써 이번 회기 내에 특별법이 신속하게 본회의를 통과하기는 어렵게 되었다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0621'};
MATCH (a:ResponseActor {name: '세월호 특위 특별법 제정팀'}), (b:ResponseAction {name: '특별법 협상 모니터링 및 입법청원안 홍보'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '협상 모니터링·반박논리 개발·언론홍보', phase: 'recovery', timing: '2014-07', evidence: '특별법 제정팀은 여야 협상 경과를 모니터링하면서 ... 반박 논리를 개발 ... 언론 인터뷰 등을 통하여 입법청원안 ... 홍보를 진행', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0622'};
MATCH (a:ResponseActor {name: '황필규·배의철 변호사'}), (b:ResponseAction {name: '변호사 100시간 단식'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '100시간 단식 결행', timing: '2014-07-20', phase: 'recovery', evidence: '황필규, 배의철 변호사가 100시간 단식을, 박종운 변호사 등 자원하는 변호사들 중심으로 24시간이상 동조 릴레이 단식에 들어간다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0623'};
MATCH (a:ResponseActor {name: '박종운 변호사 등 자원 변호사'}), (b:ResponseAction {name: '변호사 릴레이 단식 참여'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '24시간 이상 동조 릴레이 단식', phase: 'recovery', timing: '2014-07-20', evidence: '박종운 변호사 등 자원하는 변호사들 중심으로 24시간이상 동조 릴레이 단식에 들어간다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0624'};
MATCH (a:ResponseActor {name: '공익법률지원변호사단'}), (b:ResponseAction {name: '1일 단식 변호사 연대 서명'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '특별법 제정 촉구 1일 단식 연대 서명', timing: '2014-07-23', phase: 'recovery', evidence: '세월호 특위 위원들과 공익법률지원변호사단을 중심으로 특별법 제정을 촉구하는 자율적인 1일 단식 변호사 연대 서명을 받아 발표', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0625'};
MATCH (a:ResponseActor {name: '변호사 1043인'}), (b:ResponseAction {name: '4·16 특별법 제정 촉구 성명서 발표'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '4·16 특별법 제정 촉구 선언 발표', timing: '2014-07-24', phase: 'recovery', evidence: '‘4·16 특별법 제정을 촉구하는 변호사 1043인 선언’이 발표 ... 대한변협 역사상 최초로 1,000명이 넘는 변호사들이 연대', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0626'};
MATCH (a:RiskFactor {name: '여당의 반대와 대안 부재, 야당의 정치력 부족'}), (b:Damage {name: '특별법 제정 골든타임 상실'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {role: '특별법 제정 골든타임 상실 — ‘법안 침몰’', mechanism: '협상 지연·결렬 반복', probability: 'High', specialNote: '‘법 제정의 골든타임을 놓치며 침몰하고 있’다고 1043인 선언이 지적', evidence: '‘4·16 특별법은 주요 쟁점에 대한 여당의 반대와 대안 부재, 야당의 정치력 부족 속에 법 제정의 골든타임을 놓치며 침몰하고 있’음을 지적', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0627'};
MATCH (a:ResponseAction {name: '여야 특별법 협상'}), (b:ResponseAction {name: '세월호 특별법 제정 추진'}) MERGE (a)-[r:MITIGATES]->(b) SET r += {role: '쟁점이 특별검사제도로 이동 — 부분 진전', timing: '2014-07-23', effectiveness: 'Low', mechanism: '위원회 직접 수사·기소권 대신 특별검사제도와 연계 논의', evidence: '여/야간의 협상 쟁점은 이미 특별검사제도로 옮겨가고 있음에도 불구하고, 여당측은 여전히 수사 및 기소권에 대한 공격에 주력', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0628'};
MATCH (a:ResponseActor {name: '새누리당'}), (b:ResponseAction {name: '세월호 특별법 제정 추진'}) MERGE (a)-[r:FAILS]->(b) SET r += {role: '7·30 보선 전략상 협상 회피·지연', reason: '유언비어 확산으로 보수 결집·보선 승리 도모 위해 7월 넘김이 유리하다는 판단', timing: '2014-07-20', effectiveness: 'Low', evidence: '여당측에서는 ... 피해자 지원 관련 유언비어 확산을 통해 ... 흠집을 내고 ... 법안 협상은 7월을 넘기는 것이 더 낫다는 판단을 한 것으로 추정', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0629'};
MATCH (a:ResponseActor {name: '‘2+2 회담’'}), (b:ResponseAction {name: '세월호 특별법 제정 추진'}) MERGE (a)-[r:FAILS]->(b) SET r += {role: '협상 중단·결렬', timing: '2014-07-30', directCause: '특위 위원 추천 비율·의결정족수·청문회 처벌 규정 등 쟁점 미합의', effectiveness: 'Low', evidence: '저녁 무렵, ‘2+2 회담’은 결렬되고, 그날 밤 7·30 보선 결과는 야당의 참패로 평가', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0630'};
MATCH (a:Event {name: '7·30 재보궐선거 야당 참패'}), (b:Damage {name: '특별법 제정 협상 위기 및 협상 결과물 후퇴'}) MERGE (a)-[r:CAUSES]->(b) SET r += {role: '특별법 제정 협상 위기 — 야당 동력 약화·여당 협상 회피', mechanism: '선거 결과로 정치적 협상력 변화', probability: 'High', evidence: '7·30 보선이 야당의 참패로 끝나자, 특별법 제정 협상에 위기가 찾아왔다. 보선참패로 인하여 야당 국회의원들의 동력은 현저하게 약화', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0631'};
MATCH (a:Damage {name: '특별법 제정 협상 위기 및 협상 결과물 후퇴'}), (b:Damage {name: '단식 농성자 생명·신체 위험'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {role: '단식 농성자 생명·신체 위험 도래', mechanism: '협상 결렬 장기화로 단식 지속', probability: 'High', evidence: '단식 농성하던 세월호 가족대책위 단식자들의 생명 신체에 위험을 줄 상황이 도래하게 될 것이라 판단', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0632'};
MATCH (a:ResponseActor {name: '세월호 특위 특별법 제정팀'}), (b:ResponseAction {name: '진상조사·피해자지원 분리 입법 전략 수정'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '전략 수정 — 진상조사·피해자지원 분리 입법', timing: '2014-07-25', phase: 'recovery', reason: '여당의 피해자 지원 부분 조직적 공격 및 유언비어 확산', evidence: '진상규명과 피해자 지원 부분을 하나의 통합법으로 제정하기로 한 최초의 전략을 수정 ... 피해자 지원 부분을 나중으로 미루고, 먼저 진상조사 부분만을 입법화할 것을 촉구', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0633'};
MATCH (a:ResponseActor {name: '여야 원내대표'}), (b:ResponseAction {name: '여야 원내대표 합의사항(2014-08-07)'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '여야 원내대표 합의 도출', timing: '2014-08-07', phase: 'recovery', specialNote: '세월호 가족대책위·특별법 제정팀도 합의 내용을 알지 못한 채 보도로 접함', evidence: '8월 7일, 여야 원내대표 합의사항이 보도되었다 ... 원내대표 합의사항 1. ... 2. ... 진상조사특별위원회의 구성은 위원장을 포함하여 총 17인', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0634'};
MATCH (a:ResponseActor {name: '새정치민주연합 원내대표'}), (b:ResponseAction {name: '여야 원내대표 합의사항(2014-08-07)'}) MERGE (a)-[r:FAILS]->(b) SET r += {role: '가족대책위 협의 없이 여당과 합의 — 신뢰 훼손', timing: '2014-08-07', reason: '세월호 가족대책위와 협의 없이 합의 도달', effectiveness: 'Low', evidence: '새정치민주연합의 원내대표가 세월호 가족대책위와의 협의 없이 위와 같이 덜컥 여당측과 합의에 도달하자, 세월호 가족대책위 임원진은 물론 유가족들은 격분', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0635'};
MATCH (a:ResponseAction {name: '여야 원내대표 합의사항(2014-08-07)'}), (b:Damage {name: '세월호 가족대책위 유가족 격분 및 신뢰 손상'}) MERGE (a)-[r:CAUSES]->(b) SET r += {role: '유가족 격분 및 내부 갈등 — 신뢰 손상', mechanism: '가족대책위 배제 합의', probability: 'High', evidence: '세월호 가족대책위 임원진은 물론 유가족들은 격분하게 되었고 ... 그와 같은 의사를 특별법 제정팀에 전달', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0636'};
MATCH (a:ResponseAction {name: '시민 동조 단식·문화행사·서명운동'}), (b:Resilience {name: '시민 사회적 연대 역량'}) MERGE (a)-[r:BUILDS]->(b) SET r += {role: '사회적 연대·여론 회복 역량 형성', timing: '2014-07-24', phase: 'recovery', evidence: '광화문을 중심으로 ... 시민들의 동조 단식, 각종 문화행사, 서명 운동 ... 서울시청 앞 광장에서 ‘세월호 100일 음악회\'', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0637'};
MATCH (a:Event {name: '세월호 침몰사고'}), (b:Context {name: '세월호 참사 100일(2014-07-24)'}) MERGE (a)-[r:OCCURS_AT]->(b) SET r += {role: '참사 발생 100일 시점 — 추모·선언 집중일', timing: '2014-07-24', evidence: '7월 24일은 세월호 참사가 발생한 지 100일이 되는 날이었는데', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0638'};
MATCH (a:ResponseAction {name: '세월호 특별법 제정 추진'}), (b:Other {name: '조사권 강화 및 철저한 진실규명 원칙'}) MERGE (a)-[r:GUIDED_BY]->(b) SET r += {role: '조사권 강화·철저한 진실규명을 입법 원칙으로 제시', specialNote: '과거 진상조사위원회 한계 극복 목표', evidence: '과거 각종 진상조사위원회의 한계를 극복하고 철저한 진실규명을 가능케 할 <조사권의 강화>해야 함을 선언', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0639'};
MATCH (a:ManmadeHazard {name: '세월호 침몰사고'}), (b:Event {name: '세월호 침몰사고 진상규명 국정조사'}) MERGE (a)-[r:TRIGGERS]->(b) SET r += {role: '사고 발생이 진상규명 요구를 촉발', timing: '사고 후', mechanism: '사고 진상 규명 필요성 대두', evidence: '‘세월호 침몰사고 진상규명을 위한 국정조사특위’의 청문회가 열리지 못함에 따라, 청문회를 8.18(월)~8.21(목) 4일간 실시하는 것으로 한다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0640'};
MATCH (a:ManmadeHazard {name: '세월호 침몰사고'}), (b:Damage {name: '세월호 사고 희생자 및 유가족'}) MERGE (a)-[r:CAUSES]->(b) SET r += {role: '사고로 다수 사망·실종 희생자 발생', mechanism: '여객선 침몰로 탑승객 인명피해', evidence: '피해학생의 대학입학지원에 관한 특례법’을 의결, 처리한다.; 세월호 사건 유가족의 사전동의를 받아서 선정하여야 한다.; 세월호 참사 일반인 희생자 대표단 3명을 만나', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0641'};
MATCH (a:ResponseActor {name: '세월호 가족대책위'}), (b:ResponseAction {name: '세월호 특별법 제정 추진'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', role: '진상규명 특별법 제정 촉구 및 입법청원안 관철 활동', timing: '2014-08', evidence: '수사 및 기소권을 위원회에 부여하는 입법청원안의 원칙적인 규정에 77%라는 압도적인 찬성표를 던짐; 세월호 가족대책위가 원하는 특별법 제정에 힘을 써달라', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0642'};
MATCH (a:ResponseActor {name: '세월호 특위 특별법 제정팀'}), (b:ResponseActor {name: '세월호 가족대책위'}) MERGE (a)-[r:COORDINATES_WITH]->(b) SET r += {role: '유가족 의견을 정치권에 전달·조율', timing: '2014-08', evidence: '세월호 특위는 총괄지원팀 긴급회의를 통해 세월호 가족대책위의 의견을 존중하여 야당측에도 전달하였다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0643'};
MATCH (a:ResponseActor {name: '세월호 가족대책위'}), (b:ResponseActor {name: '일반인 대책위'}) MERGE (a)-[r:COORDINATES_WITH]->(b) SET r += {role: '연석회의·연락 유지 등 공동대응', timing: '2014-08', specialNote: '이후 견해 대립으로 갈등 표면화', evidence: '세월호 가족대책위 ... 일반인 대책위 임원진과도 연락을 유지하며 함께 나아갈 것을 요청하였다; 일반인 대책위 간의 견해 대립이 표면화되었다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0644'};
MATCH (a:ResponseActor {name: '세월호 가족대책위'}), (b:ResponseAction {name: '교황 면담 및 의사전달'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', role: '교황 면담 통한 진상규명 여론 환기 시도', timing: '2014-08', effectiveness: 'Low', evidence: '교황과의 직접 만남 및 대화의 자리, 편지 전달 등 ... 세월호 가족대책위와 교황과의 만남 및 의사전달 자리를 적극적으로 주선하였다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0645'};
MATCH (a:Population {name: '세월호 가족대책위 단식자'}), (b:Damage {name: '단식자 건강 악화 및 병원 후송'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {role: '단식으로 건강 악화·병원 후송 피해 발생', timing: '2014-08', mechanism: '장기 단식 농성', evidence: '단식 농성에 참여하였던 세월호 가족대책위 단식자들은 한두 분씩 쓰러져서 병원에 실려 가는 상황', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0646'};
MATCH (a:ResponseActor {name: '세월호 가족대책위'}), (b:ResponseAction {name: '여야 원내대표 특별법 합의안 수용'}) MERGE (a)-[r:FAILS]->(b) SET r += {phase: 'recovery', reason: '여야 원내대표 합의안 거부, 입법청원안 원칙 고수로 협상 타결 무산', timing: '2014-08-20', specialNote: '총회 77% 찬성으로 합의안 반대', evidence: '세월호 가족대책위은 제1안 즉, 수사 및 기소권을 위원회에 부여하는 입법청원안의 원칙적인 규정에 77%라는 압도적인 찬성표를 던짐으로써, 여야 원내대표 합의안에 반대하였다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0647'};
MATCH (a:ResponseAction {name: '세월호 특별법 제정 추진'}), (b:ManmadeHazard {name: '세월호 침몰사고'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {role: '사고 진상규명 및 재발방지 목적의 사후 대응', timing: '사고 후', evidence: '수사 및 기소권을 제외하면 그래도 상당 부분 입법청원안이 수용된 상황이므로; 세월호 침몰사고의 진상규명을 위한 국정조사계획서', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0648'};
MATCH (a:Event {name: '세월호 가족대책위와 일반인 대책위 간 갈등'}), (b:Event {name: '여당 분리정책 및 진상규명 동력 약화 우려'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {role: '대책위 간 분열이 여당 분리정책 우려로 확대', timing: '2014-08', mechanism: '조직 간 입장 차이 표면화', spreadRisk: 'Med', evidence: '인천 일반인 대책위는 총회를 통해 여야 원내대표 협상안을 받기로 의결하였고 ... 세월호 가족대책위와의 갈등이 촉발되고 말았다; 여당의 분리정책에 말려드는 것은 아닌지 우려', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0649'};
MATCH (a:Event {name: '세월호 특별법 관련 조직적 악성 댓글 확산'}), (b:ResponseAction {name: '악성 댓글 대응'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {role: '악성 댓글 확산에 대한 대응책 필요', timing: '2014-08-26', evidence: '각종 악성 댓글들이 조직적으로 확산 유포되고 있었으므로 ... 악성 댓글에 강력하게 대응하겠다는 의지를 표현하기도 하였다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0650'};
MATCH (a:Context {name: '리얼미터 세월호 특별호 추가협상 여론조사'}), (b:ResponseAction {name: '세월호 특별법 제정 추진'}) MERGE (a)-[r:QUANTIFIED_BY]->(b) SET r += {role: '특별법 협상 관련 여론 분포 정량화', timing: '2014-08-22', evidence: '리얼미터의 ‘세월호 특별법 추가협상 필요성에 대한 긴급 여론조사’ 결과가 ① ... : 45.8%, ② ... : 38.2%, ③ 모름/무응답 : 16.0%', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0651'};
MATCH (a:ResponseActor {name: '세월호 가족대책위'}), (b:ResponseAction {name: '대통령 면담 요청 및 연좌 농성'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', role: '대통령 면담 시도 및 청운효자동 연좌 농성', timing: '2014-08-22', specialNote: '경찰 제지로 청운효자동주민센터 앞 연좌', evidence: '박근혜 대통령께 ... 애절한 기자회견을 하였고, 대통령 면담을 위해 청와대쪽으로 이동을 하다가 경찰 등의 제지로 인해 청운효자동주민센터 앞에서 연좌를 시작하게 되었다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0652'};
MATCH (a:Context {name: '세월호 가족대책위 총회'}), (b:ResponseAction {name: '여야 원내대표 특별법 합의안 수용'}) MERGE (a)-[r:UNDER_CONDITION]->(b) SET r += {role: '총회 결정이 협상 진로를 좌우한 조건', timing: '2014-08-20', evidence: '8월 20일 19시 30분 안산 경기도미술관에서 세월호 가족대책위 총회가 열렸다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0653'};
MATCH (a:Event {name: '세월호 침몰사고'}), (b:Event {name: '정부의 부실한 초동대처 및 구조활동'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {mechanism: '정부의 부실한 초동대처 및 구조활동', spreadRisk: 'High', timing: '사고 발생 후 한 달', specialNote: '구조 실패가 2차 피해(불신·사회갈등)로 전파', evidence: '사고 발생 후 한 달 동안 정부의 부실한 초동대처 및 구조 활동과 언론사의 부정확한 보도 등으로 인해 피해자와 그 가족들은 사회 전반에 대하여 불신을 갖고 있었다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0654'};
MATCH (a:Event {name: '정부의 부실한 초동대처 및 구조활동'}), (b:Damage {name: '피해자·가족의 사회 전반에 대한 불신'}) MERGE (a)-[r:CAUSES]->(b) SET r += {mechanism: '부실 대응·부정확 보도 누적', directCause: '정부의 부실한 초동대처 및 구조 활동, 언론사의 부정확한 보도', evidence: '정부의 부실한 초동대처 및 구조 활동과 언론사의 부정확한 보도 등으로 인해 피해자와 그 가족들은 사회 전반에 대하여 불신을 갖고 있었다. 자발적으로 이들을 도우러 온 변호사들에게도 신뢰를 보이지 않았다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0655'};
MATCH (a:ManmadeHazard {name: '언론사의 부정확한 보도'}), (b:Damage {name: '피해자·가족의 사회 전반에 대한 불신'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {mechanism: '부정확한 정보 확산으로 불신 증폭', effectiveness: 'High', evidence: '정부의 부실한 초동대처 및 구조 활동과 언론사의 부정확한 보도 등으로 인해 피해자와 그 가족들은 사회 전반에 대하여 불신을 갖고 있었다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0656'};
MATCH (a:Event {name: '탑승객 숫자·명단 발표 오류'}), (b:ResponseAction {name: '탑승객 정확정보 취합·가족 개별면담'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {specialNote: '발표 오류라는 대응실패 현상이 정확 정보 취합 활동을 촉발', timing: '사건 발생 초기', evidence: '사건 발생 초기에 정부에서 발표하는 탑승객의 숫자나 명단에 오류가 많았다. 현장조사팀은 탑승객에 대한 정확한 정보의 취합이 중요하다고 판단하고, 변호사가 가족들을 개별적으로 면담하기로 하였다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0657'};
MATCH (a:ResponseActor {name: '대한변호사협회'}), (b:ResponseAction {name: '세월호참사피해자지원 및 진상조사특별위원회(세월호 특위) 발족'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {timing: '2014-04-30', role: '세월호 특위 정식 발족', evidence: '2014년 4월 30일 대한변협은 세월호 특위를 정식으로 발족시켰고', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0658'};
MATCH (a:ResponseActor {name: '대한변호사협회'}), (b:ResponseActor {name: '세월호 가족대책위'}) MERGE (a)-[r:COORDINATES_WITH]->(b) SET r += {timing: '2014-05-16', role: '업무 협약 체결', evidence: '5월 16일에는 가족대책위와 대한변협 사이에 업무 협약이 체결되었다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0659'};
MATCH (a:ResponseActor {name: '세월호 특위 진상조사단'}), (b:ResponseAction {name: '진상조사단 진상규명 활동(5단계)'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {timing: '2014-05~10', role: '5단계 진상조사 활동 수행', evidence: '진상조사단의 활동은 내용과 시기에 따라 크게 5단계로 구분된다. 첫째는 진상조사단을 구성하여 갖가지 자료수집활동을 한 시기이다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0660'};
MATCH (a:ResponseActor {name: '세월호 특위 진상조사단'}), (b:ResponseAction {name: '전자기기 복원 및 포렌식 작업'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {timing: '2014-05-22~', role: '전자기기 포렌식 입회·증거 추출', evidence: '5월 22일부터는 피해자들의 휴대전화 및 개인 전자기기를 복원하고 그 안에서 증거자료를 추출하는 포렌식(Forensic) 작업이 시작될 예정이었다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0661'};
MATCH (a:RiskFactor {name: '외부세력에 의한 증거 조작·권력 개입 우려'}), (b:Event {name: '증거 조작·권력 개입 사건'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'Med', reason: '참사원인에 여러 의혹이 불거진 상황', evidence: '당시 세월호 참사원인에 대해 여러 가지 의혹이 불거지고 있는 상황이었기 때문에, 작업 중에 외부 세력에 의한 부적절한 조작 내지 권력이 개입될 수 있다는 우려가 팽배하였기 때문이다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0662'};
MATCH (a:ResponseActor {name: '세월호 특위 진상조사단'}), (b:Event {name: '증거 조작·권력 개입 사건'}) MERGE (a)-[r:PREVENTS]->(b) SET r += {timing: '포렌식 진행일마다', mechanism: '변호사가 시간대별 입회하여 작업 진행 감시', effectiveness: 'Med', evidence: '이러한 사태를 미연에 방지하기 위하여 세월호 가족대책위와 함께 현장지원을 하는 진상조사단 변호사들이 ... 포렌식 현장에서 작업의 진행을 지켜보기로 하였다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0663'};
MATCH (a:ResponseActor {name: '국회 세월호 국정조사 특별위원회'}), (b:ResponseAction {name: '세월호 국정조사'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {timing: '2014-06-30~07-11', role: '세월호 국정조사 실시', evidence: '국회도 "세월호 침몰사고 진상규명을 위한 국정조사 특별위원회"를 구성하여 6월 30일부터 7월 11일까지 관련기관을 대상으로 세월호 침몰사고 진상규명을 위한 국정조사를 실시하였다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0664'};
MATCH (a:ResponseActor {name: '세월호 특위 진상조사단'}), (b:ResponseActor {name: '국회의원실'}) MERGE (a)-[r:COORDINATES_WITH]->(b) SET r += {role: '국정조사 자료 분석·의견 제시', timing: '국정조사 기간', evidence: '자료조사팀은 국회의원실에서 함께 자료를 분석하고 의견을 제시해줄 것을 요청받아 세월호 국정조사를 위해 기관보고를 통해 수집된 다양한 자료를 접할 수 있었다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0665'};
MATCH (a:ResponseActor {name: '세월호 특위 진상조사단'}), (b:ResponseAction {name: 'AIS 항적 복원 활동'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {timing: '2014-10', role: 'AIS 미기록 29초 항적 복원', evidence: '다섯째는 10월에 이루어졌던 증거 발굴 활동, 구체적으로는 AIS 항적 복원 활동 부분이다. 진상조사단과 세월호 가족대책위가 함께 협력하여 AIS에 기록되지 않은 29초 동안의 항적을 찾아낸 활동이다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0666'};
MATCH (a:ResponseActor {name: '세월호 특위 진상조사단'}), (b:ResponseActor {name: '세월호 특위 형사재판지원팀'}) MERGE (a)-[r:COORDINATES_WITH]->(b) SET r += {timing: '2014-08말~', role: '형사재판지원팀 활동 합류', evidence: '이준석 외 14인에 대한 살인 등 형사사건(광주지방법원 2014고합180)이 시작되어 8월 말부터 진상조사단 소속 변호사들이 형사재판지원팀의 활동에 합류함으로써, 여러 의혹들에 대한 답을 찾을 수 있었던 활동이다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0667'};
MATCH (a:RiskFactor {name: '세월호 특위 진상조사단 자원봉사 운영체계'}), (b:Damage {name: '진상조사 업무 연속성 저하·정보 편중'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'High', mechanism: '구성원 잦은 변경으로 업무 연속성 저하', evidence: '세월호 특위 활동은 자원봉사로서 강제력이 부여되지 않았으므로 지속적 활동을 확보하기 어려웠다. 진상조사단의 구성원이 계속해서 변경되면서 업무의 연속성이 떨어졌고 자료에 대한 보안도 부실해졌다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0668'};
MATCH (a:Damage {name: '진상조사 업무 연속성 저하·정보 편중'}), (b:Damage {name: '회의 의사결정 비효율'}) MERGE (a)-[r:CAUSES]->(b) SET r += {mechanism: '소수 변호사 반복 투입으로 정보 편중', evidence: '상근으로 활동하는 변호사가 다양한 업무를 모두 부담한 결과 정보 역시 일부 변호사에게 편중되어 회의에서 의사결정에 비효율이 발생했다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0669'};
MATCH (a:RiskFactor {name: '변호사 단체 개별·비통일 활동'}), (b:Damage {name: '초기 본격 진상규명 활동 미개시'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'High', mechanism: '활동 미통일로 초기 진상규명 활동 지연', evidence: '각 단체가 개별적으로 활동을 개시하였기 때문에 그 활동이 통일되지 못했고, 세월호 가족대책위가 변호사 단체와 연락할 창구도 통일하지 못하였다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0670'};
MATCH (a:ResponseActor {name: '세월호 특위 특별법 제정팀'}), (b:ResponseAction {name: '세월호 특별법 입법 청원·협상 지원 활동'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '국회 상주 모니터링, 여당 제안 반박논리·대안·조문화 작업', duration: '상당기간', evidence: '법제정을 위해 팀원들이 상당기간 국회에 상주하면서 여/야당 간의 협상 내용을 모니터링하면서 주로 여당 제안에 대하여 반박논리 개발, 대안 마련, 조문화 작업 등을 전개하였다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0671'};
MATCH (a:ResponseActor {name: '세월호 특위 특별법 제정팀'}), (b:Resilience {name: '재해·재난 예방 및 사후대책 모니터링 시스템'}) MERGE (a)-[r:BUILDS]->(b) SET r += {timing: '2014-11~2015-01', mechanism: '예방·사후대책-실행-모니터링 시스템 구축', evidence: '재해/재난의 예방 및 사후 대책(피해자 지원책 포함) 마련 - 관계 국가기관 등에 의한 실행 - 모니터링의 시스템을 갖추고 있다는 점이 그 무엇보다도 강점이다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0672'};
MATCH (a:ResponseActor {name: '여·야 원내대표'}), (b:ResponseAction {name: '4·16세월호참사 진상규명 및 안전사회 건설 등을 위한 특별법 제정'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {timing: '2014-10-31 협상 타결', role: '진상규명특별법 협상 타결 및 본회의 통과', evidence: '세월호 참사 발생 205일째인 11월 7일 마침내 \'4·16세월호참사 진상규명 및 안전사회 건설 등을 위한 특별법\'이 국회 본회의를 통과하였다. 위 법은 2014년 11월 19일 공포되었고, 2015년 1월 1일부터 시행되었다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0673'};
MATCH (a:ResponseActor {name: '국회(농해수위 중심)'}), (b:ResponseAction {name: '4·16세월호참사 피해구제 및 지원 등을 위한 특별법 제정'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {timing: '2015-01-06 최종 합의, 2015-01-12 본회의 통과', role: '피해구제 특별법 제정', evidence: '2015년 1월 6일 세월호 참사 265일 만에 배·보상, 피해자 및 피해지역 지원, 추모사업 등이 포함된 \'4·16세월호참사 피해구제 및 지원 등을 위한 특별법\'이 최종 합의에 이르렀고, 1월 12일 국회 본회의를 통과하였다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0674'};
MATCH (a:ResponseAction {name: '4·16세월호참사 진상규명 및 안전사회 건설 등을 위한 특별법 제정'}), (b:Event {name: '세월호 침몰사고'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {role: '참사 진상규명·재발방지 제도화', mechanism: '특별조사위원회 조사권한 부여', evidence: '2개의 세월호 관련 특별법은 그 내용으로 볼 때 기존의 위원회법이 가진 조사권한을 넘어설 뿐만 아니라 ... 진상규명, 안전사회 대책 및 피해자 지원대책 마련 등이 이루어지길 소망', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0675'};
MATCH (a:RiskFactor {name: '여당·보수 진영의 수사·기소권 집중 공격'}), (b:Damage {name: '특별법 제정 지연 및 진상규명·피해지원 특별법 분리'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'High', mechanism: '협상 난항으로 진상규명법·피해자지원법 분리 제정', evidence: '진상규명 관련 특별법 협상이 난항을 거듭함에 따라 피해자 지원 관련 특별법과 분리되어 제정될 수밖에 없었던 점, 보수 진영과 여당이 수사 및 기소권을 집중적으로 공격해 오고 ... 법 제정이 그로부터 계속 늦어지게 되었다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0676'};
MATCH (a:ResponseActor {name: '세월호 특위 특별법 제정팀'}), (b:ResponseAction {name: '조기 특별법 합의 도출'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '완강한 여당의 공격 방어 실패, 야당이 가족대책위와 제대로 협의하도록 이끌지 못함, 내부 가족대책위 설득 실패', effectiveness: 'Low', timing: '8월 중순~추석 연휴 이전', evidence: '완강한 여당의 공격을 방어해 내지 못하고 야당이 세월호 가족대책위와 제대로 협의할 수 있도록 이끌어내지 못하였으며, 내부적으로 세월호 가족대책위를 제대로 설득해 내지 못하게 됨에 따라 법 제정이 그로부터 계속 늦어지게 되었다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0677'};
MATCH (a:ManmadeHazard {name: '보수단체(어버이연합 등)의 방해 행위'}), (b:Event {name: '단식농성 관련 민·형사상 분쟁'}) MERGE (a)-[r:TRIGGERS]->(b) SET r += {mechanism: '물리적 접촉 등으로 민·형사상 문제 야기', probability: 'Med', evidence: '어버이 연합 등 보수단체에서는 이분들을 비하하는 표현, 반대시위, 단식농성장 앞에서 음식물 만들어 섭취하기, 물리적인 접촉 등을 통해 민·형사상의 문제를 야기하고 있었다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0678'};
MATCH (a:Event {name: '대리운전기사 다툼 사건(2014-09-17)'}), (b:Damage {name: '안산 세월호 가족대책위 위원장단 9명 전원 사퇴'}) MERGE (a)-[r:CAUSES]->(b) SET r += {mechanism: '언론 보도 후 책임론 확산', directCause: '임원-대리운전기사 다툼 보도', evidence: '9월 17일, 세월호 가족대책위 임원 일부와 대리운전기사 간에 다툼이 언론에 보도되었고, 이 사건으로 인하여 안산 세월호 가족대책위 위원장단 9명 전원이 사퇴하는 상황이 발생하였다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0679'};
MATCH (a:Event {name: '대한변협 상임이사회 활동비 지원 중단 협의(2014-09-23)'}), (b:Damage {name: '현장 활동 변호사들의 실망·반발'}) MERGE (a)-[r:CAUSES]->(b) SET r += {mechanism: '활동비 지원 중단 협의 소식 전달', directCause: '현장대응지원단 활동비 지원 중단 협의', evidence: '9월 23일경 대한변협 상임이사회에서 세월호 특위 현장대응지원단의 활동비 지원 중단을 협의했다는 소식이 전해지면서, 현장에서 지속적으로 활동을 해 왔던 변호사들에게 큰 실망과 반발을 안겨 주었다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0680'};
MATCH (a:ResponseAction {name: '변호사 진도 파견 및 현장 법률지원'}), (b:Event {name: '세월호 침몰사고'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {timing: '참사 다음 날', role: '피해자·가족 현장 법률지원 개시', evidence: '2014년 4월 16일 세월호 참사가 발생하고 바로 다음 날 황필규, 배의철 변호사가 진도로 파견되었다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0681'};
MATCH (a:ResponseActor {name: '민주사회를 위한 변호사 모임'}), (b:ResponseActor {name: '대한변호사협회'}) MERGE (a)-[r:COORDINATES_WITH]->(b) SET r += {role: '세월호 특위 균형 참여 3대 축(대한변협·서울지방변호사회·민변)', specialNote: '참여 변호사 514명 포괄 위한 인적 집단 조율', evidence: '크게 대한변협, 서울지방변호사회, 그리고 민변 세 단체를 축으로 삼았다. ... 세월호 특위에 참여한 514명 변호사를 가장 많이 포괄할 수 있는 인적 집단', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0682'};
MATCH (a:ResponseActor {name: '세월호 특위 진상조사단'}), (b:ResponseAction {name: '증거보전신청'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {timing: '2014-06~10', role: '각종 중요 자료 증거보전신청', evidence: '각종 증거보전신청 활동 부분이다. 6월부터 10월에 이르기까지 긴 시간동안 이루어진 각종 중요 자료들에 대한 증거보전신청은 변호사의 지원이 없었다면 이루어지기 어려운 활동이기에 더욱 의미가 있다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0683'};
MATCH (a:Event {name: '세월호 침몰사고'}), (b:Event {name: '세월호 침몰 원인 의혹 확산'}) MERGE (a)-[r:TRIGGERS_SECONDARY]->(b) SET r += {mechanism: '원인·초동대처 의혹 다수 제기로 진상규명 필요 발생', timing: '참사 직후~2014-05 중순', reason: '침몰 원인에 대한 다양한 의혹', evidence: '진상조사단이 활동을 시작했던 5월 중순경에는 세월호 가족대책위 내에서 세월호의 침몰 원인에 대한 다양한 의혹이 제기되었으며', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0684'};
MATCH (a:Event {name: '세월호 침몰사고'}), (b:Event {name: '세월호 구조 실패'}) MERGE (a)-[r:TRIGGERS_SECONDARY]->(b) SET r += {mechanism: '구조 실패에 대한 가족 대응이 진상규명 활동을 촉발', reason: '가족들에 대한 구조 실패', evidence: '언론의 무분별한 보도, 가족들에 대한 구조 실패, 위정자들의 무책임한 발언과 행동들로 상처를 받은 세월호 가족대책위', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0685'};
MATCH (a:ResponseActor {name: '대한변호사협회'}), (b:ResponseAction {name: '세월호 특위 진상조사단 운영'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'preparedness', timing: '2014-05', scale: '514명 지원', evidence: '대한변협이 전국 회원을 대상으로 두 차례에 걸쳐 세월호 특위를 모집한 결과 514명의 변호사가 지원하였는데도', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0686'};
MATCH (a:ResponseActor {name: '대한변호사협회'}), (b:ResponseAction {name: '세월호 특위 진상조사단 운영'}) MERGE (a)-[r:FAILS]->(b) SET r += {phase: 'response', reason: '장기 활동 재원 미확보·유급 상근 변호사 미배정으로 컨트롤 타워 부재', specialNote: '단순 모집 구심점 역할만 수행, 재원 확보·지원 역할 부담하지 못함', effectiveness: 'Low', evidence: '대한변협은 단순히 변호사를 모으는 구심점의 역할을 수행할 것이 아니라, 장기적 활동에 대한 재원 확보를 통하여 공익을 위해 노력하는 변호사들을 지원하는 역할 역시 부담해야한다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0687'};
MATCH (a:RiskFactor {name: '세월호 특위 자원봉사 운영구조'}), (b:Damage {name: '활동 변호사 인원의 절대적 부족'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'High', mechanism: '생계 병행 변호사 다수→시의적절한 인력 투입 불가', reason: '안정적 수입 미지원', evidence: '실제 활동하는 변호사 및 장기적으로 상근하는 변호사의 인원 부족의 근본적인 원인은 세월호 특위가 자원봉사라는 형태로 운영되었기 때문이다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0688'};
MATCH (a:RiskFactor {name: '세월호 특위 자원봉사 운영구조'}), (b:Event {name: '진상조사단 구성원 잦은 인사 변동 및 이탈'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'High', mechanism: '강제력 부재로 비상근 변호사 이탈·인사 변동 잦음', reason: '지속적 활동 지원 불확실', evidence: '세 번째 원인은 진상조사단 내부 인원의 잦은 인사 변동 및 상근 변호사 수의 절대적 부족이다... 진상조사단의 업무 연계성을 저하시킨다는 점에서 치명적이었다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0689'};
MATCH (a:Event {name: '진상조사단 구성원 잦은 인사 변동 및 이탈'}), (b:Damage {name: '진상조사단 업무 연계성·연속성 저하'}) MERGE (a)-[r:CAUSES]->(b) SET r += {directCause: '구성원 계속 변경', mechanism: '업무 연속성·연계성 저하, 자료 보안 부실', evidence: '진상조사단의 구성원이 계속해서 변경되면서 업무의 연속성이 떨어졌고 자료에 대한 보안도 부실해졌다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0690'};
MATCH (a:Event {name: '진상조사단 구성원 잦은 인사 변동 및 이탈'}), (b:Damage {name: '정보의 일부 변호사 편중 및 의사결정 비효율'}) MERGE (a)-[r:CAUSES]->(b) SET r += {directCause: '소수 변호사 반복 투입', mechanism: '정보가 일부 변호사에게 편중', evidence: '상근으로 활동하는 변호사가 다양한 업무를 모두 부담한 결과 정보 역시 일부 변호사에게 편중되어 회의에서 의사결정에 비효율이 발생했다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0691'};
MATCH (a:Event {name: '비상근 변호사의 팀 이탈'}), (b:Damage {name: '진행 작업 중도 일단락'}) MERGE (a)-[r:CAUSES]->(b) SET r += {directCause: '비상근 변호사 이탈', mechanism: '이탈 변호사 업무가 상근·연수변호사에게 이전, 한정 인력으로 커버 불가', evidence: '비상근변호사들이 진행하던 업무들은 그들이 이탈함에 따라 상근변호사와 연수변호사의 업무로 넘어오게 되었으나 이 모든 것을 한정된 인력만으로 전부 커버하기에는 무리가 있었다. 그 결과 진행하던 작업들이 중도에 일단락되어버리는 경우도 허다했다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0692'};
MATCH (a:Event {name: '비상근 변호사의 팀 이탈'}), (b:Damage {name: '연수변호사 교육 비용 낭비 및 업무 중첩 집중'}) MERGE (a)-[r:CAUSES]->(b) SET r += {directCause: '이탈자 발생', mechanism: '연수변호사 교육·업무 인수에 시간·비용 낭비, 연수변호사에 업무 중첩 집중', evidence: '기존에 당해 업무를 수행하던 변호사들의 업무를 연수 변호사가 이어받기 위하여 이를 교육하고 업무 방식을 익히는 등의 시간과 비용이 낭비될 수밖에 없었으며', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0693'};
MATCH (a:ResponseActor {name: '진상조사단 상근변호사'}), (b:ResponseAction {name: '진상조사단 전반 업무 수행'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', timing: '2014', role: '전체 업무 집중 부담', evidence: '끝내 몇몇 변호사들이 생업을 포기하고 세월호 특위 진상조사단에서 상근으로 활동하면서 이들에게 전체 업무가 집중되는 결과를 낳았다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0694'};
MATCH (a:ResponseAction {name: '연수변호사 모집'}), (b:Damage {name: '활동 변호사 인원의 절대적 부족'}) MERGE (a)-[r:MITIGATES]->(b) SET r += {effectiveness: 'Med', phase: 'recovery', reason: '중도 이탈 구성원 대체', evidence: '중도에 활동에 참여하지 못하게 된 다수의 구성원 대신 투입하기 위하여 연수변호사들을 모집하여 고질적인 변호사 인력의 부족을 메워야만 했다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0695'};
MATCH (a:RiskFactor {name: '자료 분류체계 미확립'}), (b:Damage {name: '자료 적체 및 검색 불가'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'High', mechanism: '방대한 자료가 분석 없이 누적→분류체계 무의미화', reason: '분석 인력 미확보', evidence: '방대한 자료는 초기에 만들어 놓은 분류대로 쌓이기만 할 뿐 이를 전부 읽고 분석하는 업무를 수행할 인원을 확보하지 못하였다... 자료를 읽고자 하더라도 찾아보는 것 자체가 불가능해졌다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0696'};
MATCH (a:Event {name: '진상조사단 구성원 잦은 인사 변동 및 이탈'}), (b:Damage {name: '자료 적체 및 검색 불가'}) MERGE (a)-[r:CAUSES]->(b) SET r += {directCause: '담당자 미지정·이탈', mechanism: '지속적 수행 필요 업무인 자료분류·분석이 수행 불가', reason: '구성원 지속 변동', evidence: '이러한 자료 분류 및 분석 작업은 담당자가 지정되어 지속적으로 수행해야 가능한 업무인 만큼 진상조사단 구성원이 지속적으로 변동되고 계속적으로 이탈자가 발생하는 과정에서는 어쩌면 당연한 것이었다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0697'};
MATCH (a:ResponseAction {name: '연수변호사 웹하드 자료 인덱스·정리 작업'}), (b:Damage {name: '자료 적체 및 검색 불가'}) MERGE (a)-[r:MITIGATES]->(b) SET r += {effectiveness: 'Med', phase: 'recovery', reason: '방치된 자료분류체계 재정립', timing: '2014-08', evidence: '3명의 연수 변호사가 8월 초 웹하드의 모든 자료에 대한 인덱스 작업을 하고, 8월 말 웹하드의 무의미한 자료와 중복 자료들을 삭제하는 등... 5월 이후 방치되었던 자료분류체계를 새로이 정립할 수 있었다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0698'};
MATCH (a:Event {name: '자료 신속 공유 실패'}), (b:Damage {name: '중요 정보의 미공유 소멸'}) MERGE (a)-[r:CAUSES]->(b) SET r += {directCause: '정보 회람 시스템·담당자 부재', mechanism: '파편적 정보만 보유, 비상근 변호사 이탈로 정보 미공유 소멸', evidence: '일부 비상근 변호사들은 자신의 생계를 위한 업무 인하여 이러한 정보를 공유하지 못한 채 이탈하는 상황이 발생하면서 어쩌면 중요한 정보가 공유되지 못한 채 소멸했을 지도 모를 일이다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0699'};
MATCH (a:RiskFactor {name: '정보 공유 매체 불일치'}), (b:Damage {name: '중요 정보의 미공유 소멸'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'Med', mechanism: '고령 변호사 접근성 부담, 업로드 공지 미흡으로 자료 유무 미파악', reason: '매체 일관성 부재', evidence: '어느 매체를 통하여 일정하게 정보가 업데이트 되는지를 알 수 없었다... 업로드 하였다는 사실을 제대로 공지하지 않는 경우 자료의 유무에 대해서 제대로 파악되지 않았다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0700'};
MATCH (a:Event {name: '세월호 참사 초기 신뢰관계 형성 실패'}), (b:Damage {name: '초기 중요 정보·자료 확보 기회 상실'}) MERGE (a)-[r:CAUSES]->(b) SET r += {directCause: '초기 신뢰관계 미형성', mechanism: '시간 경과로 기억 희석·증거 소멸, 초기 자료 확보 기회 상실', evidence: '세월호 참사 역시 초기 신뢰구도 형성하지 못하여 많은 정보를 놓칠 수밖에 없었다... 어떠한 사건이든 시간이 흐르면 기억은 희석되고 증거는 소멸한다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0701'};
MATCH (a:Event {name: '언론·정부의 미흡한 대응'}), (b:Event {name: '세월호 가족대책위의 대화 단절·고립'}) MERGE (a)-[r:TRIGGERS_SECONDARY]->(b) SET r += {mechanism: '피해자 가족의 사회 전체 신뢰 상실→대화 단절·고립', reason: '미흡한 대응과 무책임한 발언', evidence: '세월호 피해자 가족들이 언론 및 정부의 미흡한 대응에 의하여 사회 전체에 대한 신뢰가 많이 상실한 상태였... 세월호 가족대책위가 대화를 단절하고 고립되는 과정에서', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0702'};
MATCH (a:Event {name: '세월호 가족대책위의 대화 단절·고립'}), (b:Damage {name: '초기 중요 정보·자료 확보 기회 상실'}) MERGE (a)-[r:CAUSES]->(b) SET r += {directCause: '가족대책위 고립·대화 단절', mechanism: '초기 정보 확보·대응 가능 순간 상실', evidence: '고립되는 과정에서 초기부터 정보를 확보하고 대응할 수 있었던 많은 순간이 속절없이 흘러갔다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0703'};
MATCH (a:RiskFactor {name: '컨트롤 타워 부재 및 책임소재 불명확'}), (b:Damage {name: '변호사들의 소극적 활동 및 책임감 결여'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'High', mechanism: '타인이 할 것이라는 안일한 기대로 소극적 활동·책임감 결여 유발', reason: '통제·인력관리 주체 부재', evidence: '많은 인원이 세월호를 위하여 움직였지만, 이를 통제하고 업무를 부과할 컨트롤 타워는 부재했다... 모두의 일은 누구의 일도 아니다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0704'};
MATCH (a:Damage {name: '진상조사단 적극성 결여 및 진상규명 미실현'}), (b:Context {name: '실제 활동 변호사 비율(2014)'}) MERGE (a)-[r:QUANTIFIED_BY]->(b) SET r += {reason: '지원 514명 대비 실제 활동 인원', evidence: '514명이라는 절대적으로 다수의 변호사들이 세월호 특위에 지원했지만, 실제적으로 활동하는 인원은 1/5에도 미치지 않았다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0705'};
MATCH (a:Damage {name: '활동 변호사 인원의 절대적 부족'}), (b:Damage {name: '진상조사단 적극성 결여 및 진상규명 미실현'}) MERGE (a)-[r:CAUSES]->(b) SET r += {directCause: '실제 활동 인력 부족', mechanism: '원인·초동대처 진상규명이 적극적으로 이루어지지 못함, 일부 업무 취소', evidence: '이탈하는 변호사 수가 늘어나며 수정되었고, 일부 업무들은 실행에 옮기지 못한 채 취소되기도 하였다. 따라서 적극적인 세월호 참사 원인 및 초동대처 상의 문제점에 대한 진상규명이 이루어지지 못하였다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0706'};
MATCH (a:ResponseAction {name: '진술청취카드 기반 피해자 가족 면담'}), (b:Event {name: '세월호 침몰 원인 의혹 확산'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {phase: 'response', effectiveness: 'Med', reason: '구체적 증언·자료 확보 필요', evidence: '진상조사단은 5월 말 사고 및 수습에 대한 세월호 피해자 가족 및 생존자의 진술을 확보하기 위하여 진술청취카드초안을 만든 후, 6월부터... 1차 집단면담과 2차 집중면담을 실시하기로 하였다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0707'};
MATCH (a:Resilience {name: '정보 회람·관리 전담 인력 배치'}), (b:Damage {name: '중요 정보의 미공유 소멸'}) MERGE (a)-[r:OFFSETS]->(b) SET r += {effectiveness: 'High', reason: '정보 비대칭·소멸 완화 위한 권고 역량', evidence: '통일된 매체로 결정한 후 이를 관리하고 주기적으로 정보 공유만을 담당할 인력이 필요하다... 담당자가 자료에 대해 인덱스를 작성하여 기록하면서 가상 드라이브에 분류 체계에 맞게 저장하고', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0708'};
MATCH (a:Resilience {name: '유급 상근 변호사 사전 배정 체계'}), (b:Damage {name: '활동 변호사 인원의 절대적 부족'}) MERGE (a)-[r:OFFSETS]->(b) SET r += {effectiveness: 'High', reason: '변호사 인력 부족·이탈 구조적 완화', evidence: '장기적인 프로젝트를 수행할 수 있는 큰 축을 담당할 상근 변호사들을 유급으로 배정한 뒤에 자원한 변호사들을 그 산하에 배치하는 것이 보다 효율적인 운영의 방식이 될 것', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0709'};
MATCH (a:Resilience {name: '심리상담가·교섭전문가 자문 활용'}), (b:Damage {name: '초기 중요 정보·자료 확보 기회 상실'}) MERGE (a)-[r:OFFSETS]->(b) SET r += {effectiveness: 'Med', reason: '초기 신뢰관계 형성·정보 확보 권고 역량', evidence: '심리상담가를 비롯하여 교섭전문가 등의 자문을 받아서 최대한 빨리 피해자와 접점을 만들고 다수의 피해자들에 대한 접촉면을 넓혀야 한다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0710'};
MATCH (a:Population {name: '세월호 가족대책위'}), (b:Damage {name: '초기 중요 정보·자료 확보 기회 상실'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {reason: '대형 참사 피해자 심리상태에 대한 무지로 접근 곤란', mechanism: '사상 초유 대형 참사 피해자 심리 미고려', evidence: '사상 초유의 대형 참사 피해자들의 심리상태에 대해 무지하였던 것에도 원인이 있을 것이다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0711'};
MATCH (a:Event {name: '진상조사단 자료조사 업무 구체화·다양화'}), (b:Damage {name: '정보의 일부 변호사 편중 및 의사결정 비효율'}) MERGE (a)-[r:CAUSES]->(b) SET r += {directCause: '동일 변호사 계속 투입', mechanism: '업무가 일부 변호사에게 과도하게 편중', evidence: '6월부터는 증거보전신청, 진술청취카드의 작성 및 내용 분석, 휴대전화 및 세월호 내부 CCTV의 DVR의 포렌식... 동일한 변호사가 계속해서 투입됨으로써 업무가 일부 변호사에게 과도하게 편중되어 진행되었다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0712'};
MATCH (a:Event {name: '세월호 침몰사고'}), (b:Context {name: '2014-04-16 사고 일시'}) MERGE (a)-[r:OCCURS_AT]->(b) SET r += {timing: '사고 발생 당시', evidence: '4월 16일 오전 9시 35분경 목포 해양경찰청 123정은 세월호 침몰 현장에 가장 먼저 도착', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0713'};
MATCH (a:ResponseActor {name: '해양경찰 123정'}), (b:ResponseAction {name: '선원 우선 구조 활동(123정)'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {timing: '2014-04-16 09:35경', role: '현장 최초 구조세력', effectiveness: 'Low', evidence: '고속단정은 ... 기관부 선원들을 가장 먼저 구조하였고, 123정은 ... 선장을 비롯한 선원들을 구조하였다 / 구조한 22명 중 무려 15명이 선원', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0714'};
MATCH (a:ResponseActor {name: '해양경찰 123정'}), (b:ResponseAction {name: '승객 퇴선조치(미실시)'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '목포해양경찰서장의 지시에도 불구하고 승객 퇴선조치 미실시', effectiveness: 'Low', specialNote: '현장지휘관 김 모 경위가 퇴선방송 미실시', timing: '2014-04-16 09:57~10:05 지시 이후', evidence: '목포해양경찰서장의 지시에도 불구하고, 123정은 승객에 대한 퇴선조치를 하지 않았다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0715'};
MATCH (a:ResponseActor {name: '목포해양경찰서장'}), (b:ResponseActor {name: '해양경찰 123정'}) MERGE (a)-[r:COMMANDS]->(b) SET r += {timing: '2014-04-16 09:57, 10:05', role: '퇴선·방송 지시', directCause: '교신 지시', evidence: '목포해양경찰서장은 123정에게 9시 57분에 ... 10시 5분에 ... 라고 지시한다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0716'};
MATCH (a:ResponseActor {name: '김 모 경위(123정 정장·현장지휘관 OSC)'}), (b:ResponseAction {name: '퇴선방송(주장→번복)'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '퇴선지시 미실시 후 공문서 조작으로 은폐', effectiveness: 'Low', specialNote: '법정에서 \'죄송하다. 거짓말했다\' 진술 번복', evidence: '퇴선방송을 하였다고 주장했지만 ... \'죄송하다. 거짓말했다\'라고 번복 / 퇴선지시 미실시를 은폐하기 위하여 공문서를 조작하였던 것이다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0717'};
MATCH (a:ResponseActor {name: '김 모 경위(123정 정장·현장지휘관 OSC)'}), (b:Event {name: '세월호 구조 실패'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {timing: '2014-12-01 첫 공판준비기일~', role: '형사재판 피고인', consequence: '1심 업무상과실치사 일부 인정, 징역 4년', evidence: '업무상과실치사가 일부 승객에 대하여 인정되어 4년의 징역에 처해지는 결과를 낳았다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0718'};
MATCH (a:ResponseActor {name: '해양경찰청 본청 상황실'}), (b:ResponseAction {name: '외부 지원자원 활용(미흡)'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '경찰청·중앙119·문화재청 등 외부 지원요청을 거부·무마·미활용', effectiveness: 'Low', specialNote: '가용 인명구조 자원 사장', evidence: '해양경찰청은 사고 당시 경찰청, 중앙119, 일본 미국 문화재청 등 다양한 지원요청들을 제대로 활용하지 못하였다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0719'};
MATCH (a:ResponseActor {name: '경찰청'}), (b:ResponseActor {name: '해양경찰청 본청 상황실'}) MERGE (a)-[r:COORDINATES_WITH]->(b) SET r += {timing: '2014-04-16 09:51경', role: '지원의사 표명(거부됨)', effectiveness: 'Low', specialNote: '해양경찰청이 거부', evidence: '경찰청은 사고 당일 오전 9시 51분경 해양경찰청 측에 지원의사를 밝혔으나 ... 경찰청 측의 지원의사를 거부하였다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0720'};
MATCH (a:ResponseActor {name: '중앙119구조본부'}), (b:ResponseActor {name: '해양경찰청 본청 상황실'}) MERGE (a)-[r:COORDINATES_WITH]->(b) SET r += {timing: '2014-04-16 13:02경', role: '적극 지원의사 표명(무마됨)', effectiveness: 'Low', specialNote: '해경 본청이 구체 답변 없이 무마', evidence: '사고 당일 오후 1시 2분경에는 중앙119 역시 적극적으로 지원의사를 밝히지만 ... 구체적인 답변을 하지 않은 채 무마시켰다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0721'};
MATCH (a:Resilience {name: '중앙119구조본부 인명구조 헬기·장비'}), (b:Damage {name: '세월호 참사 인명피해'}) MERGE (a)-[r:OFFSETS]->(b) SET r += {effectiveness: 'High(잠재)', specialNote: '실제로는 미활용되어 피해저감 실패', reason: '해경의 지원 무마', evidence: '두 종류의 헬기는 모두 인명구조기(hoist), 화물인양기(cargo sling), 외부스피커(speaker)를 모두 갖추고 있는 등 해양경찰의 헬기 3대보다 인명구조에 보다 효율적인 장비', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0722'};
MATCH (a:ResponseActor {name: '문화재청'}), (b:ResponseAction {name: '수중탐사선 현장 파견(문화재청)'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {timing: '2014-04-16 19:50경(씨뮤즈호 도착), 2014-04-17 08:10경(누리안호 도착)', role: '수중탐사선 현장 파견', effectiveness: 'Low(초기)', specialNote: '초기엔 직접 구조작업 전무', evidence: '문화재청은 ... \'씨뮤즈호\'와 \'누리안호\'를 사고 현장으로 파견하기로 결정 / 직접적인 구조작업을 전혀 실시한 바가 없다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0723'};
MATCH (a:Resilience {name: '수중탐사선 씨뮤즈호·누리안호'}), (b:Damage {name: '세월호 참사 인명피해'}) MERGE (a)-[r:OFFSETS]->(b) SET r += {effectiveness: 'High(잠재)', reason: '해경의 적절한 지휘 부재로 초기 미활용', specialNote: '초기 활용했다면 추가 구조 가능했을 것', evidence: '사고 당일부터 이미 현장에 있었던 씨뮤즈호와 누리안호를 적극 활용하였다면 단 한 명이라도 더 구조해낼 수 있었을 것', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0724'};
MATCH (a:ResponseActor {name: '해양경찰청 본청 상황실'}), (b:ResponseAction {name: '수중탐사선 현장 파견(문화재청)'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '적절한 지휘 부재로 문화재청 수중탐사선 미활용', effectiveness: 'Low', timing: '2014-04-16~04-20', evidence: '해양경찰청 측의 적절한 지휘가 있었다면 ... 잘 활용할 수 있었을 것이다. 그렇지만 해양경찰청은 이러한 문화재청의 지원 역시 제대로 활용하지 못하였다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0725'};
MATCH (a:ResponseActor {name: '해양경찰청'}), (b:ResponseAction {name: '수중탐사선 재투입(실종자 수색)'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {timing: '2014-04-21', role: '지원요청 공문 재발신·재투입', effectiveness: 'High(후기)', specialNote: '철수 결정 후 재투입, 실종자 수색서 활약', evidence: '4월 21일 해양경찰은 지원요청 공문을 재발신하여 씨뮤즈호와 누리안호를 재투입하였다 ... 실종자 수색 업무에서 큰 활약을 하였다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0726'};
MATCH (a:ManmadeHazard {name: '사복경찰 투입(피해자 가족 감시)'}), (b:Population {name: '세월호 피해자 가족'}) MERGE (a)-[r:AFFECTS]->(b) SET r += {timing: '2014-04-16~06-12', scale: '총 4,154명 투입', mechanism: '지속적 감시·정보수집·가족 사칭', specialNote: '불법과 합법 경계를 넘나드는 활동', evidence: '진도, 안산에 투입된 사복경찰은 총 4,154명이다. 총 58일 동안 하루 평균 약 72명 사복경찰이 투입 / 사복경찰의 투입과 경찰의 가족 사칭 등', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0727'};
MATCH (a:ManmadeHazard {name: '사복경찰 투입(피해자 가족 감시)'}), (b:Damage {name: '피해자 가족 인권침해·정신적 상처'}) MERGE (a)-[r:AFFECTS]->(b) SET r += {mechanism: '지속적 감시·정보수집활동으로 정신적 상처 유발', consequence: '피해자 가족에게 상처', evidence: '경찰의 정보수집활동은 피해자 가족들에게 상처로 다가왔다 / 경찰에 의한 불법적인 인권침해가 발생하지 않도록', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0728'};
MATCH (a:ResponseActor {name: '세월호 특위 진상조사단 변호사'}), (b:ResponseAction {name: '진술청취카드 작성·집단면담'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', timing: '2014-05~06', role: '진술 수집·진상조사', effectiveness: 'Med', evidence: '진술청취카드초안을 만든 후, 6월부터 ... 1차 집단면담과 2차 집중면담을 실시 / 2014년 6월 16일 경 ... 분류작업이 완료', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0729'};
MATCH (a:ResponseAction {name: '진술청취카드 작성·집단면담'}), (b:Context {name: '반별 개인면담 진술청취 인원 집계'}) MERGE (a)-[r:QUANTIFIED_BY]->(b) SET r += {specialNote: '단원고 반별 개인면담 진술청취 인원', evidence: '단원고 1반 13명, 2반 6명, 3반 22명, 4반 13명, 5반 32명, 6반 9명, 7반 14명, 8반 18명, 9반 14명, 10반 2명 외 미분류 16명 그리고 일반인 피해자 14명', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0730'};
MATCH (a:ResponseActor {name: '세월호 특위 진상조사단 변호사'}), (b:ResponseAction {name: '진술청취카드 작성·집단면담'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '변호사 인력 부족·상근 변호사 장기근무 불가, 반별 다른 변호사 투입으로 연계성 저하', effectiveness: 'Low', specialNote: '교사·선원 진술청취 미실시, 전원 면담 미달성', evidence: '변호사의 인력 부족과 상근 변호사의 장기 근무가 불가능 ... 작업의 연계성이 저하 ... 결국 본 작업은 마무리 되지 못한 채 종료 / 교사 및 선원에 대한 진술청취는 이루어지지 못했다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0731'};
MATCH (a:RiskFactor {name: '변호사 인력 부족·컨트롤타워 부재'}), (b:Damage {name: '진상조사 자료 활용 실패'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {mechanism: '장기 프로젝트 연계성 저하·자료 사장', probability: 'High', reason: '임기응변식 작업 진행', evidence: '인력의 부족으로 인하여 이러한 작업이 연계되지 못한 채 원자료(Raw Data) 형태로만 저장되었을 뿐 내용을 진상조사에 활용하지 못하였다 / 적체된 채 사장된 자료들이 존재', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0732'};
MATCH (a:Resilience {name: '컨트롤타워'}), (b:Damage {name: '진상조사 자료 활용 실패'}) MERGE (a)-[r:OFFSETS]->(b) SET r += {effectiveness: 'High(잠재)', specialNote: '실제로는 통제력 약화로 미작동', reason: '변호사 지휘 부담', evidence: '장기 프로젝트를 끝까지 끌고나가기 위해서는 컨트롤타워가 무엇보다 중요하다 ... 통제력 자체가 약할 수밖에 없었다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0733'};
MATCH (a:ResponseActor {name: '세월호 특위 진상조사단 변호사'}), (b:ResponseAction {name: '전자기기 복원 및 포렌식 작업'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', role: '전자기기 복원·포렌식 추진', effectiveness: 'Med', directCause: '침몰로 휴대폰·전자기기 바닷물 손상', evidence: '전자기기에 대한 복원 및 포렌식 작업을 한양대 김인성 교수가 3000만원에 수락하면서 서울지방변호사회에서 비용이 지급되었다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0734'};
MATCH (a:Event {name: '세월호 침몰사고'}), (b:Damage {name: '피해자 전자기기 손상'}) MERGE (a)-[r:CAUSES]->(b) SET r += {mechanism: '바닷물 침수로 피해자 휴대폰·전자기기 손상', directCause: '침몰·침수', evidence: '피해자, 실종자 그리고 생존자의 휴대폰 및 전자기기가 바닷물로 인하여 손상되었기 때문에', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0735'};
MATCH (a:RiskFactor {name: '세월호 가족대책위 신뢰 상실'}), (b:ResponseAction {name: '진술청취카드 작성·집단면담'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {mechanism: '피해자 가족 진술 기피로 진상조사 자료 수집 저해', probability: 'Med', evidence: '언론 및 정부의 미흡한 대응에 의하여 사회 전체에 대한 신뢰가 많이 상실한 상태였기 때문에 개인적 경험에 대해 상세히 표현하기 어려워하였다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0736'};
MATCH (a:Event {name: '세월호 침몰사고'}), (b:Event {name: '전자기기 침수 손상'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {mechanism: '침몰로 전자기기가 바닷물에 침수·손상', directCause: '바닷물 침수', timing: '사고 발생 후', evidence: '휴대폰 및 전자기기가 바닷물로 인하여 손상되었기 때문에, 그 안에 저장된 내용을 확인하기 위해서는 복원을 비롯하여 복원된 기기에 대한 별도의 포렌식 작업이 필요했다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0737'};
MATCH (a:Event {name: '전자기기 침수 손상'}), (b:ResponseAction {name: '전자기기 복원 및 포렌식 작업'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {role: '원인 사건에 대한 대응 필요성 발생', evidence: '그 안에 저장된 내용을 확인하기 위해서는 복원을 비롯하여 복원된 기기에 대한 별도의 포렌식 작업이 필요했다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0738'};
MATCH (a:ResponseActor {name: '세월호 가족대책위'}), (b:ResponseActor {name: '세월호 특위 진상조사단'}) MERGE (a)-[r:COORDINATES_WITH]->(b) SET r += {role: '협조·동의 및 작업 참관', timing: '총회 동의 후', evidence: '세월호 가족대책위 총회에서 설명을 한 뒤 동의를 얻어 작업을 실시할 수 있게 되었다... 변호사와 세월호 가족대책위가 반별로 돌아가며 2인 이상 작업을 계속 참관하였다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0739'};
MATCH (a:ResponseActor {name: '한양대 김인성 교수'}), (b:ResponseAction {name: '전자기기 복원 및 포렌식 작업'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '초기 복원·포렌식 작업 수행', amount: 30000000, unit: '원', specialNote: '프로보노 판단했으나 유상 계약', evidence: '휴대전화와 카메라 등 전자기기에 대한 복원 및 포렌식 작업을 한양대 김인성 교수가 3000만원에 수락하면서 서울지방변호사회에서 비용이 지급되었다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0740'};
MATCH (a:ResponseAction {name: '전자기기 복원 및 포렌식 작업'}), (b:Damage {name: '김인성 교수 초기 계약 비용'}) MERGE (a)-[r:CAUSES]->(b) SET r += {role: '복원 비용 발생', directCause: '유상 계약(프로보노 미성사)', evidence: '초기 한양대 김인성 교수와의 계약 당시... 3000만원의 초기 계약 사항에는 세월호 참사 피해자들의 개인물품에 대한 것으로만 한정', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0741'};
MATCH (a:ResponseActor {name: '세월호 특위 진상조사단'}), (b:ResponseAction {name: '클라우드 저장 기록 조사 작업'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '클라우드 기록 조사 주체', phase: 'recovery', specialNote: '개인정보 관련 협조공문·전화요청 필요', evidence: '구글, 네이버, 다음, 카카오톡 등 클라우드에 남은 기록에 대해서도 조사하는 작업을 진행하였다... 대한변협 차원에서 협조공문 발송 및 전화요청을 필요로 하였다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0742'};
MATCH (a:ResponseActor {name: '삼성·엘지·팬택 서비스센터'}), (b:ResponseActor {name: '세월호 특위 진상조사단'}) MERGE (a)-[r:COORDINATES_WITH]->(b) SET r += {role: '기기별 수리 인력 협조', directCause: '대한변협 공식협조 공문 발송', evidence: '삼성, 엘지, 팬택 등 서비스센터에 회사당 1명씩, 총 2일 간 작업에 협조해 줄 것을 대한변협 차원에서 공식협조 공문을 발송하였다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0743'};
MATCH (a:ResponseActor {name: '주식회사 명정보기술'}), (b:ResponseAction {name: '전자기기 복원 및 포렌식 작업'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '침수 기기 복원·포렌식 작업 수행', timing: '2014-05-22 시작 예정', phase: 'recovery', evidence: '2014년 5월 22일부터 시작될 예정이었던 침수 기기에 대한 복원 및 포렌식 작업은 과거 천안함 사건에서도 디지털 포렌식을 담당하였던 주식회사 명정보기술... 에 작업을 의뢰하였다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0744'};
MATCH (a:ResponseActor {name: '세월호 특위 진상조사단'}), (b:ResponseAction {name: '복원 작업 CCTV 운영 및 참관 감독'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '조작·손상 방지 위한 보안·참관 조치', phase: 'recovery', evidence: '외부에 의한 부적절한 조작 내지 자료 손상에 대한 의혹을 방지하기 위하여 자료가 보관되는 위치에 24시간 CCTV를 운영하며... 2인 이상 작업을 계속 참관하였다. 포렌식 참관 업무는 황다연, 조대진 변호사가 전담하기로 하였다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0745'};
MATCH (a:ResponseAction {name: '전자기기 복원 및 포렌식 작업'}), (b:Event {name: '세월호 침몰사고'}) MERGE (a)-[r:MITIGATES]->(b) SET r += {role: '진상규명 증거 확보', effectiveness: 'High', consequence: '70개 이상 휴대전화 복원·인도', evidence: '복원 및 포렌식 작업을 통하여 세월호 참사 피해자들의 70개 이상의 휴대전화 등이 복원되어 피해자 가족들에게 인도될 수 있었다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0746'};
MATCH (a:ResponseAction {name: '전자기기 복원 및 포렌식 작업'}), (b:Resilience {name: '진상규명 증거 자료'}) MERGE (a)-[r:BUILDS]->(b) SET r += {role: '진상규명 증거 역량 형성', mechanism: '선내 영상·마지막 메시지 복원으로 쟁점 규명', evidence: '한 학생의 휴대전화에 복원된 영상의 커튼과 벽면의 각도... 선내 대기 방송이 실제로 이루어졌는지 여부에 대해서도... 방송한 사람이 누구인지도 추정할 수 있는 중요한 자료가 되었다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0747'};
MATCH (a:Event {name: '세월호 침몰사고'}), (b:Context {name: '조타실 선원 선내 대기 방송 후 승객 방치'}) MERGE (a)-[r:OCCURS_AT]->(b) SET r += {role: '선내 대기 방송 정황 시점', evidence: '사고 발생 후 조타실 선원들이 선내 대기 방송을 믿고 선내 대기하던 세월호 승객들을 방치한 채 구조되던 시각에 배의 기울기가 얼마인지가 선원사건의 쟁점이 되던 시기', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0748'};
MATCH (a:Event {name: 'DVR 인양 및 포렌식'}), (b:ResponseAction {name: '전자기기 복원 및 포렌식 작업'}) MERGE (a)-[r:TRIGGERS_SECONDARY]->(b) SET r += {role: 'DVR 인양으로 포렌식 새 국면', timing: '침몰 2달여 후(2014-06)', evidence: '6월, 세월호 침몰 2달여가 지난 이후 세월호에서 CCTV 영상이 기록된 DVR이 인양되면서, 포렌식은 새로운 국면을 맞이하게 된다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0749'};
MATCH (a:ResponseAction {name: '전자기기 복원 및 포렌식 작업'}), (b:Damage {name: 'DVR 감정료 비용 타격'}) MERGE (a)-[r:CAUSES]->(b) SET r += {role: 'DVR 감정료 청구로 비용 타격', directCause: '증거보전신청 감정료 청구', evidence: '광주지방법원 목포지원 2014카기208 증거보전신청에서 세월호의 64개 CCTV의 영상저장장치(DVR)의 감정료가 80,641,000원이 청구되었다. 이러한 비용 청구는 향후 진상조사단 활동에 있어서... 큰 타격을 주게 되었다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0750'};
MATCH (a:ResponseAction {name: '전자기기 복원 및 포렌식 작업'}), (b:Damage {name: '추가 복원·포렌식 비용'}) MERGE (a)-[r:CAUSES]->(b) SET r += {role: '추가 비용 발생', directCause: '초기 계약이 개인물품에 한정되어 별도 계약 필요', evidence: '별도의 비용이 추가되었고, 그 비용 역시 8000만원으로 세월호 특위 차원에서 해결할 수 없을 만큼이 청구되었다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0751'};
MATCH (a:ResponseActor {name: '세월호 특위 진상조사단'}), (b:ResponseAction {name: '증거보전 소송구조신청'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '비용 보전 위한 소송구조신청', phase: 'recovery', timing: '2015-01 정식 청구, 2015-01-23 결정', evidence: '2015년 1월이 되어서야 소송구조신청을 정식으로 청구하였고, 2015년 1월 23일 광주지방법원 목포지원 2015카구1001로 소송구조를 받을 수 있었다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0752'};
MATCH (a:ResponseActor {name: '세월호 특위 진상조사단'}), (b:ResponseAction {name: '보정명령 비용 조달 및 보전'}) MERGE (a)-[r:FAILS]->(b) SET r += {role: '보정명령 비용 미조달', reason: '담당 책임자가 명확하지 않아 보전 미이행, 장기간 미해결', effectiveness: 'Low', evidence: '광주지방법원 목포지원에 의해 8000만원의 비용으로 80,641,000원에 대한 보정명령이 내려졌다. 그러나 보정명령이 있음에도 불구하고 비용을 조달하지 못하였으나 담당 책임자가 명확하지 않아 보전이 되지 않고 있는 상황이 장기간 유지되었다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0753'};
MATCH (a:ResponseActor {name: '세월호 특위 진상조사단'}), (b:ResponseAction {name: '클라우드 서비스 생전 자료 확보'}) MERGE (a)-[r:FAILS]->(b) SET r += {role: '클라우드 자료 확보 노력 부족', reason: '전자기기 복구에만 편중, 클라우드 자료 확보 노력 부족', timing: '사고 발생 5개월 후 9월까지 미해결', effectiveness: 'Low', evidence: '세월호 참사 피해자들이 이용하던 클라우드 서비스를 통한... 다양한 자료 확보에 대해서는 노력이 부족하였다. 따라서 이 경우 사고 발생 5개월 후인 9월까지도 세월호 특위가 해결하지 못하고', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0754'};
MATCH (a:RiskFactor {name: '넉넉하지 않은 예산'}), (b:Event {name: '증거보전절차 차질'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {role: '예산 부족이 증거보전절차 차질 유발', probability: 'High', mechanism: '비용 미조달로 증거보전절차 진행 불가', evidence: '넉넉하지 않은 예산에서 모든 비용을 지불하면서 포렌식 작업을 진행하는 것은 여러모로 쉽지 않은 과정이었다... 향후 진상조사단 활동에 있어서 적극적으로 증거보전절차를 진행할 수 없는 등 큰 타격', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0755'};
MATCH (a:RiskFactor {name: '정치적 이슈화 및 국민 감정 악화'}), (b:Event {name: '외부 조력 확보 곤란'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {role: '여론 악화가 외부 조력 확보를 어렵게 함', probability: 'Med', mechanism: '국민적 감정 악화 후 조력 확보 곤란', evidence: '정치적인 이슈로 변질되어 국민적 감정이 돌아선 다음에는 이에 대한 조력을 받는 것이 더욱 어려워 질 수 있기 때문에', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0756'};
MATCH (a:ResponseActor {name: '세월호 특위 진상조사단'}), (b:ResponseAction {name: '자료 분류체계 및 인덱스 작업'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '방대한 자료 분류·인덱스 작업', phase: 'recovery', timing: '2014-08 인덱스 작업', evidence: '2014년 8월 연수 변호사들이 웹하드에 저장되어 있는 모든 자료에 대한 인덱스를 만드는 작업을 수행하였다... 자료를 어느 정도 정리해서 보관', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0757'};
MATCH (a:RiskFactor {name: '초기 자료분류체계 미확립'}), (b:Event {name: '자료 활용 실패 및 진상규명 지체'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {role: '초기 체계 미비가 자료 활용 실패 유발', probability: 'High', mechanism: '시기별 분류체계 분열로 통일성 결여', evidence: '초기에 자료분류체계를 제대로 확립하지 않은 결과... 자료가 수집된 시기별로 그 자료분류체계가 달라질 수밖에 없었다... 어떤 자료가 어느 카테고리에 분류되어 있는지 찾기 어려울 뿐만 아니라', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0758'};
MATCH (a:ResponseActor {name: '세월호 특위 진상조사단'}), (b:ResponseAction {name: '자료 정리 및 분석 작업'}) MERGE (a)-[r:FAILS]->(b) SET r += {role: '자료 정리·분석 미흡', reason: '자료 수집 자체에 편중, 정리·분석 미흡, 임시방편적 분류', effectiveness: 'Low', evidence: '이번 세월호 특위 활동에서는 자료의 수집 자체에 편중되었고 그 정리와 분석에 대해서는 미흡했다... 문헌정보학의 전문가의 조력 없이 임시방편적인 자료 분류', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0759'};
MATCH (a:ResponseActor {name: '세월호 특위 진상조사단'}), (b:ResponseAction {name: '컨트롤타워 리더십 및 지휘체계 확립'}) MERGE (a)-[r:FAILS]->(b) SET r += {role: '컨트롤타워 지휘체계 미확립', reason: '변호사 단독자 활동 익숙, 지휘체계 미정착으로 각자 활동 몰두', effectiveness: 'Low', evidence: '이러한 지휘체계가 확고히 뿌리 내리지 못하였다. 그 결과 진상조사단의 변호사들은 각자의 활동에 몰두하는 경향을 보이게 되었다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0760'};
MATCH (a:ResponseActor {name: '세월호 특위 진상조사단'}), (b:ResponseAction {name: '진상조사 중간보고서 발간'}) MERGE (a)-[r:FAILS]->(b) SET r += {role: '진상조사 자료·중간보고서 미발간', reason: '정치적 국면·여론 질타로 발간 여력 부족', timing: '발족 후 6개월 이상', effectiveness: 'Low', evidence: '세월호 특위가 발족한 뒤에 6개월이 넘는 활동기간 동에 세월호 진상규명에 관련한 자료가 단 한 번도 발간되지 않았다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0761'};
MATCH (a:RiskFactor {name: '다양한 시민단체 통일 창구 부재'}), (b:Event {name: '입법안 입장 정리 의사소통 곤란'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {role: '창구 부재가 의사소통 곤란 유발', probability: 'Med', mechanism: '다양한 시민단체 합류로 통일 창구 부재', evidence: '다양한 시민단체가... 합류하게 되면서 통일된 창구가 없어, 세월호 특위가... 입법안에 대한 입장을 정리하고 필요한 법적 지원을 하기 위한 활동을 하면서 의사소통에 어려움을 겪었다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0762'};
MATCH (a:ResponseActor {name: '세월호 가족대책위'}), (b:ResponseAction {name: '세월호 참사 대응 각계 원탁회의'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '원탁회의 구성 참여', phase: 'response', timing: '2014-05 초', evidence: '임시적으로 5월 초 \'세월호 참사 대응 각계 원탁회의\'가 구성되었으', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0763'};
MATCH (a:Event {name: '세월호 침몰사고'}), (b:Damage {name: '세월호 참사 피해 확대'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {mechanism: '정부의 부실 대응과 미비한 재난 대응 체계로 인해 인적 피해가 확대됨', directCause: '정부의 부실한 대응·미비한 재난 대응 체계', spreadRisk: 'High', specialNote: '사회적 지탄·정치적 논란으로 2차 전파', evidence: '세월호 참사는 정부의 부실한 대응과 미비한 재난 대응 체계로 인해 피해가 확대된 만큼 정부는 사회적 지탄은 피할 수 없었다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0764'};
MATCH (a:RiskFactor {name: '정부의 미비한 재난 대응 체계'}), (b:Damage {name: '세월호 참사 피해 확대'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {mechanism: '초동·전반 대응 실패로 인명피해 확대', probability: 'High', reason: '재난 대응 체계 미비', evidence: '세월호 참사는 정부의 부실한 대응과 미비한 재난 대응 체계로 인해 피해가 확대된 만큼', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0765'};
MATCH (a:ResponseActor {name: '해양경찰청'}), (b:ResponseAction {name: '세월호 초동 구조 조치'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '초기 부적절한 구조 조치로 입증 대상이 됨', phase: 'response', timing: '참사 초기', specialNote: '세월호 참사 초기 부적절한 구조 조치', evidence: '세월호 참사의 원인을 비롯한 초기 부적절한 구조 조치에 대해 입증하는 것은 많은 난관에 봉착했다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0766'};
MATCH (a:ResponseActor {name: '해양경찰청'}), (b:ResponseAction {name: '수난구호명령 발령'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', timing: '2014-04-19', effectiveness: 'Med', specialNote: '산업잠수기능사 자격 개인 등에게 명령', evidence: '해양경찰이 4월 19일 산업잠수기능사 자격을 갖춘 개인에게 수난구호명령을 내린 문서를 포함하여, 다양한 개인 및 단체들에게 수난구호명령을 내린 사실이 확인되었기 때문이다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0767'};
MATCH (a:Facility {name: '통영함'}), (b:Damage {name: '세월호 참사 피해 확대'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {reason: '전력화 단계 미도달·해군 인도 전 상태로 작전 투입 불가', mechanism: '함정 전력화 미완으로 구조 자원 미가용', timing: '참사 당시', effectiveness: 'Low', evidence: '세월호 참사 당시 ‘통영함’은 전력화 단계는커녕 아직 해군에 인도조차 되지 않은 상태에 있었던 사실을 자료 정리 과정에서 알 수 있었다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0768'};
MATCH (a:RiskFactor {name: '방위사업청 관급장비 구매 관행'}), (b:Facility {name: '통영함'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {mechanism: '장비 납품 비리로 전력화 지연→구조 자원 미가용', probability: 'Med', specialNote: '방위사업비리 합동수사단 수사로 사실 확인', evidence: '방위사업청이 관급장비를 구매할 때의 몇 가지 관행들이 문제가 됐었던 것이 아니냐는 문제를 제기하고 있었고, 이후 방위사업비리 합동수사단의 수사에 의해 그와 같은 문제 제기가 사실임이 드러났다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0769'};
MATCH (a:ResponseActor {name: '방위사업비리 합동수사단'}), (b:ResponseAction {name: '통영함·소해함 납품비리 수사'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', actionType: '수사', effectiveness: 'High', specialNote: '황모 대령·최모 중령 각 1000만원·3000만원 금품수수 혐의 포착', evidence: '방위사업청 소속 황모 대령과 최 모 중령이 지난 2011년 ‘통영함’과 ‘소해함’에 장비를 납품한 미국 방위산업체의 대표로부터 각 1000만원, 3000만원 상당의 금품을 받은 혐의가 포착된 것이다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0770'};
MATCH (a:ResponseActor {name: '세월호 참사 국민대책회의'}), (b:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}) MERGE (a)-[r:COORDINATES_WITH]->(b) SET r += {role: '통일된 창구', reason: '약 800개 시민단체를 아우르기 위해 조직 재구성·정비', timing: '2014-05-22 출범', effectiveness: 'Med', evidence: '약 800개의 시민단체가 함께 운영해나갈 수 있도록 조직을 재구성하고 정비하여, 2014년 5월 22일 범시민사회단체 연대기구인 ‘세월호 참사 국민대책회의’가 공식 출범하였다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0771'};
MATCH (a:ResponseActor {name: '대한변호사협회'}), (b:ResponseAction {name: '완충지대 역할 수행'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '정치적 부담감에서 자유롭지 못해 적극 개입하지 못함', phase: 'response', effectiveness: 'Low', specialNote: '완충지대 역할 의도했으나 적극 개입 실패', evidence: '대한변협은 ... 시민단체와 결합 사이에서 완충지대로서 역할을 수행했으나, 대한변협 역시 그러한 부담감에서 자유롭지 못했기 때문에 적극 개입하지 못하고 말았다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0772'};
MATCH (a:RiskFactor {name: '세월호 참사의 정치적 변질'}), (b:Damage {name: '진상규명 지연'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {mechanism: '정치적 색채·언론 질타로 시민단체-특위 자료공유·연대 위축', probability: 'High', reason: '특별법 제정이 정치적 논리로 변질되며 국민 성원 저하', evidence: '정치적인 색이 입혀진 채 언론의 질타를 받는 상황에서 시민단체와 자료를 공유하며 적극적으로 함께 진상조사를 진행하는 것이 어려워졌다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0773'};
MATCH (a:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}), (b:ResponseAction {name: '시민단체-특위 자료 공유 및 공조'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '시민단체와 세월호 특위가 각각 내부에서 진상조사를 진행하며 정보 공유·피드백 거의 안 됨', phase: 'recovery', effectiveness: 'Low', specialNote: '통합 자료공유 무산', evidence: '시민단체와 세월호 특위가 각각 자신의 단체 내부에서 진상조사를 진행하면서 정보의 공유 및 피드백이 거의 이루어지지 않았다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0774'};
MATCH (a:ResponseActor {name: '민주사회를 위한 변호사 모임'}), (b:ResponseAction {name: '시민단체와의 유연한 연대 구축'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '대표 창구 통일 형태 불편·독자 행보로 시민단체와의 유연한 연대 미실현', phase: 'recovery', effectiveness: 'Low', specialNote: '대한변협 기대와 달리 업무공조·정보공유 미흡, 시민단체 상처', evidence: '대한변협이 민변 소속 변호사들에게 기대하였던 시민단체와의 유연한 연대관계는 현실화되지 못하고 말았다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0775'};
MATCH (a:ResponseActor {name: '뉴스타파 등 대안언론'}), (b:ResponseActor {name: '민주사회를 위한 변호사 모임'}) MERGE (a)-[r:COORDINATES_WITH]->(b) SET r += {role: '전문 분석 지원', effectiveness: 'Med', specialNote: 'AIS 항적 분석 등 독자 분석으로 진상조사단 업무 분담, 비밀 보장 조건 녹취록 제작', evidence: '이 과정에서 대안언론을 비롯한 여러 시민단체에서 별도로 전문가를 섭외하거나 이 분야를 연구하여 진상조사를 진행시킴으로써 진상조사단의 변호사들만으로는 불가능했을 다양한 상상력을 동원한 세월호 참사 원인에 대한 가능성들을 독자적으로 검토하였다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0776'};
MATCH (a:ResponseActor {name: '박주민 변호사'}), (b:ResponseActor {name: '진상규명 보고서 작성단(연수 변호사 4명)'}) MERGE (a)-[r:COMMANDS]->(b) SET r += {role: '총괄 지휘', timing: '2014-07-29 1차 회의', specialNote: '보고서를 5개 파트로 분할·역할분담 제안', evidence: '진상규명 보고서 작성 활동은 세월호 특위 진상조사단 소속의 박주민 변호사가 총괄하여 지휘하였다. ... 4명의 연수 변호사들은 각각의 역할분담을 하였다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0777'};
MATCH (a:ResponseActor {name: '진상규명 보고서 작성단(연수 변호사 4명)'}), (b:ResponseAction {name: '세월호 특위 진상규명 보고서'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', actionType: '진상규명 보고서 작성', duration: '약 2달', effectiveness: 'Med', specialNote: '5개 파트(사고원인·초동대처·수사·언론·정부대응)로 작성, 1~4차 회의 통해 보완·통합', evidence: '약 2달 동안 집필진들은 각종 증거보전절차를 통해 밝혀진 자료들, 세월호 국정조사과정에서 제출된 자료들 ... 등을 모두 망라한 보고서를 작성하였으며', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0778'};
MATCH (a:ResponseActor {name: '관련 정부기관(해양경찰·해양수산부·국가정보원 등)'}), (b:ResponseAction {name: '진상조사 자료 제공'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '핵심 증거가 책임 질타 받는 정부기관 보유 자료로 임의 제출 안 됨, 국정원 자료 접근 불가', phase: 'recovery', effectiveness: 'Low', specialNote: '진상조사 핵심 자료 미제공', evidence: '진상조사에 핵심적인 역할을 하는 증거들이 대부분 세월호 참사에 일정한 책임이 있다는 질타를 받고 있는 정부기관, 예를 들어 해양경찰, 해양수산부 등이 보유하고 있는 자료인 경우가 대부분이었기 때문이다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0779'};
MATCH (a:ResponseAction {name: '세월호 국정조사'}), (b:Event {name: '세월호 침몰사고'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {role: '대응실태 보고·진상규명', specialNote: '22개(주15에 따르면 총 23개) 피조사기관 참여, 8차 기관보고', count: 23, evidence: '무려 22개에 달하는 피조사기관들이 기관보고에 참여하여 사고 당시 각 기관의 대응실태 등에 대해 보고하였으며, 그 결과 무려 800페이지 이상에 달하는 임시회의록이 만들어졌다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0780'};
MATCH (a:ResponseActor {name: '4·16 세월호참사 특별조사위원회'}), (b:Event {name: '세월호 침몰사고'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {role: '진상조사', specialNote: '세월호 특위 진상규명 보고서를 기초자료로 활용 예정', timing: '2015 출간 예정', evidence: '특별법에 의해 구성되는 4·16 세월호참사 특별조사위원회로 전달되어, 세월호 특별조사위원회가 진상조사활동을 하는 데에 있어 기초자료로 활용될 예정이다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0781'};
MATCH (a:Resilience {name: '공식 협의체·창구 일원화'}), (b:Damage {name: '진상규명 지연'}) MERGE (a)-[r:OFFSETS]->(b) SET r += {reason: '공식 창구 일원화 시 진상규명 가속·자료 공유 문제 방지', effectiveness: 'Med', specialNote: '백서의 향후 권고(완충)', evidence: '처음부터 공식적인 협의체로서 함께 하는 방안을 고려해야 할 것이다. ... 만약 함께 자료를 공유하고 그 자료를 분석한 인력을 모아 함께 논의하였다면 진상규명은 보다 빠르게 진행되었을 것이다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0782'};
MATCH (a:ResponseActor {name: '세월호 가족대책위'}), (b:ResponseAction {name: '피해자·피해자 가족 증언 자료 확보'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', actionType: '증언·자료 확보', effectiveness: 'High', specialNote: '경기도미술관 내 자료실에 선내 상황·해경 대응 관련 영상 증언 보관', evidence: '세월호 가족대책위가 보유하고 있던 피해자 및 피해자 가족들의 증언은 사고 당시의 상황을 정확하게 분석하기 위해 필수적인 자료였음에도 ... 경기도 안산에 위치한 경기도미술관 내의 세월호 가족대책위 자료실에서 직접 확인하는 작업', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0783'};
MATCH (a:ManmadeHazard {name: '세월호'}), (b:Event {name: '세월호 침몰사고'}) MERGE (a)-[r:TRIGGERS]->(b) SET r += {mechanism: '급변침으로 인한 복원성 상실', directCause: '급변침(급격한 변침)', probability: 'High', scale: '대형', evidence: '세월호 침몰사고 발생시각인 오전 8시 48분경; 세월호 침몰의 주원인으로 꼽히는 급변침 순간', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0784'};
MATCH (a:Event {name: '세월호 대각도 변침'}), (b:Event {name: '세월호 침몰사고'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {mechanism: '급변침→선체 급격 기울어짐→침수 진행', directCause: '급변침', probability: 'High', timing: '08:48 전후 세월호 속도 저하 및 비정상 항로', evidence: '세월호 침몰의 주원인으로 꼽히는 급변침 순간; 오전 8시 48분 전후로 세월호의 속도가 느려지는 점이 확인; 정상적인 항해 상황으로 보이지 않는 항로를 세월호가 그리고 있는 것', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0785'};
MATCH (a:ResponseActor {name: '세월호 선원'}), (b:ResponseAction {name: '초동 인명구조 조치'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '제대로 된 초동조치를 하지 않음, 승객 두고 먼저 탈출', mechanism: '선내대기방송 유지·퇴선명령 미이행', effectiveness: 'None', specialNote: '검찰 측: 살인의 미필적 고의 주장 근거', evidence: '세월호 선원들이 제대로 된 초동조치를 하지 않았음을 적나라하게 보여주고 있었기 때문; 대다수의 선원들이 아무런 조치도 취하지 않은 상태에서 123정에 의해 구출', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0786'};
MATCH (a:ResponseActor {name: '세월호 선원'}), (b:Event {name: '세월호 침몰사고'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {role: '탈출(승객 방치)', timing: '사고 당시', effectiveness: 'negative', specialNote: '기관부 선원 구명보트 탑승→123정 이동, 갑판부 선원 조타실 탈출', evidence: '기관부 선원들이 구명보트에 탑승한 후 123정으로 옮겨가는 과정; 갑판부 선원들이 조타실에서 탈출하는 과정; 세월호 선원들이 승객을 두고 먼저 탈출했다는 사실이 명확하게 증명', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0787'};
MATCH (a:ResponseActor {name: '진도VTS'}), (b:ResponseAction {name: 'VTS 관제 및 이상징후 감지'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '관제사들의 관제 소홀, 야간 변칙근무·교신일지 허위작성', mechanism: '관제구역 진입한 세월호 지속 관제 미실시', effectiveness: 'None', specialNote: '사고시각(08:48)보다 19분 지난 09:07에야 교신 시작 — 19분 허비', evidence: '사람들의 의문점은 관제사들의 관제 소홀로 인한 것이었다; 진도VTS는 사고 발생 시각인 오전 8시 48분보다 19분이 지난 오전 9시 7분에서야 사고 상황을 파악하고 세월호와 교신을 시작; 관제 역할을 제대로 하지 않음으로 인해 ... 19분이라는 시간이 그저 허비', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0788'};
MATCH (a:RiskFactor {name: '진도VTS 관제 소홀'}), (b:Damage {name: '세월호 참사 인명피해'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {mechanism: '조기 이상징후 감지·교신 지연으로 구조 골든타임 단축', reason: '관제 미실시', probability: 'High', evidence: '진도VTS의 경우에는 ... 세월호를 지속적으로 관제하기만 하였어도 ... 구조시간을 몇 분은 더 연장할 수 있었을 것; 진도VTS 소속 직원들은 ... 야간근무시간대 1섹터 관제요원만 근무 ... 교신일지를 허위작성', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0789'};
MATCH (a:ResponseActor {name: '검찰'}), (b:ResponseAction {name: '진도VTS 직무유기 수사·기소'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {timing: '사고 후 수사·재판', effectiveness: 'High', specialNote: '진도VTS 센터장 및 관제사 13명 전원 직무유기 등으로 기소', evidence: '검찰은 진도VTS 센터장 및 관제사 13명 전원을 직무유기 등으로 기소하였으며, 2015년 1월 29일 센터장은 징역 10월에 집행유예 2년', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0790'};
MATCH (a:ResponseActor {name: '세월호 가족대책위'}), (b:ResponseAction {name: '세월호 마지막 29초 항적 규명'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', effectiveness: 'High', timing: '2014-06~10', specialNote: '대한변호사협회 도움으로 법원에 증거보전신청', evidence: '세월호 참사 6개월 만인 2014년 10월 세월호 가족대책위 측은 세월호가 급변침한 29초간의 항적을 찾아낼 수 있었다; 가장 핵심적인 역할을 한 것은 바로 진도VTS에 대한 증거보전신청을 통해 얻어낸 AIS DATA', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0791'};
MATCH (a:Facility {name: '진도VTS'}), (b:Context {name: '맹골수도'}) MERGE (a)-[r:LOCATED_IN]->(b) SET r += {role: '증거보전 대상 — 사고 당시 교신·항적 증거', timing: '2014-04-16 07:00~12:00', evidence: 'VTS의 경우 교신기록 보존기간을 2개월(60일)로 하고 있는데 ... 6월 15일에는 진도VTS, 제주VTS와 세월호 간의 교신기록이 지워질 상황', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0792'};
MATCH (a:ResponseActor {name: '둘라에이스호'}), (b:Event {name: '세월호 침몰사고'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {role: '라이프링 착용 및 승객 탈출 권고', timing: '오전 9시대 교신', effectiveness: '권고(미이행됨)', evidence: '“라이프링이라도 착용시키고 (승객들을) 띄우십시오. 빨리!”라는 다급한 목소리의 둘라에이스호 측 교신', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0793'};
MATCH (a:ResponseActor {name: '해양수산부'}), (b:ResponseAction {name: '세월호 마지막 29초 항적 규명'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '실제 운항 항로와 판이한 항적 공개, 급변침 순간 미포함 항적만 공개', effectiveness: 'Low', specialNote: '급변침 29초 AIS DATA 일부 소실 사유 제시, 4차례 공개 모두 신뢰 저하', evidence: '해양수산부에서는 사고 당일부터 무려 4차례에 걸쳐 세월호의 항적을 복원하여 일반에 공개; 가장 처음 공개했던 세월호의 항적은 ... 판이하게 다른 것; 급변침 순간이 나타나지 않은 항적만을 공개', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0794'};
MATCH (a:ResponseActor {name: '해양경찰청 123정 및 헬기(B511·B512·B513)'}), (b:Event {name: '세월호 침몰사고'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {role: '최근접 구조활동(불충분)', timing: '2014-04-16 08:52~20:00 활동, 영상 09:08~11:19', effectiveness: 'Low', specialNote: '오전 10시~10시 20분 사이 공통 미촬영 구간 존재', evidence: '세월호에 대한 구조활동을 벌인 해양경찰청 소속 123정 경비정, B511, B512, B513 헬기에서 촬영한 동영상; 세월호와 가장 가까운 거리에서 구조 활동을 벌였던 123정 경비정 및 3대의 헬기', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0795'};
MATCH (a:ResponseActor {name: '전남도청 어업지도선 201호'}), (b:Event {name: '세월호 승객 선내 고립'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {role: '현장 구조활동 및 침몰상황 기록', timing: '2014-04-16 10:04~10:25(약 21분)', effectiveness: 'Med', specialNote: '해경 미촬영 시간대 구조상황 기록 — 의미 큰 자료', evidence: '어업지도선 201호 ... 세월호에 접근하여 승객들에 대한 구조 활동을 벌이는 장면; 위 동영상은 2014년 4월 16일 오전 10시 4분부터 오전 10시 25분까지 약 21분간 촬영', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0796'};
MATCH (a:RiskFactor {name: '골든타임 내 구조·퇴선명령 부재'}), (b:Damage {name: '세월호 참사 인명피해'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {mechanism: '초기 대응 부재로 침몰 진행 중 탈출 기회 상실', reason: '선원·관제·구조세력 모두 적시 대응 실패', probability: 'High', evidence: '골든타임이라고 하는 사고 초기에 적절한 구조 활동이 취해졌어야 했음; 오전 9시 45분까지도 적절한 퇴선명령이 이루어졌더라면 승객 전원이 탈출할 수 있었다는 결론', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0797'};
MATCH (a:ResponseActor {name: '가천대학교 박형주 교수'}), (b:ResponseAction {name: '세월호 탈출 시뮬레이션 분석'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', effectiveness: 'High', role: '과학적 탈출 시뮬레이션 구상', evidence: '가천대학교 박형주 교수는 ... 탈출 시뮬레이션을 구상하였으며, 이를 통해 ... 오전 9시 45분까지도 적절한 퇴선명령이 이루어졌더라면 승객 전원이 탈출할 수 있었다는 결론을 도출', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0798'};
MATCH (a:Facility {name: '세월호 DVR'}), (b:Context {name: '맹골수도'}) MERGE (a)-[r:LOCATED_IN]->(b) SET r += {role: '선내상황 입증 핵심 증거물', specialNote: '부식방지조치 및 포렌식 분석 의뢰', evidence: '세월호 DVR(Digital Video Recorder) 및 노트북 ... 세월호 3층 로비 안내실에서 발견되어 인양; 세월호에 설치된 총 64개의 CCTV 화면이 저장되어 있는 것으로 추정', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0799'};
MATCH (a:ResponseActor {name: '광주지방법원 목포지원'}), (b:ResponseAction {name: '세월호 DVR·노트북 증거보전(현장검증)'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', timing: '2014-06-24 신청 당일 저녁 현장검증', effectiveness: 'High', specialNote: 'DVR 하드디스크 2개, 노트북 HDD 1개, SD카드 1개 현장검증', evidence: '광주지방법원 목포지원은 세월호 DVR 하드디스크 2개 및 노트북 하드디스크 1개, 디지털카메라 SD메모리카드 1개에 대한 현장검증을 실시', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0800'};
MATCH (a:Context {name: '2014-04-16 08:48 사고발생시각'}), (b:Event {name: '세월호 침몰사고'}) MERGE (a)-[r:OCCURS_AT]->(b) SET r += {role: '사고 발생 기준시각', timing: '08:48', evidence: '사고 발생 시각인 오전 8시 48분; 세월호 침몰사고 발생시각인 오전 8시 48분경', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0801'};
MATCH (a:Event {name: '세월호 침몰사고'}), (b:Context {name: '2014-04-16 오전 10시 23분경'}) MERGE (a)-[r:OCCURS_AT]->(b) SET r += {timing: '오전 10시 23분경 거의 전체 침몰', evidence: '시각 기준 19분경(실제 시각 오전 10시 23분경) 에는 선수 부분만 남기고 거의 모든 부분이 침몰되기에 이른다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0802'};
MATCH (a:Event {name: '세월호 침몰사고'}), (b:Damage {name: '세월호 DVR 부식'}) MERGE (a)-[r:CAUSES]->(b) SET r += {mechanism: '장기간 해수 침수로 DVR 부식 진행', scale: '복구 지연 초래', evidence: '세월호 DVR의 경우에는 오랜 기간 동안의 해수 침수로 인해 부식이 많이 진행되었기 때문에 복구 작업에 상당한 시간이 걸렸다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0803'};
MATCH (a:ResponseActor {name: '세월호 특위 진상조사단'}), (b:ResponseAction {name: '세월호 DVR·노트북 증거보전신청'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', timing: '2014-06-24', effectiveness: 'High', evidence: '2014년 6월 24일 세월호 가족대책위의 당시 가족대책위원장 김병권 외 1인을 신청인으로 하여 세월호 DVR(Digital Video Recorder) 및 노트북 등에 대한 증거보전이 신청되었다(광주지방법원 목포지원 2014카기208).', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0804'};
MATCH (a:Facility {name: '세월호 DVR'}), (b:Context {name: '세월호 3층 로비 안내실'}) MERGE (a)-[r:LOCATED_IN]->(b) SET r += {timing: '2014-06-22 23:40경 발견·인양', evidence: '2014년 6월 22일 저녁 11시 40분경 세월호 DVR과 노트북, 디지털카메라가 세월호 3층 로비 안내실에서 발견되어 인양됐다는 소식을 접하자마자', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0805'};
MATCH (a:ResponseActor {name: '세월호 특위 진상조사단'}), (b:ResponseAction {name: 'DVR 부식방지조치 및 포렌식 분석 의뢰'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', role: '신속 증거 확보', effectiveness: 'High', evidence: '세월호 특위 진상조사단은 위 증거보전을 신청하기에 앞서, 부식이 계속되고 있는 세월호 DVR에 대한 부식방지조치 및 포렌식 분석을 의뢰하는 등의 기민한 대처를 하기도 하였다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0806'};
MATCH (a:ResponseActor {name: '광주지방법원 목포지원'}), (b:ResponseAction {name: '보전대상증거 현장검증 실시'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', timing: '2014-06-24 저녁 7시 40분경', role: '신속 현장검증', evidence: '증거보전신청을 접수한 당일 저녁 7시 40분경 광주지방법원 목포지원은 세월호 DVR 하드디스크 2개 및 노트북 하드디스크 1개, 디지털카메라 SD메모리카드 1개에 대한 현장검증을 실시하였다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0807'};
MATCH (a:ResponseActor {name: '광주지방법원 목포지원'}), (b:ResponseAction {name: '보전대상증거 복원절차 진행'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', role: '복원촉탁인 지정', evidence: '그를 위해 부식방지조치 및 포렌식 분석 등을 도맡을 복원촉탁인을 지정하여 보전대상증거에 대한 복원절차를 진행하도록 하였다. 복원촉탁인으로는 한양대학교 컴퓨터공학과의 김인성 교수와 명정보기술이 지정되었다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0808'};
MATCH (a:ResponseActor {name: '주식회사 명정보기술'}), (b:ResponseAction {name: '세월호 DVR 하드디스크 복구작업'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', duration: '37일', effectiveness: 'High', timing: '2014-06-26 입고 ~ 2014-08-18 복구완료', evidence: '세월호 DVR 하드디스크 2개는 2014년 6월 26일 명정보기술의 오창 본사에 입고되어 세척 작업이 시작되었다. 총 37일 간의 세척 작업을 진행한 결과 2014년 8월 9일과 8월 18일에 각 하드디스크를 모두 복구하는 데 성공하였다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0809'};
MATCH (a:ResponseAction {name: '세월호 노트북·디지털카메라 복구작업'}), (b:Context {name: '2014-07-05'}) MERGE (a)-[r:OCCURS_AT]->(b) SET r += {timing: '복구 완료일', evidence: '세월호 노트북과 디지털카메라는 2014년 7월 5일 복구 작업이 완료되었다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0810'};
MATCH (a:Event {name: '세월호 DVR 복구 장기화'}), (b:Damage {name: '증거보전절차 지연'}) MERGE (a)-[r:CAUSES]->(b) SET r += {mechanism: '복구 장기화로 절차 정체', scale: '절차 지연', evidence: '세월호 DVR에 대한 복구 작업이 장기화되어 증거보전절차가 진행되지 못하고 있는 상황이었고, 그에 대한 해결책으로 세월호 특위 진상조사단에서는 세월호 노트북과 디지털카메라에 대한 증거보전절차를 우선적으로 진행해달라는 취지의 기일지정신청서를 제출하였다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0811'};
MATCH (a:ResponseActor {name: '광주지방법원 목포지원'}), (b:ResponseAction {name: '노트북·디지털카메라 검증 우선 실시'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', timing: '2014-07-25', role: '노트북·디지털카메라 우선 검증', evidence: '광주지방법원 목포지원은 신청을 받아들여 2014년 7월 25일 세월호 노트북과 디지털카메라에 대한 검증을 우선적으로 실시하였다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0812'};
MATCH (a:ResponseAction {name: '세월호 DVR 하드디스크 복구작업'}), (b:Context {name: '2014-08-09'}) MERGE (a)-[r:OCCURS_AT]->(b) SET r += {timing: 'AS201406260000046 복구 완료', evidence: '| 8월 9일 | 하드디스크(AS201406260000046) 복구 완료 |', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0813'};
MATCH (a:ResponseAction {name: '세월호 DVR 하드디스크 복구작업'}), (b:Context {name: '2014-08-18'}) MERGE (a)-[r:OCCURS_AT]->(b) SET r += {timing: 'AS201406260000045 복구 완료', evidence: '| 8월 18일 | 하드디스크(AS201406260000045) 복구 완료 | ... | 8월 1일 | 세척 완료 | | 8월 2일 - 8월 8일 | 복구작업 중단 |', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0814'};
MATCH (a:ResponseActor {name: '세월호 특위 진상조사단'}), (b:ResponseAction {name: '복구과정 참관'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', duration: '37일', role: '참관인 파견', effectiveness: 'High', evidence: '위와 같은 일련의 하드디스크 복구 과정에는 신청인 측 유가족 1인, 세월호 특위 측 변호사 1인, 피신청인의 소관청인 서해지방해양청장 측 인사 1인이 참관하였다. 세월호 특위는 37일 간의 세척 작업 동안 매번 특위 소속 변호사들을 명정보기술 오창 본사로 파견하여 참관인으로서의 역할을 다하도록 하였다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0815'};
MATCH (a:ResponseActor {name: '광주지방법원 목포지원'}), (b:ResponseAction {name: '세월호 DVR 검증'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', timing: '2014-08-22', role: 'DVR 검증 실시', evidence: '광주지방법원 목포지원은 2014년 8월 22일 세월호 DVR에 대한 검증을 실시하였다. ... 오후 2시부터 장장 5시간에 걸쳐 세월호 DVR에 저장되어 있던 세월호 내 64개의 CCTV를 눈으로 확인하는 검증 절차가 진행되었다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0816'};
MATCH (a:ResponseAction {name: '디지털카메라 증거보전'}), (b:Event {name: '세월호 침몰사고'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {role: '사고 전 선내 정상상태 간접 확인', timing: '마지막 촬영 2014-04-16 08:24경', evidence: '세월호 디지털카메라에 대한 증거보전을 통해 얻은 성과는 사고 당일 오전 8시 24분경 까지는 세월호에 별다른 이상 징후가 없었다는 점을 간접적으로 확인할 수 있었다는 것이다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0817'};
MATCH (a:ResponseAction {name: '디지털카메라 증거보전'}), (b:Context {name: '2014-04-16 오전 8시 24분경'}) MERGE (a)-[r:OCCURS_AT]->(b) SET r += {timing: '마지막 촬영 사진 시각', evidence: '해당 기기를 이용하여 가장 마지막으로 촬영된 사진은 2014년 4월 16일 오전 8시 24분경이었던 것으로 밝혀졌으며, ... 2014년 4월 15일 오후 4시 27분경 촬영된 사진까지 확인하는 절차를 진행하였다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0818'};
MATCH (a:ResponseAction {name: '노트북 증거보전'}), (b:Event {name: '세월호 침몰사고'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {role: '국정원 지적사항.hwp 발견 — 실소유주 의혹 촉발', evidence: '세월호 노트북에 대한 증거보전을 통해 얻은 가장 큰 성과는 바로 \'국정원 지적사항.hwp\' 파일을 발견하였다는 것이다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0819'};
MATCH (a:Event {name: '국정원 지적사항.hwp 파일 발견'}), (b:Damage {name: '세월호 국정원 실소유주 의혹'}) MERGE (a)-[r:CAUSES]->(b) SET r += {mechanism: '안보무관 부분까지 국정원 지적 → 실소유주 의혹 증폭', scale: '사회적 논쟁', evidence: '이는 세월호의 실소유주가 국가정보원이 아니냐는 새로운 의혹을 불러일으켜 다양한 논쟁을 야기하는 등의 많은 파장을 낳았다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0820'};
MATCH (a:ResponseActor {name: '국가정보원'}), (b:ResponseAction {name: '국정원 보안측정 해명'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', role: '의혹 반박 해명', effectiveness: 'Low', evidence: '국가정보원은 \'국정원 지적사항.hwp\' 파일은 국가보호장비 지정을 위해 보안측정을 한 결과물에 지나지 않는 것이고, 일정톤급 이상의 선박의 경우에는 통상적으로 보안측정이 이루어진다고 해명하였다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0821'};
MATCH (a:ResponseActor {name: '검찰'}), (b:ResponseAction {name: '세월호 침몰사고 관련 수사 설명자료 발표'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', timing: '2014-10-06', effectiveness: 'Med', evidence: '검찰은 2014년 10월 6일 발표한 \'세월호 침몰사고 관련 수사 설명자료\'를 통해 위와 같은 의혹에 대해 반박하였다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0822'};
MATCH (a:Event {name: '세월호 CCTV 일제 종료'}), (b:Damage {name: '세월호 CCTV 종료 경위 의혹'}) MERGE (a)-[r:CAUSES]->(b) SET r += {mechanism: '사고 직전 영상 부재로 진상 파악 불가', scale: '진상규명 공백', evidence: '세월호 내 64개의 CCTV는 세월호 침몰사고 발생 전인 오전 8시 30분 59초경 모두 일제히 꺼졌기 때문이다. ... 누군가 세월호 CCTV를 갑작스레 끈 것이 아니냐는 의혹이 바로 그것이다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0823'};
MATCH (a:Event {name: '세월호 침몰사고'}), (b:Event {name: '세월호 CCTV 일제 종료'}) MERGE (a)-[r:CONCURRENT_WITH]->(b) SET r += {timing: '사고 발생 직전', reason: 'CCTV가 사고 발생 직전(약 8시 48분경) 종료되어 양 사건이 근접', evidence: '오전 8시 30분 59초경이 아닌 사고 시각과 근접한 오전 8시 48분경 세월호 CCTV가 꺼졌다는 것이다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0824'};
MATCH (a:ResponseActor {name: '검찰'}), (b:ResponseAction {name: 'CCTV 시각 보정 및 고의종료 정황 부인 발표'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', role: 'CCTV 시각 보정·고의종료 부인', effectiveness: 'Med', evidence: '세월호 CCTV 영상에 표시된 시각은 실제 시각보다 18분가량 빠르다고 한다. ... 누군가 세월호 CCTV를 고의로 종료한 정황은 발견되지 않는다고 발표하였다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0825'};
MATCH (a:ResponseActor {name: '세월호 특위 진상조사단'}), (b:ResponseAction {name: '해군 KNTDS 자료 증거보전신청'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', timing: '2014-07-29', effectiveness: 'Low', role: '민감자료 증거보전 시도', evidence: '2014년 7월 29일 진상조사단은 세월호 가족대책위 측을 대리하여 해군이 보유하고 있는 KNTDS 자료, 레이더 영상정보 음성교신내역에 대한 증거보전을 신청하였다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0826'};
MATCH (a:ResponseActor {name: '해군'}), (b:ResponseAction {name: '해군 KNTDS 자료 증거보전신청'}) MERGE (a)-[r:FAILS]->(b) SET r += {phase: 'recovery', reason: '국가안보·군사기밀(II급 비밀)상 제출 불가 항변', effectiveness: 'Low', specialNote: 'KNTDS 공개 시 해군 작전·전개 상황 노출 우려', evidence: 'KNTDS 자료는 군사기밀보호법상 Ⅱ급 비밀로 지정되어 있는 것으로, KNTDS 자료가 공개될 경우 해군의 작전 수행 현황 및 중요 전개 상황 등이 그대로 노출될 가능성이 있어 국가안보상 제출할 수 없다는 피신청인 측의 강력한 항변이 있었기 때문이다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0827'};
MATCH (a:ResponseActor {name: '세월호 특위 진상조사단'}), (b:ResponseAction {name: '국가정보원 자료 증거보전신청'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', timing: '2014-08-07', effectiveness: 'Low', evidence: '2014년 8월 7일 진상조사단은 세월호 가족대책위 측을 대리하여 국가정보원에 대한 증거보전신청을 하였다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0828'};
MATCH (a:ResponseActor {name: '국가정보원'}), (b:ResponseAction {name: '국가정보원 자료 증거보전신청'}) MERGE (a)-[r:FAILS]->(b) SET r += {phase: 'recovery', reason: '국가안보상 제출 곤란 항변', effectiveness: 'Low', evidence: '이 역시 해군에 대한 증거보전신청과 마찬가지로 국가안보상 제출이 어렵다는 강력한 항변에 부딪치게 되었다. ... 신청에 대한 인용 결정을 받아 해당 자료들을 얻는 데까지는 성공하지 못하였다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0829'};
MATCH (a:ResponseActor {name: '세월호 특위 진상조사단'}), (b:ResponseAction {name: '진상조사단-형사재판지원팀 정보공유'}) MERGE (a)-[r:FAILS]->(b) SET r += {phase: 'response', reason: '진상조사단-형사재판지원팀 간 원활한 의사소통 부재', effectiveness: 'Low', specialNote: '확보 자료가 형사재판지원팀에 제대로 전달되지 않음', evidence: '진상조사단과 형사재판지원팀 간의 원활한 의사소통이 이루어지지 않는 등의 문제로 인하여서 증거보전신청 결과 확보한 자료들이 형사재판지원팀에게 제대로 전달이 되지 않는 상황이 발생하였다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0830'};
MATCH (a:Event {name: '세월호 DVR 감정료 분쟁'}), (b:Damage {name: '세월호 DVR 감정료'}) MERGE (a)-[r:CAUSES]->(b) SET r += {mechanism: '감정료 부담 주체 미정으로 업무 지연', scale: '절차 지연', evidence: '명정보기술이 가지고 있는 고도의 기술을 이용하여 상당한 시간동안 복구 작업이 진행되었던 세월호 DVR에 대한 감정료가 문제가 되었다. 그 비용이 무려 80,641,000원에 달했기 때문이다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0831'};
MATCH (a:ResponseActor {name: '광주지방법원 목포지원'}), (b:ResponseAction {name: '세월호 DVR 감정료 소송구조 결정'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', timing: '2015-01-23', role: '감정료 소송구조 수용', effectiveness: 'High', evidence: '2015년 1월 23일 세월호 DVR에 대한 증거보전신청사건을 담당하였던 재판부(광주지방법원 목포지원)에서 감정료에 대한 소송구조를 받아들일 것이니 소송구조신청서를 제출하라는 연락을 ... 소송구조결정(광주지방법원 목포지원 2015카구1001)이 되어 80,641,000원의 감정료 문제를 일단락되었다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0832'};
MATCH (a:ResponseActor {name: '대한변호사협회'}), (b:ResponseAction {name: '증거보전 소송비용 부담'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', role: '공익활동 소송비용 부담', effectiveness: 'Med', evidence: '소송비용은 대한변협 측이 부담을 하였다. ... 공익활동의 일환으로서 큰 문제없이 대한변협 측이 대한변협 법률구조재단을 통해 부담을 해 왔던 것이다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0833'};
MATCH (a:ResponseActor {name: '세월호 특위 형사재판지원팀'}), (b:ResponseAction {name: '진상조사단-형사재판지원팀 연계 운영'}) MERGE (a)-[r:FAILS]->(b) SET r += {phase: 'response', reason: '공판기일 집중(주 2~3일)으로 부담→이탈인원 증가, 인원부족, 진상조사단과 연계 시간 부족', effectiveness: 'Low', evidence: '형사재판 진행과정에서 광주지방법원에서 공판기일들이 집중적으로 주 2일 내지 3일로 지정하면서 변호사들에게 부담을 느끼게 되었다. 그 결과 형사재판지원팀의 이탈인원이 증가하였고 ... 형사재판지원팀은 진상조사단과 별도의 팀처럼 운영되기 시작했다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0834'};
MATCH (a:ResponseActor {name: '세월호 특위 진상조사단'}), (b:ResponseAction {name: '공판기일 피해자 신문사항 정리·제출'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', timing: '2014-08-26~08-27 증인신문 대비', role: '피해자 신문사항 정리·제출', effectiveness: 'High', evidence: '선원사건 진행 중 2014년 8월 26일과 8월 27일에 예정되어 있던 세월호 선장 신모와 오하마나호 선장 박 모에 대한 증인 신문에서의 피해자 신문 사항을 정리하면서부터이다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0835'};
MATCH (a:Facility {name: '세월호(여객선)'}), (b:Event {name: '세월호 침몰사고'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {mechanism: '화물 과적·미흡한 고박으로 복원성 저하', probability: 'High', specialNote: '동급 선박 오하마나호와 같은 노선', evidence: '혹시 8시 45분 이전부터 세월호가 침몰할 예후를 보였던 것은 아닌지에 대해서 의문이 제기되었다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0836'};
MATCH (a:RiskFactor {name: '화물 과적 및 미흡한 고박'}), (b:Event {name: '세월호 침몰사고'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {mechanism: '복원성에 부정적 영향을 미쳐 전복 유발', probability: 'High', directCause: '화물 미흡 고박이 복원성에 미친 영향', evidence: '화물의 미흡한 고박이 복원성에 미친 영향 이 두 가지에 대한 질문을 집중적으로 제출하였다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0837'};
MATCH (a:Event {name: '지그재그 운항'}), (b:Event {name: '세월호 침몰사고'}) MERGE (a)-[r:TRIGGERS]->(b) SET r += {mechanism: '급변침으로 화물 이동·복원성 상실 유발 가능성', probability: 'Med', reason: '지그재그로 운항 시 화물 고박상태에 부정적 영향', specialNote: '검경합동수사본부 전문가자문단에 질의된 가설', evidence: '지그재그로 운항하는 경우 화물의 고박상태에 어떤 부정적인 영향을 주게 되는 지에 대한 판단을 구했다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0838'};
MATCH (a:Event {name: '세월호 침몰사고'}), (b:Event {name: '세월호 선내 정전(CCTV 데이터 저장 중단)'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {mechanism: '선체 침수 진행에 따른 선내 정전·전력 차단', timing: '08:30 전후', probability: 'High', evidence: '사고 발생 전인 8시 30분 59초 경 CCTV가 일제히 꺼진 사실에 대해서는 의문을 가지고 있었다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0839'};
MATCH (a:Event {name: '세월호 선내 정전(CCTV 데이터 저장 중단)'}), (b:Context {name: '2014-04-16 08:30:59 (CCTV 기록 중단 시점)'}) MERGE (a)-[r:OCCURS_AT]->(b) SET r += {timing: '사고 직전', evidence: '64개의 CCTV가 화면 표시 시각 8시 30분을 전후해서 데이터 저장 기록이 멈춘 점', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0840'};
MATCH (a:ResponseAction {name: '비상발전기 작동'}), (b:Event {name: '세월호 침몰사고'}) MERGE (a)-[r:MITIGATES]->(b) SET r += {mechanism: '비상발전기 작동 시 침몰 속도에 영향', effectiveness: 'Med', specialNote: '작동 여부가 쟁점으로 질의됨', evidence: '기관장 박 모가 비상발전기를 작동하였는지, 비상발전기를 작동하였다면 세월호의 침몰 속도에 영향을 줄 수 있었는지', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0841'};
MATCH (a:ResponseActor {name: '기관장 박 모'}), (b:ResponseAction {name: '비상발전기 작동'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '비상전원 조치 주체', specialNote: '작동 여부 불확실', evidence: '기관장 박 모가 비상발전기를 작동하였는지', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0842'};
MATCH (a:Facility {name: '세월호 운항관리규정 보고계통도'}), (b:ResponseAction {name: '세월호 해양사고 보고'}) MERGE (a)-[r:GUIDED_BY]->(b) SET r += {role: '사고 보고 절차 규정', specialNote: '오하마나호 등 동급선박은 국정원 보고의무 없음', evidence: '세월호의 운항관리규정의 해양사고 보고계통도를 살펴보면 해운조합, 해양경찰만 아니라 국가정보원에도 보고하도록 규정되어 있고, 더 나아가서는 국가정보원에 가장 우선적으로 보고하도록 규정되어있다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0843'};
MATCH (a:ResponseActor {name: '청해진해운'}), (b:ResponseAction {name: '세월호 해양사고 보고'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '사고 보고 주체', timing: '참사 당일 오전 9시 10분 경', specialNote: '해양경찰보다 먼저 국가정보원에 연락', evidence: '세월호 참사 당일 청해진 해운은 해양경찰보다 먼저 국가정보원에 연락을 취했다는 청해진 해운 사장 김한식의 진술이 있었다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0844'};
MATCH (a:ResponseActor {name: '국가정보원'}), (b:ResponseAction {name: '세월호 국가보호장비 보안측정'}) MERGE (a)-[r:COORDINATES_WITH]->(b) SET r += {role: '보안측정 공동 수행', specialNote: '인천해양항만청·항만공사·해운조합·인천해양경찰·기무사와 보안측정 함께 실시', evidence: '보안측정을 함께 실시한 인천해양항만청, 항만공사, 해운조합, 인천해양경찰, 기무사 등 다른 기관에서 한 지적사항이라는 주장이다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0845'};
MATCH (a:RiskFactor {name: '세월호 AIS 항적 기록 누락'}), (b:Damage {name: '세월호 침몰 원인 규명 곤란'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {mechanism: '항적 기록 결손으로 침몰 원인 규명 곤란·의혹 증폭', reason: '29초간 항적 미복원', probability: 'Med', evidence: '4월 기록의 8시 48분 44초부터 8시 49분 13초까지의 29초간의 기록이 복원되지 않았다. 따라서 이 29초간의 세월호 항적에 대해 다양한 의문이 제기될 수밖에 없었다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0846'};
MATCH (a:ResponseActor {name: '세월호 특위 진상조사단'}), (b:ResponseAction {name: '세월호 CCTV·DVR·AIS 증거보전 및 분석'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '증거 분석·진상규명', phase: 'recovery', timing: '2014-08~10', evidence: '진상조사단은 CCTV 64개의 14시간동안의 기록을 보고 이상 징후를 체크하는 작업을 가족대책위와 상의하여 영상을 전달받을 수 있었다. 그 후 2주에 걸쳐 약 8인의 변호사들이 여러 팀으로 나뉘어 이상 징후에 대해 파악하는 작업을 했다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0847'};
MATCH (a:Event {name: '3등 기관사 이 모의 청테이프 작업'}), (b:Event {name: '세월호 침몰사고'}) MERGE (a)-[r:CONCURRENT_WITH]->(b) SET r += {timing: '사고 직전 (07:58~08:28)', specialNote: '침몰 예후와의 관련성 의혹 — 복원성 관계 여부 미확정', probability: 'Low', evidence: '사고 당일인 4월 16일 7시 58분경부터 약 30분 간 3등 기관사 이 모가 청테이프를 가지고 한 파이프 부근에서 작업을 하는 것이 발견되었던 것이다. 따라서 혹시 8시 45분 이전부터 세월호가 침몰할 예후를 보였던 것은 아닌지에 대해서 의문이 제기되었다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0848'};
MATCH (a:RiskFactor {name: '70톤 이상 거대 화물(군용화물 의혹)'}), (b:Event {name: '세월호 침몰사고'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {mechanism: '거대 화물 적재로 복원성 저하, 적재 시 선체 크게 흔들림', probability: 'Med', directCause: '거대 화물 적재', evidence: '인청항구의 CCTV에 한 화물을 싣는 순간 세월호가 크게 흔들리는 모습이 포착되었기 때문이었다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0849'};
MATCH (a:Facility {name: '오하마나호'}), (b:Context {name: '인천~제주 항로'}) MERGE (a)-[r:LOCATED_IN]->(b) SET r += {role: '비교대조 동급선박', specialNote: '세월호와 운항 노선 동일', evidence: '세월호와 같이 청해진 해운 소속이며, 동일한 노선인 인천~제주를 오가는 6000t급 여객선인 오하마나호', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0850'};
MATCH (a:Damage {name: '세월호 참사 인명피해'}), (b:Context {name: '탈출 시뮬레이션(방재 전문가)'}) MERGE (a)-[r:QUANTIFIED_BY]->(b) SET r += {role: '탈출 시뮬레이션 검증 대상', specialNote: '방재 시뮬레이션 전문가가 탈출 소요시간·생존확률 측정', evidence: '방재 시뮬레이션 전문가에 대해서는 여러 가지 상황마다 승객들이 탈출하는데 소요되는 시간 등을 측정하는 연구를 진행하였으므로', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0851'};
MATCH (a:ResponseAction {name: '선내 대기 방송'}), (b:Event {name: '세월호 침몰사고'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {role: '사고 시 승객 통제 조치', effectiveness: 'Low', reason: '대기 지시가 오히려 탈출 지연 초래', evidence: '선장과 선원들이 대기하라고 했던 선실에 있는 경우와 대기 방송 없이 사람들이 산발적으로 배 안에 있는 경우 탈출이 편이 유리한 지에 대해서 설명을 구했다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0852'};
MATCH (a:Facility {name: 'KRISO 세월호 침몰사고 원인 분석 보고서'}), (b:ResponseAction {name: '세월호 침몰 원인 규명'}) MERGE (a)-[r:GUIDED_BY]->(b) SET r += {role: '침몰 원인 분석 근거자료', specialNote: '검경합동수사본부 전문가자문단 보고서와 별도 작성', evidence: 'KRISO(한국해양과학기술원 부설 선박해양플랜트 연구소)에서 2014년 10월 작성한 \'세월호 침몰사고 원인 분석 - 선박 조종 및 침수·침몰 시뮬레이션\'', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0853'};
MATCH (a:ResponseActor {name: '검경 합동수사본부'}), (b:ResponseAction {name: '세월호 침몰 원인 규명'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '침몰 원인 조사·보고서 작성', phase: 'recovery', evidence: '침몰 원인을 조사한 검경합동수사본부 전문가자문단 허용범 단장이 보고서 내용 중 자신이 작성한 선체운동 부분에 대하여 진술하기로 예정되어 있었으므로', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0854'};
MATCH (a:RiskFactor {name: '세월호 화물 고박 부실'}), (b:Event {name: '세월호 복원성 상실'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {mechanism: '대각도 변침 시 무게중심이 급격히 이동하면서 고박 부실 화물이 한 방향으로 쏠림', probability: 'High', evidence: '세월호의 무게중심이 대각도 변침으로 인하여 급격히 이동하면서 세월호 내의 고박이 제대로 이루어지지 않았던 화물 등이 한 방향으로 무게 중심이 쏠리면서', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0855'};
MATCH (a:Event {name: '세월호 지그재그 조타'}), (b:Event {name: '세월호 대각도 변침'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {mechanism: '복원성이 저하되던 중 대각도 변침으로 이어짐', probability: 'High', timing: '사고 직전', evidence: '세월호가 조타실 선원들의 지그재그 조타에 의해 선체의 복원성이 저하되던 중에 대각도 변침을 함으로써 침몰한', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0856'};
MATCH (a:Event {name: '세월호 대각도 변침'}), (b:Event {name: '세월호 복원성 상실'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {mechanism: '대각도 변침으로 무게중심 급이동→복원성 상실', probability: 'High', directCause: '대각도 변침', evidence: '세월호가 변침을 통해서 기울어진 방향... 대각도 변침을 하며 회전하였을 가능성이 높고', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0857'};
MATCH (a:Event {name: '세월호 정전'}), (b:Damage {name: '세월호 CCTV 기록 중단'}) MERGE (a)-[r:CAUSES]->(b) SET r += {mechanism: '전원 차단으로 CCTV 영상 기록 중단', timing: '급변침 무렵', evidence: '64개의 CCTV 영상이 8시 30분을 이후에는 기록이 전혀 되지 않은 점... CCTV 영상이 끊긴 시각은 8시 30분이 아닌 8시 45분경으로, 세월호 급변침 시각 무렵', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0858'};
MATCH (a:Context {name: '세월호 CCTV 영상시각 오차'}), (b:Damage {name: '세월호 CCTV 기록 중단'}) MERGE (a)-[r:QUANTIFIED_BY]->(b) SET r += {specialNote: 'CCTV 끊긴 실제 시각 산정 근거', evidence: 'CCTV 영상에 표시되어 있는 시각이 실제 시각보다 15분 21초가량 늦은 것을 확인', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0859'};
MATCH (a:ResponseAction {name: '기관장 박모 비상발전기 작동 여부'}), (b:Event {name: '세월호 침몰사고'}) MERGE (a)-[r:MODIFIES_RISK_OF]->(b) SET r += {effectiveness: 'Unknown', reason: '비상발전기 작동이 침몰 속도에 영향을 줄 수 있었는지 쟁점', specialNote: '작동 여부 자체가 불확실', evidence: '기관장 박 모가 비상발전기를 작동하였는지, 비상발전기를 작동하였다면 세월호의 침몰 속도에 영향을 줄 수 있었는지', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0860'};
MATCH (a:ResponseActor {name: '해양경찰 123정'}), (b:ResponseAction {name: '세월호 현장 인명구조'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', specialNote: '구조 목적으로 출동, 로프 연결 음모론 제기됨', evidence: '구조하러 왔던 해양경찰의 123정 보트가 로프를 세월호에 연결하여 끌어서 더 빠르게 침몰시키려 하였다는 음모론... 과연 100톤 단정이 6000톤 세월호의 침몰에 영향을 줄 수 있는지', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0861'};
MATCH (a:ResponseActor {name: '검경 합동수사본부'}), (b:ResponseAction {name: '세월호 침몰 원인 분석 보고서 작성'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', specialNote: '사고 원인 분석 보고서 작성', evidence: '검경합동수사본부 전문가자문단 보고서... 검경합동수사본부 전문가자문단의 결론이었다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0862'};
MATCH (a:ResponseActor {name: 'KRISO(한국해양과학기술원 부설 선박해양플랜트 연구소)'}), (b:ResponseAction {name: 'KRISO 세월호 침몰사고 원인 분석 보고서 작성'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', timing: '2014-10', specialNote: '선박 조종 및 침수·침몰 시뮬레이션', evidence: 'KRISO(한국해양과학기술원 부설 선박해양플랜트 연구소)에서 2014년 10월 작성한 \'세월호 침몰사고 원인 분석 - 선박 조종 및 침수·침몰 시뮬레이션\'', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0863'};
MATCH (a:ResponseActor {name: '세월호 특위 진상조사단'}), (b:ResponseAction {name: '진상조사단 AIS·CCTV 자료 분석'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', specialNote: 'AIS 항적·레이더 자료 분석 및 CCTV 영상 확보·분석', evidence: 'AIS 항적을 비롯하여 다양한 레이더 자료를 분석하였던 진상조사단... 증거보전절차를 진행하여 CCTV 영상을 확보한 뒤, 정밀하게 영상을 분석', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0864'};
MATCH (a:ResponseActor {name: '세월호 특위 진상조사단'}), (b:ResponseAction {name: '전문가 보고서 독립 검증'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '보고서가 사전 입수·분석되지 않아 적절한 질문사항 정리에 한계, 지속적 전문가 교류 미성사', effectiveness: 'Low', specialNote: '시간·비용 문제로 독립 전문가 검증 실현 못함', evidence: '이 보고서 역시 사전에 입수되어 분석된 바가 없었기 때문에 적절한 질문사항을 정리하는데 한계가 있었다... 시간과 비용의 문제로 인하여 실현되지는 못하였다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0865'};
MATCH (a:ResponseActor {name: '해양수산부'}), (b:ResponseAction {name: '세월호 AIS 항적도 복구·발표'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: 'AIS 데이터 소실 시간 발표를 3분36초→36초→29초→35초로 번복하며 조작·은폐 의혹 자초', effectiveness: 'Low', specialNote: '동일 원자료로 해양안전심판원과 누락 구간 상이 발표', evidence: '데이터 소실 시간도 애초 3분36초라고 했으나, 후에 계속해서 36초, 29초, 35초 등으로 발표를 번복하며 의혹을 자초했다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0866'};
MATCH (a:RiskFactor {name: '세월호 AIS 항적 기록 누락'}), (b:Event {name: '세월호 침몰 원인 의혹 확산'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {mechanism: 'AIS 공백구간으로 외부충돌·은폐 등 침몰 원인 의혹 증폭', probability: 'Med', evidence: 'AIS가 중간에 저장되지 않은 공백구간이 있는 것에 대해서 왕왕 의도적인 항적로의 은폐 또는... 외부적 원인에 의한 침몰 의혹 등이 불거졌다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0867'};
MATCH (a:RiskFactor {name: '세월호 AIS 서버 이중화 작업'}), (b:Damage {name: '세월호 AIS 항적 기록 누락'}) MERGE (a)-[r:CAUSES]->(b) SET r += {mechanism: '이중화 후 전송량 증가로 저장 지연', directCause: '게이트웨이 포트 데이터 전송량 불규칙 증가', specialNote: 'AIS 기록 누락이 고의가 아님을 일부 규명', evidence: '2014년 4월 1일 서버(AIS DB, 통합 게이트웨이 등) 이중화 작업을 실시하여 신규 통합 게이트웨이의 일부 포트에서 데이터 전송량이 불규칙적으로 증가하면서 항적정보 저장이 지연되었다는 해명', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0868'};
MATCH (a:RiskFactor {name: '세월호 AIS 송신 간격 제한'}), (b:Damage {name: '세월호 AIS 항적 기록 누락'}) MERGE (a)-[r:CAUSES]->(b) SET r += {mechanism: '송신 간격 변동 및 기계 성능 한계로 신호 단속', directCause: '기계 성능 제한·시스템 오류', specialNote: '사고 원인과는 무관하다는 허용범 단장 진술', evidence: '변침 직전 속도가 약 17kts로 6초 간격으로 위치 정보를 진도VTS 등에 송신... 대각도 변침 시에는 속도가 6kts가 돼 2초 간격으로 송신... 중간 중간 뚝뚝 끊어진 것은 기계 자체의 성능 상 제한이나 시스템의 오류일 뿐', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0869'};
MATCH (a:ResponseActor {name: '허용범 단장'}), (b:ResponseAction {name: '검경합동수사본부 전문가 진술'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', specialNote: 'AIS 신호 단절 정상성·편각 개념 등 전문가 진술', evidence: '허용범 단장은 세월호 AIS가 사고 당시 끊긴 것은 극히 정상적인 것으로... 편각의 개념을 제대로 이해하지 못한 오해에서 나온 결론이라고 허용범 단장은 확언하였다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0870'};
MATCH (a:ResponseActor {name: '검경 합동수사본부'}), (b:ResponseActor {name: '광주지방법원 형사재판부'}) MERGE (a)-[r:BELONGS_TO]->(b) SET r += {specialNote: '전문가자문단 보고서가 2014.9.16 공판에서 처음 일부 공개', evidence: '2014년 9월 16일 공판 외 기일은 검경합동수사본부 전문가자문단의 보고서가 처음으로 재판정에서 전문가에 의해서 일부 공개되는 자리였다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0871'};
MATCH (a:Event {name: '세월호 자이로콤파스 순간 오류'}), (b:Damage {name: '세월호 AIS 선회각 이상 수치'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {mechanism: '무게중심 변화→자이로콤파스 오류→비현실적 선회각 기록', probability: 'High', specialNote: '외부 충돌 아닌 내부적 충돌로 추정', evidence: '세월호의 무게중심이 대각도 변침으로 인하여 급격히 이동하면서... 자이로콤파스의 세차운동이 순간 오류가 났던 것으로 추정... 1초에 15도, -22도의 방향 전환을 하였다는 수치', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0872'};
MATCH (a:Damage {name: '세월호 AIS 선회각 이상 수치'}), (b:Event {name: '세월호 침몰 원인 의혹 확산'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {mechanism: '비현실적 수치가 외부충돌 침몰 의혹 증폭', probability: 'Med', evidence: '조타실수가 아닌 외부적 충돌로 인하여 세월호가 복원성을 상실하고 침몰한 것은 아닌지에 대한 의문이 지속적으로 제기', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0873'};
MATCH (a:Context {name: '세월호 AIS 기록'}), (b:Event {name: '세월호 대각도 변침'}) MERGE (a)-[r:UNDER_CONDITION]->(b) SET r += {specialNote: '지그재그 운항·대각도 변침 판단의 정량 근거', evidence: '8시 44분 5초의 HDG는 129.4도... 8시 49분 32초에 HDG 159.1도로 운항하였던 바', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0874'};
MATCH (a:Context {name: '세월호 AIS 기록 누락 구간'}), (b:Damage {name: '세월호 AIS 항적 기록 누락'}) MERGE (a)-[r:QUANTIFIED_BY]->(b) SET r += {specialNote: 'AIS 누락 구간 정량 근거', evidence: '해양수산부의 경우 8시 48분 37초부터 8시 52분 13초까지의 3분 36초의 누락구간... 해양안전심판원은 8시 47분 35초부터 52분 30초까지, 4분 55초 동안의 기록이 없다고 발표', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0875'};
MATCH (a:ResponseActor {name: '해양수산부'}), (b:ResponseActor {name: '해양안전심판원'}) MERGE (a)-[r:COORDINATES_WITH]->(b) SET r += {role: '동일 원자료(진도VTS Raw data) 공유', specialNote: '동일 자료로 상이한 누락 구간 도출', evidence: '동일한 원자료(Raw data)를 전달받은 해양수산부와 해양안전심판원은 누락 구간을 다르게 발표했는데', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0876'};
MATCH (a:ResponseAction {name: '3등기관사 이모 청테이프 작업'}), (b:Event {name: '세월호 복원성 상실'}) MERGE (a)-[r:MODIFIES_RISK_OF]->(b) SET r += {effectiveness: 'None', reason: '청테이프 작업 파이프가 복원성 관련 기관이 아님으로 밝혀짐', specialNote: '기관장 박모가 사전 예고 없이 지시한 페인트 예비작업', evidence: '이 모가 청테이프를 붙인 파이프가 복원성에 관련된 특별한 기관은 아닌 것으로 밝혀졌다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0877'};
MATCH (a:ManmadeHazard {name: '세월호'}), (b:Context {name: '국가정보원 보안측정 지적사항'}) MERGE (a)-[r:OCCURS_AT]->(b) SET r += {specialNote: '국가정보원 보안측정 대상 시설', evidence: '국가정보원 측의 지적사항은 CCTV 사각지대 없애는 것, CCTV 화소 안 나오는 부분을 수정하는 것, 일본어 안내판을 한국어로 변경하는 것, 항만 쪽에 울타리 관리하고, 경비를 충원하고 경비실 보강하는 보안 관련 부분', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0878'};
MATCH (a:Resilience {name: 'AIS 서버 이중화'}), (b:Damage {name: '세월호 AIS 항적 기록 누락'}) MERGE (a)-[r:OFFSETS]->(b) SET r += {effectiveness: 'Low', specialNote: '이중화가 데이터 안정성 목적이었으나 오히려 누락 유발', evidence: '서버(AIS DB, 통합 게이트웨이 등) 이중화 작업을 실시하여 신규 통합 게이트웨이의 일부 포트에서 데이터 전송량이 불규칙적으로 증가하면서 항적정보 저장이 지연', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0879'};
MATCH (a:ResponseActor {name: '세월호 특위 형사재판지원팀'}), (b:ResponseAction {name: '진상조사단-형사재판지원팀 정보 공유'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '지휘체계 미규정으로 진상조사단과 별도 운영, 정보 공유 시스템 미구축으로 상호 정보 공유 단절', effectiveness: 'Low', specialNote: '급박한 협조 필요 시 신속 지원 안 됨', evidence: '지휘체계가 명확하게 규정되지 않으면서... 정보를 공유하는 시스템이 구축되지 않았기 때문에 각 팀이 수집한 자료나 분석의 경우 각 팀 내부에서만 유통... 신속하게 지원이 되지 않는 어려움', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0880'};
MATCH (a:ResponseActor {name: '세월호 특위 진상조사단'}), (b:ResponseActor {name: '세월호 가족대책위'}) MERGE (a)-[r:COORDINATES_WITH]->(b) SET r += {role: '자료 공유·질문서 공동 작성', effectiveness: 'Med', specialNote: '재판 활용을 위한 협력', evidence: '세월호 가족대책위 진상조사단과 내용을 공유하며 재판의 흐름에서 진상규명의 단서를 확보하기 위해 노력하였다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0881'};
MATCH (a:RiskFactor {name: '선원 사건 증거자료 방대성'}), (b:ResponseAction {name: '진상조사단 AIS·CCTV 자료 분석'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {mechanism: '방대한 자료 취합·해석 부담으로 진상규명 지연·누락 위험', probability: 'Med', evidence: '3000개 이상의 증거와 15000 페이지 이상의 증거자료가 제출되었다. 이러한 자료를 취합하여 적절하게 피해자들을 대변하고 진상규명을... 방대한 작업', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0882'};
MATCH (a:Event {name: '세월호 침몰사고'}), (b:ResponseAction {name: '세월호 특위 진상조사단 진상조사 활동'}) MERGE (a)-[r:TRIGGERS_SECONDARY]->(b) SET r += {mechanism: '참사 원인 진상조사를 위한 대규모 법률·조사 대응 활동 촉발', timing: '사고 후', evidence: '특히 세월호 참사와 같이 사회 전반의 비리와 과실의 누적이 원인이 되어 발생한 사고에 관해 진상조사를 하려면 전문가의 조력이 필수적이다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0883'};
MATCH (a:RiskFactor {name: '세월호 참사 원인의 복합성(비리·과실 누적)'}), (b:Event {name: '세월호 침몰사고'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {mechanism: '복합 원인 구조로 진상규명에 전문가 조력·방대한 자료 분석 필수', reason: '방대한 자료에 각 분야 전문가 의견 필수', evidence: '사회 전반의 비리와 과실의 누적이 원인이 되어 발생한 사고에 관해 진상조사를 하려면 전문가의 조력이 필수적이다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0884'};
MATCH (a:RiskFactor {name: '지휘체계·정보공유 시스템 미비'}), (b:Event {name: '진상조사단-형사재판지원팀 정보공유 단절'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {mechanism: '급박한 협조 필요시 신속 지원 불가, 시너지 효과 발휘 어려움', probability: 'High', reason: '자료공유 기본원칙 미확립', evidence: '지휘체계가 명확하게 규정되지 않으면서 ... 상호간의 정보 공유가 단절되었다. ... 각 팀이 수집한 자료나 분석의 경우 각 팀 내부에서만 유통이 되었다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0885'};
MATCH (a:Event {name: '진상조사단-형사재판지원팀 정보공유 단절'}), (b:Event {name: '형사재판 자료 제출 적시성 실패'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {mechanism: '공판기일 직전에야 임시방편적 협조, 시기적절한 자료 제출 실패', timing: '공판기일 직전', effectiveness: 'Low', evidence: '공판기일 직전에 형사재판지원팀은 지원을 요청하게 되고 ... 임시방편적인 형태로 협조를 할 수밖에 없었다. ... 초기의 계획이 실현되지 못하였다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0886'};
MATCH (a:Event {name: '진상조사단-형사재판지원팀 정보공유 단절'}), (b:Event {name: '양 팀 간 사건 인식 괴리'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {mechanism: '양 팀 간 사건 인식 괴리 발생, 중요 단초 누락', reason: '재판 속기 취합·분석 구성원 부재', evidence: '재판에서 진상 규명이 이루어진 부분이 진상조사단에서는 여전히 진상조사가 필요한 부분으로 인식되는 등 양 팀 간의 사건의 인식에 대한 괴리가 발생했다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0887'};
MATCH (a:ResponseActor {name: '세월호 특위 진상조사단'}), (b:ResponseAction {name: '재판 속기·진술조서 적시 분석'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '재판 속기를 정기적으로 취합·분석하는 구성원 부재, 검찰의 진술조서 미전달', effectiveness: 'Low', specialNote: '결심공판 임박해서야 자료 확보', evidence: '재판 속기를 진상조사단에서 정기적으로 취합하여 분석하는 역할을 수행하는 구성원이 없었다. ... 검찰에서 공판에 제시되기 전까지 세월호 특위에 자료를 전달해주지 않았으며', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0888'};
MATCH (a:ResponseActor {name: '검찰'}), (b:ResponseAction {name: '진술조서 적시 전달'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '공판 제시 전까지 진술조서를 세월호 특위에 미전달', timing: '결심공판 임박', effectiveness: 'Low', evidence: '검찰에서 공판에 제시되기 전까지 세월호 특위에 자료를 전달해주지 않았으며 그로 인하여 결심 공판이 가까워져서야 겨우 해당 자료를 얻을 수 있었다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0889'};
MATCH (a:RiskFactor {name: '전문가 집단과의 연계 부재'}), (b:Event {name: '전문가 자료 해석 지연'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {mechanism: '공판기일 이후 뒤늦은 전문가 섭외로 프로보노 지원 불가, 비용 발생', reason: '국민적 관심 돌아선 이후 섭외 시도', evidence: '전문가 집단과 연계가 제대로 갖춰져 있지 못하였기 때문에 적절한 시기에 필요한 조력을 받기는 항상 어려웠다. ... 전문가를 섭외하는 과정에서는 필연적으로 프로보노 형태의 전문가 지원을 기대하기 어려웠고 프로젝트를 발주', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0890'};
MATCH (a:Damage {name: '전문가 분석 프로젝트 발주 비용'}), (b:Context {name: '전문가 프로젝트 발주 비용 2000만원'}) MERGE (a)-[r:QUANTIFIED_BY]->(b) SET r += {role: '비용 정량', evidence: '전문가에게 프로젝트를 발주하는 비용 자체가 2000만원 상당에 달하는 바', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0891'};
MATCH (a:RiskFactor {name: '세월호 침몰 원인 음모론·낭설'}), (b:Event {name: '세월호 침몰 원인 의혹 확산'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {mechanism: '피해자·가족의 오해 심화, 규명된 사실 불신', reason: '규명 사실의 공식 브리핑·홍보 미흡', probability: 'High', evidence: '‘음모론’이라고 불리는 다양한 세월호 침몰 원인으로 주장되는 낭설들에 대해서 사실이라고 신뢰하는 ... 가족들도 일부 존재하였으며', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0892'};
MATCH (a:RiskFactor {name: '잠수함 충돌 침몰 의혹'}), (b:Event {name: '세월호 침몰 원인 의혹 확산'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {mechanism: '공식 브리핑·자료 배부 미흡으로 의혹 반복 제기', reason: '반증 사실 미홍보', probability: 'Med', evidence: '잠수함의 충돌로 인한 침몰이라는 의혹에 대해서는 ... 급격하게 방향이 전환되는 등의 충돌 정황을 보인 바가 없으며 ... 잠수함 충돌에 대한 여러 가지 의혹은 반복적으로 제기되고 있는 실정이다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0893'};
MATCH (a:ResponseActor {name: '해양수산부'}), (b:ResponseAction {name: 'AIS 항적 누락 구간 복원·발표'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: 'AIS 항적 발표 잦은 번복, 3차에 걸쳐 발표하며 누락 구간 미복원', timing: '2014-04-17~2014-04-26', effectiveness: 'Low', specialNote: '29초 여전히 미복원', evidence: '해양수산부의 발표는 잦은 번복을 계속했다. ... 36초도 복구했다고 설명했지만, 36초 중 이는 일부에 불과하며 29초간은 여전히 복원되지 않은 상태였다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0894'};
MATCH (a:Context {name: 'AIS 항적 발표 잦은 번복'}), (b:Event {name: '세월호 침몰 원인 의혹 확산'}) MERGE (a)-[r:UNDER_CONDITION]->(b) SET r += {role: '발표 번복 정황', evidence: '해양수산부는 세월호 사고 다음날부터 3차에 걸쳐 3분 36초가 빠진 항적도를 복구하며 발표했다. 최초 발표에서 누락된 3분 36초 구간 때문에 J자 급변침 항적도가 되었고', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0895'};
MATCH (a:ResponseActor {name: '해양수산부·해양경찰·검찰·국방부'}), (b:ResponseAction {name: '세월호 마지막 29초 항적 규명'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '4개월간 누구도 29초 항적 규명에 적극 나서지 않음, AIS 기록에만 매몰', duration: '4개월', effectiveness: 'Low', evidence: '4개월 간 해양수산부, 해양경찰, 검찰, 국방부 등 누구 하나 밝혀지지 않은 29초간의 항적을 찾는 데에 적극적으로 나서지 않았다는 점', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0896'};
MATCH (a:RiskFactor {name: '정부의 AIS 기록 편중·비전문적 분석'}), (b:Event {name: '정부의 29초 항적 규명 실패'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {mechanism: '동일 진도VTS 자료 입수했으나 비전문 분석으로 29초 항적 미발견', reason: 'AIS 기록에만 매몰', evidence: '진도VTS 자료에 대해서 ... AIS 기록에 대해서만 집중하였고 이를 비전문적으로 분석한 결과 29초의 항적을 찾지 못하는 미흡함을 보였다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0897'};
MATCH (a:ResponseActor {name: '세월호 특위 진상조사단'}), (b:ResponseAction {name: '진도VTS 교신기록 증거보전신청'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '증거 확보 법적 조치', timing: '2014-06-05', effectiveness: 'High', evidence: '2014년 6월 5일 광주지방법원 해남지원에 ... 진도VTS가 보유한 교신기록 등 자료에 대해 증거보전신청(광주지방법원 해남지원 2014카기502)하였다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0898'};
MATCH (a:ResponseActor {name: '세월호 가족대책위'}), (b:ResponseAction {name: '진도VTS 항적 자료 포렌식 복원'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '데이터 복원 분석', effectiveness: 'High', mechanism: '법원 지정 전문 감정인 통한 포렌식', evidence: '세월호 가족대책위는 진도VTS의 항적 자료를 확보한 뒤 법원이 결정한 전문 감정인을 통해 데이터를 복원한 포렌식 작업을 거쳤다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0899'};
MATCH (a:RiskFactor {name: '진도VTS 분석 프로그램 설치 비용·기술 장벽'}), (b:ResponseAction {name: '진도VTS 자료 분석'}) MERGE (a)-[r:PRECONDITIONS]->(b) SET r += {role: '분석 장벽', reason: '특수 프로그램 설치비 2000만원 이상', evidence: '화면에 현출하기 위해서는 별도의 특수한 프로그램을 설치 운용이 필요하였는데 이에 2000만원이 이상의 비용을 요했기 때문에', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0900'};
MATCH (a:ResponseActor {name: '세월호 특위 진상조사단'}), (b:ResponseAction {name: '세월호 마지막 29초 항적 규명'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '29초 항적 규명 핵심 성과', timing: '2014-10-11', effectiveness: 'High', specialNote: '국가가 못한 것을 피해자·대리인이 달성', evidence: '2014년 10월 11일 기자회견을 통해 ... 세월호 침몰의 원인을 밝혀내는 데에 가장 중요한 29초, 즉 8시 48분 44초부터 8시 49분 13초 사이의 세월호 항적을 명확하게 특정할 수 있게 되었다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0901'};
MATCH (a:ResponseAction {name: '세월호 마지막 29초 항적 규명'}), (b:Event {name: '세월호 침몰 원인 의혹 확산'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {role: '원인 의혹 해소 단초', effectiveness: 'Med', specialNote: '급변침 항로에서 큰 이변 없이 진행됨을 증명, 외부충돌·좌초·고의침몰의 결정적 증거는 아님', evidence: '29초간의 항적을 찾아낸 것이 외부충돌, 좌초, 지그재그 운항에 대한 고의 침몰의 결정적인 증거에 해당하는 것은 아니며 ... 진상규명의 첫걸음', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0902'};
MATCH (a:ResponseActor {name: '세월호 특위 진상조사단·가족대책위'}), (b:ResponseAction {name: 'KNTDS 군 레이더 영상 증거보전신청'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '증거보전절차로 KNTDS 군 레이더 자료 확보 시도', effectiveness: 'Low', specialNote: '국가안보 사유 공개 불가, 절차 잠정 중단', evidence: '세월호 특위 역시 KNTDS에 대한 증거보전신청을 하였으나, 국가안보문제 상 공개가 불가능하다는 해군 측과 ... 현재는 절차가 잠정적으로 중단된 상태이다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0903'};
MATCH (a:ResponseActor {name: '해군'}), (b:ResponseAction {name: 'KNTDS 군 레이더 자료 공개'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '국가안보 사유로 KNTDS 자료 공개 거부, 증거보전절차 잠정 중단', effectiveness: 'Low', evidence: '국가안보문제 상 공개가 불가능하다는 해군 측과 계속해서 주장과 항변을 주고받으며 기일이 늘어졌고, 현재는 절차가 잠정적으로 중단된 상태이다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0904'};
MATCH (a:RiskFactor {name: '진도VTS 저장장치 2개 분리·기록 불일치'}), (b:Event {name: '추가 진상규명 필요 사항 발생'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {mechanism: '장치별 기록 차이가 추가 진상조사 대상', reason: '분석 과정에서 발견', evidence: '진도VTS의 저장장치는 2개로 분리되어 있고, 기록된 AIS 항적기록이 저장장치별로 차이가 있다는 사실이 밝혀졌다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0905'};
MATCH (a:ResponseAction {name: '진상조사단 차원의 가족대책위 재판 결과 보고'}), (b:Event {name: '세월호 침몰 원인 의혹 확산'}) MERGE (a)-[r:MITIGATES]->(b) SET r += {role: '오해 완화 조치', effectiveness: 'Low', reason: '인력 부족으로 미수행', evidence: '진상조사단 차원에서 재판에서 밝혀진 실체 사실에 관하여 세월호 가족대책위의 총회에서 보고하는 등의 노력을 기울였어야 하지만, 인력의 부족 등으로 이러한 업무를 수행하지 못한 결과', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0906'};
MATCH (a:ResponseActor {name: '세월호 특위 진상조사단'}), (b:ResponseAction {name: '진상조사단 차원의 가족대책위 재판 결과 보고'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '인력 부족으로 규명 사실의 가족대책위 보고·홍보 미수행', effectiveness: 'Low', evidence: '인력의 부족 등으로 이러한 업무를 수행하지 못한 결과, 세월호 참사의 원인에 대한 오해가 깊어지는 등의 문제가 발생하기도 하였다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0907'};
MATCH (a:ResponseActor {name: '검경 합동수사본부'}), (b:ResponseAction {name: '검경합수부 전문가자문단 보고서 작성'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: 'AIS 항적 분석 통한 의혹 반증', effectiveness: 'Med', specialNote: '신뢰도 검증 필요성 제기됨', evidence: '검경합동수사본부 전문가자문단의 보고서에 따를 때 사고 발생 전후 AIS 항적을 살펴본 결과 급격하게 방향이 전환되는 등의 충돌 정황을 보인 바가 없으며', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0908'};
MATCH (a:ResponseActor {name: '재판부'}), (b:ResponseAction {name: '전문가자문단 보고서 적시 전달'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '전문가자문단 보고서를 예고일보다 3주가량 늦게 전달, 결심공판 직전 열람·급박 분석', effectiveness: 'Low', evidence: '전문가자문단 보고서의 경우 역시 재판부에서 전달하기로 예고한 날짜로부터 3주가량이나 늦게 입수할 수 있었기 때문에 결심공판 직전에나 그에 대한 열람이 가능했고 분석 역시 급박하게 이루어질 수밖에 없었다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0909'};
MATCH (a:ResponseAction {name: '세월호 마지막 29초 항적 규명'}), (b:Resilience {name: '피해자·시민 주도 진상규명 역량'}) MERGE (a)-[r:BUILDS]->(b) SET r += {role: '피해자·대리인 자체 진상규명 역량 입증', effectiveness: 'High', evidence: '국가의 조사 능력으로도 밝혀내지 못한 사실을 세월호 가족대책위와 함께 한 세월호 특위 변호사들의 치열한 노력과 분석의 결과였다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0910'};
MATCH (a:Context {name: 'AIS 항적 누락 구간(29초)'}), (b:Event {name: '세월호 침몰사고'}) MERGE (a)-[r:OCCURS_AT]->(b) SET r += {role: '급변침 발생 시점', evidence: '8시 48분 44초부터 8시 49분 13초 사이의 세월호 항적을 명확하게 특정', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0911'};
MATCH (a:RiskFactor {name: '세월호 과적'}), (b:Event {name: '세월호 침몰사고'}) MERGE (a)-[r:TRIGGERS]->(b) SET r += {probability: 'High', directCause: '과적', mechanism: '복원성 상실로 전복·침몰 유발', reason: '안전불감증으로 인한 무리한 화물 적재', evidence: '세월호 참사는 과적, 안전 점검과 감독 소홀, 즉 안전불감증으로 인하여 발생했다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0912'};
MATCH (a:RiskFactor {name: '안전 점검·감독 소홀'}), (b:Event {name: '세월호 침몰사고'}) MERGE (a)-[r:TRIGGERS]->(b) SET r += {probability: 'High', directCause: '안전 점검·감독 소홀', mechanism: '위험 요인 방치로 침몰 발생', reason: '안전불감증', evidence: '세월호 참사는 과적, 안전 점검과 감독 소홀, 즉 안전불감증으로 인하여 발생했다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0913'};
MATCH (a:RiskFactor {name: '불량 고박'}), (b:Event {name: '세월호 침몰사고'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'High', mechanism: '화물 쏠림으로 복원성 상실 가속', reason: '고박업체 우련통운 직원이 부실 시행', evidence: '고박업체인 주식회사 우련통운... 무리한 증개축, 고박불량을 지시하거나 묵인한 청해진해운 임직원, 이를 직접 실시한 우련통운 직원', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0914'};
MATCH (a:Damage {name: '세월호 참사 인명피해'}), (b:Context {name: '사망·실종자 304명'}) MERGE (a)-[r:QUANTIFIED_BY]->(b) SET r += {role: '사망·실종 집계', evidence: '사망, 실종자 304명의 생명 침해에 관한 적용법조', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0915'};
MATCH (a:ResponseActor {name: '선장 이준석 등 선원'}), (b:ResponseAction {name: '선내 승객 구호조치'}) MERGE (a)-[r:FAILS]->(b) SET r += {phase: 'response', reason: '대기방송 후 구호조치 없이 가장 먼저 탈출', effectiveness: 'Low', specialNote: '부작위에 의한 살인의 미필적 고의 쟁점', evidence: '선장, 선원들은 승객들에게는 대기방송을 해 놓고는 다른 구호조치 없이 가장 먼저 탈출하여 해경에 구조되었다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0916'};
MATCH (a:ResponseAction {name: '선내대기 안내방송'}), (b:Damage {name: '세월호 참사 인명피해'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {mechanism: '승객 선내대기로 탈출 시기 상실', spreadRisk: 'High', specialNote: '성인 화물기사 등은 조기 탈출하여 생존율 높음', evidence: '학생들은 선원과 해양경찰이 구조해 줄 것을 기대하고 선내에 대기하고 있었다가 탈출시기를 놓쳤다... 화물기사 등 성인들은 조기에 빠져 나와 생존율이 높았지만', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0917'};
MATCH (a:Population {name: '수학여행 고등학생 승객'}), (b:Damage {name: '세월호 참사 인명피해'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {mechanism: '선내대기로 탈출시기 상실, 피해 집중', specialNote: '대부분 피해자가 수학여행 학생', evidence: '대부분의 피해자들이 수학여행을 가던 고등학생들이었고, 이들이 어른들의 무책임과 무능으로 인하여 구조되지 못하였다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0918'};
MATCH (a:Event {name: '언론 오보 및 관계당국 미숙 대응'}), (b:Damage {name: '세월호 피해자·유가족 2차 피해'}) MERGE (a)-[r:CAUSES]->(b) SET r += {directCause: '언론 오보·미숙한 대응', mechanism: '사고 처리 과정에서 추가 피해 발생', evidence: '사고 처리 과정에서 언론의 갖은 오보와 관계 당국의 미숙한 대응으로 인하여 2차적인 피해를 입은 상태였다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0919'};
MATCH (a:Event {name: '남영호 침몰사고'}), (b:Damage {name: '남영호 침몰 인명피해'}) MERGE (a)-[r:CAUSES]->(b) SET r += {scale: '대형', mechanism: '여객선 침몰로 대규모 사망', evidence: '1970년 12월 15일 발생한 남영호 침몰사고(사망자 326명)', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0920'};
MATCH (a:Event {name: '서해훼리호 침몰사고'}), (b:Damage {name: '서해훼리호 침몰 인명피해'}) MERGE (a)-[r:CAUSES]->(b) SET r += {scale: '대형', mechanism: '여객선 침몰로 대규모 사망', evidence: '1993년 10월 10일 발생한 서해훼리호 침몰사고(사망자 292명)', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0921'};
MATCH (a:ResponseActor {name: '세월호 특위 형사재판지원팀'}), (b:ResponseAction {name: '형사재판 피해자 지원 활동'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', role: '피해자 절차적 권리 보장', effectiveness: 'Med', evidence: '형사재판지원팀은 법원, 검찰, 피해자 간의 의사소통 창구로서 피해자들의 요구사항을 법원, 검찰에 전달하여 일정 정도 피해자의 절차적 권리를 보장받는 성과를 얻었다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0922'};
MATCH (a:ResponseAction {name: '형사재판 피해자 지원 활동'}), (b:Damage {name: '세월호 피해자·유가족 2차 피해'}) MERGE (a)-[r:MITIGATES]->(b) SET r += {effectiveness: 'Med', mechanism: '재판 과정 피해자 보호절차 적용으로 2차 피해 경감', evidence: '세월호 참사의 피해자들이 형사재판과정에서 2차적인 피해를 입는 것을 방지하고, 재판과정에 최대한 피해자의 입장을 반영하는 것을 1차적인 과제로 삼고', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0923'};
MATCH (a:ResponseActor {name: '세월호 특위 형사재판지원팀'}), (b:ResponseAction {name: '세월호 특위 진상조사단 진상조사 활동'}) MERGE (a)-[r:FAILS]->(b) SET r += {phase: 'recovery', reason: '인력·역량·비용·시간 부족, 진상조사단과 연계 단절, 18,000페이지 방대한 전문 기록', effectiveness: 'Low', specialNote: '피해자 기대 충족에 부족', evidence: '피해자 변호인이라는 위치의 한계 및 비용, 시간, 역량의 문제로 사고원인과 관련하여 검찰에서 제출한 시뮬레이션보고서의 내용을 검증하는 등 큰 틀에서 진상을 규명하는 작업을 주체적 적극적으로 할 수가 없다는 한계가 있는지라 하지 못하였으므로', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0924'};
MATCH (a:ResponseActor {name: '검경 합동수사본부'}), (b:ResponseAction {name: '세월호 참사 형사 수사·기소'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', role: '참사 원인·책임 수사', evidence: '참사 당일부터 이준석 등 세월호 선장, 선원들에 대해서 수사가 시작... 발표일 기준으로 세월호 참사와 관련하여 399명이 입건되었고 그 중 구속기소된 사람은 총 154명', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0925'};
MATCH (a:ResponseAction {name: '세월호 참사 형사 수사·기소'}), (b:Event {name: '세월호 침몰사고'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {timing: '참사 당일부터', role: '책임자 처벌', evidence: '참사 당일부터 이준석 등 세월호 선장, 선원들에 대해서 수사가 시작되었는데', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0926'};
MATCH (a:ResponseActor {name: '청해진해운 대표이사 김한식 등 임직원'}), (b:ResponseAction {name: '선박 운항 안전관리'}) MERGE (a)-[r:FAILS]->(b) SET r += {phase: 'prevention', reason: '불법 운항·복원성 미달 묵인', effectiveness: 'Low', evidence: '청해진해운의 대표이사 김한식이 2014년 5월 9일 업무상과실치사상 등의 혐의로 구속되는 등... 무리한 증개축, 고박불량을 지시하거나 묵인한 청해진해운 임직원', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0927'};
MATCH (a:ResponseActor {name: '한국선급·한국해양안전설비 점검업체'}), (b:ResponseAction {name: '선박 안전 검사'}) MERGE (a)-[r:FAILS]->(b) SET r += {phase: 'prevention', reason: '증개축시 복원성 검사·구명벌 검사 소홀', effectiveness: 'Low', evidence: '증개축시 복원성 검사에 소홀한 한국선급 직원... 구명벌 검사에 소홀한 한국해양안전설비 주식회사 직원', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0928'};
MATCH (a:ResponseAction {name: '세월호 특위 휴대폰 포렌식 증거수집'}), (b:Event {name: '세월호 구조 실패'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {role: '구조 과정 진상 규명', reason: '검경합동수사본부 수사 불신 및 통화기록 삭제 의혹', evidence: '세월호 특위는 피해자들로부터 직접 휴대폰을 수거하여 전문가에게 포렌식 작업을 의뢰하였고... 제출한 결과는 재판과정에서 선장, 선원들이 구체적으로 몇 시에 어떤 구호조치를 했는지 입증하는 중요한 증거로 사용되었다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0929'};
MATCH (a:Event {name: '수사기관 휴대폰 수거·통화기록 처리'}), (b:Damage {name: '세월호 피해자·유가족 2차 피해'}) MERGE (a)-[r:CAUSES]->(b) SET r += {mechanism: '수사기관 불신 심화로 협조 거부', directCause: '유가족 동의 없는 증거 처리', evidence: '수사기관에서 유가족의 동의 없이 사망자의 휴대폰을 수거해 간다거나 사망자나 주변인의 통화기록이 삭제되고 있다는 의혹이 제기되었다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0930'};
MATCH (a:Event {name: '세월호 침몰사고'}), (b:Context {name: '2014-04-16 세월호 참사 당일'}) MERGE (a)-[r:OCCURS_AT]->(b) SET r += {role: '사고 발생 일시', evidence: '세월호 참사 당일부터 수사가 개시됨... 참사 당일부터 이준석 등 세월호 선장, 선원들에 대해서 수사가 시작', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0931'};
MATCH (a:ResponseAction {name: '형사재판 피해자 지원 활동'}), (b:Other {name: '세월호 사건 적용법조 체계'}) MERGE (a)-[r:GUIDED_BY]->(b) SET r += {role: '적용법조 체계', specialNote: '검찰이 생명침해 적용법조와 선박 침몰·운항 안전 적용법조 두 유형으로 의율', evidence: '검찰이 의율한 적용법조는 크게 두 유형으로 범주화... 살인(형법 제250조), 특가법위반(도주선박), 유기치사상, 업무상과실선박매몰, 수난구호법위반, 선원법위반, 선박안전법위반, 해양환경관리법위반', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0932'};
MATCH (a:ResponseActor {name: '선장 이준석'}), (b:ResponseAction {name: '선내 승객 구호조치'}) MERGE (a)-[r:FAILS]->(b) SET r += {phase: 'response', reason: '급박한 위험 발생에도 구호조치 미실시 후 퇴선', effectiveness: 'Low', specialNote: '선원법 제11조 위반, 부작위 살인 미필적 고의 인정 쟁점', evidence: '선장 이준석은 선장으로서 선박에 급박한 위험이 발생하였음에도 구호조치를 하지 않았으므로 선원법위반죄도 적용되었다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0933'};
MATCH (a:Facility {name: '진도VTS'}), (b:Region {name: '맹골수도 인근 해상'}) MERGE (a)-[r:LOCATED_IN]->(b) SET r += {role: '관제 기록 출처', specialNote: '마지막 항적 29초 규명에 사용된 자료원', evidence: '기존에 모든 기관에 제공되었던 진도VTS 정보를 분석한 것이다... 진도VTS의 저장장치는 2개로 분리되어 있고, 기록된 AIS 항적기록이 저장장치별로 차이가 있다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0934'};
MATCH (a:ResponseAction {name: '정부 세월호 침몰 원인 조사·수사'}), (b:Event {name: '세월호 침몰사고'}) MERGE (a)-[r:FAILS]->(b) SET r += {phase: 'recovery', reason: 'AIS 기록에만 매몰, 29초 누락 미규명, 레이더·VHF 미분석', effectiveness: 'Low', specialNote: '서투른 조사·수사', evidence: '정부가 AIS 기록에만 매몰되어... 얼마나 정부가 서투르게 세월호 사건의 조사와 수사를 진행했는지 적나라케 보여주는 부분', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0935'};
MATCH (a:ResponseActor {name: '세월호 특위 형사재판지원팀'}), (b:ResponseActor {name: '세월호 특위 진상조사단'}) MERGE (a)-[r:BELONGS_TO]->(b) SET r += {role: '조직 위계', specialNote: '세월호 특위 진상조사단 산하', evidence: '세월호 특위 조직도 상에서도 진상조사단의 산하에 위치하였다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0936'};
MATCH (a:Resilience {name: '법정외 신문·재판 중계 제도'}), (b:Damage {name: '세월호 피해자·유가족 2차 피해'}) MERGE (a)-[r:OFFSETS]->(b) SET r += {effectiveness: 'High', mechanism: '장거리 이동 곤란 피해자의 재판 접근성 보장으로 2차 피해 경감', evidence: '트라우마 때문에 장거리 이동이 어려운 안산 단원고등학교 학생과 화상을 크게 입은 화물 기사 등이 거주지 근처인 수원지방법원 안산지원에서 법정외 신문을 받을 수 있었다... 대법원 규칙이 개정되어 선원사건은 안산지원에서 재판이 중계되었다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0937'};
MATCH (a:ResponseActor {name: '세월호 특위 형사재판지원팀'}), (b:Resilience {name: '법정외 신문·재판 중계 제도'}) MERGE (a)-[r:BUILDS]->(b) SET r += {role: '제도적 역량 구축', effectiveness: 'High', evidence: '형사재판지원팀에서 담당 재판부에 지속적으로 필요성을 설명하여... 거주지 근처에서 중계된 재판을 방청하게 될 수 있는 근거가 새로 마련된 것이다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0938'};
MATCH (a:RiskFactor {name: '세월호 무리한 증·개축'}), (b:Event {name: '세월호 복원성 상실'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {directCause: '무게중심 상승·전후좌우 불균형', mechanism: '구조 개조로 복원성 약화', probability: 'High', specialNote: '검찰이 든 복원성 약화·상실 요인 ①', evidence: '증개축 과정에 선미 4, 5층에 객실 및 전시실을 증설하고, 선수의 40톤 상당 카램프를 철거함으로써, 좌우불균형에 더하여 선수가 더 가벼운 전후불균형이 발생한 점 / 증설 후 무게중심이 11.78m로서 증설 전보다 약 51cm 높아졌다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0939'};
MATCH (a:RiskFactor {name: '세월호 화물 과적(1,065톤 초과)'}), (b:Event {name: '세월호 복원성 상실'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {directCause: '과적 및 평형수 부족', mechanism: '적재 불균형으로 복원성 약화', probability: 'High', specialNote: '검찰이 든 복원성 약화·상실 요인 ②', evidence: '화물운송으로 이윤을 남겨야 했으므로, 화물 및 차량을 과적하는 대신 평형수, 적재유, 청수를 모두 덜 채우고 출항한 점 / 복원성을 유지하면서 적재할 수 있는 화물의 최대치는 1,077톤인데 비해, 실제로는 2,142톤을 적재하여 1,065톤을 초과 적재하였다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0940'};
MATCH (a:RiskFactor {name: '세월호 화물 고박불량(허술한 라싱)'}), (b:Event {name: '세월호 복원성 상실'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {mechanism: '고박 허술로 화물 쏠림 발생', probability: 'High', specialNote: '검찰이 든 복원성 약화·상실 요인 ③', evidence: '컨테이너 고박은 콘과 트위스트 락과 함께 ×자형으로 라싱하여야 하고, 차량은 앞뒤 라싱밴드 4가닥을 연결하여 고박하여야 함에도 불구하고, 실제는 컨테이너 2단 상단을 로프로 둘러 묶거나 차량은 앞뒤 2가닥만 연결하는 방식으로 허술하게 고박한 점', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0941'};
MATCH (a:Event {name: '세월호 대각도 변침'}), (b:Event {name: '세월호 복원성 상실'}) MERGE (a)-[r:TRIGGERS]->(b) SET r += {directCause: '외방경사로 선체 좌현 급경사', mechanism: '선수 우회두 → 외방경사 → 좌현 급경사 → 고박 허술 화물 한쪽 쏠림', probability: 'High', timing: '출항 후 맹골수도 통과 중', evidence: '선장 이준석은 자리를 비우고 당직 3등 항해사 박한결의 지시로 조타수 조준기가 우현 변침을 시도하다 원하는 대로 변침이 이루어지지 않자 당황하여 임의로 조타기를 우현 측으로 대각도로 돌리는 잘못을 저지르는 바람에 선수가 우회두하면서 외방경사의 영향으로 선체가 좌현 측으로 급속이 기울어졌고, 고박이 허술한 화물이 한쪽으로 쏠리면서 아예 복원력을 상실하여 8시 52분경 정지', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0942'};
MATCH (a:ResponseActor {name: '선장 이준석 및 선원'}), (b:ResponseAction {name: '승객 구조·퇴선 조치'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '승객을 구조해야 할 결정적 순간을 방치, 선내대기 안내방송 후 추가 구호조치 포기, 승객 안전 포기하고 홀로 탈출', timing: '복원성 상실 위험 현존 시점', specialNote: '수난구호법 제18조 제1항 단서가 요구하는 구호의무 위반', effectiveness: 'Low', evidence: '선원사건의 피고인들은 인근 관제와 선박 등에 신속히 구호요청하고, 승객을 구조가 용이한 갑판 등에 대기시키고 안전하게 퇴선하도록 ... 할 의무가 있음에도, 선내대기 안내방송 후 추가적인 구호조치를 포기하고 승객들을 방치', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0943'};
MATCH (a:Event {name: '승객 구조 및 퇴선 조치 실패(구호의무 방치)'}), (b:Damage {name: '세월호 참사 인명피해'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {mechanism: '침몰 자체보다 구조 방치가 사상 규모를 확대', probability: 'High', specialNote: '대응실패가 피해를 증폭', evidence: '승객의 안전을 포기하고 홀로 탈출하였다는 것이다 / 추가적인 구호조치를 포기하고 승객들을 방치한 후 ... 탈출하여 대량 사상으로 이어졌다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0944'};
MATCH (a:ResponseActor {name: '한국선급 직원'}), (b:ResponseAction {name: '증개축 복원성 검사'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '증개축 시 복원성 검사에 소홀', specialNote: '검찰이 복원성 약화 관련 검사 부실 책임 의율', effectiveness: 'Low', evidence: '증개축시 복원성 검사에 소홀한 한국선급 직원(2014고합218)', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0945'};
MATCH (a:ResponseActor {name: '한국해양안전설비 주식회사 직원'}), (b:ResponseAction {name: '구명벌 검사'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '구명벌 검사에 소홀', specialNote: '구명설비 검사 부실 책임 의율', effectiveness: 'Low', evidence: '구명벌 검사에 소홀한 한국해양안전설비 주식회사 직원(2014고합224)', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0946'};
MATCH (a:Context {name: '선박안전법 제28조(복원성 유지 기준)'}), (b:ResponseAction {name: '증개축 복원성 검사'}) MERGE (a)-[r:GUIDED_BY]->(b) SET r += {role: '복원성 유지 법적 기준', specialNote: '세월호는 여객선으로 복원성 유지 대상', evidence: '선박안전법 제28조[복원성의 유지] ① ... 선박소유자는 해양수산부장관이 정하여 고시하는 기준에 따라 복원성을 유지하여야 한다 ... 1. 여객선 2. 선박길이가 12미터 이상인 선박', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0947'};
MATCH (a:Event {name: '세월호 침몰사고'}), (b:Damage {name: '세월호 피해자·유가족 2차 피해'}) MERGE (a)-[r:CAUSES]->(b) SET r += {mechanism: '참사 충격 + 잘못된 언론보도·명예훼손 발언·정부 초기 대응 미숙이 결합', scale: '광범위', specialNote: '사고 충격에 버금가는 2차 피해', evidence: '잘못된 언론 보도, 일부 몰지각한 사람들의 명예훼손적 발언, 정부의 초기 대응 미숙 등으로 인하여 사고로 인한 충격에 버금갈 만큼 추가 피해를 입었으며, 공공기관에 대한 신뢰를 크게 상실한 상태', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0948'};
MATCH (a:ResponseActor {name: '세월호 특위 형사재판지원팀'}), (b:ResponseAction {name: '피해자 재판지원 활동'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', role: '피해자 권리구제 및 재판지원', timing: '2014년 6월~', evidence: '세월호 특위에서는 ... 피해자 변호인으로 활동할 형사재판지원팀을 꾸리기로 하고, 김희수 변호사를 팀장으로 정하였다 / 2014년 6월 2일 피해자 변호인 선임계를 제출 / 모든 형사기록에 대한 열람, 등사를 허가해 달라는 ... 신청서를 제출', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0949'};
MATCH (a:ResponseAction {name: '법원 직원 트라우마 사전교육'}), (b:Damage {name: '세월호 피해자·유가족 2차 피해'}) MERGE (a)-[r:MITIGATES]->(b) SET r += {effectiveness: 'Med', mechanism: '법정 절차 중 피해자 2차 피해 완화', phase: 'recovery', evidence: '법원에서도 그 필요성을 인식하였던지라 피해자들의 심리치료를 담당하는 전문가를 섭외하여 법원 직원에 대한 트라우마 관련 사전교육을 자체적으로 시행하였었다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0950'};
MATCH (a:Event {name: '서해훼리호 침몰사고'}), (b:Event {name: '세월호 침몰사고'}) MERGE (a)-[r:CONCURRENT_WITH]->(b) SET r += {role: '유사 선례', specialNote: '두 침몰사고 간 유사성 비교 관계', evidence: '김희수 변호사는 서해훼리호 침몰사고의 수사검사였는데, 세월호 참사가 서해훼리호 사고와 유사점이 있었기 때문에 ... 서해훼리호 사고 수사 당시 미진하였던 부분이 반복되지 않도록 한다는 계획', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0951'};
MATCH (a:ManmadeHazard {name: '세월호 선원의 구호조치 부작위(퇴선명령 미실시)'}), (b:Damage {name: '세월호 참사 인명피해'}) MERGE (a)-[r:TRIGGERS]->(b) SET r += {mechanism: '퇴선명령 부재로 승객 선내 잔류, 탈출 기회 상실', probability: 'High', reason: '검찰 주장: 승객보다 먼저 구조받기 위해 일부러 퇴선명령 미실시', evidence: '위급 상황에서 적절한 구호조치를 취하지 못한 것은 사실; 피고인들이 승객들보다 먼저 구조받기 위해 일부러 승객들에 대한 퇴선명령을 내리지 않았다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0952'};
MATCH (a:RiskFactor {name: '비상벨 미작동(퇴선신호 미발신)'}), (b:Damage {name: '세월호 참사 인명피해'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {mechanism: '퇴선신호 부재로 승객 탈출 타이밍 상실', probability: 'High', reason: '진상조사단 검증: 비상벨을 눌렀다면 승객들이 선원 탈출시점에 탈출 가능', evidence: '선장, 선원들이 탈출한 브릿지에 비상벨이 있어 탈출과정에서라도 이를 눌러 퇴선신호를 보냈다면 승객들이 선장, 선원들의 탈출시점에 탈출을 할 수 있었다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0953'};
MATCH (a:Population {name: '세월호 승객'}), (b:Damage {name: '피해자 외상후 스트레스 장애(PTSD)'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {mechanism: '장거리 이동수단(여객선) 탑승 중 사고로 이동수단·장기이동 트라우마 가중', specialNote: '생존자·유가족의 이동수단 트라우마', evidence: '세월호에 탑승한 승객 뿐 아니라 그 가족들의 경우도 현재 자책, 분노, 회피 등 외상후 스트레스 장애 증상을 겪고 있다; 생존자 및 유가족들이 이동수단에 대한 트라우마가 있거나 장기간 이동에 어려움이 있는 상태', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0954'};
MATCH (a:Event {name: '세월호 침몰사고'}), (b:Event {name: '피해자 외상후 스트레스 장애(PTSD)'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {mechanism: '사고 충격이 생존자·유가족 정신건강 손상으로 전파', timing: '사고 이후 지속', spreadRisk: 'High', evidence: '탑승한 승객 뿐 아니라 그 가족들의 경우도 현재 자책, 분노, 회피 등 외상후 스트레스 장애 증상을 겪고 있다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0955'};
MATCH (a:ManmadeHazard {name: '해경의 사고 피해자(전병삼) 명예훼손 고소'}), (b:Damage {name: '전병삼 2차 피해(고소에 의한 피해)'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {mechanism: '사고 피해자에 대한 조직차원 고소가 2차 가해로 작용', reason: '세월호 특위가 2차 피해로 규정', timing: '2014-07-01', evidence: '해경이 사고로 인하여 골절상 및 외상 후 스트레스 장애를 앓고 있는 피해자에게 조직차원에서 고소를 한 것은 2차 피해', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0956'};
MATCH (a:ManmadeHazard {name: '재판 증거영상·동영상 상영(법정 노출)'}), (b:Damage {name: '재판과정 2차 피해(피해자 트라우마 가중)'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {mechanism: '증거영상 시청·증언과정에서 피해자 2차 외상 발생 위험', spreadRisk: 'Med', timing: '재판 과정', evidence: '당시 모습을 처음 접한 부모님들이 오열하고; 증언한 학생들이 증언과정에서 2차 피해를 입는 것', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0957'};
MATCH (a:ResponseActor {name: '형사재판지원팀(세월호 특위 변호사)'}), (b:ResponseAction {name: '피해자 재판 지원·심리 배려 조치'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', effectiveness: 'Med', role: '피해자 심리·재판 지원', evidence: '형사재판지원팀은... 재판안내문과 방청권을 배포하고; 증언한 학생들이 증언과정에서 2차 피해를 입는 것을 최대한 방지', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0958'};
MATCH (a:ResponseAction {name: '피해자 재판 지원·심리 배려 조치'}), (b:Damage {name: '재판과정 2차 피해(피해자 트라우마 가중)'}) MERGE (a)-[r:MITIGATES]->(b) SET r += {effectiveness: 'High', mechanism: '비공개 증언·신뢰관계인 동석·사전답사·정신과 전문의 협력으로 2차 외상 방지', phase: 'recovery', evidence: '이러한 노력으로 증언한 학생들이 증언과정에서 2차 피해를 입는 것을 최대한 방지할 수 있었다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0959'};
MATCH (a:ResponseAction {name: '트라우마 사전교육·심리전문가 협력'}), (b:Damage {name: '재판과정 2차 피해(피해자 트라우마 가중)'}) MERGE (a)-[r:MITIGATES]->(b) SET r += {effectiveness: 'Med', mechanism: '피해자 심리상태 이해 기반 섬세한 배려로 재판과정 외상 완화', phase: 'preparedness', evidence: '피해자들의 심리치료를 담당하는 전문가를 섭외하여 법원 직원에 대한 트라우마 관련 사전교육을 자체적으로 시행; 정신건강의학과 전문의인 정혜신 박사를 초청하여... 강연', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0960'};
MATCH (a:ResponseActor {name: '담당 재판부(광주지방법원)'}), (b:ResponseAction {name: '피해자 배려 재판 진행 조치'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', effectiveness: 'High', role: '피해자 배려 재판 진행', evidence: '담당 재판부는 피해자 변호인 측이 제출한 의견서의 내용을 수용하여... 완곡하게 표현하는가 하면 피해자들을 위해 쉬운 말로 재판절차를 설명', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0961'};
MATCH (a:ResponseAction {name: '안산지원 재판 중계'}), (b:Damage {name: '피해자 외상후 스트레스 장애(PTSD)'}) MERGE (a)-[r:MITIGATES]->(b) SET r += {effectiveness: 'High', mechanism: '거주지 인근 방청으로 이동 트라우마·접근성 부담 완화', phase: 'recovery', evidence: '대법원은... 재판 중계를 위한 녹음, 녹화, 촬영을 명할 수 있는 근거를 마련; 안산지원에서는 좀 더 편안한 상황에서 재판을 방청할 수 있게 되었다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0962'};
MATCH (a:ResponseAction {name: '법정외 신문(안산지원)'}), (b:Damage {name: '재판과정 2차 피해(피해자 트라우마 가중)'}) MERGE (a)-[r:MITIGATES]->(b) SET r += {effectiveness: 'High', mechanism: '비공개·거주지 인근 신문으로 증언 부담·노출 위험 완화', phase: 'recovery', evidence: '생존자 중 미성년자와 화상을 심하게 입은 화물 기사에 대해서는 연령, 건강 상태 기타의 사정을 고려하여 법정외 신문을 하기로 하였고... 안산지원에서 법정외 신문', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0963'};
MATCH (a:RiskFactor {name: '재판 설명회 미흡(재판내용 미전달)'}), (b:Damage {name: '피해자 재판 불만·정보 단절'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {mechanism: '정보 미전달로 피해자 불만·갑갑함 누적', probability: 'Med', evidence: '예상과 달리 재판 내용이 각 피해자들에게 잘 전달되지 않았고... 대다수의 피해자들은 재판에서 어떤 사실이 밝혀지고 있는지 잘 알지 못하는 상황', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0964'};
MATCH (a:ResponseAction {name: '재판 설명회 개최'}), (b:Damage {name: '피해자 재판 불만·정보 단절'}) MERGE (a)-[r:MITIGATES]->(b) SET r += {effectiveness: 'Med', mechanism: '재판 정보 직접 설명으로 정보 단절 보완', phase: 'recovery', evidence: '형사재판지원팀은 2014년 10월 연수변호사를 중심으로 공소사실, 재판 중 밝혀진 세월호 참사 원인... 재판 설명회를 총 10회에 걸쳐 진행', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0965'};
MATCH (a:ResponseActor {name: '검찰'}), (b:ResponseAction {name: '선원 피고인 구형'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', role: '구형', timing: '2014-10-27 결심공판', evidence: '검찰은 선장 이준석에게 사형, 1등 항해사 강원식, 2등 항해사 김영호, 기관장 박기호에 대해서 각 무기징역, 3등항해사 박한결 및 조타수 조준기에 대해서 각 징역 30년... 을 구형', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0966'};
MATCH (a:Event {name: '세월호 침몰사고'}), (b:Context {name: '선원사건 법적 쟁점'}) MERGE (a)-[r:OCCURS_AT]->(b) SET r += {role: '법적 책임 쟁점', specialNote: '살인죄(선장·기관장·1·2등항해사), 특가법위반 도주선박(3등항해사·조타수), 유기치사상(선원)', evidence: '검찰의 핵심적이고 주위적인 적용법조는, 고의범으로서의 살인죄... 해상뺑소니라 할 수 있는 특가법위반(도주선박)... 보충적이고 예비적인 적용법조가 유기치사상', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0967'};
MATCH (a:ResponseAction {name: '선장 이준석의 퇴선지시(2등항해사 경유)'}), (b:Event {name: '세월호 침몰사고'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {effectiveness: 'Low', phase: 'response', reason: '지시는 인정되나 실효적 퇴선·구조로 이어지지 못함', timing: '해경정 도착 무렵', evidence: '피고인 이준석(선장)이 해경정이 도착할 무렵 피고인 김영호(2등 항해사)에게 승객들을 퇴선시키라는 지시를 하였고, 피고인 김영호는 이를 사무장에게 전달하기 위해 무전기에 대고 탈출시키라는 취지의 말을 한 사실을 인정', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0968'};
MATCH (a:RiskFactor {name: '세월호 자체 복원력 상실'}), (b:Event {name: '세월호 침몰사고'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {mechanism: '복원력상실이 전복·침몰 사건을 유발', probability: 'High', evidence: '세월호 참사와 같이 자체 복원력상실로 전복된 경우 ... 스스로 조난을 당한', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0969'};
MATCH (a:Damage {name: '생존 피해자 정신적 상해'}), (b:Event {name: '세월호 침몰사고'}) MERGE (a)-[r:DERIVES_FROM]->(b) SET r += {reason: '위난 및 구조 지연에 따른 트라우마', specialNote: '유기행위와의 인과관계 부인', evidence: '유기행위와 정신적 상해(스트레스, 우울, 불안, 감정의 기복) 등의 인과관계도 다투었지만, 인정되지 않았다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0970'};
MATCH (a:Context {name: '사고 해역 저수온'}), (b:Damage {name: '세월호 참사 인명피해'}) MERGE (a)-[r:UNDER_CONDITION]->(b) SET r += {role: '생존 가능 시간 제약 조건', specialNote: '조류·수온이 사망 불가피 사유라는 변소는 배척됨', evidence: '당시 수온이 12.6℃로서 특수한 보호복을 착용하지 않은 상태에서도 생존 예상 시간이 6시간 미만', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0971'};
MATCH (a:Context {name: '사고 지점 조류'}), (b:Event {name: '세월호 침몰사고'}) MERGE (a)-[r:UNDER_CONDITION]->(b) SET r += {role: '구조 가능 여건 판단 근거', specialNote: '조류가 사망 불가피 사유라는 변소 배척', evidence: '사고 지점의 조류도 0.4 내지 0.5노트 정도에 불과하고 당시 구명뗏목, 초계기, 어선, 헬기 등이 구조에 동원된 사정', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0972'};
MATCH (a:ResponseActor {name: '선장 이준석'}), (b:ResponseAction {name: '퇴선명령 및 승객 구호조치'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '한계상황 도래 시 지체 없는 퇴선명령 의무 불이행', timing: '9시 26분경(유기 기수시기) 이후 미실시', specialNote: '선원법 제11조상 보호의무 위반, 유기치사상 인정', evidence: '피고인 이준석은 ... 지체 없이 퇴선명령을 내려야 한다는 지침 ... 구호조치를 취한 바 없음 ... 유기의 고의를 인정', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0973'};
MATCH (a:ResponseActor {name: '세월호 선원'}), (b:ResponseAction {name: '퇴선명령 및 승객 구호조치'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '침몰 후 약 30분 경과까지 구호조치 미실시', timing: '침몰 후 늦어도 약 30분 경과', specialNote: '계약상 보호의무 위반, 유기치사상죄 인정', evidence: '피고인들이 침몰 후 (늦어도) 약 30분 경과쯤에는 취했어야 할 위와 같은 구호조치를 취한 바 없음 ... 유기치사상죄가 인정되었다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0974'};
MATCH (a:ResponseAction {name: '퇴선명령 및 승객 구호조치'}), (b:Damage {name: '세월호 참사 인명피해'}) MERGE (a)-[r:MITIGATES]->(b) SET r += {effectiveness: 'High', mechanism: '9시 26분경 구호조치 시 약 20분 내 탈출 가능', specialNote: '미실시로 피해 확대', evidence: '9시 26분경 ... 적절한 구호조치가 있었다면 약 20분의 시간 동안 세월호 탈출이 가능', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0975'};
MATCH (a:ResponseActor {name: '기관장 박기호'}), (b:ResponseAction {name: '조리부 직원 구조조치'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '이동 불가한 조리부 직원 2명에 대한 구조의무 불이행', specialNote: '부작위에 의한 살인죄 인정', timing: '3층 선실 복도 상황', evidence: '피고인 박기호(기관장)가 3층 선실 복도에서 조리부 직원 둘이 ... 이동이 불가능하므로 이들을 구조할 의무가 있음에도 아무런 구호조치를 취하지 않은 점 ... 살인죄가 인정', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0976'};
MATCH (a:ResponseAction {name: '조리부 직원 구조조치'}), (b:Damage {name: '조리부 직원 2명 사망'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {effectiveness: 'Low', specialNote: '구조조치 미실시로 사망', evidence: '조리부 직원 둘이 머리를 다치거나 굴러 떨어져 이동이 불가능하므로 ... 오직 조리부 직원 둘에 대해서는 부작위에 의한 살인죄가 인정', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0977'};
MATCH (a:ResponseActor {name: '해경 123정 정장 김경일'}), (b:ResponseAction {name: '해경 현장 구조활동'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '퇴선명령 미실시 등 업무상과실', specialNote: '업무상과실치사죄 일부 인정(징역 4년), 일부 승객에 대해서만 인과관계 인정', effectiveness: 'Low', evidence: '피고인 김경일에 대해서 퇴선명령을 안하는 등의 업무상과실을 인정 ... 일부 장소에 있었던 승객들에 대해서만 업무상과실치사죄를 인정', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0978'};
MATCH (a:ResponseAction {name: '해경 현장 구조활동'}), (b:Event {name: '세월호 침몰사고'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {effectiveness: 'Low', specialNote: '미진한 구조활동, 선원 우선 구조 정황', timing: '기수시기 9시 26분경 이후', evidence: '세월호 침몰 후 미진한 구조활동과 더불어 선원들을 우선적으로 구조한 정황', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0979'};
MATCH (a:ResponseActor {name: '해양경찰청'}), (b:ResponseAction {name: '해경 현장 구조활동'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '부실한 구조행위, 퇴선명령 미실시', specialNote: '다만 기수시기 9시 26분경 이후의 사정으로 선원 인과관계는 부인되지 않음', evidence: '사망의 주된 원인은 해경의 부실한 구조행위에 있으므로 ... 해경의 부실한 구조행위가 있더라도, 그것은 ... 9시 26분경 이후의 사정', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0980'};
MATCH (a:Resilience {name: '구명뗏목·초계기·어선·헬기 등 구조 동원 자원'}), (b:Damage {name: '세월호 참사 인명피해'}) MERGE (a)-[r:OFFSETS]->(b) SET r += {effectiveness: 'Med', specialNote: '구조 자원이 동원 가능했으므로 사망 불가피 변소 배척', evidence: '구명뗏목, 초계기, 어선, 헬기 등이 구조에 동원된 사정을 보면 역시 피고인들의 주장은 이유 없다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0981'};
MATCH (a:Other {name: '선원법 제11조 등 보호의무 규정'}), (b:ResponseAction {name: '퇴선명령 및 승객 구호조치'}) MERGE (a)-[r:GUIDED_BY]->(b) SET r += {role: '구호조치의 법적 보호의무 근거', specialNote: '이준석은 선원법 제11조(법률상), 전원은 계약상 보호의무 인정', evidence: '선원법 제11조, 수난구호법 제18조 제1항 단서, ... 세월호의 운항관리규정 ... 계약상 보호의무 ... 이준석에 대해서는 선원법 제11조를 법률상 보호의무의 근거로 인정', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0982'};
MATCH (a:ResponseAction {name: '형사재판 피해자 지원 활동'}), (b:Resilience {name: '대량 피해자 사건 원격 증언 제도'}) MERGE (a)-[r:BUILDS]->(b) SET r += {effectiveness: 'High', mechanism: '대법원 규칙 개정으로 거주지 근처 법원 중계 근거 마련', evidence: '대법원 규칙 개정을 통하여 앞으로 대량의 피해자가 있는 사건에서 거주지 근처의 법원에서 중계될 수 있도록 근거를 마련한 것도 큰 성과', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0983'};
MATCH (a:Other {name: '다중 인명피해 상상적 경합 1죄 처벌'}), (b:Damage {name: '세월호 참사 인명피해'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {role: '헌법소원 청구 대상', reason: '다중인명피해에도 1죄 처벌로 피해자 평등권 침해', timing: '2015-02-09', evidence: '다중의 인명피해가 발생했음에도 불구하고 형법 제40조 상상적 경합 규정을 적용하여 1죄로 처벌한 것은 피해자들의 평등권을 침해 ... 헌법소원청구를 제기', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0984'};
MATCH (a:Other {name: '해경사건 공판 절차'}), (b:ResponseActor {name: '세월호 특위 형사재판지원팀'}) MERGE (a)-[r:DEPLOYED_TO]->(b) SET r += {role: '재판 참여를 위한 변호사 파견 대상 절차', specialNote: '서울에서 변호사 파견·속기록 작성', evidence: '해경사건은 ... 2015년 1월 20일부터 1월 28일까지 총 5회의 공판기일 ... 서울에서 다시 변호사가 파견되었다 ... 단 하루도 빠짐없이 변호사가 파견되고 속기록이 작성', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0985'};
MATCH (a:Event {name: '세월호 침몰사고'}), (b:Damage {name: '세월호 참사 관련 형사사건(154명 구속기소)'}) MERGE (a)-[r:CAUSES]->(b) SET r += {mechanism: '대량 인명피해 발생으로 형사책임 추궁', scale: '대형', evidence: '세월호 참사와 관련하여 154명이 구속기소되고, 불구속기소된 재판도 파악하기 힘들만큼 많은 상태였다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0986'};
MATCH (a:Event {name: '세월호 침몰사고'}), (b:Population {name: '세월호 피해자·유가족 발생'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {mechanism: '대량 사망·실종으로 유가족 발생', reason: '인명피해와 직접 관련된 선원·선사·해경 사건 다수', evidence: '인명피해와 직접 관련된 선원사건, 선사사건 및 해경사건의 경우 많게는 주 5회 기일이 열릴 만큼 강도 높게 진행', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0987'};
MATCH (a:Event {name: '세월호 침몰사고'}), (b:Damage {name: '피해자 트라우마'}) MERGE (a)-[r:CAUSES]->(b) SET r += {mechanism: '사랑한 가족 상실로 인한 극도의 심리적 충격', timing: '사고 직후', evidence: '세월호 피해자들은 왕방한 참사로 인한 극도의 트라우마에 시달리는 동시에 정부와 언론에 대한 극도의 불신과 분노를 나타내고 있었고', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0988'};
MATCH (a:Damage {name: '피해자 트라우마'}), (b:Damage {name: '법률상담 지원 곤란'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {mechanism: '민감한 심리상태로 법률상담·지원 접근 곤란', reason: '변호사 일거수일투족이 지나치게 긴장됨', evidence: '유가족들이 트라우마에 시달리며 매우 민감한 상태였던지라, 변호사들의 말 한마디 눈빛 하나 ... 법률상담이 아니라 심리적인 위로 위안까지 담당해야', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0989'};
MATCH (a:Event {name: '세월호 침몰사고'}), (b:Damage {name: '유가족 대상 명예훼손(악성 댓글·유언비어)'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {mechanism: '온라인상 유언비어·악의적 댓글 유포로 2차 가해', timing: '사고 초기', evidence: '초기 사건에 관한 인터넷 기사에 악의적인 댓글을 달거나, 유언비어 혹은 조작된 사진을 유포하는 경우가 자주 있었다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0990'};
MATCH (a:Damage {name: '유가족 대상 명예훼손(악성 댓글·유언비어)'}), (b:ResponseAction {name: '악성댓글 작성자 형사고소 지원'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {role: '피해자 측 법적 대응', effectiveness: 'Med', evidence: '상담이 들어온 건들에 대해서는 실제 형사고소를 한 경우도 있었다 ... 고소장 작성은 ... 무료로 작성해 주었고', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0991'};
MATCH (a:Event {name: '세월호 침몰사고'}), (b:Damage {name: '한부모가정 상속·보험금 분쟁'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {mechanism: '미성년 자녀 사망 시 직계존속 공동상속 → 보험금·배보상 분쟁', timing: '사고 직후', evidence: '한부모 가정 중에는, 생활비나 양육비 ... 주지 않고 ... 상대방이 갑자기 나타나 자녀의 사망에 따른 보험금에 대한 상속을 주장한 경우들이 있었다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0992'};
MATCH (a:Damage {name: '한부모가정 상속·보험금 분쟁'}), (b:ResponseAction {name: '한부모가정 상속분쟁 법률지원(상속포기·공증·가압류)'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {role: '법률상담·소송지원', effectiveness: 'Med', specialNote: '원칙적으로 부모간 협의 권유', evidence: '부득이 합의가 안 될 경우 ... 보험금이나 정부 보상금에 대해 가압류가 가능하다고 안내하였고, 필요한 경우 무료로 가압류신청과 과거양육비 청구소송 등을 무료로 제기', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0993'};
MATCH (a:ResponseActor {name: '한부모가정 소송지원팀(여성변호사 14명)'}), (b:ResponseAction {name: '한부모가정 상속분쟁 법률지원(상속포기·공증·가압류)'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '전담 지원팀', evidence: '2015년 1월 초순부터는 14명의 여성변호사들로 구성된 한부모가정 소송지원팀을 만들어 별도의 법률상담과 소송지원을 도와주고 있다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0994'};
MATCH (a:ResponseActor {name: '대한변호사협회'}), (b:ResponseAction {name: '진도 팽목항 변호사 현장 파견'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '현장 인력 파견', timing: '사고 다음날', effectiveness: 'High', evidence: '사건 발생 다음날인 2014년 4월 17일 대한변협 인권위원회 간사인 황필규 변호사를 사고 현장의 진도 팽목항에 파견하였고, 그 다음날인 4월 18일 7명의 변호사가 진도에 파견', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0995'};
MATCH (a:ResponseActor {name: '대한변호사협회'}), (b:ResponseAction {name: '세월호 피해대책 TF팀 구성 및 특위 확대'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '조직화', timing: '사고 5일 후~한 달', phase: 'preparedness', evidence: '2014년 4월 21일 정식으로 세월호 피해대책 TF팀을 만들어 ... 4월 28일 TF팀을 "세월호참사피해자지원 및 진상조사 특별위원회"로 확대', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0996'};
MATCH (a:ResponseActor {name: '세월호 특위 법률상담팀'}), (b:ResponseAction {name: '안산 합동분향소 법률상담 텐트 운영'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '현장 상주 무료 법률상담', effectiveness: 'High', specialNote: '3단계(초기·중기·후기) 운영', evidence: '합동분향소 앞에 법률상담을 위한 대한변협 세월호 특위 텐트가 설치되기에 이르렀다 ... 아침 9시부터 저녁 9시까지 두 명씩 조를 짜서 상담 텐트를', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0997'};
MATCH (a:ResponseAction {name: '안산 합동분향소 법률상담 텐트 운영'}), (b:Damage {name: '피해자 트라우마'}) MERGE (a)-[r:MITIGATES]->(b) SET r += {role: '심리적 위안 제공', effectiveness: 'High', mechanism: '변호사 상주로 피해자가 언제든 상담 가능', evidence: '언제든지 서너 발걸음만 옮기면 상담 변호사가 상주하고 있는지라 심리적으로도 매우 큰 위안을 받곤 했다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0998'};
MATCH (a:ResponseActor {name: '세월호 특위 법률상담팀'}), (b:Resilience {name: '피해자-변호사 신뢰관계'}) MERGE (a)-[r:BUILDS]->(b) SET r += {role: '신뢰관계 구축', mechanism: '헌신적 변호사들이 배척·비난 속에서도 밤낮으로 상주하며 진심으로 도움', timing: '사고 후 한 달여', evidence: '현신적인 멧 변호사들로 인해서 차츰 신뢰가 형성되어 2014. 5. 16. 대한변협과 안산 중심의 세월호 사고 가족대책위원회와 협약식을 체결', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0999'};
MATCH (a:ManmadeHazard {name: '김시곤 KBS 보도국장 세월호 교통사고 비유 발언'}), (b:Event {name: 'KBS 항의 집회(영정 동반 KBS본사 방문)'}) MERGE (a)-[r:TRIGGERS]->(b) SET r += {mechanism: '유가족 분노 유발', probability: 'High', evidence: '2014년 5월 8일 세월호 참사를 교통사고에 비유한 김시곤 KBS 보도국장 발언을 항의하기 위해 안산 합동분향소에 설치된 영정을 안고 KBS본사를 방문', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1000'};
MATCH (a:ResponseActor {name: '대한변협 세월호 특위 변호사단'}), (b:Event {name: 'KBS 항의 집회(영정 동반 KBS본사 방문)'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {role: '피해자 대리·질서유지', timing: '2014-05-08 저녁', effectiveness: 'Med', evidence: '세월호 특위 소속 변호사들과 ... 민변 소속 변호사 등 20-30여명의 변호사들이 KBS 앞에 현장에 모여서 분노한 피해자들을 대리하여 ... KBS측과 협상', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1001'};
MATCH (a:ResponseAction {name: '형사재판 피해자 지원 활동'}), (b:Damage {name: '피해자 트라우마'}) MERGE (a)-[r:MITIGATES]->(b) SET r += {role: '피해자 보호 목적 달성', effectiveness: 'High', mechanism: '피해자에게 변호사 동행으로 위안 제공', evidence: '형사재판지원팀은 피해자 보호라는 본래의 목적은 달성하였으나 ... 피해자들은 자신들도 변호사와 함께 하고 있다는 사실에 조금이나마 위안을 느끼기도', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1002'};
MATCH (a:ResponseActor {name: '세월호 특위 형사재판지원팀'}), (b:ResponseAction {name: '검찰이 밝히지 못한 진상규명 활동'}) MERGE (a)-[r:FAILS]->(b) SET r += {role: '진상규명 목표 미달성', reason: '인력 비효율 배치로 몇몇 사람에게 업무 집중, 자원봉사 형식의 한계', effectiveness: 'Low', evidence: '처음 계획했던 검찰에서 밝히지 못하는 진상을 규명한다는 목표는 달성하지 못하였다 ... 피해자들이 기대하는 진상규명 활동은 여러 한계로 인하여 부족했다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1003'};
MATCH (a:ResponseActor {name: '대한변협 공익법률지원단'}), (b:ResponseAction {name: '형사재판 피해자 지원 활동'}) MERGE (a)-[r:FAILS]->(b) SET r += {role: '인력 배치 실패', reason: '자원봉사 형식·실비만 지급으로 업무강도 대비 참여 유지 곤란, 변호사들의 팀활동 이탈', effectiveness: 'Low', evidence: '500여명의 공익법률지원단 이름을 걸고 활동을 시작하였지만, 인력을 효율적으로 배치하지 못하여 결국 몇몇 사람이 희생하는 구조가 되었고', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1004'};
MATCH (a:RiskFactor {name: '자원봉사 형식 변호인 활동'}), (b:Damage {name: '참여 변호사 확보 실패'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {mechanism: '변호사 이탈 유발로 지원 지속성 위협', probability: 'High', evidence: '업무의 강도가 높았기 때문에 자원 봉사로 참여하려 했던 변호사들은 점점 팀활동에서 이탈하였고 ... 참여 변호사를 구하는 것이 가장 큰 문제', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1005'};
MATCH (a:Damage {name: '참여 변호사 확보 실패'}), (b:Damage {name: '업무 간사 변호사 집중·연수변호사 의존'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {mechanism: '업무가 간사 변호사에게 집중, 연수변호사가 실질 담당', reason: '분업 체계 미비', evidence: '모든 업무가 간사 변호사에게 집중되게 되었다. 재판 참여 및 신문을 실질적으로 연수변호사들이 담당하는 일도 늘어갔다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1006'};
MATCH (a:RiskFactor {name: '진상조사단 협업구조 미확립'}), (b:Damage {name: '진상조사단-재판지원팀 협조 실패'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {mechanism: '신문사항 검토 요청에 활발한 협조 불발', probability: 'High', evidence: '진상조사단에도 필요한 신문사항 검토를 요청했지만, 상호 문제의식이 공유되지 않아 활발한 협조가 이루어지지 못하였다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1007'};
MATCH (a:RiskFactor {name: '광주지원단 카톡방 미참여(단장 외)'}), (b:Damage {name: '광주지원단 신문과정 소극 참여'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {mechanism: '신문사항 필요성에 의문 제기 등 소극적 참여 유발', probability: 'Med', evidence: '광주지원단의 경우 단장 외에는 형사재판지원팀 카톡방에 참여하지 않아 ... 전체적인 사건 흐름이나 피해자들의 관심사 ... 공유하지 못하였다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1008'};
MATCH (a:RiskFactor {name: '재판내용 전달체계 미비'}), (b:Damage {name: '재판 진상에 대한 유가족 불신'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {mechanism: '가족이 사고 원인 미규명으로 인식, 진상 신뢰 저하', probability: 'High', evidence: '결국 사고 원인을 스스로 단정해 버리게 되어 재판에서 밝혀진 진상에 대해서 신뢰하지 못하는 사람도 있었다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1009'};
MATCH (a:ResponseActor {name: '세월호 특위 형사재판지원팀'}), (b:ResponseAction {name: '피해자·증인 보호 제도 개선(영상중계·기록열람·진술기일)'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '증인보호·신문권 확보', effectiveness: 'High', specialNote: '대법원 규칙 개정 근거 마련 성과', evidence: '생존학생에 대한 증인신문은 비공개로 ... 영상 중계로 증언을 할 수 있게 하였다 ... 대법원 규칙 개정을 통하여 ... 거주지 근처의 법원에서 중계될 수 있도록 근거를 마련', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1010'};
MATCH (a:ResponseActor {name: '조준기(조타수)'}), (b:Damage {name: '조준기 1심 판결(징역 10년)'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {role: '1심 형사판결 대상', specialNote: '광주지방법원 2014고합180', evidence: '조준기 | 조타수 | 예비적 | 유기치사상 | 일부 유죄 | 징역 10년', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1011'};
MATCH (a:ResponseActor {name: '신정춘(1등 항해사)'}), (b:Damage {name: '신정춘 1심 판결(징역 7년)'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {role: '1심 형사판결 대상', specialNote: '광주지방법원 2014고합180', evidence: '신정춘 | (견습) 1등 항해사 | 유기치사상 | 일부 유죄 | 징역 7년', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1012'};
MATCH (a:ResponseActor {name: '박기호(기관장)'}), (b:Damage {name: '박기호 1심 판결(징역 30년)'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {role: '1심 형사판결 대상', specialNote: '광주지방법원 2014고합180', evidence: '주위적 | 살인, 살인미수 | 조리부 선원 2인에 대해서 유죄, 나머지 무죄 | 징역 30년 ... 박기호 | 기관장', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1013'};
MATCH (a:ResponseActor {name: '나머지 피고인(선원)'}), (b:Damage {name: '나머지 선원 피고인 1심 판결(각 징역 5년)'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {role: '1심 형사판결 대상', specialNote: '광주지방법원 2014고합180', evidence: '나머지 피고인 등 | 유기치사상 | 일부 유죄 ... 각 징역 5년', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1014'};
MATCH (a:ResponseAction {name: '안산 합동분향소 법률상담 텐트 운영'}), (b:Context {name: '안산 합동분향소'}) MERGE (a)-[r:OCCURS_AT]->(b) SET r += {role: '상담 거점', evidence: '합동분향소 앞에 있는 가족대책위 텐트 바로 뒤에 대한법협 세월호 특위 텐트를 마련', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1015'};
MATCH (a:ResponseActor {name: '세월호 특위 법률상담팀'}), (b:Other {name: '법률상담 원칙 매뉴얼'}) MERGE (a)-[r:GUIDED_BY]->(b) SET r += {role: '상담 표준화', specialNote: '초기 상담 매뉴얼 및 수정 매뉴얼', evidence: '처음 상담을 오는 변호사들을 위하여 아래와 같은 일정한 상담 원칙을 정해서 ... ① 내담자들이 모두 유족분들이라는 점을 감안해 잡담 및 큰 소리의 대화를 자제', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1016'};
MATCH (a:ResponseActor {name: '인천 법률지원팀(김상하·박소영 변호사)'}), (b:ResponseAction {name: '일반인 피해자 법률상담·지원'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '일반인 피해자 별도 지원', effectiveness: 'Med', evidence: '인천에서는 인천에서 개업한 김상하, 박소영변호사를 중심으로 법률지원팀을 만들어 일반인 피해자들의 법률상담과 지원을 별도로 진행', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1017'};
MATCH (a:RiskFactor {name: '일반인 피해자 식별·접촉 곤란'}), (b:Damage {name: '일반인 피해자 지원 사각지대'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {mechanism: '피해자 지원 누락 위험', probability: 'Med', evidence: '가장 큰 고민은 ... 일반인 피해자들을 파악할 방법이 없다는 사실과 ... 안산단원고 피해자들은 모든 사람에 대한 불신과 신뢰가 너무 커서 가까이 다가오는 것 자체를 거부', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1018'};
MATCH (a:RiskFactor {name: '여러 법률상담 단체 분산 운영'}), (b:ResponseAction {name: '법률상담 통합·연속성 확보'}) MERGE (a)-[r:MODIFIES_RISK_OF]->(b) SET r += {role: '통합으로 위험 완화', mechanism: '대한변협 텐트로 다른 단체 상담 자연 통합', effectiveness: 'Med', evidence: '대한변협 세월호 특위 상담 텐트가 마련된 이후에는 멀리 떨어진 경기도 미술관 내에 마련된 다른 법률상담 단체들도 세월호특위 법률상담에 자연스럽게 옮겨지게 되었다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1019'};
MATCH (a:Resilience {name: '대한변협-세월호 가족대책위원회 협약'}), (b:Damage {name: '피해자 트라우마'}) MERGE (a)-[r:OFFSETS]->(b) SET r += {role: '지속적 지원 기반 제공', mechanism: '협약·상담텐트 설치로 신뢰 기반 마련', effectiveness: 'High', evidence: '2014. 5. 16. 대한변협과 안산 중심의 세월호 사고 가족대책위원회와 협약식을 체결하기에 이르렀고, 합동분향소 앞에 법률상담을 위한 ... 텐트가 설치', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1020'};
MATCH (a:ResponseActor {name: '이명숙 위원장'}), (b:ResponseAction {name: '한부모가정 집단 법률상담·간담회'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '한부모가정 집단 법률상담 주관', effectiveness: 'Med', evidence: '이명숙 위원장은 10여명, 20-30여명, 50여명 등 한부모 가정 학부모들과 한자리에서 만나 법률상담도 하고, 간담회도 하고', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1021'};
MATCH (a:ResponseAction {name: '상담텐트 철수 결정'}), (b:ResponseAction {name: '안산 합동분향소 법률상담 텐트 운영'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {role: '수요 변화 대응', effectiveness: 'Med', evidence: '상담을 오는 이도 없는 빈 텐트를 유지하면서 변호사들이 상주하는 것은 더 이상 유지할 명분도 ... 월요일부터 금요일까지 매일 오후 1시부터 6시까지 상담텐트를 지키는 것으로 합의', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1022'};
MATCH (a:Resilience {name: '단원고 반별 담임변호사제'}), (b:Damage {name: '법률상담 텐트 비효율(빈 자리 상주)'}) MERGE (a)-[r:OFFSETS]->(b) SET r += {role: '빈 텐트 비효율 해소·맞춤 지원', mechanism: '수요 발생 시에만 반별 상담 제공', effectiveness: 'High', evidence: '지원하는 변호사들 중에서 반별 담임변호사를 지정하게 되었다 ... 담임변호사가 당직날 미리 유가족 반대표에게 전화로 상담을 요청하는 사람이 있는지 확인', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1023'};
MATCH (a:Event {name: '세월호 침몰사고'}), (b:Event {name: '유가족 대상 악성댓글·유언비어·명예훼손 사건'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {mechanism: '참사 후 인터넷 기사에 악의적 댓글·유언비어·조작된 사진 유포', spreadRisk: 'High', timing: '참사 초기', specialNote: '온라인 2차 가해', evidence: '초기 사건에 관한 인터넷 기사에 악의적인 댓글을 달거나, 유언비어 혹은 조작된 사진을 유포하는 경우가 자주 있었다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1024'};
MATCH (a:Event {name: '유가족 대상 악성댓글·유언비어·명예훼손 사건'}), (b:Damage {name: '세월호 피해자·유가족 2차 피해'}) MERGE (a)-[r:CAUSES]->(b) SET r += {mechanism: '집단(유가족 전체)에 대한 명예훼손·모욕', directCause: '비방·모욕적 발언(미개하다 등)', evidence: '대부분은 특정 유기족에 대한 명예훼손이 아니라 유기족 전체에 대한 비방이거나 모럴적 발언들(미개하다, 개들 잘 죽는 것 아니냐는 등)', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1025'};
MATCH (a:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}), (b:ResponseAction {name: '악성댓글 작성자 형사고소 지원'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', effectiveness: 'High', role: '악성 댓글·유언비어 작성자 대상 형사고소 지원', evidence: '상담이 들어온 건들에 대해서는 실제 형사고소를 한 경우도 있었다 ... 고소장 작성은 상담 변호사들이 ... 무료로 작성해 주었고', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1026'};
MATCH (a:ResponseAction {name: '악성댓글 작성자 형사고소 지원'}), (b:Damage {name: '세월호 피해자·유가족 2차 피해'}) MERGE (a)-[r:MITIGATES]->(b) SET r += {effectiveness: 'Med', mechanism: '형사고소를 통한 가해 대응', phase: 'recovery', evidence: '상담이 들어온 건들에 대해서는 실제 형사고소를 한 경우도 있었다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1027'};
MATCH (a:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}), (b:ResponseAction {name: '상속포기 신고 안내·지원'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', effectiveness: 'High', role: '상속포기 신고 안내 및 신고서 작성 지원', timing: '초기', evidence: '사망 후 3개월 내에 신고해야 하므로 일단 7월 16일까지 상속 포기자가 안전법원에 가서 상속포기신고를 하도록 하였다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1028'};
MATCH (a:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}), (b:ResponseAction {name: '상속 합의사항 공증 안내'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', role: '상속지분 합의사항 공증 안내', evidence: '부모사이에 상속지분에 대해 합의하는 경우(예컨대, 8:2)가 있는 테, 그 경우 합의사항에 대해 가까운 공증인사무소 가서 공증을 받도록 안내하였다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1029'};
MATCH (a:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}), (b:ResponseAction {name: '가압류 및 무료 소송지원'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', role: '가압류 등 법적 조치 및 무료 소송 제기', mechanism: '양육비·기여분 청구 근거 가압류', evidence: '양측친은 양측비나 기여분 청구에 근거하여 보험금이나 정부 보상금에 대해 가입류가 가능하다고 안내하였고, 필요한 경우 무료로 가입류신청과 과거양속 청구소송 등을 무료로 제기해 주었다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1030'};
MATCH (a:ResponseActor {name: '한부모가정 소송지원팀'}), (b:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}) MERGE (a)-[r:BELONGS_TO]->(b) SET r += {role: '특위 산하 전담팀', evidence: '2015년 1월 초순부터는 14명의 여성변호사들로 구성된 한부모가정 소송지원팀을 만들어 별도의 법률상담과 소송지원을 도와 주고 있다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1031'};
MATCH (a:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}), (b:ResponseAction {name: '희생 학생 디지털 기록 확인·복구 지원'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', role: '학생 인터넷·디지털 기록 확인 지원', mechanism: '한국인터넷진흥원·네이버·법원 협조 확인', evidence: '자녀들의 핸드폰이나 카메라 컴퓨터 등은 대한법원 세월호 특위에서 비용을 부담하고 복구를 할 수 있도록 지원해 주어서 상당 부분 북구가 가능했다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1032'};
MATCH (a:ResponseActor {name: '한국인터넷진흥원'}), (b:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}) MERGE (a)-[r:COORDINATES_WITH]->(b) SET r += {role: '디지털 기록 확인 협조', evidence: '한국인터넷진흥원에 문의한 결과, 헨드폰, 신용카드, 공용 아이핀 등을 이용해서 접속사이트 내역을 확인할 수 있다는 답변을 들었으나', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1033'};
MATCH (a:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}), (b:ResponseAction {name: '중국동포 유가족 귀화시험 면제 지원'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', role: '귀화시험 면제 요청 등 개별 법률문제 해결', effectiveness: 'High', evidence: '상담 변호사가 법무부에 직접 전화를 걸어 사정을 설명하여 국적법에 따른 귀화시험면제 사유로 인정해 달라고 요청했다. 머칠 후 법무부 담당자가 시험면제결정을 통보', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1034'};
MATCH (a:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}), (b:ResponseAction {name: '기록단체 협약서 작성·체결 지원'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', role: '기록단체 협약서 작성·체결 지원', timing: '중기(2014-07~10)', evidence: '여러 단체들과 활영 · 기록 등에 대한 명확한 상호 협약이 필요하게 되었고, 협약서 조안 작성의 의뢰를 받았다 ... 여러 단체와 협약서를 작성 · 체결하게 되었다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1035'};
MATCH (a:ResponseActor {name: '세월호참사 시민기록위원회'}), (b:ResponseActor {name: '세월호 가족대책위'}) MERGE (a)-[r:COORDINATES_WITH]->(b) SET r += {role: '공동저작권자·평등 협력 관계', mechanism: '협약서 체결, 공동저작권(위임 법리)', evidence: '유가족들과 기록자를 공동저작권자로 하기로 했고, 시민기록위원회는 가족대 ... 가족대책위와 시민기록위원회 모두 중요한 기록의 주체라는 점, 평등하고 협력적인 관계 (제2조)', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1036'};
MATCH (a:ResponseActor {name: '4·16기록단'}), (b:ResponseActor {name: '세월호 가족대책위'}) MERGE (a)-[r:COORDINATES_WITH]->(b) SET r += {role: '평등·협력 관계, 인격권 강조 협약', mechanism: '협약서 체결(인격권 강조, 제5조·제7조)', evidence: '4·16기록단 역시 중요한 기록의 주체로서 가족대책위와 평등하고 협력적인 관계(제2조) ... 인격권이 특히 강조되고(제5조 2.)', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1037'};
MATCH (a:ResponseActor {name: '뉴스타파'}), (b:ResponseActor {name: '세월호 가족대책위'}) MERGE (a)-[r:COORDINATES_WITH]->(b) SET r += {role: '평등·협력 관계, 자료 위탁 협약', mechanism: '자료 소유권은 가족대책위, 뉴스타파 위탁 분석·정리(사전합의 이용)', evidence: '뉴스타파 역시 공정보도의 주체로서 가족대책위와 평등하고 협력적인 관계 (제2조) ... 자료의 소유권은 가족대책위에 있으며, 이를 뉴스타파에게 위탁', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1038'};
MATCH (a:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}), (b:ResponseAction {name: '현장 상주 무료 법률상담'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', role: '현장 상주 무료 법률상담 제공', effectiveness: 'High', mechanism: '유가족텐트 옆 상담텐트 상주, 반별 담임변호사제', evidence: '법률전문가인 변호사들이 유가족이 머무는 유가족텐트 바로 옆에 상담 텐트를 마련해서 유가족만 전용으로 하루 종일 변호사가 상주하면서 직접 상담', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1039'};
MATCH (a:ResponseAction {name: '현장 상주 무료 법률상담'}), (b:Damage {name: '세월호 피해자·유가족 2차 피해'}) MERGE (a)-[r:MITIGATES]->(b) SET r += {effectiveness: 'High', mechanism: '지속적 상담·심리적 지지로 유가족 위로', phase: 'recovery', evidence: '변호사들이 참사 초기부터 지금까지 가족들 옆에서 상담을 제공함으로써 가족들에게 심리적으로 많은 위로가 되었다 ... 더 없는 의지처가 되어 주었다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1040'};
MATCH (a:ResponseActor {name: '공익법률단'}), (b:ResponseAction {name: '현장 상주 무료 법률상담'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', role: '변호사 인력 배치·공익 법률활동', effectiveness: 'Med', specialNote: '효율적 배치·적재적소 활용에 한계', evidence: '514명의 변호사들이 공익법률단에 지원했지만, 이를 효율적으로 배치하여 적재적소에서 활발히 활동하도록 배치하는 것에는 한계가 있었다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1041'};
MATCH (a:ResponseActor {name: '공익법률단'}), (b:ResponseAction {name: '현장 상주 무료 법률상담'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '전국 단위 변호사 참여 한계, 과도한 시간·노력 희생 요구, 활동비 미지급으로 지속가능성 의문, 상담자료 부실 정리', phase: 'recovery', effectiveness: 'Low', specialNote: '교훈: 활동비 지급·상담자료 체계화·반별 담임변호사제 조기 전환 필요', evidence: '전국 단위의 변호사들이 참여하는데 한계가 있고, 변호사가들에게는 너무 많은 시간과 노력의 희생이 요구되기 때문이다 ... 빈텐트를 지키는 시간이 필요 이상으로 길어졌던 것은 아쉬움', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1042'};
MATCH (a:Resilience {name: '생명안전위원회(집단재난대책위원회)'}), (b:Damage {name: '세월호 피해자·유가족 2차 피해'}) MERGE (a)-[r:OFFSETS]->(b) SET r += {mechanism: '신속·실질적 도움으로 2차 피해 감소, 예방 제도 참여', effectiveness: 'Med', timing: '향후 재난 대비', evidence: '‘생명안전위원회’와 같은 특별위원회를 설치하여 ... 집단재난 발생 시 신속하게 실질적인 도움을 주어 2차 피해를 줄이고, 장기적으로는 집단재난 예방을 위한 제도 정비과정에 적극적으로 참여', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1043'};
MATCH (a:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}), (b:Resilience {name: '생명안전위원회(집단재난대책위원회)'}) MERGE (a)-[r:BUILDS]->(b) SET r += {mechanism: '세월호 특위 활동 경험을 토대로 상설기구 설치 당위성 인식', phase: 'recovery', evidence: '세월호 특별위원회 활동을 통하여 대한변협 내에 상설기구로서 ‘생명안전위원회’와 같은 특별위원회를 설치하여 ... 토대를 마련해야하는 당위성', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1044'};
MATCH (a:Other {name: '광주지법 세월호 선장 1심 재판'}), (b:Event {name: '세월호 침몰사고'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {role: '참사 책임 규명 사법절차', phase: 'recovery', specialNote: '참사 가해 책임에 대한 형사재판 대응', evidence: '광주에서 세월호 선장 등에 대한 1심 재판 결과가 나오자 문의가 많았다. 특히 선장에 대해 살인죄가 무죄 나온 것에 많이 분개하며', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1045'};
MATCH (a:Other {name: '4·16세월호참사 진상규명 및 안전사회 건설 등을 위한 특별법'}), (b:Event {name: '세월호 침몰사고'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {role: '참사 진상규명·재발방지 제도적 대응', phase: 'recovery', specialNote: '참사 대응 입법', evidence: '국회에서 4·16세월호참사 진상규명 및 안전사회 건설 등을 위한 특별법(이하 “세월호특별법“이라 한다)이 통과되자 진상조사위원회가 어떻게 구성되는지', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1046'};
MATCH (a:ResponseActor {name: '세월호 가족대책위'}), (b:ResponseAction {name: '세월호 인양 촉구 활동'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', role: '세월호 인양 촉구 활동', mechanism: '반별 팽목항 방문 등 대책 수립', evidence: '가족들은 세월호 인양을 촉구하기 위해 반별로 돌아가면서 팽목항을 방문하는 등 여러 가지 대책을 수립하고 있었는데', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1047'};
MATCH (a:Event {name: '실종자 수색 중단'}), (b:ResponseAction {name: '세월호 인양 촉구 활동'}) MERGE (a)-[r:TRIGGERS_SECONDARY]->(b) SET r += {mechanism: '수색 중단으로 인양 여부 문의·논의 증가', timing: '수색 중단 이후', evidence: '우여곡절 끝에 실종자 수색이 중단되고 세월호 인양여부에 대한 문의가 많아졌다 ... 수색의 다른 방법으로 세월호를 인양하여야 한다는 입장', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1048'};
MATCH (a:ResponseAction {name: '추모관·추모비 건립'}), (b:Event {name: '세월호 침몰사고'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {role: '희생자 추모 복구 조치', phase: 'recovery', evidence: '가족들은 하루 빨리 추모관과 추모비의 건립을 바라고 있으며, 이와 관련하여 건립시기와 관리주체가 누구인지 문의가 많았다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1049'};
MATCH (a:ResponseAction {name: '세월호 참사 배상·보상'}), (b:Damage {name: '세월호 참사 인명피해'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {role: '피해 배상·보상 복구 조치', phase: 'recovery', evidence: '배상·보상문제에 대해 가끔씩 문의하는 경우가 있었으나, 국회에서 특별법으로 통과할 예정이라', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1050'};
MATCH (a:Resilience {name: '서울시 공익변호사단 상담 후 수임 준수규정'}), (b:Damage {name: '공익법률상담 수임 관련 신뢰관계 훼손 위험'}) MERGE (a)-[r:OFFSETS]->(b) SET r += {mechanism: '수임 기준 마련으로 공익상담 신뢰관계 악용·2중 고통 방지', effectiveness: 'Med', evidence: '변협차원에서 상담 과정에서 생긴 신뢰로 사건 의뢰를 받을 경우 ... 일정한 기준 마련이 필요하다 ... 아래와 같은 서울시 공익변호사단의 상담 후 사건을 수임하는 경우 준수해야 할 규정', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1051'};
MATCH (a:Damage {name: '세월호 참사 인명피해'}), (b:Event {name: '유가족 내부·사회적 갈등'}) MERGE (a)-[r:TRIGGERS_SECONDARY]->(b) SET r += {mechanism: '유가족 내부 갈등(희생자 vs 실종자, 집행부 vs 일반 유가족) 및 사회적 갈등(국회·정부·언론·국민)', spreadRisk: 'Med', specialNote: '참사 피해가 유가족 내부·사회적 갈등으로 파급', evidence: '국회와 정부, 언론과 국민들로부터 수많은 갈등을 경험하면서 울분과 분노로 시달렸던 유가 ... 집행부와 일반 유가족 사이의 갈등', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1052'};
MATCH (a:ResponseActor {name: '법무부'}), (b:ResponseAction {name: '중국동포 유가족 귀화시험 면제 지원'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', role: '귀화시험 면제 결정 통보', effectiveness: 'High', evidence: '법무부 담당자가 시험면제결정을 통보하면서, 시험통과자와의 균형상 귀화허가는 ... 2015년 12월에 통보될 것', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1053'};
MATCH (a:Event {name: '세월호 침몰사고'}), (b:Event {name: '세월호 언론보도로 인한 제2의 피해'}) MERGE (a)-[r:TRIGGERS_SECONDARY]->(b) SET r += {mechanism: '언론·여론의 왜곡·과장·확산 보도', spreadRisk: 'High', specialNote: '쌍방향 IT·SNS 환경에서 통제 불가능하게 확산되어 2차 피해 양산', evidence: '단순한 사실을 전달하는 수준을 벗어나 왜대·재정산했으며, 통제 불가능하게 피저나가 결국 제2의 피해를 양산했다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1054'};
MATCH (a:RiskFactor {name: '쌍방향 IT·SNS 미디어 환경'}), (b:Event {name: '세월호 언론보도로 인한 제2의 피해'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {mechanism: '과거 신문·방송 대비 언론 파급력 급증, 부작용 확대', probability: 'High', evidence: '이전과는 다른 미디어 환경 속, 쌍방향 의사소통이 가능한 IT시대이며 보니 과거의 대형 재난 사고에 비해 언론의 과급력은 엄청났다. ... 블로그, SNS까지 이용하는 다양한 매체들이 등장하면서 부작용도 컸던 탓이다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1055'};
MATCH (a:RiskFactor {name: '재난보도 매뉴얼 부재'}), (b:Event {name: '세월호 언론보도로 인한 제2의 피해'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {mechanism: '검증된 대응방법 부재로 무에서 유를 창조하듯 대응', probability: 'Med', evidence: '여태까지 이러한 대형사고에 참고를만 한 매뉴얼이 개발되어 있지 않고, 특히 의견을 표출하는 매체가 다양해지면서 대응 자체가 어렵고 까다로워 서, 무에서 유를 창조하듯이 대응방법을 강구해야 했다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1056'};
MATCH (a:RiskFactor {name: '받아쓰기식 보도 행태'}), (b:Event {name: '세월호 보도 오보·왜곡·편파보도'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {directCause: '정부 발표 무검증 인용', probability: 'High', mechanism: '현장 확인 없이 정부 집계만 보도', evidence: '결국 기자들은 현장에 가서 상황을 과학하지 않은 채 정부에서 알려주는 내용으로만 보도했고 요보는 양산되었다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1057'};
MATCH (a:RiskFactor {name: '언론사 시청률 경쟁'}), (b:Event {name: '세월호 보도 오보·왜곡·편파보도'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'High', reason: '시청률 하락 위험 회피', evidence: '기사 내용을 현장에서 확인하면 보도 시간이 늘어져서 경쟁사보다 뒤놓게 보도할 가능성이 있고, 이는 결국 시청률이 하락할 수 있는 위험성이 있기 때문이다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1058'};
MATCH (a:Event {name: '세월호 보도 오보·왜곡·편파보도'}), (b:Event {name: '유가족의 언론 불신 및 인터뷰 거부'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {mechanism: '오보·왜곡보도로 유족이 언론을 불신·외면, 인터뷰 거부', spreadRisk: 'Med', specialNote: '왜곡 보도된다고 생각해 인터뷰 자세 거부', evidence: '검증이 안 된 보도들이 쏟아지다보니 유족들은 인터뷰 자세를 거부 했다. ... 결국 유족은 언론을 외면했다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1059'};
MATCH (a:Event {name: '메인 언론(KBS·MBC) 세월호 뉴스'}), (b:Event {name: 'JTBC 세월호 보도'}) MERGE (a)-[r:CONCURRENT_WITH]->(b) SET r += {specialNote: 'JTBC는 보도량을 비슷한 수준으로 유지, KBS·MBC는 감소 — 대조적 추이', timing: '참사 후 5일~2주', evidence: 'JTBC의 보도 량은 비슷한 수준을 유지하면서 보도가 된 반면, KBS, MBC는 중반에 2배 이상의 비율이었다가 시간이 지나면서 JTBC와 비슷한 보도 량을 보이는 것을 알 수 있다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1060'};
MATCH (a:ResponseActor {name: 'MBC'}), (b:ResponseAction {name: '전원구조 오보 보도'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '사고당일 11시 1분 \'전원구조\' 오보 방송', effectiveness: 'Low', timing: '2014-04-16 11:01', specialNote: '목포MBC \'전원구조 아니다\' 보도에도 오보 수정 안 함, 오보 경위 미규명', evidence: 'MBC보도의 경우 사고당일 11시 1분에 \'전원 구조\' 라는 잘못된 정보를 방송했다. ... 목포MBC "전원구조 아니다" 보도에도 불구하고 오보 수정', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1061'};
MATCH (a:Event {name: '단원고 전원구조 오보'}), (b:Event {name: '세월호 언론보도로 인한 제2의 피해'}) MERGE (a)-[r:TRIGGERS_SECONDARY]->(b) SET r += {mechanism: '사실과 다른 정보 전달로 구조 방해·국민 혼선', spreadRisk: 'High', evidence: '사고 당일 오전 11시 경 대다수 언론이 \'탑승 학생 전원 구조\' 라고 대대적으로 보도했다. 그리고 한 시간도 못되어서 이 보도는 완전한 오보였음이 밝혀졌고', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1062'};
MATCH (a:Event {name: '정부·해경 \'사상 최대 구조\' 발표'}), (b:Event {name: '유가족의 언론 불신 및 인터뷰 거부'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {mechanism: '실제 현장과 전혀 다른 발표를 검증없이 보도', directCause: '검증 부재', specialNote: '함정 261척 중 잠수사 2명만 투입 등 발표와 현장 괴리', evidence: '궁 지상 최대 구조\'보도는 검증 없이 정부 발표를 받아쓴 대표적 사례라 할 수 있다. ... 합정 261척은 고시하고 잠우사 조자 기우 2명이 투입되었다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1063'};
MATCH (a:ResponseActor {name: 'MBC'}), (b:ResponseAction {name: '누락·축소·오보 보도'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '데스크(박상우 부장 등)가 현장 기자 발제를 묵살·거부, 불리한 사실 누락·축소', effectiveness: 'Low', specialNote: '기념촬영 논란·해경 구조혼선·동영상 은폐 등 다수 아이템 누락·지시 거부', timing: '2014-04~05', evidence: '[표1] 누락, 축소, 오보 등으로 문제됐던 사례들 ... 현장 기자들 발제 했으나 박상우 부장이 묵은.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1064'};
MATCH (a:ResponseActor {name: 'MBC'}), (b:ResponseAction {name: '유족 폄훼·왜곡 보도'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '잠수사 사망을 실종자 가족 조급증 탓으로 왜곡, 인과관계 비약·짜깁기', effectiveness: 'Low', timing: '2014-05-07', specialNote: '잠수사 사망원인 미규명 시점에 가족 행동과 연관, 중국 사례에 빗댐', evidence: 'MBC는 5월 7일, "일부 실종자 가족들과 희생자 유족들 이 조급증을 보여 감수사의 죽음까지 발생했다"는 식의 유족 폄훼 모욕 보도를 했다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1065'};
MATCH (a:ResponseAction {name: '유족 폄훼·왜곡 보도'}), (b:Damage {name: '세월호 피해자·유가족 2차 피해'}) MERGE (a)-[r:CAUSES]->(b) SET r += {directCause: '왜곡·폄훼·편파·비보도', mechanism: '유가족 폄훼·희화화·홍미위주 보도', specialNote: '가족 잃은 슬픔 이상의 고통', evidence: '이러한 비정상적인 보도로 인해 유가족은 가족을 잃은 슬픔, 그 이상을 고스란히 느껯을지 모른다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1066'};
MATCH (a:ResponseActor {name: '방송통신심의위원회'}), (b:ResponseAction {name: '세월호 보도 심의'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '편파·이중잣대 심의 — 다이빙벨 보도(JTBC)는 관계자 징계(최고수위), 전원구조·시신 오보는 경징계(권고)', effectiveness: 'Low', specialNote: '2014 국정감사에서 편파 심의 지적, 한국 \'부분적 언론자유국\' 강등 일조', evidence: '유승희 의원은 "방심위의 세원호 보도 심의는 이중 잣대이자 편파심의이고 ... " ... 다이빙벨 문제를 다른 방송은 중 정계를 받은 것이다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1067'};
MATCH (a:ResponseActor {name: '방송통신위원회'}), (b:ResponseAction {name: '방통위 민원 회신'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '편파성·왜곡성 찾기 어렵다며 민원 기각, 별건 KBS는 \'권고\'만 조치', effectiveness: 'Low', timing: '2014-07-24', specialNote: '전원구조 오보가 예능 자막 오류와 동일한 \'권고\' 수준 처분 — 유가족 납득 불가', evidence: '방통위는 7월 24일에 이 민원 신청에 대하여는 평과성이나 왜곡성을 찾기 어렵다고 회신을 했다. ... \'단원고 전원구조\' 와 같은 오보가 똑같이 권고 처분에 그쳤다는 것은', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1068'};
MATCH (a:ResponseActor {name: '세월호 특위 법률상담팀'}), (b:ResponseAction {name: '유가족 법률상담 및 현장지원'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '피해자 법률상담·현장지원', effectiveness: 'High', phase: 'recovery', evidence: '법률상담팀도 유가족을 비롯한 피해자들의 옆에서 큰 신뢰와 심리적 위안을 주며 끈기와 애정을 가지고 헌신적인 노력을 해 왔다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1069'};
MATCH (a:ResponseAction {name: '유가족 법률상담 및 현장지원'}), (b:Resilience {name: '유가족-지원조직 간 신뢰 자본'}) MERGE (a)-[r:BUILDS]->(b) SET r += {mechanism: '상담·현장지원을 통한 신뢰 형성', effectiveness: 'High', evidence: '유가족들이 초기에 가지고 있던 우리 사회 모두에 대한 불신과 반감의 벽을 상담과 현장 지원 등을 통하여 변호사들은 이를 극복할 수 있었고, 어느 순간부터 가장 두터운 신뢰와 기대라는 부수적인 결과까지 얻게 되었다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1070'};
MATCH (a:Other {name: '재난방송 및 민방위경보방송 실시 기준(방통위 고시)'}), (b:ResponseAction {name: '누락·축소·오보 보도'}) MERGE (a)-[r:GUIDED_BY]->(b) SET r += {specialNote: '기자들이 재난방송 고시 준수를 이유로 정부 공식 집계를 그대로 인용 — 준칙이 오히려 무검증 보도의 방패로 악용됨', effectiveness: 'Low', evidence: '재남보도 고지를 준수한다는 이유로 정부에서 하는 공식 집계를 그대로 인용하는 보도를 한 것일 수 있다. 보도 준칙은 ... 여으로 이를 방패삼아', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1071'};
MATCH (a:Facility {name: '진도실내체육관'}), (b:Damage {name: '세월호 피해자·유가족 2차 피해'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {mechanism: '구조인력보다 경찰·취재 인력이 훨씬 많아 유가족이 \'동물원 원숭이\'처럼 취재 대상화됨', specialNote: '오열·기절 장면 경쟁 취재·촬영', evidence: '사건 조기 진도재육관에는 구조인력보다 경찰과 쥐재 인력이 훨씬 많았다고 한다. ... 마치 자신들이 \'둥들원 원숭이\'가 된 느낌이었다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1072'};
MATCH (a:Event {name: '언론사 취재차량 사고현장 주차'}), (b:Damage {name: '구조·구급 활동 장애'}) MERGE (a)-[r:CAUSES]->(b) SET r += {directCause: '길에 주차된 대형 언론사 차량', mechanism: '주차 차량이 구조·구급차 운행 방해', specialNote: '시신 이송 구급차가 언론사 차량 피해 지그재그 운행', evidence: '길에 주차된 대형 언론사 차향은 구조 현동에 장애물이 된 것이다. 시신 수습 후 인근 병원으로 이송을 해야하는 구급차가 주차된 언론사 차향을 이리저리 피해서 운행을 했다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1073'};
MATCH (a:ResponseActor {name: 'KBS 보도국장(김시준)'}), (b:ResponseAction {name: '재난주관방송 부적절 보도 지시'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '세월호 참사를 교통사고에 비유, 아나운서에게 깊은 애도 표하지 말라 지시', effectiveness: 'Low', specialNote: '유가족 항의 방문 후 사임', evidence: 'KBS 보도국장은 사석에서 세월호 참사를 교통사고에 비유하고 아나운서들에게 깊은 웃음 입지 말라고 지시했었으며', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1074'};
MATCH (a:ResponseAction {name: '광화문 단식 농성에 대한 편파·홍미위주 보도'}), (b:Damage {name: '세월호 피해자·유가족 2차 피해'}) MERGE (a)-[r:CAUSES]->(b) SET r += {directCause: '균형 잃은 편파보도', mechanism: '농성 동기 외면·희화화, 대리기사 폭행사건 추측성 반복 보도', evidence: '유가족이 농성을 시작한 이유 등은 보도하지 않고 농성에 대해 비판적인 기사들이 등장했다. 또한 유가족의 단식 농성을 희화화하거나, 종미위주로 만들들이 보도하는 언론도 있었다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1075'};
MATCH (a:ResponseActor {name: '서울시 공익변호사단'}), (b:ResponseAction {name: '공익 법률상담 및 사건 수임'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '공익 법률상담 및 수임', phase: 'recovery', evidence: '서울시 공익변호사단의 상담 후 사건을 수임하는 경우 준수해야 할 규정은 눈여겨 볼 만한 일이다. ① 선임을 원하는 당사자의 자발적이고 적극적인 동의가 전제되어야 한다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1076'};
MATCH (a:Event {name: '세월호 보도 오보·왜곡·편파보도'}), (b:Damage {name: '유가족·국민의 언론 불신'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {reason: '참사 보도 과정에서 발생한 오보가 유가족 불신·고통으로 전이', mechanism: '잘못된 정보 전달', evidence: '일련의 위와 같은 사태는 유가족 및 국민들이 언론을 불신하게 된 원인 중 하나', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1077'};
MATCH (a:Event {name: '단원고 전원구조 오보'}), (b:Event {name: '세월호 보도 오보·왜곡·편파보도'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {reason: '거짓정보 확산으로 사회 혼란·불신 가중', mechanism: '정부 발표 미확인 보도', evidence: '세월호 초반 보도에서 \'전원구조\'라는 오보가 나갔을 때도 언론에서는 정부의 발표일지라도 재차 확인했어야 한다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1078'};
MATCH (a:ResponseActor {name: '방송통신위원회'}), (b:ResponseAction {name: '방통위 편파·왜곡보도 민원 신청'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {phase: 'response', timing: '2014-07-24', role: '민원 회신', effectiveness: 'Low', specialNote: '편파성·왜곡성 찾기 어렵다고 회신, 유가족 납득 못함', evidence: '방통위는 7월 24일에 이 민원 신청에 대하여는 편파성이나 왜곡성을 찾기 어렵다고 회신을 했다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1079'};
MATCH (a:ResponseActor {name: '방송통신위원회'}), (b:ResponseAction {name: '방통위 \'권고\' 처분'}) MERGE (a)-[r:FAILS]->(b) SET r += {phase: 'response', reason: '\'단원고 전원구조\' 오보가 예능 자막 오류와 동일한 \'권고\' 처분에 그침', effectiveness: 'Low', specialNote: '처분 수위 과소로 국민·유가족 불신 심화', evidence: '\'단원고 전원구조\'와 같은 오보가 똑같이 권고 처분에 그쳤다는 것은 국민이 \'합당한 처분이었다\'고 받아들이기는 어려웠을 것', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1080'};
MATCH (a:ResponseAction {name: '재난보도준칙 제정 토론회'}), (b:Resilience {name: '재난보도 컨트롤타워 및 공동 보도준칙'}) MERGE (a)-[r:BUILDS]->(b) SET r += {effectiveness: 'Med', role: '재난보도 컨트롤타워·공동 보도준칙 마련 제언', evidence: '정부기관이 언론사들과 연계하여 재난보도준칙을 지키도록 하는 컨트롤타워가 필요하다 ... 공동의 구체적인 보도준칙을 도출', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1081'};
MATCH (a:RiskFactor {name: '방송사 재난사고 보도 관행'}), (b:Event {name: '세월호 보도 오보·왜곡·편파보도'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'High', mechanism: '성숙치 못한 재난보도 태도가 오보·왜곡보도 확률 증가', reason: '준칙이 있어도 자사이기주의로 힘을 못 받음', evidence: '방송사들의 재난사고 보도는 흥미 위주의 기사와 자극적인 기사 ... 이러한 지적이 반복되고 있는 것', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1082'};
MATCH (a:ResponseAction {name: 'KBS 기자 \'릴레이 반성\''}), (b:Event {name: '세월호 보도 오보·왜곡·편파보도'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {phase: 'recovery', effectiveness: 'Low', specialNote: '사측 행동에 큰 변화는 없었으나 다른 모습을 보이려 노력', evidence: 'KBS 내부 게시판에 기자들이 반성의 글을 올린 일명 \'릴레이 반성\'', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1083'};
MATCH (a:RiskFactor {name: '인터넷 익명성·비대면성'}), (b:Event {name: '유가족 대상 악성댓글·허위사실 유포'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'High', mechanism: '익명성·비대면성이 막말·비하·명예훼손·모욕 확률 증가', evidence: '익명성과 비대면성을 바탕으로 감정을 정제하지 않고 의견을 표현 ... 사람을 죽일 수도 있는 무서운 칼', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1084'};
MATCH (a:Event {name: '유가족 대상 악성댓글·허위사실 유포'}), (b:Damage {name: '세월호 피해자·유가족 2차 피해'}) MERGE (a)-[r:CAUSES]->(b) SET r += {role: '직접 정신적 가해', mechanism: '유가족이 스마트폰으로 모욕적 댓글에 직접 노출', scale: '상상 이상', evidence: '세월호 피해자 및 그 유가족들에게 악성 댓글 하나하나의 파장은 상상 이상으로 컸다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1085'};
MATCH (a:RiskFactor {name: '세월호 희생자 부모 연령대(40대)'}), (b:Damage {name: '세월호 피해자·유가족 2차 피해'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {probability: 'High', reason: 'SNS 적극 사용 세대라 인터넷 법익 침해의 직접적 영향 큼', evidence: '이들은 ... 적극적으로 사용하고 활용하는 세대이기에 인터넷의 법익 침해 행위는 직접적으로 그들에게 큰 영향을 미쳤다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1086'};
MATCH (a:Event {name: '권은희 의원 SNS 허위사실 게시'}), (b:Damage {name: '세월호 피해자·유가족 2차 피해'}) MERGE (a)-[r:CAUSES]->(b) SET r += {role: '유가족 명예훼손', mechanism: '실제로는 단원고 실종자 가족이었음에도 선동꾼으로 비난', evidence: '권은희 의원의 발언으로 촉발된 인터넷 상의 논란 속에서 결국 상처를 입은 것은 세월호의 피해자와 그 가족들', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1087'};
MATCH (a:ResponseActor {name: '권은희 국회의원'}), (b:ResponseAction {name: '권은희 의원 사과'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', role: '부적절 행동 사과', effectiveness: 'Low', evidence: '결국 권은희 의원은 국회의원으로서 부적절한 행동을 일삼은 점에 대해 사과했다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1088'};
MATCH (a:ResponseActor {name: '유가족 가족대책위 댓글 모니터링팀'}), (b:ResponseAction {name: '악성댓글 증거 수집·고소'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', role: '증거 수집 및 고소 진행', timing: '초기 단독 진행', evidence: '유가족 가족 대책위 댓글 모니터링 팀이 별도로 운용 중에 있었으며, 이 팀에서 각종 자료를 모으고 수집', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1089'};
MATCH (a:ResponseActor {name: '세월호 특위 언론대응팀'}), (b:ResponseAction {name: '악성댓글 모욕죄 고소(약 70건)'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', timing: '2014-08-04까지', role: '악성댓글 모욕죄 고소 지원', effectiveness: 'Med', evidence: '2014년 8월 4일까지 안산 경찰서 사이버수사팀에 약 70여 건의 악성댓글에 대한 모욕죄 고소를 했다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1090'};
MATCH (a:ResponseActor {name: '안산 단원경찰서 사이버수사팀'}), (b:ResponseAction {name: '악성댓글 수사'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', role: '악성댓글 수사 및 검찰 송치 준비', detail: '약 15건 수사 마침, 30여 건 추가 발견', evidence: '당시 안산 단원 경찰서 사이버수사팀에서 수사를 마친 사안은 ... 15건이었다 ... 30여 건의 댓글을 찾아냈', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1091'};
MATCH (a:ResponseActor {name: '세월호 특위 언론대응팀'}), (b:ResponseAction {name: '블로거 허위사실 명예훼손 고발'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', timing: '2014-07-28', role: '허위사실 명예훼손 고발', evidence: '언론대응팀은 2014년 7월 28일 허위사실 적시 명예훼손 혐의로 블로거 \'우여의 OOO\'을 고발했으며 ... 5건을 더 고발조치', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1092'};
MATCH (a:ResponseActor {name: '유가족'}), (b:ResponseAction {name: '\'국민 미개\' 발언 명예훼손 고소'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', role: '\'국민 미개\' 발언 명예훼손 고소', timing: '2014-04-18 발언 관련', evidence: '유가족 중 한분이 이를 명예훼손으로 고소하였다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1093'};
MATCH (a:ResponseActor {name: '세월호 특위 언론대응팀'}), (b:ResponseAction {name: '목사 발언 사자명예훼손 고소'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', role: '사자명예훼손·유가족 폄하 고소', evidence: '언론대응팀은 사랑의 교회 오 담임목사와 한국기독교총연합 공동부회장 조목사를 사자(死者)에 대한 명예훼손일 뿐만 아니라 유가족을 폄하한 혐의로 고소', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1094'};
MATCH (a:Event {name: '세월호 마타도어(흑색선전)'}), (b:Damage {name: '국민 분열 및 대립·반목'}) MERGE (a)-[r:CAUSES]->(b) SET r += {role: '국민 분열 및 유가족 폄하', mechanism: '\'유가족이 막대한 이익을 챙기려 한다\'식 공격', evidence: '유가족을 비하하고 거짓이 진실처럼 둔갑하는 등 끊임없이 대립과 반목을 양산했다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1095'};
MATCH (a:Event {name: '유가족 허위 특혜설 유포'}), (b:Event {name: '세월호 마타도어(흑색선전)'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {reason: '허위 특혜설이 마타도어·여론 공작으로 확대', mechanism: '선정적 제목으로 쉽게 확산, 되돌리기 매우 어려움', evidence: '세월호에 대한 마타도어는 허위사실에 기반을 두고 있다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1096'};
MATCH (a:ResponseActor {name: '세월호 특위 언론대응팀'}), (b:ResponseAction {name: '마타도어 적극 반박 홍보'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', role: '마타도어 적극 반박·홍보', timing: '방어적 대응에서 적극적 홍보로 전환', evidence: '이제는 방어적 대응에서 적극적 홍보로 방향전환을 해야 할 때 ... 마타도어에 대해서 적극적인 반박 내용을 담은 글들을 홍보하기로 결정', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1097'};
MATCH (a:ResponseActor {name: '국가기관(정부)'}), (b:ResponseAction {name: '세월호 운항관리규정 승인·안전점검 감독'}) MERGE (a)-[r:FAILS]->(b) SET r += {phase: 'prevention', reason: '재해 예방 및 국민 보호 의무 미이행', effectiveness: 'Low', specialNote: '참사 발생 이전부터 누적된 국가기관 과실', evidence: '부실한 세월호 운항관리규정에 대해 승인을 해주거나 운항관리자의 부실한 안전점검에 대해 감독의무를 해태하는 등 ... 누적된 국가기관의 과실', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1098'};
MATCH (a:RiskFactor {name: '부실한 운항관리규정 승인 및 안전점검 감독 해태'}), (b:Event {name: '세월호 침몰사고'}) MERGE (a)-[r:PRECONDITIONS]->(b) SET r += {probability: 'High', reason: '국가의 누적된 과실이 참사의 배경조건', evidence: '세월호 참사 발생 이전부터 누적된 국가기관의 과실이 있다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1099'};
MATCH (a:Event {name: '컨트롤타워 미작동(미숙한 대처)'}), (b:Damage {name: '세월호 참사 인명피해'}) MERGE (a)-[r:CAUSES]->(b) SET r += {role: '인명피해 증폭의 직접 원인', directCause: '구조 골든타임 상실', mechanism: '초기 구조 실패', evidence: '컨트롤타워가 제대로 작동하지 않는 등의 미숙한 대처로 인해 구조를 위한 골든타임을 놓치며 인명피해를 더욱 키웠다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1100'};
MATCH (a:ResponseActor {name: '국가기관(정부)'}), (b:ResponseAction {name: '세월호 초기 구조 대응'}) MERGE (a)-[r:FAILS]->(b) SET r += {phase: 'response', reason: '컨트롤타워 미작동, 미숙한 대처로 골든타임 상실', effectiveness: 'Low', specialNote: '국민 보호 의무 불이행으로 불법행위 책임', evidence: '미숙한 대처로 인해 구조를 위한 골든타임을 놓치며 인명피해를 더욱 키웠다 ... 국가기관의 과실이 존재', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1101'};
MATCH (a:RiskFactor {name: '유병언 일가의 무분별한 이윤추구'}), (b:Event {name: '세월호 침몰사고'}) MERGE (a)-[r:PRECONDITIONS]->(b) SET r += {probability: 'High', reason: '선사의 무분별한 이윤추구가 참사의 근본 원인 중 하나', evidence: '세월호 참사의 근본적인 원인 중 하나는 청해진 해운의 무분별한 이윤추구였다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1102'};
MATCH (a:ResponseActor {name: '세월호 가족대책위'}), (b:ResponseAction {name: '세월호 특별법(가족대책위안) 청원'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', role: '진상규명용 특별법안 마련·청원', objective: '질서있는 진상규명 및 재발방지대책 수립', evidence: '세월호 가족대책위가 대한변협과 함께 마련하여 청원한 법안 ... 조사권, 수사권, 그리고 기소권까지 갖춘 특별위원회가 설립되어야 한다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1103'};
MATCH (a:ResponseAction {name: '세월호 특별법(가족대책위안) 청원'}), (b:Resilience {name: '수사권·기소권 갖춘 특별조사위원회'}) MERGE (a)-[r:BUILDS]->(b) SET r += {effectiveness: 'Med', role: '재발방지·진상규명 역량 구축', evidence: '특별위원회에 수사권과 기소권을 부여해야 ... 강력한 진실규명을 해 나갈 수 있다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1104'};
MATCH (a:Resilience {name: '4.16 재단(가칭)'}), (b:Damage {name: '세월호 참사 인명피해'}) MERGE (a)-[r:OFFSETS]->(b) SET r += {effectiveness: 'Med', role: '재난 재발방지 역량으로 미래 피해 완충', evidence: '이 법에 의해 설립된 4.16 재단(가칭)이 재난에 대처하는 경각심을 고양하는 기념사업, 4.16. 재난방지의 날로 지정하는 사업, 재난 예방 및 방지교육', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1105'};
MATCH (a:RiskFactor {name: '기존 강제력 없는 조사위원회 한계'}), (b:Damage {name: '진상규명 실패 위험'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'High', reason: '수사권·기소권 없으면 진상규명 형식적 결과에 그칠 위험', evidence: '강제력 없는 조사권한에 따른 관계기관의 비협조로 인해 많은 만큼의 성과를 내지 못했다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1106'};
MATCH (a:ResponseActor {name: '서울중앙지검'}), (b:ResponseActor {name: '서울시선거관리위원회'}) MERGE (a)-[r:COORDINATES_WITH]->(b) SET r += {role: '선관위 고발 접수', timing: '2014-07-29', evidence: '서울시선거관리위원회(이하 \'선관위\')는 이 광고를 실은 어버이연합 간부를 7월 29일에 서울중앙지검에 고발', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1107'};
MATCH (a:ResponseActor {name: '서울시선거관리위원회'}), (b:ResponseAction {name: '어버이연합 광고 고발'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', timing: '2014-07-29', role: '공직선거법 위반 광고 고발', legalBasis: '공직선거법 제93조', evidence: '광고 게재 행위가 공직선거법 제93조를 위반한 것이라고 판단 ... 어버이연합 간부를 ... 고발했다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1108'};
MATCH (a:Event {name: '어버이연합 문화일보 광고·전단지'}), (b:Event {name: '세월호 마타도어(흑색선전)'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {reason: '허위 특혜 광고가 정치적 논란·조직적 흑색선전 의혹으로 확대', timing: '7.30 재보선 직전', evidence: '광고가 7.30 국회의원 재보선을 앞두고 있던 시기 ... 세월호 특별법이 마치 반정부 선동을 하는 것처럼 호도', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1109'};
MATCH (a:Event {name: '방통위 보도통제 의혹 문건'}), (b:Damage {name: '유가족·국민의 언론 불신'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {reason: '보도통제 의혹이 언론 불신을 정부 불신으로 확대', mechanism: '정부의 언론 통제 정황 공개', evidence: '보도통제 의혹이 있을 법한 방통위의 문건이 ... 공개되면서 언론의 불신은 정부의 불신으로 이어졌다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1110'};
MATCH (a:Population {name: '세월호 피해자 가족'}), (b:Damage {name: '세월호 참사 인명피해'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {role: '노출된 피해집단', reason: '고등학생 희생자라는 점이 댓글 문제의 심각성 증폭', evidence: '세월호 희생자의 대다수는 고등학생이었고 이들 부모는 대부분 40대', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1111'};
MATCH (a:ResponseActor {name: '이준석 선장 등 세월호 선원·청해진해운'}), (b:ResponseAction {name: '세월호 초기 구조 대응'}) MERGE (a)-[r:FAILS]->(b) SET r += {phase: 'response', reason: '승객 구조 책임 방기', specialNote: '인명피해를 키운 책임 규명 필요', evidence: '이준석 선장을 비롯한 세월호 선원 ... 인명피해를 키운 책임이 누구에게 있고', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1112'};
