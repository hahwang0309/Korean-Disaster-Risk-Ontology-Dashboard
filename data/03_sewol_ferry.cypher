MATCH (a:Event {name: '세월호 침몰사고'}), (b:ResponseAction {name: '세월호 특별법 제정 추진'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {phase: 'recovery', specialNote: '참사로 드러난 제반 문제 해결을 위해 특별법 제정 논의가 촉발됨', timing: '참사 직후~', evidence: '특별법 제정이야말로 세월호 참사로 인해 드러난 제반 문제들을 해결하는데 가장 좋은 대안이라는 결론이었다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0556'};
MATCH (a:ResponseAction {name: '세월호 특별법 제정 추진'}), (b:Other {name: '‘세월호 참사 진상 규명 대책Ⅱ(제도적 고찰)’ 비교 문건'}) MERGE (a)-[r:GUIDED_BY]->(b) SET r += {specialNote: '특별검사제도·국정조사청문회·특별법 제정 세 제도를 비교 분석', reason: '각 제도의 장단점 비교 후 특별법 제정으로 결론', evidence: '회, 특별법 제정 비교"라는 문건1)을 통하여, 각 제도에 대한 비교 설명과 장단점을 분석하면서 결론적으로는 특별법 제정으로 나아가야 함을 역설하였다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0557'};
MATCH (a:Other {name: '특별검사제도'}), (b:ResponseAction {name: '세월호 특별법 제정 추진'}) MERGE (a)-[r:MITIGATES]->(b) SET r += {phase: 'recovery', effectiveness: 'Low', reason: '짧은 수사기간·정치적 독립성 미확보로 세월호 과제 해결에 미흡', specialNote: '진상규명 수단으로 평가되었으나 부적합 판정', evidence: '진상규명 뿐만 아니라 재해/재난의 예방 및 사후 대처 방안까지 논의되어야 하는 세월호 참사의 과제를 풀기에는 미흡하다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0558'};
MATCH (a:Other {name: '국정조사 및 청문회'}), (b:ResponseAction {name: '세월호 특별법 제정 추진'}) MERGE (a)-[r:MITIGATES]->(b) SET r += {phase: 'recovery', effectiveness: 'Med', reason: '필요한 과정이나 세월호 난제 해결에는 부족', specialNote: '진상규명 수단 평가', evidence: '세월호 진상조사를 위해 필요한 과정임에는 틀림이 없으나 이 역시 세월호 참사가 던져준 난제를 풀기에는 많이 부족하다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0559'};
MATCH (a:ResponseActor {name: '대한변호사협회'}), (b:ResponseAction {name: '세월호 가족대책위-대한변협 간 업무협약 체결'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', timing: '2014-05-16', specialNote: '세월호 가족대책위와 업무협약 조인식', evidence: '대한변협은 세월호 가족대책위와 ... 2014년 5월 16일 참사 법률지원 및 대책 마련을 위한 ... 업무 협약("세월호 ... 조인식을 가졌', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0560'};
MATCH (a:ResponseActor {name: '세월호 사고 희생자·실종자·생존자 및 가족대책위원회'}), (b:ResponseActor {name: '대한변호사협회'}) MERGE (a)-[r:COORDINATES_WITH]->(b) SET r += {phase: 'recovery', timing: '2014-05-16', role: '업무협약 당사자', evidence: '대한변협은 세월호 가족대책위와 ... 업무 협약 ... 조인식을 가졌', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0561'};
MATCH (a:ResponseActor {name: '세월호 가족대책위'}), (b:ResponseAction {name: '세월호 특별법 제정 요구 서명 운동'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', specialNote: '천만인 서명용지를 통한 특별법 제정 요구', detail: '참고자료 3-2', evidence: '"세월호 사고 실종자 조속한 수습과 철저한 진상규명 촉구 서명용지" ... 특별법 제정 등을 통한 철저한 진상 규명 및 재발방 지 대책마련을 강력히 요구', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0562'};
MATCH (a:ResponseAction {name: '세월호 특별법 제정 요구 서명 운동'}), (b:Event {name: '세월호 침몰사고'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {phase: 'recovery', specialNote: '참사 실종자 수습·진상규명 요구', evidence: '세월호 사고 실종자에 대한 조속한 수습과 철저한 진상 규명을 강력히 요구합니다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0563'};
MATCH (a:ResponseActor {name: '세월호 특위 특별법 제정팀'}), (b:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}) MERGE (a)-[r:BELONGS_TO]->(b) SET r += {phase: 'recovery', specialNote: '법제도개선단 산하 백서제작팀·해상팀과 함께 설치', evidence: '법제도 개선단 산하에 백서제작팀, 해상팀 뿐만 아니라, \'특별법 제정팀\'을 두고 박종운 변호사를 팀장으로 임명하였다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0564'};
MATCH (a:ResponseActor {name: '박종운 변호사'}), (b:Other {name: '대한변협 세월호 특위 초안(특별법)'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', timing: '2014-05-13', specialNote: '특별법 초안 작성 후 제정팀 설치 계기로 발전(참고자료 3-3)', evidence: '박종운 변호사는 이미 5월 13일경 "세월호 참사 진상규명, 피해자 지원, 재발 방지책 마련 등에 관한 특별법 초안"을 내놓은 바 있는데', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0565'};
MATCH (a:ResponseActor {name: '신현호 변호사'}), (b:ResponseAction {name: '박종운 초안 수정안 제안'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', specialNote: '박종운 초안에 대한 수정안 제안(참고자료 3-4)', evidence: '특히 신현호 변호사는 위 초안에 대한 수정안을 제안하기도 하였다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0566'};
MATCH (a:ResponseActor {name: '김희수 변호사'}), (b:Other {name: '김희수 초안(특별법)'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', specialNote: '개인 차원의 특별법 제정안 작성·세월호 특위에 입법 제안', evidence: '개인으로는 김희수 변호사이고 ... 개인 차원에서 특별법 제정(안)을 만들어서 세월호 특위에 입법 제안을 해 왔던 것이다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0567'};
MATCH (a:ResponseActor {name: '민주사회를 위한 변호사 모임'}), (b:Other {name: '민변 초안(특별법)'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', timing: '참사 발생 초기부터', specialNote: '내부 특별법 제정팀 운영·수차례 수정(참고자료 3-5)', evidence: '단체로는 \'민주사회를 위한 변호사 모임\'(이하, "민변") ... 내부에 특별법 제정팀을 두고 이미 여러 차례 수정 작업을 거듭하고 있었다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0568'};
MATCH (a:ResponseActor {name: '민주사회를 위한 변호사 모임'}), (b:ResponseActor {name: '세월호참사 국민대책회의'}) MERGE (a)-[r:BELONGS_TO]->(b) SET r += {phase: 'recovery', specialNote: '국민대책회의에 단체 단위로 참여', evidence: '민변은 ... 국민대책회의에 단체 단위로 참여하였을 뿐만 아니라', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0569'};
MATCH (a:ResponseActor {name: '세월호 특위 특별법 제정팀'}), (b:ResponseAction {name: '대한변호사협회 통합안 작성'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', specialNote: '3개 법안(대한변협 세월호 특위 초안·김희수 초안·민변 초안)을 하나로 녹여 통합안 작성 결정', reason: '법률가 그룹의 다수 법안이 혼란·제정 지연 초래 우려', evidence: '위 3개의 법안을 하나로 녹여낸 대한변호사협회 통합안 ... 을 만들기로 하고 ... 의원입법하는 것을 목표로 삼게 되었다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0570'};
MATCH (a:ResponseAction {name: '대한변협 통합안 작성 제1차 전체회의'}), (b:Context {name: '2014-05-28 법무법인 소명'}) MERGE (a)-[r:OCCURS_AT]->(b) SET r += {phase: 'recovery', timing: '2014-05-28', evidence: '제1차 전체회의는 5월 28일 법무법인 소명에서 열렸다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0571'};
MATCH (a:ResponseActor {name: '김희수 변호사'}), (b:Other {name: '대한변협 통합안 최종 수정본'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', timing: '2014-06-16', specialNote: '대한변협 세월호 특위 초안·민변 초안 내용을 녹여 통합안 최종 수정본 작성', evidence: '마침내 6월 16일 대한변협 통합안 최종 수정본이 작성되었는데, 법명은 "4·16 참사 진실규명 등에 관한 특별법(안)"으로 하였다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0572'};
MATCH (a:ResponseActor {name: '세월호 특위 특별법 제정팀'}), (b:ResponseAction {name: '안산 세월호 가족대책위 설명회'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', timing: '2014-06-19', specialNote: '안산 세월호 가족대책위 방문·통합안 설명·질의응답', evidence: '6월 19일 안산에 있는 세월호 가족대책위를 방문하여 대한변협 통합안을 설명하고 질의 및 응답 시간을 가졌는데', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0573'};
MATCH (a:ResponseActor {name: '세월호 특위 특별법 제정팀'}), (b:ResponseAction {name: '인천 일반인 가족대책위 설명회'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', timing: '2014-06-21', specialNote: '인천 일반인 가족대책위 방문·통합안 설명', evidence: '6월 21일(토)에는 인천에 있는 일반인 가족대책위를 방문하여 ... 대한변협 통합안을 설명하였는데', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0574'};
MATCH (a:ResponseActor {name: '세월호 가족대책위'}), (b:ResponseActor {name: '세월호 특위 특별법 제정팀'}) MERGE (a)-[r:COORDINATES_WITH]->(b) SET r += {phase: 'recovery', role: '수사·기소권 강화 수정 요청', specialNote: '피해자 지원보다 진상규명에 집중 요청', evidence: '수사 및 기소권 등 위원회의 조사권한을 강화하는 방향으로 확정하여 수정 보완해 줄 것을 요청하였다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0575'};
MATCH (a:ResponseActor {name: '김희수 변호사'}), (b:Other {name: '공청회 발제안(4·16 참사 진실규명 및 안전사회 건설 등을 위한 특별법안)'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', timing: '2014-06-30경', specialNote: '박종운 변호사 수정 통합법안을 김희수 변호사가 최종 수정', reason: '안전사회 건설 부분 미흡 지적 반영', evidence: '6월 30일경 박종운 변호사가 수정한 통합법안을 김희수 변호사가 최종 수정함으로써 공청회 발제안이 완성되었다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0576'};
MATCH (a:ResponseAction {name: '세월호 특위 특별법 제정팀 6월 29일 회의'}), (b:ResponseAction {name: '세월호 특별법 제정 추진'}) MERGE (a)-[r:MODIFIES_RISK_OF]->(b) SET r += {phase: 'recovery', specialNote: '안전사회 건설 부분 대폭 수정 보완 결정으로 재발방지 강화', effectiveness: 'Med', evidence: '대한변협 통합안이 안전사회 건설 부분에서는 너무 미흡하다고 지적되었다 ... 그 부분을 대폭 수정 보완하기로 하였다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0577'};
MATCH (a:ResponseAction {name: '세월호 특별법 제정 추진'}), (b:Context {name: '2014-07-02 국회 입법조사처 대회의실'}) MERGE (a)-[r:OCCURS_AT]->(b) SET r += {phase: 'recovery', timing: '2014-07-02', evidence: '7월 2일 "4·16 참사 진실규명 및 안전사회 건설 등을 위한 특별법 공청회\'가 국회 입법조사처 대회의실에서 개최되었다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0578'};
MATCH (a:ResponseActor {name: '김희수 변호사'}), (b:ResponseAction {name: '세월호 특별법 제정 추진'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', timing: '2014-07-02', specialNote: '공청회에서 대한변협 통합안(공청회 발제안) 발표', evidence: '김희수 변호사가 대한변협 통합안(공청회 발제안)을 발표하였고', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0579'};
MATCH (a:ResponseActor {name: '전해철 국회의원(새정치민주연합)'}), (b:ResponseAction {name: '세월호 특별법 제정 추진'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', timing: '2014-07-02', specialNote: '야당안을 기초로 공청회 발제안 토론', evidence: '전해철 의원은 야당안을 기초로 공청회 발제안에 대해 토론하였고', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0580'};
MATCH (a:ResponseActor {name: '전명선 세월호 가족대책위 부위원장'}), (b:ResponseAction {name: '세월호 특별법 제정 추진'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', timing: '2014-07-02', specialNote: '피해자 지원보다 진상규명에 힘써 줄 것 요청', evidence: '전명선 부위원장은 피해자 지원보다는 진상규명에 좀 더 힘써 줄 것을 요청하였으며', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0581'};
MATCH (a:ResponseActor {name: '이태호 참여연대 사무처장'}), (b:ResponseAction {name: '세월호 특별법 제정 추진'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', timing: '2014-07-02', specialNote: '국민참여형 진상규명·포괄적 재발방지 대책 강조, 위원회와 특별검사제 동시 추진 제안', evidence: '이태호 사무처장은 국민참여형 진상규명 ... 위원회와 특별검사제 동시 추진을 제안하였다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0582'};
MATCH (a:ResponseActor {name: '김택수 변호사(민변)'}), (b:ResponseAction {name: '세월호 특별법 제정 추진'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', timing: '2014-07-02', specialNote: '특별검사 임명방안과 진상규명위원회 설치방안을 별개 특별법으로 정하는 안 제시', evidence: '김택수 변호사는 ... 특별검사 임명방안과 진상규명위원회 설치방안을 각각 별개의 특별법으로 정하는 안', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0583'};
MATCH (a:Other {name: '4·16 참사 진실규명 및 안전사회 건설 등을 위한 특별법(안)'}), (b:Event {name: '세월호 침몰사고'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {phase: 'recovery', specialNote: '참사의 진실규명 및 재해 방지책 수립 목적', directCause: '2014-04-16 진도군 관매도 부근 해상 참사', evidence: '"2014. 4. 16. 전라남도 진도군 관매도 부근 해상에서 발생한 4·16 참사 사건의 진실규명과 아울러 재해 방지책을 수립하고"', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0584'};
MATCH (a:Other {name: '4·16 참사 진실규명 및 안전사회 건설 등을 위한 특별법(안)'}), (b:ResponseAction {name: '세월호 특별법 제정 추진'}) MERGE (a)-[r:MODIFIES_RISK_OF]->(b) SET r += {phase: 'recovery', specialNote: '재해재발 예방·안전사회 확립을 위한 4·16 안전재단 설립 규정으로 재발위험 완화 의도', effectiveness: 'Med', timing: '위원회 활동 종료 전 재단 설립', evidence: '정부로 하여금 ... 4·16 안전재단을 설립하도록 하고 ... 위 재단은 안전사회 관련 사업과 기억 사업, 트라우마 치유 관련 업무 등을 수행하도록 규정', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0585'};
MATCH (a:Resilience {name: '4·16 안전재단'}), (b:Event {name: '세월호 침몰사고'}) MERGE (a)-[r:OFFSETS]->(b) SET r += {phase: 'recovery', specialNote: '안전사회 건설·트라우마 치유로 참사 후유·재발위험 완충', effectiveness: 'Med', evidence: '위 재단은 안전사회 관련 사업과 기억 사업, 트라우마 치유 관련 업무 등을 수행하도록 규정하고 있다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0586'};
MATCH (a:ResponseAction {name: '대한변협 세월호 특위 초안(특별법)의 진상규명 시스템'}), (b:ResponseAction {name: '세월호 특별법 제정 추진'}) MERGE (a)-[r:MODIFIES_RISK_OF]->(b) SET r += {phase: 'recovery', specialNote: '과거 위원회의 이행 부족 문제를 보완해 재발방지대책 이행 모니터링 체계 구축', effectiveness: 'Med', reason: '과거 결과보고서 이행 부족 감안', evidence: '진상규명 → 진상규명에 따른 대책 마련 → 국회 및 관계 기관 등을 통한 대책 이행 → 위원회를 통한 대책 이행 사항 모니터링의 시스템을 갖추고 있다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0587'};
MATCH (a:ResponseActor {name: '장완익 변호사'}), (b:ResponseActor {name: '세월호 특위 특별법 제정팀'}) MERGE (a)-[r:BELONGS_TO]->(b) SET r += {phase: 'recovery', specialNote: '유사 위원회 경력자로 특별법 제정팀 합류', evidence: '친일반민족행위자재산조사위원회 사무처장 등 유사한 위원회 경력을 가진 장완익 변호사 ... 등이 모여서', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0588'};
MATCH (a:Event {name: '세월호 침몰사고'}), (b:ResponseAction {name: '4·16 참사 진실규명 및 안전사회 건설 등을 위한 특별법(안) 입법청원'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {role: '참사 대응 후속', timing: '참사 후 88일째(7월 13일 기준)', reason: '진상규명 및 재발방지 입법 추진', evidence: '7월 9일 입법청원을 한 후 곧바로 입법투쟁에 돌입하게 되었다 / 4·16 참사가 발생한지 88일째 되는 날', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0589'};
MATCH (a:ResponseActor {name: '세월호 특위 특별법 제정팀'}), (b:ResponseAction {name: '4·16 참사 진실규명 및 안전사회 건설 등을 위한 특별법(안) 입법청원'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '입법청원안 작성·완성', timing: '7월 5~6일 최종안 완성', effectiveness: 'Med', evidence: '7월 5일(토) 밤을 거쳐 7월 6일(일)에 최종안이 완성되었다 / 특별법 제정팀의 입법 투쟁은 박종운, 장완익 변호사가 국회 현장을 담당', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0590'};
MATCH (a:ResponseActor {name: '세월호 특위 특별법 제정팀'}), (b:ResponseAction {name: '입법청원 방식 채택 결정'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '입법방식 채택 결정', reason: '정부입법 배제, 의원입법보다 천만인 서명운동 성과 감안', timing: '7월 5일 확대회의', evidence: '입법청원 방식을 채택하기로 결정하였다 / 오랜 시간이 소요되는 정부입법은 배제하고', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0591'};
MATCH (a:Other {name: '수사 및 기소권 위원회 부여 쟁점'}), (b:ResponseAction {name: '4·16 참사 진실규명 및 안전사회 건설 등을 위한 특별법(안) 입법청원'}) MERGE (a)-[r:MODIFIES_RISK_OF]->(b) SET r += {role: '최대 쟁점으로 입법 성공 가능성에 영향', specialNote: '수사·기소권 관철 시 법 제정 난항, 미관철 시 진상규명 한계', probability: 'Low', reason: '정치적 역학관계상 관철 곤란', evidence: '수사 및 기소권을 위원회에 둘 것인지 여부는 쉽사리 결론이 나지 않았다 / 여당을 비롯한 보수층의 격렬한 반대가 예상되고', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0592'};
MATCH (a:ResponseActor {name: '특별법 제정팀장'}), (b:ResponseAction {name: '수사·기소권 입법청원안 포함 및 단계적 양보 방침 결정'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '수사·기소권 처리 방향 정리', timing: '7월 5일 확대회의', effectiveness: 'Med', mechanism: '참여 위원 동의 확보', evidence: '입법청원안에 수사 및 기소권을 포함시키되 ... 어느 시기가 되면 수사 및 기소권을 포기할 수 있는 것으로 정리한 후, 참여 위원들의 동의를 구하였고', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0593'};
MATCH (a:ResponseActor {name: '세월호 가족대책위'}), (b:ResponseAction {name: '진상규명 및 수사·기소권 관철 요구'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '진상규명·수사기소권 관철 요구', timing: '7월 6일 총회 등 다수', effectiveness: 'High', reason: '정치권에 진상규명을 맡길 수 없다는 판단', evidence: '가족들은 수사 및 기소권 관철을 강력하게 요구하였고 / 설사 보상/배상 부분을 삭제하는 한이 있더라도 반드시 진실을 규명해 달라고 강력하게 요청', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0594'};
MATCH (a:ResponseActor {name: '세월호 가족대책위'}), (b:ResponseAction {name: '3자협의체 구성 제안'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '3자협의체 구성 제안', timing: '2014-07-09 입법청원 기자회견', effectiveness: 'Low', evidence: '세월호 가족대책위와 여당, 야당 3자가 협의하여 특별법을 제정할 것을 요구하였다(3자협의체 구성 제안)', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0595'};
MATCH (a:ResponseActor {name: '4·16 특별법 청원 국민대표단'}), (b:ResponseAction {name: '4·16 참사 진실규명 및 안전사회 건설 등을 위한 특별법(안) 입법청원'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '입법청원 절차 진행', timing: '2014-07-09', scale: '단 하루 만에 1,490명 모집', evidence: '\'4.16 특별법 청원 국민대표단\'(7월 9일 12시 1,490명)의 이름으로 입법청원 절차를 진행하였는데, 위 인원은 단 하루 만에 모아진 것이다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0596'};
MATCH (a:ResponseAction {name: '특별법 제정 촉구 천만인(350여만명) 서명운동'}), (b:Event {name: '세월호 침몰사고'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {role: '특별법 제정 촉구 여론 압박', timing: '2014-07-15', effectiveness: 'High', evidence: '7월 15일에는 특별법 제정을 촉구하는 3,501,266명의 서명지가 국회에 제출되었는데', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0597'};
MATCH (a:ResponseActor {name: '조속입법 TF'}), (b:ResponseAction {name: '여야 특별법 협상'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '여야 특별법 협상', timing: '2014-07-12~', effectiveness: 'Low', specialNote: '여당안·야당안만으로 협의, 입법청원안 배제 우려', evidence: '\'세월호 사건 조사 및 보상에 관한 조속 입법 TF\'(이하, \'조속입법 TF\'이라 함)가 가동되어 여야 협상에 들어갔다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0598'};
MATCH (a:ResponseActor {name: '조속입법 TF'}), (b:ResponseAction {name: '3자협의체 구성 제안'}) MERGE (a)-[r:FAILS]->(b) SET r += {role: '3자협의체·참관 거부', reason: '법안은 국회의원이 심의하는 것이지 민간인이 관여할 수 없다는 여당측 위원 반대', effectiveness: 'Low', consequence: '세월호 가족대책위의 여당 불신·연좌농성 촉발', evidence: '3자협의체는 물론 참관조차도 여당측 위원들에 의해 거부당하자 / \'법안은 국회의원들이 심의하는 것이지 민간인이 관여할 수 없다\'는 여당측 위원들의 강력한 반대', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0599'};
MATCH (a:ResponseActor {name: '여당측 위원(새누리당)'}), (b:ResponseAction {name: 'TF 참관·회의공개 요청'}) MERGE (a)-[r:FAILS]->(b) SET r += {role: '참관·회의공개 요청 거부', reason: '민간인 관여 불가 입장, 요지부동', consequence: '여야 밀실야합 우려 현실화', evidence: '차선책으로 TF 회의에 세월호 가족대책위 대표 몇 명만이라도 참관하도록 해 달라, 최소한 회의를 공개라도 해달라고 요청하였으나 모두 거절당하고', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0600'};
MATCH (a:Other {name: '5대 쟁점(수사·기소권, 특별사법경찰리 지위, 청문회, 특위 구성 추천비율, 보·배상)'}), (b:ResponseAction {name: '여야 특별법 협상'}) MERGE (a)-[r:MODIFIES_RISK_OF]->(b) SET r += {role: '협상 결렬 위험 증대', probability: 'High', reason: '여당측 위원 반대·부정적 의견', evidence: '5가지 쟁점에 대하여 여당측 위원들이 반대 혹은 부정적 의견를 가지고 있다는 사실을 알 수 있었다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0601'};
MATCH (a:ResponseActor {name: '세월호 가족대책위'}), (b:ResponseAction {name: '국회·광화문 단식 연좌 농성'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '국회 본청 앞 연좌·단식농성', timing: '2014-07-13 연좌 시작, 7월 14일부터 단식', reason: '3자협의체·참관 거부에 따른 여당 불신', effectiveness: 'Med', evidence: '그날부터 국회의사당 본청 앞에서 세월호 가족대책위의 모임 및 연좌가 시작되었다 / 세월호 가족대책위는 14일부터 국회와 광화문에서 단식 연좌 농성에 들어갔다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0602'};
MATCH (a:ResponseActor {name: '세월호 가족대책위'}), (b:ResponseAction {name: '\'무늬만 특별법 단호히 반대\' 입장 발표'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '기자회견 입장 발표', timing: '2014-07-13', effectiveness: 'Med', evidence: '11시 세월호 가족대책위는 기자회견을 통해 \'무늬만 특별법, 단호히 반대한다\'는 입장을 발표하였고', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0603'};
MATCH (a:ResponseActor {name: '세월호 특위 특별법 제정팀'}), (b:ResponseAction {name: '입법청원안 언론 설명·유언비어 불식 대응'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '언론 대응·입법청원안 설명회', timing: '2014-07-13~16', effectiveness: 'Med', mechanism: '라디오·TV 인터뷰 및 자료 배포', evidence: '인터넷과 일부 언론에서 떠도는 잘못된 정보, 비방, 유언비어(流言蜚語) 등이 사실과 다르다는 점을 널리 알림으로써 ... 부탁하면서', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0604'};
