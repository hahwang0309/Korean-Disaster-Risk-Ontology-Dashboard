MATCH (a:Event {name: '세월호 침몰사고'}), (b:Context {name: '2014-04-16 전남 진도군 병풍도 앞 해상'}) MERGE (a)-[r:OCCURS_AT]->(b) SET r += {role: '발생일시·장소', evidence: '2014. 4. 16. ... 전남 진도군 병풍도 앞 인근 해상에서 침몰하였다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1114'};
