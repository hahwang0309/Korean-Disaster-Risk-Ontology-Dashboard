MATCH (a:Event {name: '세월호 침몰사고'}), (b:Event {name: '남영호 침몰사고'}) MERGE (a)-[r:CONCURRENT_WITH]->(b) SET r += {role: '유사 반복 사고(역사적 선례)', mechanism: '안전 점검·감독 소홀로 인한 반복된 대형 해상 침몰사고', specialNote: '동일 원인의 반복 사고로 비교됨', evidence: '1970년 12월 14일 발생한 남영호 침몰 사고(사망자 326명) ... 와 유사한 반복된 사고', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0019'};
MATCH (a:Event {name: '세월호 침몰사고'}), (b:Event {name: '서해훼리호 침몰사고'}) MERGE (a)-[r:CONCURRENT_WITH]->(b) SET r += {role: '유사 반복 사고(역사적 선례)', mechanism: '안전불감증으로 인한 반복된 해상 침몰사고', specialNote: '동일 원인의 반복 사고로 비교됨', evidence: '1993년 10월 10일 발생한 서해훼리호 침몰사고(사망자 292명)와 유사한 반복된 사고', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0020'};
MATCH (a:Event {name: '단원고 전원구조 오보'}), (b:Event {name: '국민 신뢰의 좌절·원망'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {probability: 'Med', mechanism: '전원 구조 오보가 국민 신뢰를 좌절·원망으로 전환', timing: '사고 당일', evidence: '전원 구조되었다는 언론보도가 오보로 밝혀졌고 ... 다수 국민들의 당초의 믿음은 좌절로, 그리고 다시 원망으로 변해 갔다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0021'};
MATCH (a:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}), (b:ResponseAction {name: '세월호 피해자 법률지원 활동'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '피해자 지원 활동 수행', timing: '참사 발생 직후~8개월', effectiveness: 'Med', evidence: '세월호 특위를 출범하여 피해자들을 위한 다양한 활동을 전개 ... 법률상담부터 진상조사, 입법활동지원 등에 이르기까지 종합적인 지원', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0022'};
MATCH (a:ResponseAction {name: '세월호 피해자 법률지원 활동'}), (b:Damage {name: '세월호 참사 인명피해'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {timing: '참사 발생 직후', effectiveness: 'Med', specialNote: '민간단체로서 인력·비용 한계로 진상조사·입법 활동이 벽에 부딪힘', evidence: '대한변협는 세월호 참사 발생 직후 어느 때 보다 발 빠르게 피해자 지원 및 진상조사 활동을 하였다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0023'};
MATCH (a:ResponseActor {name: '대한변협 공익법률지원단'}), (b:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}) MERGE (a)-[r:BELONGS_TO]->(b) SET r += {role: '특위 산하 지원 인력', evidence: '부족한 인력을 보충하기 위하여 공익법률지원단을 모집하였던 바 ... 총 514명의 ... 회원들이 지원', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0024'};
MATCH (a:ManmadeHazard {name: '세월호(카페리)'}), (b:Event {name: '세월호 침몰사고'}) MERGE (a)-[r:TRIGGERS]->(b) SET r += {scale: '대형', probability: 'High', mechanism: '급격한 변침 중 복원성 상실로 침몰', specialNote: '남영호(1970, 사망 326)·서해훼리호(1993, 사망 292)와 유사한 반복 사고', evidence: '세월호는 ... 오전 8시 25분경 ... 항로를 변경하다가 돌연 선체가 좌현으로 약 30도 가량 기울었고 ... 11시 18분 경 선수의 일부만 남기고 바다 밑으로 침몰되었다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0025'};
MATCH (a:RiskFactor {name: '세월호 무리한 증·개축(복원성 악화)'}), (b:Event {name: '세월호 침몰사고'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'High', mechanism: '복원성 악화로 전복 위험 상승', reason: '직접적 침몰원인 ①', evidence: '① 세월호는 2012년 일본에서 수입된 후 ... 무리한 증·개축 과정을 거쳤고, 이 과정에서 ... 복원성이 크게 악화되었다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0026'};
MATCH (a:RiskFactor {name: '세월호 과적'}), (b:Event {name: '세월호 침몰사고'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'High', mechanism: '평형수 부족·고박 미흡으로 복원력 저하 및 화물 이동', reason: '직접적 침몰원인 ②', evidence: '② 세월호는 사고 당일 최대 화물 적재량의 2배에 달하는 화물을 적재하였고, 과적단속을 피하기 위하여 ... 평형수를 감축하였으며, 화물 고박 관련 규정 또한 준수하지 않았다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0027'};
MATCH (a:Event {name: '급격한 변침(맹골수도)'}), (b:Event {name: '세월호 복원성 상실'}) MERGE (a)-[r:TRIGGERS_SECONDARY]->(b) SET r += {probability: 'High', directCause: '급격한 변침', mechanism: '변침으로 인한 기울어짐이 복원성 상실 유발', reason: '직접적 침몰원인 ③', evidence: '③ ... 급격하게 항로를 바꾸는 바람에 약 15도가량 기울어졌고, 이 과정에서 급격한 변침이 발생하여 침몰한 것으로 밝혀졌다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0028'};
MATCH (a:Event {name: '세월호 복원성 상실'}), (b:Event {name: '세월호 침몰사고'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {probability: 'High', mechanism: '복원성 상실→표류→완전 침몰', timing: '08:25 기울기 시작~11:18 완전 침몰(약 2시간)', evidence: '결국 세월호는 사고 발생 후 2시간이 지난 오전 11시 18분, 선수 일부만을 남기고 뒤집어진 상태로 완전히 침몰하였다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0029'};
MATCH (a:Event {name: '세월호 복원성 상실'}), (b:Event {name: '세월호 승객 선내 고립'}) MERGE (a)-[r:TRIGGERS_SECONDARY]->(b) SET r += {probability: 'High', mechanism: '선체 90도 기울어 출입구가 천정이 되고 \'가만히 있으라\' 방송으로 선내 대기→탈출 불가', timing: '오전 10시 10분경 90도', evidence: '‘가만히 있으라’는 선내 방송을 따랐던 대부분의 학생들과 승객들은 기울어진 선내에 대기하다 선실에 갇히게 되었고', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0030'};
MATCH (a:Event {name: '세월호 승객 선내 고립'}), (b:Damage {name: '세월호 참사 인명피해'}) MERGE (a)-[r:CAUSES]->(b) SET r += {scale: '최악의 참사', mechanism: '구조활동 미시도로 단 한 명도 구조 못함', evidence: '단 한명도 구조하지 못하고 남은 304명이 사망하거나 실종되는 최악의 참사가 발생하였다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0031'};
MATCH (a:ResponseActor {name: '청해진해운'}), (b:ResponseAction {name: '비상시 퇴선 훈련·교육훈련'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '비상시 퇴선 훈련 등 교육훈련 의무 규정대로 미실시', effectiveness: 'Low', directCause: '직접적 침몰원인 ④', evidence: '④ 세월호 선사인 청해진해운은 선원들에게 비상시를 대비한 퇴선 훈련 등 ... 교육 훈련을 ... 규정대로 실시하지 않았고', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0032'};
MATCH (a:ResponseActor {name: '세월호 선원'}), (b:ResponseAction {name: '승객 퇴선조치·초기 인명구조'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '퇴선조치·인명구조 의무 방치, \'가만히 있으라\' 방송만 반복', effectiveness: 'Low', timing: '선내 대기 지시 후 자신들 먼저 탈출', evidence: '승객들에게는 “가만히 있으라”는 방송만을 반복하고서 정작 자신들은 경비정을 타고 먼저 탈출해버리는 등 승객들의 인명구조에 노력해야 할 의무를 방치하여', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0033'};
MATCH (a:ResponseActor {name: '진도 해상교통관제센터(진도VTS)'}), (b:ResponseAction {name: '세월호 관제·사고 인지'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '사고 당일 오전 9시 6분 목포해경 통보 전까지 약 20분간 세월호 전혀 관제 안 함', effectiveness: 'Low', evidence: '진도 해상교통관제센터 ... 는 사고당일 오전 9시 6분 경 목포해경으로부터 사고소식을 전해들을 때까지 약 20분 동안 세월호에 대해 전혀 관제하지 않았고', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0034'};
MATCH (a:RiskFactor {name: 'VTS 관할 이원화(해수부·해경)'}), (b:Event {name: '진도VTS 부실 관제'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'Med', mechanism: '이원화된 관리가 진도VTS 부실 관제 초래', evidence: '항만의 15개 VTS는 해양수산부 관할이며, 진도와 여수 두 곳은 해양경찰청 관할로 이원화되어 ... 진도VTS의 부실 관제를 초래했다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0035'};
MATCH (a:ResponseActor {name: '목포해양경찰서·서해지방해양경찰청'}), (b:ResponseAction {name: '초기 사고 보고 및 퇴선명령'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '상급자 보고 누락·구조인력 미전달로 구조 1시간 이상 지체', effectiveness: 'Low', mechanism: '최종 명령권자(서해지방해양경찰청장)가 퇴선명령 등 적절한 조치 못 취함', evidence: '최초 사고신고를 접수한 목포해경 및 서해지방해경도 초기대응을 태만히 하고 보고를 누락하여 최종 명령권자인 서해지방해양경찰청장이 퇴선명령 등 적절한 조치를 취할 수 없게 하였다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0036'};
MATCH (a:ResponseActor {name: '故 최덕하 학생(단원고)'}), (b:ResponseAction {name: '119 최초 사고 신고'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {timing: '배가 기울기 시작한 직후', role: '최초 신고', evidence: '4월 16일 8시 52분 경 단원고등학교 故 최덕하 학생이 전남소방본부 119 상황실에 사고 신고를 하고, 약 2분 뒤 119 상황실은 목포해양경찰에 사고신고 내용을 전달하였다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0037'};
MATCH (a:ResponseActor {name: '해양경찰 123정'}), (b:ResponseAction {name: '현장 퇴선방송·승객 구조'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '선미 승객 미구조·선원 먼저 구조, 퇴선방송 미실시', effectiveness: 'Low', specialNote: '도착 시 세월호 약 52.5도 기울었으나 갑판 이동 가능 상황', evidence: '목포 해양경찰청 소속 123정은 ... 오전 9시 35분경 현장에 가장 먼저 도착하였는데, 선미의 승객들은 구조하지 않고, ... 선원들을 먼저 구조했다. ... 123정은 퇴선방송을 하지는 않았다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0038'};
MATCH (a:ResponseActor {name: '123정 정장'}), (b:ResponseAction {name: '현장 퇴선명령·구조지휘'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '뒤늦은 현장보고 받고도 즉시 퇴선명령·구조지휘 안 함', effectiveness: 'Low', evidence: '구조함정인 123정의 정장은 현장에 도착한 9시 43분 경 뒤늦은 현장보고를 받고서도 그 즉시 퇴선명령 등 적절한 구조지휘를 하지도 않았다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0039'};
MATCH (a:ResponseActor {name: '서해경찰청 특공대(잠수구조 전담 7명)'}), (b:ResponseAction {name: '잠수구조 인력 출동·투입'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '출동지시(08:58)에도 자체 헬기 없어 민간어선으로 갈아탐, 침몰 이후 11시 15분 현장 도착', effectiveness: 'Low', mechanism: '잠수 구조 인력 배치·실전투입 대비 허술', evidence: '서해경찰청 특공대 7명은 세월호가 선수만 남기고 침몰한 이후인 11시 15분에서야 현장에 도착했다. 잠수구조 인력의 지연된 출동 및 도착은 ... 자체 헬기조차 없는 등 ... 대비가 매우 허술했기 때문이다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0040'};
MATCH (a:ResponseActor {name: '해양경찰청'}), (b:ResponseAction {name: '외부 구조지원 배치·운용'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '경찰청·중앙119·해군 특수요원·미 해군(본험 리처드함) 등 외부 지원 의사에도 제대로 배치·운용 안 함', effectiveness: 'Low', specialNote: '외부 지원 배제 의혹', evidence: '해경은 사고 발생 초기에 경찰청, 소방본부(중앙119), 해군 특수요원 및 미 해군(본험 리처드함) 등에서 구조 활동 지원 의사를 밝혔음에도 ... 이를 제대로 배치하거나 운용하지 않아 해경이 외부 지원을 배제하였다는 의혹이 있다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0041'};
MATCH (a:RiskFactor {name: '규제완화정책(선박 안전점검 기준 완화)'}), (b:Event {name: '세월호 침몰사고'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'High', mechanism: '안전점검 기준 완화로 구조적 결함 방치', reason: '구조적 원인', evidence: '① 정부가 ... 무분별한 규제완화정책을 펼쳤던 바, ... 선박의 안전점검 기준이 완화되어 선박의 복원성 등 구조적인 결함에 대한 사전관리가 없었다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0042'};
MATCH (a:RiskFactor {name: '선원법 시행령 개정(선장 조종지휘대행 허용)'}), (b:Event {name: '급격한 변침(맹골수도)'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'Med', mechanism: '경험 부족 항해사 운항·사전 점검 부재', reason: '구조적 원인', evidence: '② 선원법 시행령을 개정해 선장의 조종지휘대행을 허용함으로써 위험한 수로에서도 경험이 부족한 항해사가 운항할 수 있었고 ... 제대로 된 사전 현장 점검이 이루어 질 수 없었다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0043'};
MATCH (a:RiskFactor {name: '안전관리 민영화·외주화(한국해운조합·한국해양구조협회)'}), (b:Event {name: '세월호 침몰사고'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'High', mechanism: '부실점검·민관유착·정부 재난대응 역량 부족과 연관', reason: '구조적 원인', evidence: '③ 해상 안전점검을 선사들이 운영하는 한국해운조합에 담당케 하여 ... 구조작업은 민간 업체인 언딘의 주도로 진행되었고, 해경은 제대로 된 구조장비조차 갖추고 있지 못하여 ... 안전관리의 민영화·외주화는 부실점검과 이른바 ‘해피아’ ... 담합과 비리, 정부의 재난 대응 역량의 부족과 밀접하게 연관되는 일이었다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0044'};
MATCH (a:RiskFactor {name: '국가재난관리 시스템 부실(컨트롤타워 부재)'}), (b:Damage {name: '세월호 참사 인명피해'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {probability: 'High', reason: '초기 부실 대처와 이기적 행위로 사고를 참사로 만듦', mechanism: '재난대응 역량 부족', evidence: '사고를 참사로 만든 국가재난관리 시스템의 부실, 국가재난 컨트롤 타워 역할의 부재, 구조지휘부의 구성 문제와 지휘의 부실 ... 인명피해를 최소한으로 줄일 수 있는 초기에 부실한 대처와 이기적인 행위로 사고를 참사로 만들었던 것이다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0045'};
MATCH (a:Event {name: '언론 재난보도(세월호)'}), (b:Damage {name: '언론 오보·인권침해에 의한 2차 피해'}) MERGE (a)-[r:CAUSES]->(b) SET r += {scale: '2차 피해', mechanism: '오보·인권침해 보도 반복으로 피해자·유가족 2차 피해', evidence: '세월호 참사에 대한 언론보도에는 선정적 보도, 전원 구조 오보 ... 심각한 문제점이 발생하였다. ... 피해자들의 인권을 침해하는 보도를 반복했다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0046'};
MATCH (a:RiskFactor {name: '정부 언론·보도개입(방통위 방송통제)'}), (b:Damage {name: '언론 오보·인권침해에 의한 2차 피해'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {reason: '정부의 언론·보도개입으로 언론 자율성 침해', mechanism: '방송 통제', evidence: 'KBS 보도 개입, 방송통신위원회 ... 의 ‘방송 통제’, 방통위의 구조적 통제 등 정부의 언론 및 보도개입으로 언론의 자율성이 심각하게 침해되었다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0047'};
MATCH (a:ResponseActor {name: '대한변호사협회'}), (b:ResponseAction {name: '세월호 피해자 법률지원 활동'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', timing: '참사 발생 직후', effectiveness: 'High', role: '피해자 지원·진상규명', evidence: '대한변호사협회 ... 는 세월호 참사 발생 직후 어느 때 보다 발 빠르게 피해자 지원 및 진상조사 활동을 하였다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0048'};
MATCH (a:ResponseActor {name: '대한변호사협회'}), (b:ResponseAction {name: '진도 팽목항 변호사 파견·현장지원'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', timing: '참사 다음날', role: '현장 파견', evidence: '세월호 참사가 발생한 다음날 구조현장인 진도 팽목항에 소속 변호사를 파견했고 ... 대한변협이 진도에 현장지원활동으로 배의철 변호사를 파견하여 활동한 기간은 총 172일', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0049'};
MATCH (a:ResponseActor {name: '대한변호사협회'}), (b:ResponseAction {name: '4.16세월호참사 진상규명 및 안전사회 건설 특별법 제정 지원'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', effectiveness: 'High', role: '특별법 성안·제정 지원', specialNote: '국회 여야 합의 법안 통과에 결정적 기여', evidence: '유가족들의 의사를 반영한 4.16세월호참사 진상규명 및 안전사회 건설 등을 위한 특별법 ... 의 성안 및 제정 절차에서 헌신적인 지원활동을 하여, 국회로 하여금 여야 합의로 법안을 통과시키는데 결정적인 기여를 했다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0050'};
MATCH (a:ResponseActor {name: '국회 세월호 국정조사 특별위원회'}), (b:ResponseAction {name: '세월호 국정조사'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '청문회 증인채택 힘겨루기로 청문회 미개최', effectiveness: 'Med', specialNote: '22개 관련기관 기관보고로 내부자료 최초 공개는 의미 있음', evidence: '국회는 2014년 6월 2일부터 8월 30일까지 약 90일 동안 이례적으로 긴 세월호 국정조사를 진행하였다. ... 결국 청문회는 열지도 못한 채 활동을 마쳤다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0051'};
MATCH (a:ResponseActor {name: '검찰(세월호 수사)'}), (b:ResponseAction {name: '세월호 검찰 수사'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '구조적 비리가 참사에 미친 영향·책임 규명보다 직접 관련자 비리 나열에 그침, 규제완화·안전관리감독 상관관계·민영화 영향·국가재난관리 부실 등 근본원인 침묵', effectiveness: 'Med', evidence: '검찰 수사는 ... 단순히 직접 관련자의 비리 혐의를 나열하는데 그치고 있고 ... 근본적인 원인과 구조적인 배경과 원인에 대해서는 침묵함으로써 수사권한의 범위를 매우 피상적인 범위로 제한한 한계가 있다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0052'};
MATCH (a:ResponseActor {name: '감사원(세월호 감사)'}), (b:ResponseAction {name: '세월호 감사원 감사'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '감사 대상을 안전행정부·해양수산부·해양경찰청에 한정, 국방부·국정원·청와대 제외, 징계 하위직급 실무자에 집중, 규제완화·민영화 근본 검토 미실시', effectiveness: 'Med', evidence: '감사원의 감사는 그 대상을 안전행정부, 해양수산부, 해양경찰청에 한정하고 ... 국방부, 국정원 및 청와대를 제외하였다는 점 ... 하위직급의 실무자들에게 집중되어 있다는 점 ... 표면적인 현상을 지적하는 내용에 그쳤다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0053'};
MATCH (a:Event {name: '세월호 침몰사고'}), (b:Context {name: '맹골수도'}) MERGE (a)-[r:OCCURS_AT]->(b) SET r += {role: '사고 발생 위치·험난한 조류 항로', evidence: '전남 진도군 병풍도 북방 1.8마일(약 2.9킬로미터) 해상(맹골수도)을 지나던 중 ... 조류가 험난한 항로인 맹골수도를 통과할 때', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0054'};
MATCH (a:Damage {name: '세월호 참사 인명피해'}), (b:Context {name: '세월호 사고 경과 시각표(2014.4.16)'}) MERGE (a)-[r:QUANTIFIED_BY]->(b) SET r += {role: '사고 발생 일시·경과 시각', evidence: '오전 8시 25분경 ... 좌현으로 약 30도 가량 기울었고 ... 10시 17분경 108.1도까지 기울었고, 11시 18분 경 ... 바다 밑으로 침몰되었다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0055'};
MATCH (a:RiskFactor {name: '수난구호법(개정) 구조업체 선정 제도'}), (b:Event {name: '세월호 구조 실패'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'Med', mechanism: '구조 능력보다 비용 우선 구조업체 선정 유발', reason: '구조 실패 구조적 배경', evidence: '사고 책임선주는 사고초기에 직접 구난구조업체를 선정 ... 선주는 사고의 빠른 수습과 구조 활동 능력보다 좀 더 싼값의 구난업체를 찾으려 하게 되고, 이 과정에 해경 간부가 자신과 친분이 있는 업체를 소개시켜 주는 등의 부작용이 발생할 수밖에 없는 구조이다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0056'};
MATCH (a:Event {name: '정부·언론의 부실·부정확 대응'}), (b:Damage {name: '세월호 피해자·유가족 2차 피해'}) MERGE (a)-[r:CAUSES]->(b) SET r += {mechanism: '부실 대응·부정확 정보로 실종자 구조 실패 및 가족 2차 피해', evidence: '대한변협은 초기 지원활동을 통해 정부의 부실한 대응과 혼선, 언론의 부정확한 정보제공 및 이로 인한 실종자 구조의 실패, 피해 가족들에 대한 2차 피해 등을 확인하였고', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0057'};
MATCH (a:Event {name: '세월호 침몰사고'}), (b:Event {name: '세월호 승객 선내 고립'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {mechanism: '선체 침몰로 다수 탑승자 선내 갇힘', directCause: '급속 침수', probability: 'High', specialNote: '구조 지연으로 생존 가능성 소멸', evidence: '세월호가 침몰하는 광경을 지켜보면서 배 안에 남아 있던 3백여 생명이 죽어간 사실을 알고', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0058'};
MATCH (a:Damage {name: '세월호 참사 인명피해'}), (b:Damage {name: '국민·피해가족 정신적 고통'}) MERGE (a)-[r:CAUSES]->(b) SET r += {mechanism: '참사 충격으로 국민·피해가족 정신적 외상', specialNote: '2차적 심리피해', evidence: '한동안 헤어나기 어려운 고통에 빠졌다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0059'};
MATCH (a:Event {name: '세월호 승객 선내 고립'}), (b:Event {name: '세월호 희생자 수습(시신 수습)'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {mechanism: '사망자·시신 수습 단계로 전환', timing: '2014-04-19 첫 선내 진입 이후', specialNote: '생존 구조에서 시신 수습으로 국면 전환', evidence: '4월 19일 민관군 합동구조팀이 첫 선내 진입에 성공하여 시신을 수습한 이후 희생자 수습은 급속히 늘어나기 시작하였다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0060'};
MATCH (a:ResponseActor {name: '민관군 합동구조팀'}), (b:ResponseAction {name: '세월호 선내 진입 및 시신 수습'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', timing: '2014-04-19', effectiveness: 'Med', specialNote: '첫 선내 진입 성공', evidence: '4월 19일 민관군 합동구조팀이 첫 선내 진입에 성공하여 시신을 수습한 이후', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0061'};
MATCH (a:Event {name: '세월호 희생자 수습(시신 수습)'}), (b:Event {name: '안산 희생자 장례절차 문제'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {mechanism: '안산에서 희생자 장례절차 문제 대두', timing: '수습 본격화 후', specialNote: '수습→장례 문제 연쇄', evidence: '안산에서 이루어지는 장례절차에 관한 문제가 대두되었고, 안산에서 장례와 관련된 문제가 부각되어 지원 요청을 받은 후', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0062'};
MATCH (a:ResponseActor {name: '대한변호사협회'}), (b:ResponseAction {name: '세월호 공익법률지원단 운영'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', actionType: 'recruitment', timing: '대국민성명 발표 후 1주일 내', scale: '514명 지원', specialNote: '과거 유례없이 많은 회원 지원', evidence: '공익법률지원단을 모집한지 1주일 만에 총 514명의, 과거 유례없이 많은 회원들이 지원한 가운데 세월호 특위를 출범하고', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0063'};
MATCH (a:ResponseActor {name: '대한변호사협회'}), (b:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', timing: '공익법률지원단 모집 후', role: '조직 구성', evidence: '세월호 특위를 출범하고, 전체적인 사업을 총괄하는 총괄지원팀 및 각 쟁점별 지원 및 대응을 위한 현장대응지원단, 진상조사단, 법제도개선단, 재판지원팀, 백서제작팀, 특별법제정팀, 법률상담/지원단, 언론모니터링팀, 상담매뉴얼작성팀으로 업무를 재분장', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0064'};
MATCH (a:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}), (b:ResponseActor {name: '대한변호사협회'}) MERGE (a)-[r:BELONGS_TO]->(b) SET r += {role: '산하 조직', evidence: '이렇게 구성된 세월호 특위는 ... 활동을 전개해왔다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0065'};
MATCH (a:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}), (b:ResponseAction {name: '언론 정정보도 요청 및 허위사실 유포 대응'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', actionType: 'media_response', specialNote: '허위사실·악성댓글 대응', evidence: '언론사에 대한 정정보도 요청, 방송통신위원회에 대한 민원신청, 희생자 허위사진 유포 방지, 허위사실을 유포한 인터넷 블로그와 악성댓글에 대한 고소 고발 등', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0066'};
MATCH (a:ResponseActor {name: '대한변호사협회'}), (b:ResponseAction {name: '배의철 변호사 진도 현장지원 파견'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', actionType: 'field_deployment', scale: '총 172일', timing: '2014-04-18 ~ 11-11', specialNote: '참사 210일째 수중수색 중단선언일까지', evidence: '배의철 변호사를 파견하여 활동한 기간은 총 172일 ... 1차진도 파견은 ... 4차 파견은 10월 23일부터 11월 11일까지 총 20일로 나누어진다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0067'};
MATCH (a:ResponseActor {name: '대한변협 현장조사단(대표단)'}), (b:ResponseAction {name: '대한변협 1차 진도 파견(현장대응 파악)'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', actionType: 'field_assessment', timing: '2014-04-18 저녁(사건 발생 3일째)', effectiveness: 'Low', reason: '당시 피해자 불신으로 변호사 불필요 답변', evidence: '1차 파견은 사건 발생 3일째인 4월 18일 저녁, 황필규 변호사와 배의철 변호사를 변협 대표단 자격으로 진도로 파견하였다 ... ① 상황 및 현장대응 파악, ② 기록, ③ 향후 신뢰를 얻기 위한 계속적 활동에 집중', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0068'};
MATCH (a:Population {name: '세월호 피해자 가족'}), (b:Context {name: '팽목항'}) MERGE (a)-[r:LOCATED_IN]->(b) SET r += {role: '대기·항의 장소', evidence: '피해자의 생존 가능성이 있다는 일말의 희망을 가지고 팽목항에서 밤을 지새우며 정부에 구조를 촉구하며 거센 항의를 이어나가고 있었다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0069'};
MATCH (a:Context {name: '에어포켓 생존 가능성(피해자 희망)'}), (b:Event {name: '세월호 승객 선내 고립'}) MERGE (a)-[r:UNDER_CONDITION]->(b) SET r += {role: '당시 피해자 인식 조건', timing: '1차 파견 당시', evidence: '이른바 세월호 내에 ‘에어포켓’이 형성되어 피해자의 생존 가능성이 있다는 일말의 희망을 가지고', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0070'};
MATCH (a:ResponseActor {name: '경찰병력(청와대 진출 저지)'}), (b:ResponseAction {name: '피해자 가족 청와대 항의방문 저지'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', actionType: 'crowd_control', specialNote: '대한변협이 법적근거 제시·불법 공권력 행사 지적했으나 물러서지 않음', evidence: '300여명의 경찰들이 학부모, 가족들을 막아서며 이들의 청와대 진출과 버스 탑승을 저지했다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0071'};
MATCH (a:Event {name: '세월호 희생자 수습(시신 수습)'}), (b:Event {name: '세월호 실종자 수중수색'}) MERGE (a)-[r:CONCURRENT_WITH]->(b) SET r += {timing: '2014-04-25 무렵', specialNote: '생존 구조에서 실종자 수색 국면으로 전환', evidence: '2차 진도 파견은 ... 4월 25일 진도의 상황은 초기와는 달리 생존의 가능성을 염두에 둔 구조가 아니라 실종자의 발견과 수습을 조속히 마칠 것을 요구하는 ‘수색’에 대한 항의가 이어지고 있었다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0072'};
MATCH (a:ResponseActor {name: '언딘마린인더스트리'}), (b:Event {name: '세월호 실종자 수중수색'}) MERGE (a)-[r:FAILS]->(b) SET r += {phase: 'response', reason: '민간의 구조를 막는 혼선 야기, 실종자 가족 불신', effectiveness: 'Low', specialNote: '해경·해군이 민간 구조 막는 원인으로 지목됨', evidence: '실종자 가족들은 해경, 해군이 민간의 구조를 막고 있고 그 원인으로 정부와 계약한 언딘마린인더스트리(이하 “언딘”)의 존재를 지적하며 혼선을 해결해줄 것을 요구하였다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0073'};
MATCH (a:ResponseActor {name: '알파잠수공업(다이빙벨)'}), (b:ResponseAction {name: '다이빙벨 사고해역 투입'}) MERGE (a)-[r:FAILS]->(b) SET r += {phase: 'response', reason: '다이빙벨 사고해역 투입 시도했으나 접안 실패', effectiveness: 'Low', timing: '2차 파견 당시', evidence: '‘다이빙벨’(알파잠수공업)을 가족들의 요구로 사고해역에 투입하고자 하였으나 접안에 실패하자 실종자 가족들은 거세게 항의', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0074'};
MATCH (a:ResponseActor {name: '대한변호사협회'}), (b:ResponseAction {name: '대한변협-세월호 가족대책위 지원협약 체결'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', actionType: 'agreement', timing: '2014-05-16', effectiveness: 'High', specialNote: '신뢰 형성 후 정식 법률대리인 자격 확보', evidence: '5월 16일 대한변협과 세월호 가족대책위는 지원협약 체결식 및 기자회견을 개최해 본격적으로 세월호 가족들에 대한 지원을 시작', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0075'};
MATCH (a:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}), (b:ResponseAction {name: '대한변협 3차 진도 파견(146일)'}) MERGE (a)-[r:FAILS]->(b) SET r += {phase: 'response', reason: '실종자 가족과 유가족의 소통 부재, 의견 대립, 담당변호사 악의적 소문 확산', effectiveness: 'Low', specialNote: '극심한 갈등으로 3차 파견 종료·파견 해제 결정', evidence: '실종자 가족과 유가족의 소통 부재로 인하여 의견이 대립되는 경우도 빈번하였고, 심지어 실종자 가족 담당변호사에 대한 악의적 소문이 퍼지기도 하였다. 이에 변협은 ... 변호사 진도 파견을 해제하기로 결정하고 146일에 달하는 진도 3차 파견을 종료', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0076'};
MATCH (a:Event {name: '진도군민과 실종자 가족 갈등'}), (b:Damage {name: '실종자 가족 심리적 고통'}) MERGE (a)-[r:TRIGGERS_SECONDARY]->(b) SET r += {mechanism: '복지지원 중단 보도와 갈등으로 실종자 가족 불안 심화', specialNote: '사회적 2차 피해', evidence: '진도군민들은 실종자 가족에게 진도체육관에서 이전해 줄 것을 요청하여 ... 갈등이 심화되었고, 실종자 가족 복지지원이 중단된다는 내용이 언론을 통해 보도되어 실종자 가족은 불안감을 감추지 못했다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0077'};
MATCH (a:RiskFactor {name: '부정확한 언론 보도(재난보도)'}), (b:Damage {name: '실종자 가족 심리적 고통'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {mechanism: '오보·미확인 보도로 피해자 정신적 고통 가중', probability: 'High', evidence: '사실여부가 명확히 확인되지 않은 기자들의 보도로 인해 실종자 가족의 정신적 고통과 상처 또한 심화되고 있어서 ‘피해자 가족의 고통에 대한 배려’ 라는 재난보도의 대원칙을 준수해 줄 것을 언론에 강력히 촉구', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0078'};
MATCH (a:ResponseActor {name: '대한변호사협회'}), (b:ResponseAction {name: '수중수색 지속 결정 공표(오보 차단)'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', actionType: 'media_correction', timing: '2014-10-27', effectiveness: 'High', specialNote: '오보 확산 차단', evidence: '10월 27일 기자회견을 열어 ... 인양이 아니라 ‘수중수색을 지속’하기로 결정되었다는 바를 공표하여 ... 일부 오보의 확산을 차단하였다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0079'};
MATCH (a:ResponseActor {name: '민관군 합동구조팀'}), (b:ResponseAction {name: '295번째 희생자 발견'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', actionType: 'search_recovery', timing: '2014-10-28(사고 197일째)', effectiveness: 'Med', evidence: '10월 28일 세월호 사고 197일만에 수색팀이 295번째 희생자를 발견했다. 이러한 소식에도 실종자 가족들은 기쁨보다 부실수색 가능성에 대한 분노를 표출', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0080'};
MATCH (a:Event {name: '세월호 실종자 수중수색'}), (b:Damage {name: '잠수사 생명·안전 위협'}) MERGE (a)-[r:TRIGGERS_SECONDARY]->(b) SET r += {mechanism: '수색여건 악화와 잠수사 안전 위협', probability: 'High', specialNote: '수중수색 지속이 잠수사 생명·안전 위협', evidence: '문제는 갈수록 악화되는 수색여건과 잠수사의 안전이었다. 수중수색을 지속하는 선택이 ... 잠수사들에게 고통을 주고 생명과 안전에 위협이 되는 반면', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0081'};
MATCH (a:Population {name: '실종자 가족'}), (b:ResponseAction {name: '수중수색 중단 결정'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', actionType: 'decision', timing: '2014-11-11', specialNote: '잠수사 안전과 가족 고통 사이 선택', evidence: '11월 11일 진도체육관에서 실종자 가족들의 수색중단 선언으로 세월호 특위의 총 172일에 걸친 진도에서의 네 차례 상주 파견 현장지원 활동도 마무리되었다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0082'};
MATCH (a:ResponseAction {name: '수중수색 중단 결정'}), (b:Event {name: '세월호 실종자 수중수색'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {reason: '잠수사 안전 위협 및 수색여건 악화', specialNote: '수색 중단은 가족에게 평생 고통', evidence: '수색을 중단하는 선택은 가족들에게 평생 지울 수 없는 고통이 될 수밖에 없었다. 11월 11일 ... 수색중단 선언', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0083'};
MATCH (a:ResponseAction {name: '수중수색 중단 결정'}), (b:Damage {name: '세월호 미수습 실종자'}) MERGE (a)-[r:CAUSES]->(b) SET r += {specialNote: '남은 실종자 미수습', evidence: '세월호의 남은 실종자 9명이 모두 가족의 품으로 돌아갈 수 있기를 간절히 바란다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0084'};
MATCH (a:ResponseActor {name: '범정부사고대책본부'}), (b:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}) MERGE (a)-[r:COORDINATES_WITH]->(b) SET r += {role: '회의·브리핑 참석 및 요구사항 전달', specialNote: '실종자 가족 법률대리인이 회의·브리핑 참석', evidence: '범정부사고대책본부(범대본, 본부장 해양수산부 이주영 장관) 회의, 해경 수색브리핑에 실종자 가족 법률대리인 자격으로 참석하여', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0085'};
MATCH (a:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}), (b:ResponseAction {name: '실종자 가족-정부 부처 가교·중재 활동'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', actionType: 'mediation', role: '가교·중재', effectiveness: 'Med', evidence: '실종자 가족-해양수산부-해경-정부 부처 상호간의 가교 역할을 통해 논의사항을 조율하여 결정, 집행되도록 하는 중재·지원 활동도 하였다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0086'};
MATCH (a:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}), (b:ResponseAction {name: '세월호 CCTV 증거보전 활동'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', actionType: 'evidence_preservation', specialNote: 'CCTV 증거보전', evidence: '세월호 선체 내 세월호 CCTV 증거보전 활동(부식방지조치, 실물보전, 재판진행 등)을 하고', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0087'};
MATCH (a:ResponseActor {name: '국회 세월호 국정조사 특별위원회'}), (b:ResponseAction {name: '국회 국정조사 청문회 개최'}) MERGE (a)-[r:FAILS]->(b) SET r += {phase: 'response', reason: '활동 기간이 청문회도 열리지 못한 채 만료', effectiveness: 'Low', specialNote: '여야 국회의원 실종자 가족 지원활동도 마무리', evidence: '국회 국조특위의 활동 기간이 청문회도 열리지 못한 채 만료되면서 여야 국회의원들의 국조특위를 통한 실종자 가족 지원활동도 마무리되는 안타까운 상황을 맞이', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0088'};
MATCH (a:ResponseActor {name: '대한변호사협회'}), (b:ResponseAction {name: '대한변협 현장조사단 파견 결정'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', actionType: 'field_deployment_decision', timing: '2014-04-16(참사 다음날)', evidence: '4월 16일 세월호 참사 발생 다음날 대한변협 협회장은 현장조사단 파견 결정을 한 이래', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0089'};
MATCH (a:ResponseActor {name: '세월호 가족대책위'}), (b:ResponseActor {name: '대한변호사협회'}) MERGE (a)-[r:COORDINATES_WITH]->(b) SET r += {role: '법률대리인-피해가족 협력 체계', timing: '2014-05-16 협약 이후', evidence: '5월 16일 협약식을 체결하고 대한변협은 가족대책위의 정식 법률대리인으로서 공식적인 활동을 개시', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0090'};
MATCH (a:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}), (b:ResponseAction {name: '세월호 가족대책위 조직 운영 자문'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', actionType: 'organization_support', effectiveness: 'Med', specialNote: '가족대책위 조직 운영·활동 밀착 자문', evidence: '현장지원활동의 주된 내용은 세월호 가족대책위 조직체계 확정 및 집행부 선거, 구성 ... 사단법인화 ... 등 피해가족 조직 운영 및 활동을 자문하였다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0091'};
MATCH (a:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}), (b:ResponseAction {name: '특위 활동-현장지원활동 연계 시스템 구축'}) MERGE (a)-[r:FAILS]->(b) SET r += {phase: 'recovery', reason: '전체 특위 활동과 현장지원활동의 유기적 연계 시스템 미구축, 법률상담·협력체계 미구축', effectiveness: 'Low', specialNote: '현장대응 활동 연계성 설정 미비점', evidence: '전체 특위 활동과 현장지원활동이 유기적인 연계를 가지고 이루어지는 시스템을 구축하지 못한 점이 아쉽다 ... 10월부터 현장활동 변호사들에 대한 대한변협 차원의 지원은 축소', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0092'};
MATCH (a:Resilience {name: '현장대응활동계획 예측가능 시스템'}), (b:ResponseAction {name: '특위 활동-현장지원활동 연계 시스템 구축'}) MERGE (a)-[r:OFFSETS]->(b) SET r += {reason: '현장대응 연계성 미비 보완 필요성 대두', effectiveness: 'Med', specialNote: '향후 과제로 제시', evidence: '장기적 관점에서 피해가족 현장대응활동계획이 예측 가능한 큰 틀 내에서 수립되고 집행되는 시스템을 구축할 필요성이 대두되었다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0093'};
MATCH (a:Event {name: '세월호 침몰사고'}), (b:Event {name: '세월호 진상규명 제도 논의'}) MERGE (a)-[r:TRIGGERS_SECONDARY]->(b) SET r += {mechanism: '참사 원인규명·재발방지를 위한 제도적 대응 논의 촉발', specialNote: '특검·국정조사·특별법 3개 방안 논의', evidence: '근본적인 해결을 위한 대처 방안을 고민 ... ① 특별검사제도 활용, ② 국회 국정조사권 발동, ③ 관련 특별법 제정 등 3가지 방안이 집중 논의', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0094'};
MATCH (a:ResponseActor {name: '대한변호사협회'}), (b:ResponseAction {name: '세월호 특별법 제정 추진'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', actionType: 'policy_advocacy', effectiveness: 'Med', reason: '특검·국정조사 한계 분석 후 특별법 제정 역설', evidence: '대한변협은 각 제도를 비교, 분석한 뒤 특별법 제정으로 나아가야 함을 역설하였다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0095'};
MATCH (a:Other {name: '특별검사제도'}), (b:Event {name: '세월호 진상규명 제도 논의'}) MERGE (a)-[r:FAILS]->(b) SET r += {phase: 'recovery', reason: '짧은 수사기간, 예방·사후대처 과제 풀기 미흡', effectiveness: 'Low', evidence: '특별검사제도는 ... 짧은 수사기간(통상 60일 이내), 주요 수사 인력의 검찰로부터의 파견 등으로 충분한 수사가 어렵다 ... 세월호 참사의 과제를 풀기에는 미흡한 것으로 평가', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0096'};
MATCH (a:Resilience {name: '진상조사위원회 구성 특별법'}), (b:Damage {name: '세월호 참사 인명피해'}) MERGE (a)-[r:OFFSETS]->(b) SET r += {reason: '세월호 참사로 드러난 제반 문제 해결의 최선 대안', effectiveness: 'High', evidence: '전문가의 효율적이고 심도 있는 진상규명과 안전사회 대책 마련이 가능한 진상조사위원회를 구성하는 특별법의 제정이야말로 ... 가장 좋은 대안이라는 결론', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0097'};
MATCH (a:ResponseActor {name: '세월호 특위 특별법 제정팀'}), (b:ResponseAction {name: '세월호 특별법 초안 마련'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', actionType: 'legislation', timing: '2014-05-19경', effectiveness: 'Med', evidence: '법제도개선단 산하에 ‘특별법 제정팀’을 두고 ... 초기 세월호 특위안(김희수, 박종운)과 민변 초안을 통합한 변협안을 마련하고, 이를 토대로 피해자 단체 특별법 제정안을 만들어 의원입법하는 것을 목표', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0098'};
MATCH (a:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}), (b:ResponseAction {name: '세월호 특별법 제정 추진'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', actionType: 'public_hearing', timing: '2014-07-02', location: '국회', evidence: '7월 2일 세월호 특위가 관여한 “4․16 참사 진실규명 및 안전사회 건설 등을 위한 특별법 공청회”가 국회에서 개최', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0099'};
MATCH (a:ResponseActor {name: '4.16 특별법 청원 국민대표단'}), (b:ResponseAction {name: '특별법 제정 촉구 입법청원(서명지 제출)'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', actionType: 'legislative_petition', timing: '2014-07-15', scale: '350여 만 명 서명', effectiveness: 'Med', evidence: '7월 15일에는 특별법 제정을 촉구하는 3,501,266명의 서명지가 국회에 제출', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0100'};
MATCH (a:ResponseActor {name: '조속입법 TF'}), (b:ResponseAction {name: '여야 특별법 협상'}) MERGE (a)-[r:FAILS]->(b) SET r += {phase: 'recovery', reason: '조속입법TF 해체 후 여야 협상 중단, 주요 쟁점 미합의', effectiveness: 'Low', specialNote: '정책적 결단 필요 사항 미해결', evidence: '당시 조속입법TF가 해체된 후 여야 간 협상이 중단되었는데, 합의되지 못한 주요 쟁점에 대해서는 정책적인 결단이 필요한 사항', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0101'};
MATCH (a:ResponseActor {name: '세월호 가족대책위'}), (b:ResponseAction {name: '세월호 가족대책위 협상 참여(3자협의체)'}) MERGE (a)-[r:FAILS]->(b) SET r += {phase: 'recovery', reason: '여당측 위원 반대로 가족대책위 협상 참여 무산, 밀실 야합 우려', effectiveness: 'Low', evidence: '3자협의체를 제안했던 세월호 가족대책위는 여당과 야당 간에 밀실 야합을 우려하며 반발 ... 세월호 가족대책위의 참여에는 여당측 위원들이 반대', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0102'};
MATCH (a:ResponseAction {name: '세월호 가족대책위 협상 참여(3자협의체)'}), (b:Event {name: '유가족 국회 연좌·단식 농성'}) MERGE (a)-[r:TRIGGERS_SECONDARY]->(b) SET r += {mechanism: '협상 참여 좌절로 유가족 연좌·단식 농성 촉발', timing: '2014-07-15 무렵', evidence: '이 소식을 전해들은 유가족들은 국회 본청 앞에서 연좌농성을 시작 ... 변호사들은 유가족들의 연좌 단식 농성에 호응하여 릴레이 단식에 참여', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0103'};
MATCH (a:ResponseActor {name: '대한변협 특별법제정팀·현장대응지원단'}), (b:ResponseAction {name: '변호사 릴레이 단식 참여'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', actionType: 'solidarity_action', timing: '2014-07-15', specialNote: '유가족 농성 호응', evidence: '대한변협 특별법제정팀, 현장대응지원단 소속 변호사들은 유가족들의 연좌 단식 농성에 호응하여 릴레이 단식에 참여', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0104'};
MATCH (a:ResponseActor {name: '대한변호사협회'}), (b:ResponseAction {name: '4·16 특별법 제정 촉구 성명서 발표'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', actionType: 'declaration', timing: '2014-07-24(참사 100일)', scale: '1043인', effectiveness: 'Med', specialNote: '역사상 최초 1000명 넘는 변호사 연대', evidence: '7월24일 ... 1,000명이 넘는 변호사들이 연대한 ‘4·16 특별법 제정을 촉구하는 변호사 1043인 선언’을 발표하여 ... ‘조사권의 강화’를 요구', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0105'};
MATCH (a:ResponseAction {name: '여야 특별법 협상'}), (b:Event {name: '세월호 진상규명 제도 논의'}) MERGE (a)-[r:FAILS]->(b) SET r += {phase: 'recovery', reason: '특검 추천권 부여 형식·주체 논쟁으로 협상 결렬', timing: '2014-07-27', effectiveness: 'Low', evidence: '7월 27일 협상이 재개되었으나 이번에는 특검 추천권을 누구에게 어떤 형식으로 줄 것인가 여부를 놓고 논쟁하다가 협상이 결렬', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0106'};
MATCH (a:Other {name: '여야 원내대표 합의사항(8.7)'}), (b:Event {name: '유가족 8.7 합의 반발'}) MERGE (a)-[r:TRIGGERS_SECONDARY]->(b) SET r += {mechanism: '합의 보도에 유가족 야합으로 인식, 격분', timing: '2014-08-07', evidence: '8월 7일, 여야 원내대표 합의사항이 보도되자, 유가족들은 야합이라며 격분하게 되었고, 세월호 특위는 총괄지원팀 긴급회의를 통해', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0107'};
MATCH (a:Event {name: '세월호 침몰사고'}), (b:Context {name: '2014-04-16'}) MERGE (a)-[r:OCCURS_AT]->(b) SET r += {role: '발생 일시', evidence: '2014년 4월 16일, 세월호 참사가 발생하자', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0108'};
MATCH (a:ResponseActor {name: '세월호 가족대책위'}), (b:ResponseActor {name: '일반인희생자유가족대책위'}) MERGE (a)-[r:COORDINATES_WITH]->(b) SET r += {role: '통합 가능성 모색 대상', specialNote: '관계 개선·통합 자문', evidence: '세월호 가족대책위와 일반인희생자유가족대책위의 관계 개선 및 통합 가능성 모색 (인천소재 일반인희생자유가족대책위 사무실 10여 차례 방문 포함)', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0109'};
MATCH (a:Event {name: '세월호 침몰사고'}), (b:Event {name: '세월호 급속 침수·전복 진행'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {mechanism: '초반 더디게 진행되던 침수가 후반에 급속도로 진행', timing: '사고 발생 1시간 경과(오전 10시) 이후 선내 탈출 사실상 불가능', probability: 'High', evidence: '세월호의 침몰이 초반에는 더디게 진행되었지만 후반에는 급속도로 빠르게 진행된 사실... 사고 발생시각으로부터 1시간 이상 경과한 오전 10시 이후로는 사실상 선내에서 탈출하는 것이 불가능하다고 할 수 있을 정도로 급속하게 침몰이 진행되는 광경', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0110'};
MATCH (a:Event {name: '세월호 급속 침수·전복 진행'}), (b:Damage {name: '세월호 참사 인명피해'}) MERGE (a)-[r:CAUSES]->(b) SET r += {directCause: '오전 10시 이후 선내 탈출 불가능', timing: '사고 발생 1시간 경과 이후', probability: 'High', evidence: '사고 발생시각으로부터 1시간 이상 경과한 오전 10시 이후로는 사실상 선내에서 탈출하는 것이 불가능하다고 할 수 있을 정도로 급속하게 침몰이 진행', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0111'};
MATCH (a:ResponseActor {name: '해양경찰청'}), (b:ResponseAction {name: '세월호 현장 인명구조'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '선원을 우선 구조하고 승객 구조에는 소극적', effectiveness: 'Low', specialNote: '소극적인 구조 활동', evidence: '해경이 선원을 우선 구조하고, 123정 정장이 퇴선방송을 하지 않은 사실... 등의 소극적인 구조 활동이다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0112'};
MATCH (a:ResponseActor {name: '123정 정장'}), (b:ResponseAction {name: '퇴선방송'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '퇴선방송을 하지 않음', effectiveness: 'Low', directCause: '퇴선조치 부재', evidence: '123정 정장이 퇴선방송을 하지 않은 사실', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0113'};
MATCH (a:ResponseActor {name: '해양경찰청'}), (b:ResponseAction {name: '외부 구조 지원 수용'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '경찰청, 중앙119, 일본·미국 문화재청의 지원요청 거절', effectiveness: 'Low', specialNote: '외부 지원 거절', evidence: '경찰청, 중앙119, 일본 미국 문화재청의 지원요청도 거절한 사실 등의 소극적인 구조 활동이다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0114'};
MATCH (a:ResponseActor {name: '세월호 선원'}), (b:ResponseAction {name: '세월호 현장 인명구조'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '123정에 의해 구출된 이후 어떠한 구조활동도 하지 않음', effectiveness: 'Low', directCause: '승객 구조 부작위', evidence: '당시 대다수의 선원들이 아무런 조치도 취하지 않은 상태에서 123정에 의해 구출된 이후, 어떠한 구조활동도 하지 않은 사실이 위 동영상들을 통해 명확하게 밝혀졌다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0115'};
MATCH (a:ResponseActor {name: '진도VTS'}), (b:ResponseAction {name: '세월호 해상교통관제'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '관제소홀', effectiveness: 'Low', specialNote: '증거보전신청으로 관제소홀 사실 확인', evidence: '진도VTS와 제주VTS를 대상으로 한 증거보전신청을 통하여, 진도VTS의 관제소홀 사실을 파악할 수 있었고', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0116'};
MATCH (a:ResponseActor {name: '주변 어선 및 어업지도선'}), (b:ResponseAction {name: '세월호 현장 인명구조'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '구조할 승객이 없어 속수무책으로 침몰하는 세월호를 바라만 봄', effectiveness: 'Low', timing: '선내 탈출 불가 시점', evidence: '대부분의 주위 어선들은 구조할 승객이 없어 속수무책으로 침몰하는 세월호를 바라만 보고 있는 상황이었던 것이 201호에서 촬영된 동영상을 통해 확인되었다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0117'};
MATCH (a:RiskFactor {name: '세월호 운항 보고체계'}), (b:Event {name: '세월호 침몰사고'}) MERGE (a)-[r:PRECONDITIONS]->(b) SET r += {role: '운영 특이성·의혹', specialNote: '실소유주 의혹 야기', reason: '내항여객선 운항관리규정 분석 결과 세월호만 국정원 보고체계 보유', evidence: '내항여객선의 운항관리규정을 모두 분석한 결과, 해양사고 발생 시 국가정보원에 대한 별도의 보고체계를 갖추고 있었던 여객선은 세월호가 유일한 것으로 드러났다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0118'};
MATCH (a:Event {name: '세월호 침몰사고'}), (b:Context {name: '사고 당일 08:24 (이상징후 없음)'}) MERGE (a)-[r:OCCURS_AT]->(b) SET r += {role: '사고 직전 정상 상태 시점', timing: '사고 당일 08:24', evidence: '세월호 디지털카메라를 통해 얻은 성과는 사고 당일 08:24경 까지는 세월호에 별다른 이상 징후가 없었다는 점을 확인하였던 것이다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0119'};
MATCH (a:Event {name: '세월호 침몰사고'}), (b:Context {name: '세월호 급변침 29초 항적'}) MERGE (a)-[r:OCCURS_AT]->(b) SET r += {role: '사고 직전 급변침 항적', specialNote: 'AIS에 기록되지 않은 29초 항적', timing: '사고 직전', evidence: '세월호 참사 6개월 만인 2014년 10월경 세월호 가족대책위 측은 세월호가 급변침한 29초간의 항적을 찾아낼 수 있었다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0120'};
MATCH (a:ManmadeHazard {name: '언론 보도'}), (b:Damage {name: '세월호 피해자·유가족 2차 피해'}) MERGE (a)-[r:TRIGGERS]->(b) SET r += {mechanism: '사실 확대·재생산', scale: '전국', spreadRisk: 'High', specialNote: '제2의 피해 양산', evidence: '단순히 사실을 전달하는 수준을 벗어나 사실을 확대・재생산하고, 결국은 제2의 피해를 양산하기도 한다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0121'};
MATCH (a:ManmadeHazard {name: '언론 보도'}), (b:Event {name: '세월호 보도 오보·왜곡·편파보도'}) MERGE (a)-[r:TRIGGERS]->(b) SET r += {mechanism: '비판적 시각 없는 정부 발표 받아쓰기, 누락·축소·오보', specialNote: '정확성·신속성 문제 발생', directCause: '검증 부재', evidence: '초기 침몰 및 구조에 대한 언론의 집중 보도에도 누락, 축소, 오보로 정확성과 신속성에 문제가 발생하였다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0122'};
MATCH (a:Event {name: '세월호 보도 오보·왜곡·편파보도'}), (b:Damage {name: '세월호 피해자·유가족 2차 피해'}) MERGE (a)-[r:CAUSES]->(b) SET r += {directCause: '유가족 폄훼 보도·편파보도·취재태도', mechanism: '감정선 자극·추측 유발 보도', evidence: '유가족을 폄훼하는 보도에서부터, 편파보도, 비보도 등 그 형태가 다양하게 나타났다... 피해자 가족을 \'깡패\'라고 하는 등의 KBS, MBC 등 언론사 고위 간부들의 부적절한 발언', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0123'};
MATCH (a:ManmadeHazard {name: '인터넷·SNS 악성 콘텐츠'}), (b:Damage {name: '세월호 피해자·유가족 2차 피해'}) MERGE (a)-[r:TRIGGERS]->(b) SET r += {mechanism: '조직적 확산 유포, 허위사실 유포', scale: '전국', spreadRisk: 'High', timing: '2014-08-23 전후', evidence: '이즈음 각종 악성 댓글들이 조직적으로 확산 유포되었다... 유가족에 대한 \'세월호가 로또다\', \'적당히 해라 거지들아\' 등의 셀 수 없이 많은 막말 댓글, 유가족이 엄청난 혜택을 받는 것과 같은 허위 사실 유포', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0124'};
MATCH (a:ManmadeHazard {name: '문화일보 광고(2014-07-28)'}), (b:Damage {name: '세월호 특별법 여론 왜곡'}) MERGE (a)-[r:TRIGGERS]->(b) SET r += {mechanism: '13가지 특혜 항목으로 특별법 호도', specialNote: '많은 파문 유발', spreadRisk: 'Med', evidence: '2014년 7월 28일 자 문화일보 31면에 실린 광고에서 진상규명을 위한 세월호 특별법이 마치 반정부 선동을 하는 것처럼 호도하였기 때문에 많은 파문이 일었다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0125'};
MATCH (a:Event {name: '세월호 가족대책위 임원-대리운전기사 폭행사건'}), (b:Damage {name: '세월호 가족대책위 위원장단 사퇴'}) MERGE (a)-[r:CAUSES]->(b) SET r += {directCause: '폭행사건 언론 보도', mechanism: '위원장단 사퇴로 이어짐', evidence: '9월 17일, 세월호 가족대책위 임원 일부와 대리운전기사 간 폭행사건이 언론에 보도되어 세월호 가족대책위 위원장단 9명 전원이 사퇴하였다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0126'};
MATCH (a:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}), (b:ResponseAction {name: '세월호 특위 진상조사단 진상조사 활동'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', role: '진상규명 활동', effectiveness: 'Med', evidence: '세월호 특위는 당초 진상조사 소위원회가... \'진상조사단\'이라는 이름으로 운영하였다. 진상조사단의 활동은 시기에 따라 크게 5단계로 구분할 수 있다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0127'};
MATCH (a:ResponseActor {name: '세월호 특위 특별법 제정팀'}), (b:ResponseAction {name: '세월호 특별법 제정 추진'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', role: '입법 활동', effectiveness: 'High', specialNote: '입법 청원안 상당 부분 현실 법률 반영', evidence: '특별법제정팀 팀원들이 상당 기간 국회에 상주하면서 여야 간의 협상 내용을 모니터링하면서 대안 마련, 조문화 작업 등을 전개하여 온 결과 입법 청원안은 상당 부분 현실 법률에 반영되는 성과를 거두었다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0128'};
MATCH (a:ResponseAction {name: '세월호 특별법 제정 추진'}), (b:Resilience {name: '재난 예방·사후대책 모니터링 시스템'}) MERGE (a)-[r:BUILDS]->(b) SET r += {role: '재난 예방·사후대책 제도화', effectiveness: 'High', evidence: '재해, 재난의 예방 및 사후 대책(피해자 지원책 포함) 마련, 관계 국가기관 등에 의한 실행, 모니터링의 시스템을 갖추고 있다는 점에서 강점을 가지고 있다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0129'};
MATCH (a:ResponseAction {name: '4·16 진상규명 특별법'}), (b:Event {name: '세월호 침몰사고'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {role: '진상조사권 강화', effectiveness: 'High', timing: '참사 후 205일', evidence: '세월호 참사 발생 205일째인 11월 7일(금) 마침내 진상규명 특별법이 국회 본회의를 통과하고, 2015년 1월 1일부터 시행되었다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0130'};
MATCH (a:ResponseAction {name: '4·16세월호참사 피해구제 및 지원 등을 위한 특별법'}), (b:Damage {name: '세월호 참사 인명피해'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {role: '피해자·피해지역 지원·배보상', effectiveness: 'High', timing: '참사 후 265일', evidence: '2015년 1월 6일 세월호 참사 265일 만에 배·보상, 피해자 및 피해 지역 지원, 추모사업 등이 포함된 \'4·16세월호참사 피해구제 및 지원 등을 위한 특별법\'... 1월 12일 국회 본회의를 통과하였다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0131'};
MATCH (a:ResponseAction {name: '진상조사단 자료수집 활동(1단계)'}), (b:Event {name: '세월호 침몰사고'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {role: '참사 초기 자료 확보', phase: 'recovery', effectiveness: 'Med', evidence: '처음에는 진상조사 소위원회를 구성하여 갖가지 자료수집활동을 하였다. 시기적으로는 세월호 참사 발생 초기인 4월과 5월에 주로 이루어졌던 활동', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0132'};
MATCH (a:ResponseAction {name: '진상조사단 자료취합 활동(2단계)'}), (b:Event {name: '세월호 침몰사고'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {role: '국정조사 지원·핵심정보 분석', effectiveness: 'Med', specialNote: '기관보고 성과·한계 및 규명 과제 분석', evidence: '두 번째 시기에는, 수집된 자료들을 취합하는 활동을 위주로 하였다... 2014년 7월 21일 마침내 \'세월호 침몰사고 진상규명을 위한 국정조사 특별위원회 기관보고에 대한 검토보고서\'를 발간하였다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0133'};
MATCH (a:ResponseAction {name: '세월호 국정조사'}), (b:ResponseAction {name: '세월호 국정조사'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '청문회 증인 채택 문제를 둘러싼 여야 힘겨루기로 청문회 시작조차 못함', effectiveness: 'Low', specialNote: '애초 계획한 역할 미달성', evidence: '청문회 증인 채택 문제를 둘러싼 여야 간의 힘겨루기로 말미암아, 청문회는 시작조차 해보지 못한 채, 국정조사는 2014년 8월 30일 막을 내렸다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0134'};
MATCH (a:ResponseAction {name: '증거보전신청'}), (b:Event {name: '세월호 침몰사고'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {role: '필수 증거 보전·확보', effectiveness: 'High', specialNote: '총 12건', evidence: '세 번째 시기에는... 각종 중요자료들에 대한 증거보전신청 활동을 하였다... 세월호 특위에서 진행한 증거보전신청은 총 12건에 달한다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0135'};
MATCH (a:ResponseAction {name: '증거보전신청'}), (b:ResponseAction {name: '세월호 현장 인명구조'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {role: '해경 동영상 확보로 구조 부작위 입증', effectiveness: 'High', specialNote: '123정 및 헬기 3대 동영상 확보', evidence: '해양경찰청을 상대로 한 증거보전신청에서는... 123정 경비정 및 3대의 헬기가 보유하고 있는 동영상을 확보한 것이 가장 큰 성과였다. 이 동영상은 형사재판에서 범죄사실의 입증에 큰 역할을 하였다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0136'};
MATCH (a:ResponseAction {name: '진상조사단 AIS 항적복원 활동(5단계)'}), (b:Event {name: '세월호 침몰사고'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {role: 'AIS 미기록 29초 항적 복원', effectiveness: 'High', specialNote: '획기적 성과, 진도VTS 저장장치 2개 분리·기록 차이 확인', evidence: '마지막 다섯 번째 시기에는, 10월에 이루어졌던 증거 발굴 활동시기로... AIS에 기록되지 않은 29초 동안의 항적을 밝혀냈다는 점은 획기적인 성과였다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0137'};
MATCH (a:ResponseActor {name: '세월호 특위 언론대응팀'}), (b:ResponseAction {name: '방통위 편파·왜곡보도 민원 신청'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', role: '방통위 민원·법적대응', effectiveness: 'Low', specialNote: '방통위 편파·왜곡성 불인정 회신', evidence: '언론대응팀은 \'편파, 왜곡 보도\'에 대하여 방통위에 민원신청을 하여 언론에 대한 경종을 요구하였다. 비록 방통위로부터 편파성이나 왜곡성을 찾기 어렵다는 회신을 받기는 했지만', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0138'};
MATCH (a:ResponseActor {name: '세월호 특위 언론대응팀'}), (b:ResponseAction {name: '악성댓글·허위사실 법적대응'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', role: '유가족 법익 침해 법적대응', effectiveness: 'Med', evidence: '언론대응팀은 유가족 측과 협의하여 이에 대한 법적대응을 시작했다... \'변호사는 유가족의 대리인이기 때문에 유가족이 원한다면 변호사가 고소건도 지원하는 것\'으로 결론이 났다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0139'};
MATCH (a:ResponseAction {name: '악성댓글·허위사실 법적대응'}), (b:Damage {name: '세월호 피해자·유가족 2차 피해'}) MERGE (a)-[r:MITIGATES]->(b) SET r += {role: '유가족 2차 피해 완화', effectiveness: 'Med', evidence: '인터넷에서 유가족의 법익이 지나치게 침해되고 있는 사실을 지켜보면서 활동영역을 확대했다... 법적대응을 시작했다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0140'};
MATCH (a:RiskFactor {name: '특별위원회 수사권·기소권 부재'}), (b:ResponseAction {name: '세월호 특위 진상조사단 진상조사 활동'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {role: '진상규명 실패 위험 증대', reason: '조사·자료제출 거부 시 강제 수단 없음', probability: 'High', evidence: '소권이 부여되지 않는다면 관련 기관들이 제대로 된 자료들을 제출할지 의문이고, 조사를 거부하거나 자료제출을 거부할 경우 이를 강제할 수 단이 없다는 것이 결정적인 한계이다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0141'};
MATCH (a:ResponseActor {name: '세월호 특위 진상조사단'}), (b:ResponseAction {name: '확보 증거자료 형사재판지원팀 전달'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '형사재판지원팀과 원활한 의사소통 부재로 확보 자료 전달 누락', effectiveness: 'Low', specialNote: '팀 간 협업 실패', evidence: '일부의 경우 진상조사단과 형사재판지원팀 간의 원활한 의사소통이 이루어지지 않아서 증거보전신청으로 어렵게 확보한 자료들이 형사재판지원팀에게 제대로 전달이 되지 않는 상황이 발생하기도 하였다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0142'};
MATCH (a:ResponseAction {name: '세월호 특위 진상규명 보고서'}), (b:ResponseAction {name: '세월호 사고원인 규명'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '사고 원인 규명을 위한 충분한 자료 미제공', effectiveness: 'Low', specialNote: '사고 원인 부분이 가장 아쉬움', evidence: '진상규명 보고서 작성에 있어서 가장 아쉬움이 많이 남는 부분은 사고 원인 부분이라고 할 수 있다. 아직 확실하게 의혹을 해소할 수 있을 만큼의 충분한 자료들이 제공되어 있지 않았기 때문이다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0143'};
MATCH (a:Facility {name: '세월호 DVR'}), (b:Event {name: '세월호 침몰사고'}) MERGE (a)-[r:LOCATED_IN]->(b) SET r += {role: '증거자료 보유 시설', specialNote: 'CCTV 관련 의혹 미해소', evidence: '세월호 DVR에는 세월호에 설치된 총 64개의 CCTV 화면이 저장되어 있는 것으로 추정되었기 때문에 그 중요성이 컸다... 세월호 DVR의 경우에는 오랜 기간 동안의 해수 침수로 인해 부식이 많이 진행되었기 때문에 복구 작업에 상당한 시간이 걸렸다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0144'};
MATCH (a:ManmadeHazard {name: '세월호 침몰사고(4·16 세월호 참사)'}), (b:Event {name: '세월호 침몰사고'}) MERGE (a)-[r:TRIGGERS]->(b) SET r += {directCause: '과적, 안전 점검·감독 소홀', mechanism: '안전불감증으로 인한 여객선 침몰', probability: 'High', evidence: '세월호 참사는 과적, 안전 점검과 감독 소홀, 즉 안전불감증으로 인하여 발생했다는 점', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0145'};
MATCH (a:RiskFactor {name: '안전 점검·감독 소홀(안전불감증)'}), (b:Event {name: '세월호 침몰사고'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {mechanism: '안전관리 부실이 사고 확률 상승', probability: 'High', evidence: '세월호 참사는 과적, 안전 점검과 감독 소홀, 즉 안전불감증으로 인하여 발생했다는 점', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0146'};
MATCH (a:Event {name: '세월호 침몰사고'}), (b:Event {name: '세월호 구조 실패'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {mechanism: '선장·선원·해경의 구조 실패로 침몰이 대규모 사상으로 전개', directCause: '구조활동 부재', spreadRisk: 'High', specialNote: '탈출 시기를 놓침', evidence: '탈출 시기를 놓친 반면 선장, 선원들은 먼저 탈출했고, 해양경찰 또한 선내 진입이나 퇴선명령 등 적극적인 구조활동을 하지 않아 대규모 사상으로 이어졌다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0147'};
MATCH (a:Event {name: '선내 대기 방송'}), (b:Damage {name: '세월호 참사 인명피해'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {mechanism: '대기 방송을 믿은 학생들의 탈출 지연', reason: '선내 대기하라는 방송 신뢰', specialNote: '성인은 조기 탈출로 생존율 높음', evidence: '학생들은 선내에 대기하라는 방송을 믿고 있다가 탈출 시기를 놓친 반면', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0148'};
MATCH (a:Population {name: '수학여행 고등학생(세월호 탑승)'}), (b:Damage {name: '세월호 참사 인명피해'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {mechanism: '대기 방송 신뢰로 탈출 지연, 낮은 생존율', reason: '선내 대기 방송', evidence: '대부분의 피해자들이 수학여행을 가던 고등학생들로 어른들의 무책임과 무능으로 인하여 구조되지 못하였다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0149'};
MATCH (a:ResponseActor {name: '선장 이준석'}), (b:ResponseAction {name: '세월호 현장 인명구조'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '승객보다 먼저 탈출, 구조 미실시', effectiveness: 'Low', specialNote: '유기치사 인정, 법정최고형 36년형', evidence: '선장, 선원들은 먼저 탈출했고 ... 선장 이준석은 유기치사 등이 인정되어 법정최고형인 36년형을 선고받았으나', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0150'};
MATCH (a:ResponseActor {name: '해양경찰 123정(정장 김경일)'}), (b:ResponseAction {name: '세월호 현장 인명구조'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '선내 진입·퇴선명령 등 적극적 구조활동 미실시', effectiveness: 'Low', specialNote: '123정장 업무상과실치사 인정', evidence: '해양경찰 또한 선내 진입이나 퇴선명령 등 적극적인 구조활동을 하지 않아 대규모 사상으로 이어졌다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0151'};
MATCH (a:ManmadeHazard {name: '세월호 침몰사고(4·16 세월호 참사)'}), (b:ManmadeHazard {name: '1970년 남영호 침몰사고'}) MERGE (a)-[r:COMPOUNDS]->(b) SET r += {reason: '과적·안전점검 소홀(안전불감증)으로 인한 반복된 여객선 침몰 사고', specialNote: '유사 반복 사고', evidence: '1970년 남영호 침몰 사고(사망자 326명) ... 와 유사한 반복된 사고일 뿐만 아니라', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0152'};
MATCH (a:ManmadeHazard {name: '1970년 남영호 침몰사고'}), (b:Damage {name: '남영호 침몰 인명피해'}) MERGE (a)-[r:CAUSES]->(b) SET r += {scale: '대형', evidence: '1970년 남영호 침몰 사고(사망자 326명)', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0153'};
MATCH (a:ManmadeHazard {name: '1993년 서해훼리호 침몰사고'}), (b:Damage {name: '서해훼리호 침몰 인명피해'}) MERGE (a)-[r:CAUSES]->(b) SET r += {scale: '대형', evidence: '1993년 발생한 서해훼리호 침몰사고(사망자 292명)', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0154'};
MATCH (a:ManmadeHazard {name: '세월호 침몰사고(4·16 세월호 참사)'}), (b:ManmadeHazard {name: '1993년 서해훼리호 침몰사고'}) MERGE (a)-[r:DERIVES_FROM]->(b) SET r += {reason: '과적·안전감독 소홀이라는 동일 원인의 반복', specialNote: '남영호·서해훼리호와 유사한 반복 사고', evidence: '1970년 남영호 침몰 사고 ... 1993년 발생한 서해훼리호 침몰사고 ... 와 유사한 반복된 사고일 뿐만 아니라', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0155'};
MATCH (a:Population {name: '성인 탑승자(화물기사 등)'}), (b:Resilience {name: '조기 탈출 가능성'}) MERGE (a)-[r:HAS_RESILIENCE]->(b) SET r += {role: '조기 탈출로 생존', reason: '선내 대기에 구애받지 않고 조기 탈출', evidence: '화물기사 등 성인들은 조기에 빠져 나와 생존율이 높았지만', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0156'};
MATCH (a:ResponseActor {name: '검찰'}), (b:ResponseAction {name: '4·16 세월호참사 최종수사'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', timing: '2014-10', effectiveness: 'Med', evidence: '검찰이 2014년 10월 발표한 4·16세월호참사와 관련한 최종수사결과에 따르면, 발표일 기준으로 399명이 입건되었고, 그 중 154명이 구속 기소되었다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0157'};
MATCH (a:ResponseAction {name: '4·16 세월호참사 최종수사'}), (b:ManmadeHazard {name: '세월호 침몰사고(4·16 세월호 참사)'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {detail: '입건 399명 중 154명 구속 기소', timing: '2014-10', evidence: '399명이 입건되었고, 그 중 154명이 구속 기소되었다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0158'};
MATCH (a:ResponseActor {name: '주식회사 청해진해운 대표이사 김한식'}), (b:ResponseAction {name: '세월호 선박 안전관리'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '선박 안전관리 책임 위반(업무상과실치사)', effectiveness: 'Low', specialNote: '광주지법 2014고합197', evidence: '주식회사 청해진해운 대표이사 김한식 외10인에 대한 업무상과실치사 등 형사사건(광주지방법원 2014고합197 등, 이하 “선사 사건”이라 함)', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0159'};
MATCH (a:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}), (b:ResponseAction {name: '세월호 공익법률지원단 운영'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', effectiveness: 'High', specialNote: '변협 차원 별도 독립조직 구성 첫 사례', evidence: '세월호 특위가 세월호 참사의 피해자 지원을 위해 공익법률지원단을 모집하자 단시간 내 514명의 변호사들이 지원하였다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0160'};
MATCH (a:ResponseAction {name: '세월호 공익법률지원단 운영'}), (b:Damage {name: '세월호 참사 인명피해'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {role: '피해자 가족 법률조력', timing: '사건 발생일 다음날부터', effectiveness: 'High', evidence: '법률지원단은 사건 발생일 다음날부터 안산 분향소 옆 텐트에서 수시로 희생자가족들을 상담을 개시하고', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0161'};
MATCH (a:Population {name: '세월호 피해자 가족'}), (b:Context {name: '안산·인천'}) MERGE (a)-[r:LOCATED_IN]->(b) SET r += {role: '주요 활동지', detail: '희생자 다수 발생 지역', evidence: '이들은 희생자들이 많이 발생한 안산, 인천에서 주로 활동하였다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0162'};
MATCH (a:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}), (b:ResponseAction {name: '형사재판지원팀 활동'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', effectiveness: 'Med', objective: '재판과정 2차 피해 방지 및 피해자 절차적 권리 보장', evidence: '약 5개월 동안 매주 1~3회씩 열린 선원사건 재판 총 33회 및 해경사건 재판 총 8회에 전부 참여하여', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0163'};
MATCH (a:ResponseAction {name: '형사재판지원팀 활동'}), (b:Damage {name: '형사재판 2차 피해'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {role: '법원·검찰·피해자 의사소통 창구', reason: '형사재판과정 2차 피해 방지', effectiveness: 'Med', evidence: '변협 세월호 특위는, 피해자들이 형사재판과정에서 2차적인 피해를 입는 것을 방지하고', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0164'};
MATCH (a:ResponseAction {name: '형사재판지원팀 활동'}), (b:Resilience {name: '안산지원 재판 중계 제도(대법원 규칙 개정)'}) MERGE (a)-[r:BUILDS]->(b) SET r += {role: '원거리 피해자 재판 방청 근거 마련', effectiveness: 'High', evidence: '대법원 규칙이 개정되어 선원 사건에 대해서는 안산지원에서 재판 중계가 이루어질 수 있었다 ... 근거가 새로 마련된 것이다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0165'};
MATCH (a:Event {name: '선원 사건(선장·선원 업무상과실치사 형사사건)'}), (b:Damage {name: '선원 사건 선고 결과'}) MERGE (a)-[r:CAUSES]->(b) SET r += {detail: '선장 이준석 살인죄 불인정, 유기치사 등 인정 법정최고형 36년형; 나머지 피고인 구형 1/3 수준', timing: '2014-11-11', evidence: '선원 사건은 2014년 11월 11일 선고되었는데, 최대의 관심사였던 선장 이준석에 대한 살인죄는 인정되지 않았다. 선장 이준석은 유기치사 등이 인정되어 법정최고형인 36년형을 선고받았으나', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0166'};
MATCH (a:Event {name: '선사 사건(청해진해운 대표 등 업무상과실치사 형사사건)'}), (b:Damage {name: '선사 사건 선고 결과'}) MERGE (a)-[r:CAUSES]->(b) SET r += {detail: '김한식·고박업체 직원·정식 선장 등 업무상과실치사 인정, 최저 징역2년 집행유예3년 ~ 최고 징역10년 및 벌금', timing: '2014-11-20', evidence: '주식회사 청해진해운의 대표이사 김한식 및 고박업체 직원, 세월호의 정식 선장 등에게 모두 업무상과실치사 등이 인정되었으나, 그 형량은 최저 징역 2년 집행유예 3년에서 최고 징역 10년 및 벌금으로', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0167'};
MATCH (a:Event {name: '해경 사건(해경 123정장 업무상과실치사 형사사건)'}), (b:Damage {name: '해경 사건 선고 결과'}) MERGE (a)-[r:CAUSES]->(b) SET r += {detail: '123정장 50여명에 대한 업무상과실치사 인정, 국가 책임 인정 근거', timing: '2015-02-11', specialNote: '국가의 책임 인정 첫 근거', evidence: '2014년 2월 11일 ... 밖으로 빠져 나가기 쉬운 위치에 있었다는 50여명에 대한 업무상 과실치사죄만이 인정되었지만, 공식적으로 세월호 참사에 대한 국가의 책임을 인정하는 근거가 되었다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0168'};
MATCH (a:ResponseActor {name: '해양경찰 123정(정장 김경일)'}), (b:Event {name: '세월호 침몰사고'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {role: '현장 구조 책임 주체', specialNote: '업무상과실치사로 불구속기소(2014-10-06)', effectiveness: 'Low', evidence: '해경 123정장만이 업무상과실치사로 불구속기소 되었다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0169'};
MATCH (a:Damage {name: '탑승자 사망'}), (b:Context {name: '해경 50여명 인과관계 인정 기준'}) MERGE (a)-[r:QUANTIFIED_BY]->(b) SET r += {detail: '사망과 업무상과실 간 인과관계 쟁점, 구조활동 시점 탈출용이 위치 50여명 인정', evidence: '재판과정에서도 탑승자 사망과 업무상과실 간의 인과관계가 있는지 여부가 치열하게 다투어졌다 ... 50여명에 대한 업무상 과실치사죄만이 인정', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0170'};
MATCH (a:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}), (b:ResponseAction {name: '상상적 경합 위헌 헌법소원 청구'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', timing: '2015-02-09', objective: '다중인명피해범죄 합당한 처벌', evidence: '2015년 2월 9일 수백 명이 사망하였음에도 상상적 경합 조항을 적용하여 1죄로 처벌하는 것은 위헌이라는 내용의 헌법소원청구를 하여', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0171'};
MATCH (a:ResponseAction {name: '세월호 특별법 제정 추진'}), (b:Resilience {name: '재발방지 관계 법령 정비 역량'}) MERGE (a)-[r:BUILDS]->(b) SET r += {role: '재발방지·진상규명 제도화', effectiveness: 'Med', evidence: '\'안전 국가를 위한 재발방지대책의 수립\'에 이르기까지 ... 특별위원회를 구성하는 일이었다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0172'};
MATCH (a:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}), (b:ResponseAction {name: '언론·유언비어 대응 활동'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', actionType: 'media_response', effectiveness: 'Med', specialNote: '집단적 프로보노 방식 첫 대응', evidence: '변호사가 인터넷에 떠돌던 허위사실에 대해서 집단적 프로보노 방식으로 대응한 것은 처음 있었던 일이다 ... 명예훼손에 대한 고소·고발을 통해 사전예방이라는 자정작용의 효과를 달성', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0173'};
MATCH (a:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}), (b:ResponseActor {name: '세월호 가족대책위·국민대책회의'}) MERGE (a)-[r:COORDINATES_WITH]->(b) SET r += {role: '진상규명 공동활동', effectiveness: 'Med', evidence: '세월호 가족대책위 뿐만 아니라 국민대책회의 등 다른 단체들과도 협력체계를 구축하고자 했고', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0174'};
MATCH (a:ResponseActor {name: '세월호 특위 현장지원체계'}), (b:ResponseAction {name: '체계적 현장지원·보고 시스템 구축'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '정기 보고·의견수렴 시스템 미구축, 개별 변호사 판단에 방치', effectiveness: 'Low', specialNote: '10월부터 변협 차원 지원 중단·축소', evidence: '현장에서는 정기적인 보고와 의견 수렴 혹은 제시의 시스템 구축을 이루어내지 못했고 ... 10월부터 현장활동 변호사들에 대한 대한변협 차원의 지원을 중단 혹은 대폭 축소함으로써', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0175'};
MATCH (a:ResponseActor {name: '세월호 특위 법률상담팀'}), (b:ResponseAction {name: '세월호 공익법률지원단 운영'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '514명 변호사 비효율적 배치, 상담자료 미정리, 활동비 미지급, 수임기준 미정립', effectiveness: 'Low', evidence: '514명의 변호사들이 공익법률지원단에 지원했음에도 이를 효율적으로 배치하지 못했던 점, 또 상담자료를 체계적으로 정리하지 못하고 ... 활동비가 제대로 지급되지 못한 점', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0176'};
MATCH (a:ResponseAction {name: '세월호 공익법률지원단 운영'}), (b:Other {name: '법률상담 원칙 매뉴얼'}) MERGE (a)-[r:GUIDED_BY]->(b) SET r += {role: '상담 효율성·신뢰 제고', effectiveness: 'Med', evidence: '초기에 상담하면서 느낀 문제점과 주의사항을 토대로 작성한 상담원칙을 매뉴얼로 작성하여 상담의 효율성과 신뢰를 높혀 왔다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0177'};
MATCH (a:ResponseAction {name: '세월호 공익법률지원단 운영'}), (b:Context {name: '안산 합동분향소 옆 상담 텐트'}) MERGE (a)-[r:OCCURS_AT]->(b) SET r += {role: '상담 장소', evidence: '안산 분향소 옆 텐트에서 수시로 희생자가족들을 상담을 개시하고', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0178'};
MATCH (a:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}), (b:ResponseAction {name: '언론·유언비어 대응 활동'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '언론대응 전담변호사 부재, 대응방법 미세분화, 변호사 언론 문외한', effectiveness: 'Low', evidence: '변호사들이 언론과 관련하여서 문외한이었다는 점이 초기 대응에 큰 문제였다 ... 전담변호사가 존재하지 않았다는 것도 일관성 있게 대응하지 못하게 된 문제점이었다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0179'};
MATCH (a:Event {name: '세월호 승객 선내 고립'}), (b:Context {name: '에어포켓 생존가능시간 72시간'}) MERGE (a)-[r:UNDER_CONDITION]->(b) SET r += {reason: '에어포켓 생존 한계시간이 약 72시간으로 추정되어 구조 골든타임 형성', timing: '사고 직후', evidence: '\'에어포켓\'으로 생존할 수 있는 시간은 72시간 정도라는 이야기가 피해자 가족들 사이에 돌고 있었고', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0180'};
MATCH (a:Context {name: '에어포켓 생존가능시간 72시간'}), (b:Event {name: '세월호 구조 실패'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {reason: '골든타임 경과로 생존 구조 가능성 급감', probability: 'High', timing: '4월 19일 72시간 도과 시점', evidence: '정부는 생존가능시간이라는 72시간이 지난 4월 19일 밤 11시 48분에서야 처음으로 선내진입에 성공하여 시신을 수습하였다. 아무런 구조 소식이 없이 72시간이 지나자', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0181'};
MATCH (a:Damage {name: '세월호 참사 인명피해'}), (b:Context {name: '4월 21일까지 시신 87구 수습'}) MERGE (a)-[r:QUANTIFIED_BY]->(b) SET r += {timing: '2014-04-21', evidence: '4월 21일까지 87구의 시신이 수습되었으며', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0182'};
MATCH (a:Event {name: '세월호 침몰사고'}), (b:Population {name: '세월호 피해자 가족'}) MERGE (a)-[r:AFFECTS]->(b) SET r += {role: '주된 피해 노출 집단', scale: '다수', evidence: '당시 피해자 가족들은 ... 팽목항에서 밤을 새우며 정부에 구조를 촉구하고 있었다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0183'};
MATCH (a:Population {name: '세월호 피해자 가족'}), (b:Facility {name: '진도체육관'}) MERGE (a)-[r:LOCATED_IN]->(b) SET r += {evidence: '당시 세월호 피해자들은 팽목항과 진도체육관에 나뉘어 있었으며, 팽목항과 진도체육관에 학부모 대표단이 따로 있었다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0184'};
MATCH (a:ResponseActor {name: '정부(중앙 재난대응 당국)'}), (b:ResponseAction {name: '세월호 현장 인명구조'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '골든타임 내 선내진입 지연, 통합지휘체계 부재', effectiveness: 'Low', timing: '사고 후 72시간', evidence: '정부는 생존가능시간이라는 72시간이 지난 4월 19일 밤 11시 48분에서야 처음으로 선내진입에 성공하여 시신을 수습하였다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0185'};
MATCH (a:ResponseAction {name: '세월호 현장 인명구조'}), (b:Event {name: '세월호 승객 선내 고립'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {effectiveness: 'Low', timing: '2014-04-19 23:48', evidence: '정부는 ... 4월 19일 밤 11시 48분에서야 처음으로 선내진입에 성공하여 시신을 수습하였다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0186'};
MATCH (a:ResponseActor {name: '민관군 합동구조팀'}), (b:ResponseAction {name: '세월호 현장 인명구조'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {timing: '2014-04-19 23:48 첫 성공', effectiveness: 'Low', evidence: '4월 19일 밤 11시 48분경 민관군 합동구조팀이 처음으로 선내 진입에 성공하여 시신을 수습한 이후', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0187'};
MATCH (a:RiskFactor {name: '통합지휘체계 부재'}), (b:Event {name: '세월호 구조 실패'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {reason: '통합지휘 부재로 구조 지연·혼란 가중', probability: 'High', mechanism: '지휘·통제 능력 부재', evidence: '통합 지휘체계는 존재하지 않고 서로 책임을 떠넘기고만 있다고 고성이 ... / 안전행정부, 해양수산부를 통합하는 지휘체계 없음. 서로 책임 전가', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0188'};
MATCH (a:ResponseActor {name: '정부(중앙 재난대응 당국)'}), (b:ResponseAction {name: '세월호 구조 지휘·연락 체계 운영'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '구조 책임자 연락 두절, 통합지휘부 미구성, 국장급도 \'연락 받은 적 없다\' 답변', effectiveness: 'Low', timing: '2014-04-20 새벽', evidence: '구조 책임자와의 연결은 이루어지지 않았다. ... 국장급 공무원과 전화 연결이 되었으나 "연락을 받은 적 없다"는 답변에 학부모들은 더욱 격앙되었다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0189'};
MATCH (a:Population {name: '세월호 피해자 가족'}), (b:ResponseAction {name: '학부모 대책회의 및 정부 요구사항 브리핑'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', role: '정부 대응 비판·요구 주체', timing: '2014-04-19 ~ 04-20', evidence: '팽목항 학부모들은 4월 20일 새벽 1시 경 진도체육관에서 정부에 대한 요구사항을 브리핑하고 ... 2. 즉시 통합지휘부 구성하고 장관급 이상이 24시간 상주할 것 3. 구조대책 즉각 설명할 것', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0190'};
MATCH (a:ResponseActor {name: '이주영 해양수산부 장관'}), (b:Facility {name: '진도체육관'}) MERGE (a)-[r:DEPLOYED_TO]->(b) SET r += {timing: '2014-04-20 01:50', evidence: '4월 20일 새벽 1시 50분 경 이주영 해양수산부 장관이 진도체육관에 도착해 학부모 앞에서 최선을 다하고 있다고 브리핑을 하였으나', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0191'};
MATCH (a:ResponseActor {name: '정홍원 국무총리'}), (b:Facility {name: '진도체육관'}) MERGE (a)-[r:DEPLOYED_TO]->(b) SET r += {timing: '2014-04-20 03:00', evidence: '4월 20일 새벽 3시 경 정홍원 국무총리가 진도체육관에 도착했다. 학부모들은 거센 항의로 ... 총리를 에워쌌고', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0192'};
MATCH (a:ResponseActor {name: '경찰병력'}), (b:ResponseAction {name: '피해자 가족 청와대 항의방문·도보행진 저지'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', actionType: '집회·이동 저지', timing: '2014-04-20 01:30~', specialNote: '대한변협 대표단이 법적 근거 제시 요구·불법 공권력 지적했으나 물러서지 않음', evidence: '4월 20일 새벽 1시 30분 경 피해자 가족들은 청와대로 항의방문을 가기 위해 진도체육관을 나섰으나 300여명의 경찰들이 학부모, 가족들을 막아서며 이들의 버스 탑승을 저지했다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0193'};
MATCH (a:Population {name: '세월호 피해자 가족'}), (b:ResponseAction {name: '진도대교 도보행진·연좌농성'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', actionType: '거리행진·연좌농성', timing: '2014-04-20 02:30~11:00', location: '진도대교', evidence: '도보행진을 시작했던 피해자 가족 150여명은 진도대교에서 경찰병력에 의해 다시 저지당하였다. 가족들은 진도대교에서 연좌농성을 하며 정부의 신속한 구조를 촉구하였다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0194'};
MATCH (a:ResponseActor {name: '정부(중앙 재난대응 당국)'}), (b:ResponseAction {name: '구조에서 수색으로 전환'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', actionType: '구조 방식 전환(구조→수색)', timing: '2014-04-25', evidence: '4월 25일 진도의 상황은 더 이상 생존의 가능성을 염두에 둔 \'구조\'가 아니라 실종자의 발견을 위한 \'수색\'이 진행되고 있었으며, 희생자 시신이 절반 이상 수습되어', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0195'};
MATCH (a:RiskFactor {name: '잠수 가능시간 부족'}), (b:Event {name: '세월호 구조 실패'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {reason: '잠수시간 부족으로 24시간 수색 수단(다이빙벨) 도입 시도', probability: 'Med', evidence: '수색을 위한 잠수시간이 현저히 부족한 상황에서, 정부는 24시간 수색구조가 가능하다는 \'다이빙벨\'(알파잠수공업)을 가족들의 요구로 사고해역에 투입하였으나 결국 실패하였다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0196'};
MATCH (a:ResponseActor {name: '정부(중앙 재난대응 당국)'}), (b:ResponseAction {name: '다이빙벨(알파잠수공업) 투입 수색'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '다이빙벨 투입했으나 결국 실패', effectiveness: 'Low', timing: '2014-04-25', evidence: '정부는 24시간 수색구조가 가능하다는 \'다이빙벨\'(알파잠수공업)을 가족들의 요구로 사고해역에 투입하였으나 결국 실패하였다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0197'};
MATCH (a:ResponseActor {name: '언딘마린인더스트리'}), (b:ResponseAction {name: '민간 잠수사 구조·수색 활동'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '해경·해군이 언딘 위주로 민간 구조를 막고 있다는 지적, 다이빙벨 투입 지연 원인으로 지목', effectiveness: 'Low', specialNote: '가족들이 수색 혼란의 원인으로 지목', evidence: '실종자 가족들은 해경, 해군이 민간의 구조를 막고 있고, 그 원인으로 정부와 계약한 언딘 마린 인더스트리(이하 "언딘" 이라 함)이 있음을 지적하며', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0198'};
MATCH (a:ResponseActor {name: '해경·해군'}), (b:ResponseAction {name: '민간 잠수사 구조·수색 활동'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '민간 구조를 막고 있다는 실종자 가족들의 지적', effectiveness: 'Low', timing: '2014-04-25', evidence: '실종자 가족들은 해경, 해군이 민간의 구조를 막고 있고', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0199'};
MATCH (a:ResponseActor {name: '법무부 사고대책본부'}), (b:ResponseAction {name: '사고대책본부 분야별 담당자 지정'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', actionType: '담당자 지정·게시', timing: '2014-04-25', evidence: '4월 25일 법무부 사고대책본부는 사고 이후 저공으로 분사될 담당자를 지정하여 게시하였다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0200'};
MATCH (a:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}), (b:ResponseAction {name: '대한변협 진도 현장지원 활동'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', actionType: '현장 법률지원·상황 기록', duration: '172일(진도 전체 활동기간)', timing: '2014-04-19 ~ 2014-11-11', evidence: '대한변협 ... 세월호 특위가 진도에서 벌인 현장지원 활동은 대표단의 파견시기에 따라 4차로 구분되며, 진도에서의 전체 활동 기간은 172일이다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0201'};
MATCH (a:ResponseAction {name: '대한변협 진도 현장지원 활동'}), (b:Event {name: '세월호 침몰사고'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {timing: '사고 직후~210일', evidence: '진도에서의 활동을 마감한 것은 실종자 가족들이 실종자에 대한 수중수색의 중단을 요청한 2014년 11월 11일로 세월호 참사로부터 210일이 지난 때이다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0202'};
MATCH (a:ResponseAction {name: '대한변협 진도 현장지원 활동'}), (b:Context {name: '2014-11-11 수중수색 중단 요청(참사 후 210일)'}) MERGE (a)-[r:OCCURS_AT]->(b) SET r += {detail: '진도 활동 마감 시점', evidence: '실종자 가족들이 실종자에 대한 수중수색의 중단을 요청한 2014년 11월 11일로 세월호 참사로부터 210일이 지난 때이다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0203'};
MATCH (a:ResponseAction {name: '세월호 특별법 제정 추진'}), (b:Resilience {name: '독립적 진상조사기구(진상조사위원회)'}) MERGE (a)-[r:BUILDS]->(b) SET r += {reason: '독립된 진상조사기구 설치로 진상규명·안전사회 건설 역량 확보', effectiveness: 'Med', evidence: '권력으로부터 독립된 진상조사기구의 설치가 필요하다는 공감대가 형성되어 세월호 특별법이 제정되었다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0204'};
MATCH (a:RiskFactor {name: '규제완화·민영화·비용절감 정책'}), (b:Event {name: '세월호 침몰사고'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {reason: '안전 투자 대신 비용절감으로 재난예방 역량 약화', probability: 'High', mechanism: '안전망 해체, 책임 은폐', evidence: '우리 사회는 사람의 생명보다는 물질을, 안전보다는 비용절감을 추구하면서, 사회적 안전망은 규제완화라는 이름으로 서서히 해체되어 갔고 ... 정부는 재난예방을 위한 안전비용을 투자하기 보다는 민영화와 외주화를 통해 책임을 비용의 절감으로 은폐하였다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0205'};
MATCH (a:RiskFactor {name: '주입식 교육(\'가만히 있으라\')'}), (b:Damage {name: '세월호 참사 인명피해'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {reason: '위기 시 자율 판단·대피 능력 결여로 피해 확대', probability: 'Med', evidence: '주입식 교육은 \'가만히 있으라\'는 말에 학생들이 주체적으로 사고하고 판단할 수 없게 만들었다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0206'};
MATCH (a:RiskFactor {name: '정부 종합상황실 연락체계'}), (b:Event {name: '세월호 구조 실패'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {reason: '연락·지휘체계 미작동으로 구조 대응 지연', probability: 'High', evidence: '3. 정부 종합상황실로의 연락상황 (책임자에게 연결이 전혀 안됨) / 1. 상황: 피해자와의 연락체계 없음. 지휘체계 전혀 동작하지 않음', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0207'};
MATCH (a:ResponseActor {name: '정홍원 국무총리'}), (b:ResponseAction {name: '총리-학부모 대표단 면담 합의사항'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', actionType: '유가족 면담·합의', timing: '2014-04-20 15:30', evidence: '4월 20일 15:30 학부모 대표단과 총리와의 면담결과 요약 ... 4. 소통부재, 지휘부재의 대책으로 구조 지휘체계를 재정비하기로 한다. 5. 해양수산부 장관과 직통 전화를 개설하기로 한다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0208'};
MATCH (a:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}), (b:ResponseAction {name: '세월호 TF 구성 및 국내 재난 선례 정리'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'preparedness', actionType: '선례 정리·조직체계 구축', timing: '2014-04-23', evidence: '② 천안함 사건, 대구지하철 사건, 서해페리호 사건 등 국내 선례를 조속히 정리할 수 있도록 함.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0209'};
MATCH (a:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}), (b:ResponseAction {name: '안산 장례식장 순회 및 희생자 장례지원'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', actionType: '장례지원·순회보고', timing: '2014-04-22~23', evidence: '4월 22일부터 23일까지 정담훈 목사와 함께 안산의 장례식장 12곳을 순회하며 희생자 장례지원에 관해 담당 사무관 등과 면담하고', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0210'};
MATCH (a:Event {name: '세월호 희생자 안산 장례절차'}), (b:Damage {name: '장례절차 혼란(서비스 피해)'}) MERGE (a)-[r:CAUSES]->(b) SET r += {directCause: '장례지원체계 미비', timing: '2014-04-22', evidence: '장례절차는 4월 22일까지도 비용 보증 문제, 시신 안치 및 인도 절차, 유가족 명예훼손, 언론의 무분별한 접촉 등 다양한 문제로 혼란스러운 상황이었으나', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0211'};
MATCH (a:ResponseAction {name: '안산 장례식장 순회 및 희생자 장례지원'}), (b:Damage {name: '장례절차 혼란(서비스 피해)'}) MERGE (a)-[r:MITIGATES]->(b) SET r += {reason: '지원체계 확립으로 장례절차 원활화', effectiveness: 'Med', timing: '2014-04-23', evidence: '4월 23일부터는 지원체계가 확립되면서 원활하게 진행되기 시작했다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0212'};
MATCH (a:Event {name: '세월호 침몰사고'}), (b:Damage {name: '정부·언론에 대한 극도의 불신'}) MERGE (a)-[r:CAUSES]->(b) SET r += {directCause: '신뢰 붕괴·정부 대응 실패 인식', scale: '사회적', mechanism: '구조 지연·언론 오보·지휘부재 누적', evidence: '구조작업이 지체됨에 따라 ... 정부와 언론에 대한 극도의 불신이 4월 19일 팽목항과 진도체육관을 지배했다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0213'};
MATCH (a:ResponseActor {name: '언론(정부 입장 반복·오보)'}), (b:ResponseAction {name: '재난 상황 보도'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '정부 입장만 반복 보도, 오보로 얼룩짐', effectiveness: 'Low', evidence: '4. 정부의 홍보만 일방적으로 보도하거나 오보로 얼룩진 언론들 / 언론은 정부의 입장만 반복하여 보도하고 있었다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0214'};
MATCH (a:RiskFactor {name: '민영화·외주화 책임 은폐'}), (b:RiskFactor {name: '규제완화·민영화·비용절감 정책'}) MERGE (a)-[r:COMPOUNDS]->(b) SET r += {reason: '규제완화 정책과 결합하여 재난대응 능력 약화', probability: 'High', evidence: '공공부문을 사경제적인 논리와 혼동한 비용절약 논리에만 집착하는 무분별한 민영화 ... 정부는 ... 민영화와 외주화를 통해 책임을 비용의 절감으로 은폐하였다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0215'};
MATCH (a:Event {name: '세월호 침몰사고'}), (b:Context {name: '2014-04-16 세월호 참사 발생'}) MERGE (a)-[r:OCCURS_AT]->(b) SET r += {detail: '사고 발생일', evidence: '대한변협 위원장과 협회장은 세월호 참사가 발생하고 3일째인 4월 18일 저녁, ... 진도로 파견하였고', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0216'};
MATCH (a:Event {name: '세월호 침몰사고'}), (b:Damage {name: '세월호 실종자 발생 및 장기 수색 피해'}) MERGE (a)-[r:CAUSES]->(b) SET r += {mechanism: '승객 다수 선체 내부 잔류·실종', scale: '대형', evidence: '대한변협과 실종자 가족은 상호 협력하며 200일이 넘는 장기간의 수색을 끌어나갔고, 모든 실종자가 가족의 품으로 돌아가도록', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0217'};
MATCH (a:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}), (b:ResponseAction {name: '세월호 참사 대국민 성명 발표'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', dateTime: '2014-04-30', evidence: '대한변협은 4월 30일 "세월호 참사에 대한 대국민 성명"을 발표하고', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0218'};
MATCH (a:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}), (b:ResponseActor {name: '세월호 가족대책위'}) MERGE (a)-[r:COORDINATES_WITH]->(b) SET r += {timing: '2014-05-05', role: '지원계획 브리핑·제안서 공식 전달', evidence: '대한변협은 \'대한변호사협회 세월호 피해자 지원계획(안)\'을 브리핑하고, 해당 제안서를 가족대책위에 공식 전달하였다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0219'};
MATCH (a:ResponseActor {name: '세월호 가족대책위'}), (b:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}) MERGE (a)-[r:COMMANDS]->(b) SET r += {timing: '2014-05-13', role: '변호사 진도 파견 요청', specialNote: '집행부 회의 통한 공식 요청', evidence: '5월 13일에는 세월호 가족대책위가 집행부 회의를 통해 대한변협에 진도 실종자 가족 지원을 위한 변호사 파견을 요청', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0220'};
MATCH (a:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}), (b:Region {name: '진도(진도체육관·팽목항)'}) MERGE (a)-[r:DEPLOYED_TO]->(b) SET r += {timing: '2014-05-17 결정', role: '진도 상주 변호사 파견', specialNote: '3차 파견, 총 146일', evidence: '대한변협 세월호TF는 진도에 상주할 변호사로 배의철 변호사를 파견하기로 결정, 배의철 변호사가 진도로 내려가 진도체육관과 팽목항에서 실종자 가족과 함께 생활', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0221'};
MATCH (a:ResponseActor {name: '배의철 변호사'}), (b:ResponseAction {name: '진도 3차 변호사 파견 활동'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', duration: '146일', role: '실종자 가족 대리', evidence: '대한변협은 총 146일의 3차 파견을 통해... 배의철 변호사가 진도로 내려가 진도체육관과 팽목항에서 실종자 가족과 함께 생활하며 실종자 가족을 대리하는 3차 파견이 이루어지게 되었다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0222'};
MATCH (a:RiskFactor {name: '실종자 가족과 유가족 간 의견 불일치'}), (b:Event {name: '실종자 가족-유가족 간 갈등 표면화'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {mechanism: '입장 차이가 변호사 비판으로 표출', probability: 'High', evidence: '특별법을 제정하라고 정부·여당과 싸우는 유가족의 입장과 \'민관군 합동구조팀\'을 구성하여 수색작업을 하고 있는 정부에 기대야 하는 실종자 가족의 입장은 공통의 행보를 취하기 어렵게 하는 요인', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0223'};
MATCH (a:Event {name: '실종자 가족-유가족 간 갈등 표면화'}), (b:Event {name: '세월호 특위 변호사에 대한 유가족 비판·악의적 소문'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {mechanism: '갈등이 진도 상주 변호사에 대한 유가족 비판으로 전이', directCause: '의견 불일치', spreadRisk: 'Med', evidence: '실종자 가족과 유가족의 의견 불일치는 진도에 상주하며 실종자 가족을 대변하고 있던 세월호 특위 변호사에 대한 유가족의 비판으로 표출되었고, 심지어 실종자 가족 담당변호사에 대한 악의적 소문이 퍼지기도', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0224'};
MATCH (a:Event {name: '세월호 특위 변호사에 대한 유가족 비판·악의적 소문'}), (b:Event {name: '진도 3차 변호사 파견 종료(해제)'}) MERGE (a)-[r:TRIGGERS_SECONDARY]->(b) SET r += {mechanism: '갈등 조정 부적절 판단', reason: '가족 자체 해결이 타당', timing: '2014-10-09', evidence: '세월호 특위는 긴급 회의를 통해... 더 이상 변호사를 상주시켜 갈등을 조정하는 것은 적절하지 않다고 판단, 변호사 진도 파견을 해제하기로 결정하였다. 이에 10월 9일... 146일에 달하는 진도 3차 파견을 종료', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0225'};
MATCH (a:ResponseActor {name: '실종자대책위원회'}), (b:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}) MERGE (a)-[r:COMMANDS]->(b) SET r += {timing: '2014-10-22', role: '변호사 재파견·법률지원 요청 공문 발송', evidence: '10월 22일 실종자 가족회의를 통해 대한변협변호사의 재파견과 법률지원을 요청하는 공문을 변협으로 발송하였다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0226'};
MATCH (a:ResponseActor {name: '배의철 변호사'}), (b:Region {name: '진도(진도체육관·팽목항)'}) MERGE (a)-[r:DEPLOYED_TO]->(b) SET r += {timing: '2014-10-23', role: '진도 재파견', specialNote: '3차 파견 종료 2주 만에 재파견', evidence: '세월호 특위는 변호사의 진도 재파견을 결정, 3차 파견 종료 후 2주 만인 10월 23일 배의철 변호사를 다시 진도로 파견', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0227'};
MATCH (a:ResponseActor {name: '진도군민대책위원회'}), (b:ResponseAction {name: '진도체육관 이전 요청'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', role: '진도체육관 이전 요청', evidence: '진도군민들은 진도군대책위원회를 결성하여 실종자 가족에게 진도체육관을 이전해 줄 것을 요청하였고, 이에 따라 실종자 가족 및 유가족과 진도군민 사이의 갈등이 심화', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0228'};
MATCH (a:ResponseAction {name: '진도체육관 이전 요청'}), (b:Event {name: '실종자가족·유가족-진도군민 갈등 심화'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {mechanism: '이전 요청이 가족-군민 갈등 격화', probability: 'High', evidence: '실종자 가족 및 유가족과 진도군민 사이의 갈등이 심화되고 있었다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0229'};
MATCH (a:Event {name: '민간 구조팀 철수설(언론 보도)'}), (b:Damage {name: '피해자 가족 불안감·정신적 고통'}) MERGE (a)-[r:CAUSES]->(b) SET r += {mechanism: '지원 중단 우려로 가족 불안감 증대', directCause: '철수설 언론 보도', evidence: '실종자 가족에 대한 지원이 중단된다는 내용이 언론을 통해 보도되어 피해자 가족들은 불안감을 감추지 못했으며, 실종자 수색에 있어서도 \'민간 구조팀 철수설\'이 대두', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0230'};
MATCH (a:RiskFactor {name: '기자들의 부정확한 보도'}), (b:Damage {name: '실종자 가족 심리적 고통'}) MERGE (a)-[r:CAUSES]->(b) SET r += {mechanism: '사실 미확인 보도로 가족 정신적 상처 유발', directCause: '부정확 보도', evidence: '사실이 제대로 확인되지 않은 기자들의 보도로 인해 실종자 가족들이 겪는 정신적 상처와 고통이 심하였다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0231'};
MATCH (a:ResponseActor {name: '대한변호사협회 파견 변호사'}), (b:ResponseAction {name: '재난보도 대원칙 준수 촉구'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', role: '언론 대응', objective: '재난보도 대원칙 준수 촉구', evidence: '대한변협 파견 변호사는 언론에 대해 \'피해자 가족의 고통에 대한 배려\'라는 재난보도의 대원칙을 준수해 줄 것을 강력히 촉구', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0232'};
MATCH (a:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}), (b:ResponseActor {name: '이주영 장관(범정부사고대책본부장)'}) MERGE (a)-[r:COORDINATES_WITH]->(b) SET r += {timing: '2014-10-23 이후', role: '지원 중단 방지 요청 면담', evidence: '이주영 장관과의 면담을 통해 실종자 가족에 대한 지원이 중단되지 아니하도록 할 것을 요청', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0233'};
MATCH (a:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}), (b:ResponseActor {name: '88수중개발 부사장'}) MERGE (a)-[r:COORDINATES_WITH]->(b) SET r += {role: '철수설 해명 면담', effectiveness: 'Med', evidence: '민간 구조팀을 담당하고 있던 \'88수중개발\' 부사장과의 면담을 통해 철수설은 사실이 아니라는 것을 적극 해명하도록 하였다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0234'};
MATCH (a:Event {name: '88수중개발 잠수팀장 철수 인터뷰'}), (b:Event {name: '실종자 가족 인양론 대두'}) MERGE (a)-[r:TRIGGERS_SECONDARY]->(b) SET r += {mechanism: '철수 시 수중수색 불가능 우려가 인양론 대두 유발', directCause: '철수 인터뷰', spreadRisk: 'High', evidence: '\'인양론\'이 대두된 이유는 세월호 수색 민간잠수팀을 총괄하고 있던 88수중개발의 잠수팀장이 언론을 통해 "10월 30일 민간잠수팀 전체가 철수하겠다."라는 인터뷰를 했고... 민간잠수팀이 장비와 바지선 전체를 철수할 경우에는 더 이상 수중수색 자체가 불가능', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0235'};
MATCH (a:Event {name: '실종자 가족 인양 결정 오보(언론)'}), (b:Event {name: '실종자 가족 인양론 대두'}) MERGE (a)-[r:CONCURRENT_WITH]->(b) SET r += {specialNote: '오보가 인양 논의 급물살과 동시 진행', timing: '2014-10-24', evidence: '10월 24일 실종자 가족이 인양을 결정했다는 언론의 오보로 이어졌다... 언론들이 앞다투어 \'실종자 가족, 인양 첫 언급\'으로 다루면서, 향후 실종자 수색의 과제는 『수색계속 / 인양』이라는 두 축으로 발전', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0236'};
MATCH (a:RiskFactor {name: '해군 표면공기공급방식 잠수'}), (b:Event {name: '정밀 격실 수색 불가(수색 효율 저하)'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {mechanism: '실질 잠수시간 부족으로 정밀 격실 수색 불가', probability: 'High', reason: '나이트록스(1시간) 대비 잠수시간 현저히 적음', evidence: '해군의 잠수방식은 표면공기공급방식으로 약 20여분의 잠수 - ... 실질 잠수 수색시간은 약 10분 - 가 이루어지므로 민간 구조팀의 나이트록스 잠수방식 - 1시간여의 잠수 - 보다 잠수시간이 현저히 적어 정밀하고 실질적인 격실 수색이 이루어질 수 없다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0237'};
MATCH (a:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}), (b:ResponseAction {name: '수중수색 지속 결정 공표 기자회견(10.27)'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', dateTime: '2014-10-27', objective: '오보 확산 차단', evidence: '10월 27일 기자회견을 열어 실종자 가족 회의에서 인양이 아니라 \'수중수색을 지속\'하기로 결정되었음을 공표하여, 일부 언론을 통해 잘못 알려진... 오보의 확산을 차단', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0238'};
MATCH (a:ResponseActor {name: '범정부사고대책본부'}), (b:ResponseAction {name: '수난구호종사명령(민간잠수팀 수색 지속)'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', role: '수난구호종사명령으로 민간잠수팀 수색 지속', effectiveness: 'High', evidence: '정부의 수난구호종사명령에 따라 민간잠수팀이 수색을 이어나가도록 하겠다는 점을 확인하였다... 민간잠수팀의 10월 30일 철수설도 자취를 감추었고', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0239'};
MATCH (a:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}), (b:ResponseAction {name: '4층 선미 SP1·중앙 여자화장실 집중 재수색 요구'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', dateTime: '2014-10-27', role: '재수색 구역 요구', evidence: '세월호 특위는 실종자가 있을 것으로 추정되는 4층 선미 SP1, 4층 중앙 여자화장실을 집중적으로 재수색해줄 것을 현장지휘본부에 요구하였다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0240'};
MATCH (a:ResponseAction {name: '4층 선미 SP1·중앙 여자화장실 집중 재수색 요구'}), (b:Event {name: '295번째 희생자(황 모 학생) 발견'}) MERGE (a)-[r:MITIGATES]->(b) SET r += {mechanism: '재수색 요구가 295번째 희생자 발견으로 이어짐', effectiveness: 'High', timing: '2014-10-28', evidence: '기자회견을 통해 재수색을 요청한 다음 날인 10월 28일 17시 30분경, 세월호 사고 197일 만에... 수색팀이 295번째 희생자를 4층 중앙 여자화장실에서 발견', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0241'};
MATCH (a:RiskFactor {name: '현장지휘본부 부실수색'}), (b:Damage {name: '부실수색 의혹·실종자 가족 분노'}) MERGE (a)-[r:CAUSES]->(b) SET r += {mechanism: '수색완료 분류 구역에서 희생자 발견되어 부실수색 의혹', directCause: '수색완료 오분류', evidence: '4층 중앙 화장실은 이미 13차례 수색해 수색완료로 분류된 곳이고... 26회 수색해 수색 완료지점으로 분류한 3층 주방에서 발견되었으며... 23회 이상 수색해 실종자가 없는 것이 확실하다고 했던 4층 중앙 통로에서 발견... 부실수색 가능성에 대한 분노를 표출', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0242'};
MATCH (a:ResponseActor {name: '민관군 합동구조팀'}), (b:ResponseAction {name: '황 모 학생 시신 수습'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', role: '시신 수습', effectiveness: 'High', timing: '2014-10-29 18:18', evidence: '잠수팀은 유속이 거셀 때에는 무리하게 인양하지 않고 때를 기다려 마침내 29일 18시 18분경 시신 수습에 성공하였다... DNA 확인결과 황 모 학생이 맞는 것으로 판명', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0243'};
MATCH (a:Event {name: '295번째 희생자(황 모 학생) 발견'}), (b:Event {name: '수색 지속 여론 재확산'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {mechanism: '희생자 발견이 수색 지속 여론 재확산', reason: '기적적 발견으로 희망 회복', timing: '2014-10-29', evidence: '가족의 품으로 기적처럼 돌아온 실종자의 발견으로 인양 논의는 수면 아래로 가라앉고 수색을 지속해야 한다는 여론이 다시 확산', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0244'};
MATCH (a:RiskFactor {name: '악화된 수색여건(조류·파고·격벽 붕괴)'}), (b:Event {name: '해군 SSU 잠수사 안전사고'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {mechanism: '선체 균열·붕괴로 잠수사 통로 차단 위험', probability: 'High', reason: '격실 진입 후 붕괴 시 생명 직결', evidence: '30일 바지선은 다시 사고해역에서 피항했고, 해군 SSU 잠수사의 안전사고도 발생했다. 격벽 붕괴는 더욱 심화되었고, 잠수사가 격실 수색에 들어간 후 붕괴로 통로가 막힐 경우 이는 잠수사의 생명과 직결되는 문제', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0245'};
MATCH (a:Event {name: '장기 수중수색 작전'}), (b:Damage {name: '잠수사 잠수병·건강 위협'}) MERGE (a)-[r:CAUSES]->(b) SET r += {mechanism: '장기 수중수색으로 잠수사 잠수병·산소중독 발생', directCause: '100일 이상 반복 잠수', evidence: '100일이 넘도록 수색을 지속해 온 잠수조의 팀장급들은 잠수병 증상을 호소했다... 산소중독, 안전사고 등 잠수사의 생명과 안전에 위협이 가해지는 것', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0246'};
MATCH (a:Damage {name: '잠수사 잠수병·건강 위협'}), (b:Event {name: '수중수색 중단 결단(11.10)'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {mechanism: '잠수사 안전 위협이 수중수색 중단 결정 촉발', probability: 'High', reason: '안전한 수색 최우선', evidence: '다수의 실종자 가족들은 11월 10일 수중수색을 중단하기로 결단하고, 세월호 특위 변호사에게 이와 같은 뜻을 전달했다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0247'};
MATCH (a:Event {name: '수중수색 중단 결단(11.10)'}), (b:Event {name: '실종자 가족 전체회의 및 대국민 호소문 발표 결정'}) MERGE (a)-[r:TRIGGERS_SECONDARY]->(b) SET r += {mechanism: '중단 결단이 대국민 호소문 발표 전체회의로 이어짐', timing: '2014-11-11', evidence: '11월 11일 9시 진도체육관에서 실종자 가족 전체회의가 열렸다... 중대발표 형식으로 기자회견을 갖고 대국민 호소문을 발표하는 것을 \'결정\'해야 하는', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0248'};
MATCH (a:RiskFactor {name: '악화된 수색여건(조류·파고·격벽 붕괴)'}), (b:Event {name: '실종자 가족 내 수색 중단·계속 의견 대립'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {mechanism: '수색여건 악화가 실종자 가족 내 수색 중단/계속 의견 대립 초래', probability: 'High', evidence: '악화된 수색여건은 실종자 가족 사이에 수중수색을 중단해야 한다는 의견과, 수색을 계속해야 한다는 의견의 대립을 초래했다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0249'};
MATCH (a:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}), (b:ResponseAction {name: '범정부사고대책본부 인양계획 브리핑 요구'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {phase: 'response', role: '인양계획 브리핑 요구', timing: '2014-10 하순', evidence: '범정부사고대책본부에 \'인양계획에 대한 브리핑\'을 요구하였다... 세월호 특위는 범대본에 11월 수색계획을 책임 있게 수립할 것을 요구', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0250'};
MATCH (a:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}), (b:ResponseAction {name: '진도 실종자 가족 현장지원 활동(범정부사고대책본부 가교)'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', role: '진도 실종자 가족 현장지원 활동 백본', evidence: '실종자 가족-해양수산부-해경-정부 부처 상호간의 가교 역할을 담당함을 통해 현안사항을 조율하여 결정, 집행되도록 하는 중재·지원 활동', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0251'};
MATCH (a:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}), (b:ResponseAction {name: '수색구조·장비기술연구TF 지원'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', role: '수색·구조 방안 마련 지원', evidence: '다. 수색구조·장비기술연구TF 등을 통한 수색·구조 방안 마련 및 계획 수립 지원', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0252'};
MATCH (a:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}), (b:ResponseAction {name: '유실방지TF 수색 활동'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', role: '유실방지 활동', evidence: '라. 유실방지TF 등을 통한 유실품, 유품 수색 및 인계 지원 및 시신 유실방지 점검 활동', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0253'};
MATCH (a:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}), (b:ResponseAction {name: '세월호 선체 내 CCTV 증거보전 활동'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', role: 'CCTV 증거보전', evidence: '사. 세월호 선체 내 세월호 CCTV 증거보전 활동(멸실방지조치, 실물보전, 재판진행 등)', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0254'};
MATCH (a:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}), (b:ResponseAction {name: '실종자 가족 건강·트라우마 지원'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', role: '복지·건강 지원', evidence: '마. 식사, 음품, 의류 등 실종자 가족 복지지원 및 건강지원 활동', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0255'};
MATCH (a:Population {name: '실종자 가족'}), (b:Damage {name: '실종자 가족 건강 악화'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {mechanism: '장기 체류·탈진이 건강 피해 가중', scale: '200일 이상', evidence: '실종자 가족은 극도로 쇠약해진 건강 상태에 탈진을 반복하면서도... 200일이 넘도록 진도체육관과 팽목항에서 반노숙생활을 하며 피붙이의 발견을 기다려', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0256'};
MATCH (a:RiskFactor {name: '실종자 가족 대표 부재'}), (b:Event {name: '가족 간 갈등 책임의 변호사 전가'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {mechanism: '대표 부재로 가족 간 갈등 책임이 변호사에게 전가', probability: 'High', evidence: '실종자 가족 대표는 존재하지 않았으며... 발생하는 가족 간 갈등의 책임이 모두 대한변협변호사에게 돌아가는 일이 자주 발생', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0257'};
MATCH (a:ResponseActor {name: '민관군 합동구조팀'}), (b:ResponseAction {name: '민관군 합동수색팀 수중수색 재개'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', role: '수중수색 재개', timing: '2014-10-30 이후', evidence: '민관군 합동구조팀의 수중수색은 다시 재개되었다... 현장지휘본부는 실종자 가족으로부터 수색요청 구역을 받아 해당 구역에 대한 재수색에 나섰다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0258'};
MATCH (a:Event {name: '세월호 침몰사고'}), (b:Context {name: '세월호 사고 197일 경과 시점'}) MERGE (a)-[r:OCCURS_AT]->(b) SET r += {specialNote: '사고 발생 후 197일 경과 시점에 295번째 희생자 발견', evidence: '세월호 사고 197일 만에 기적이 일어났다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0259'};
MATCH (a:ManmadeHazard {name: '세월호 침몰 사고'}), (b:Event {name: '세월호 실종자 수중수색'}) MERGE (a)-[r:TRIGGERS]->(b) SET r += {mechanism: '선체 침몰로 다수 승객 실종, 수중수색·구조 필요 발생', probability: 'High', evidence: '세월호 사고 수습의 핵심인 실종자를 수습하기 위한 세월호 선체 수색·구조', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0260'};
MATCH (a:RiskFactor {name: '악화된 수색여건'}), (b:Event {name: '잠수사 안전사고 위험'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {mechanism: '수중수색 지속 시 잠수사 생명 위협', probability: 'High', evidence: '악화된 수색여건은 실종자 가족 사이에 수중수색을 중단해야 한다는 의견과...수중수색을 지속하는 선택이...잠수사들에게 고통을 주고 생명에 위협이 되는', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0261'};
MATCH (a:ResponseActor {name: '범정부사고대책본부'}), (b:ResponseAction {name: '범대본 오전 정례 회의'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '사고수습 조직체', phase: 'response', evidence: '범대본은 해양수산부를 중심으로 정부 각 부처 및 관련 지방자치단체가 사고수습을 위해 모인 조직체로...매일 오전 9시 정례 회의를 통해 수색·구조 상황을 점검', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0262'};
MATCH (a:RiskFactor {name: '부처 파견 공무원 주단위 교체'}), (b:Event {name: '의사결정 지연 및 논의 반복'}) MERGE (a)-[r:TRIGGERS]->(b) SET r += {mechanism: '인수인계 부실로 같은 논의 반복', directCause: '공무원 1주일 단위 교체', probability: 'High', evidence: '각 부처나 지방자치단체 파견 공무원들은 1주일 단위로 담당자가 교체되었으므로 이전 논의사항이 제대로 인계되지 않고 모든 논의를 다시 시작해야 하는 경우가 많았다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0263'};
MATCH (a:ResponseActor {name: '범정부사고대책본부'}), (b:ResponseAction {name: '신속한 의사결정 및 집행'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '부처간 이견 및 파견 공무원 교체로 인수인계 부실', effectiveness: 'Low', mechanism: '하나의 사안 결정 시 부처 파견 공무원 간 신속한 결정·집행 불가', evidence: '하나의 사안을 결정하기 위한 이견이 존재할 때에는 부처 파견 공무원들 간에 신속한 결정과 집행이 되지 못하는 경우가 발생하였다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0264'};
MATCH (a:ResponseActor {name: '정부(범대본)'}), (b:ResponseAction {name: '실종자 가족 법률대리인 회의 참석 보장'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '총리-가족 합의사항임에도 변호사 회의 참석 불허(5월 25일)', effectiveness: 'Low', specialNote: '이후 항의로 5월 25일 저녁 참석 허가로 번복', evidence: '5월 25일 정부는 실종자 가족의 대리인인 변호사의 법대본 회의 참석을 막아섰다...가족이 아닌 자는 참석할 수 없다며 정부는 변호사의 참석을 불허하였다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0265'};
MATCH (a:ResponseActor {name: '해양경찰청'}), (b:ResponseActor {name: '해양수산부'}) MERGE (a)-[r:COORDINATES_WITH]->(b) SET r += {role: '지휘체계 혼선', reason: '수난구호법상 지휘 주체간 의견 불일치 빈번', effectiveness: 'Low', specialNote: '해양수산부·해군과 지휘체계 혼선', evidence: '세월호 선체 수색·구조에 있어서는 수난구호법상 지휘의 주체인 해경과 해양수산부, 해군의 의견이 불일치하는 경우가 빈번하였다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0266'};
MATCH (a:Event {name: '해양수산부-해경-해군 지휘체계 혼선'}), (b:Damage {name: '수색·구조 의사결정 지연'}) MERGE (a)-[r:CAUSES]->(b) SET r += {directCause: '지휘체계 혼선으로 신속한 의사결정 지연', mechanism: '민간잠수팀 갈등, 부처간 의견 차이', evidence: '언딘과...해양수산부 간의 의견 차이가 신속한 의사결정을 지연시키기도 하였다...범대본과 해경, 해군의 지휘체계 혼선은 일사관 지휘 하에 수색·구조가 진행되기를 바라는 실종자 가족의 마음을 애타게 만들었다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0267'};
MATCH (a:ResponseActor {name: '언딘마린인더스트리'}), (b:Event {name: '세월호 실종자 수중수색'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '초기 수중수색', effectiveness: 'Med', reason: '해경 주도 계약', evidence: '사고 초기, 실종자 수색·구조를 담당한 민간 잠수팀인 언딘마린인더스트리...와의 계약은 해경이 주도', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0268'};
MATCH (a:RiskFactor {name: '언딘-해경 유착설'}), (b:ResponseAction {name: '88수중개발 섭외(해양수산부 주도)'}) MERGE (a)-[r:TRIGGERS]->(b) SET r += {mechanism: '언딘 불신으로 88수중개발을 해수부가 별도 섭외', directCause: '유착설 제기 및 불신', evidence: '언딘-해경의 유착설이 제기되고 언딘의 실종자 수색·구조에 대한 불신이 높아지자 4층 선미 절단작업에 투입된 민간 잠수팀인 88수중개발의 섭외는 해양수산부가 주도', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0269'};
MATCH (a:ResponseActor {name: '해군'}), (b:ResponseAction {name: '수색·구조 자원 유지'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '범대본 의견과 무관하게 6월말 잠수사·함정·장비 축소 계획 수립, 인양론 조기 언급', effectiveness: 'Low', specialNote: '범대본과 조율 없는 독자 행동으로 논란', evidence: '해군은 범대본의 의견과 무관하게 자체적으로 6월말 해군 잠수사와 함정, 장비의 축소 계획을 세우면서 논란이 되기도 하였고, 해군 관계자가 \'인양론\'을 조기에 언급', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0270'};
MATCH (a:Population {name: '실종자 가족'}), (b:ResponseAction {name: '4층 선미 다인실(SP구역) 외판 절개 결정'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '4층 선미 절개 결단', timing: '2014-05-27', reason: '수색 진척 위해', evidence: '4층 선미 절개의 경우, 시신 유실의 위험에 대한 우려가 제기되었고...실종자 가족은 세월호 특위를 통해 5월 27일, 기자회견을 개최하여 4층 선미 절개를 결단하였다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0271'};
MATCH (a:RiskFactor {name: '민관군 합동구조팀 수색작업 정체'}), (b:ResponseAction {name: '세월호 수색구조·장비기술연구TF 발족'}) MERGE (a)-[r:TRIGGERS]->(b) SET r += {mechanism: '혁신적 방안 연구 필요 판단', directCause: '수색 진전 없음', timing: '5월 중순 이후', evidence: '민관군 합동구조팀의 실종자 수색·구조작업에 든 진전이 없고 객실 장애물 제거가 지연되자...5월 23일...『세월호 수색구조·장비기술연구TF』...를 발족', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0272'};
MATCH (a:Event {name: '산소아크절단법 사용 중 잠수사 사망 사고'}), (b:Damage {name: '잠수사 사망'}) MERGE (a)-[r:CAUSES]->(b) SET r += {directCause: '산소아크절단법 사용 중 사고', scale: '치명적', evidence: '산소아크절단법을 사용하던 도중 잠수사가 사망하는 사고가 발생', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0273'};
MATCH (a:Event {name: '산소아크절단법 사용 중 잠수사 사망 사고'}), (b:Event {name: '추가 외판 절개 방안 논의(성형작약절단 등)'}) MERGE (a)-[r:TRIGGERS_SECONDARY]->(b) SET r += {mechanism: '가장 빠르고 효율적인 산소아크절단법 사용 불가로 대체 절단방안 논의', directCause: '잠수사 사망 사고', evidence: '산소아크절단법을 사용하던 도중 잠수사가 사망하는 사고가 발생하면서 추가적인 외판 절개 방안에 대한 논의가 전개되었다...산소아크절단법을 사용하지 못하게 되자...\'성형작약절단\'이 그 대안으로 제시', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0274'};
MATCH (a:RiskFactor {name: '성형작약절단법 기폭 시 시신 훼손 위험'}), (b:ResponseAction {name: '성형작약절단법 외판 절개 채택'}) MERGE (a)-[r:MODIFIES_RISK_OF]->(b) SET r += {reason: '온전한 실종자 수색 중시, 시신 훼손 우려', effectiveness: 'High', specialNote: '성형작약절단 채택 무산 요인', evidence: '기폭시 제트기류가 선체 내부로 강하게 형성되어 시신이 훼손될 수 있다는 점은 성형작약절단 방식으로의 외판 절개를 채택하지 못하게 하는 요인이 되었다. 이에 따라 선체 외판 절개는 4층 선미 다인실 구역으로 한정', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0275'};
MATCH (a:ResponseAction {name: '4층 선미 다인실(SP구역) 외판 절개 작업'}), (b:Event {name: '세월호 실종자 수중수색'}) MERGE (a)-[r:MITIGATES]->(b) SET r += {effectiveness: 'Med', reason: '부유물 외부 제거 및 수색 효율성 제고', specialNote: '부분 절개로 부유물 제거', evidence: '4층 선미부분에 대한 외관 절개 작업은 6월 6일에 완료되었다...선체외관을 일부 절단하여 부유물을 외부로 제거하는 방안', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0276'};
MATCH (a:ResponseActor {name: '범정부사고대책본부'}), (b:ResponseAction {name: '무인로봇 크랩스터 투입'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '크랩스터는 6개 발 외형·크기로 선체 내부 진입 불가, 한차례 투입 후 철수', effectiveness: 'Low', timing: '2014-04-23', evidence: '범대본은 4월 23일 한국해양과학기술원이 개발한 무인로봇 \'크랩스터\'...를 사고해역에 투입하였다. 그러나 크랩스터는 6개의 발이 달린 외형과 크기로 인해 선체 내부에 진입시키는 것은 애초 불가능하였다...철수하였다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0277'};
MATCH (a:RiskFactor {name: '강한 조류(맹골수도)'}), (b:Event {name: '첨단장비(ROV·소나·크랩스터) 활용 실패'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {mechanism: 'ROV 케이블-가이드라인 엉킴, 촬영 곤란, 가이드라인 사고 우려', probability: 'High', evidence: '잠수사가 수중에서 수색활동이 가능한 시간은 하루 중 정조기 최대 4시간 정도였다(압축공기방식에 의하면 하루 수색시간은 최대 160분 정도에 불과)...강한 조류로 인해...엉킴 현상을 극복하지 못해', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0278'};
MATCH (a:ResponseActor {name: '범정부사고대책본부'}), (b:ResponseAction {name: 'ROV(무인 원격제어장치) 투입'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: 'Video Ray사 ROV는 부유물로 촬영 어려움·조류 못 이김(4.21), 소방방재청 ROV는 조류·가이드라인 엉킴(5.30)으로 성과 없음', effectiveness: 'Low', specialNote: 'ROV 줄 엉킴 안전사고 우려로 투입 중단', evidence: '범대본은 4월 21일 Video Ray사의 ROV를 대여하여 사고현장에 투입했으나 많은 부유물로 인해 촬영에 어려움을 겪었고, 조류를 이기지 못하여 ROV의 활용에 실패했다. 또한 5월 30일에는 소방방재청이 보유한 ROV를 투입했으나...성과를 거두지 못하였다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0279'};
MATCH (a:ResponseActor {name: '해군'}), (b:ResponseAction {name: '소나(음파탐지기) 활용'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '폐쇄공간 부유물 장애물로 판독 곤란, 형상 발견 곤란 결론', effectiveness: 'Low', evidence: '소나는...선내에 가라앉은 시신을 탐색할 수 있을 것으로 기대가 되었으나 해군의 테스트 결과 폐쇄된 공간에서 각종 부유물이 장애물로 작용하므로 판독이 어려워 형상을 발견하기 곤란하다는 결론이 내려져 활용에 실패하였다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0280'};
MATCH (a:ResponseActor {name: '해양경찰청'}), (b:ResponseAction {name: 'Video Ray사 ROV 투입'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '업체 추가요구·선체절단 우선순위·88수중 동영상 객실식별 가능 등을 이유로 Video Ray ROV 투입 보류(5.29)', effectiveness: 'Low', specialNote: '기존 잠수팀 안전·사기 영향 판단 추정', evidence: '결국 해경은...논리에 따라 5월 29일 운용자 1명과 함께 입국한 Video Ray사의 ROV 투입을 보류하였다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0281'};
MATCH (a:Event {name: '첨단장비(ROV·소나·크랩스터) 활용 실패'}), (b:Event {name: '잠수사 의존 심화 및 언딘 불신 증대'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {mechanism: '최첨단 장비들이 제 역할 못하고 철수, 잠수사 의존 심화 및 언딘 불신 증대', directCause: '장비 활용 실패', evidence: '언딘과 해경의 장비 테스트 반대 때문에 실종자 가족과 유가족은 언딘의 잠수 수색작업에 대하여 불신이 커져갔다. 또한...최첨단 장비들이...철수함으로써 실종자 가족들은 오로지 잠수사들에게만 기댈 수밖에 없게 되었다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0282'};
MATCH (a:ResponseActor {name: '언딘마린인더스트리'}), (b:ResponseAction {name: '수중수색 실시간 촬영(헬멧 카메라)'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '헬멧 카메라 미장착으로 통신만으로 수색, 중복수색 비효율 발생', effectiveness: 'Low', specialNote: '잠수기록지 활용 주장하나 비효율 지적됨', evidence: '언딘의 잠수팀은 헬멧에 카메라를 장착하지 아니하고 통신수와 잠수사의 의사소통으로만 수색상황을 파악하여 같은 구역에 진입하는 잠수사가 이전 잠수사의 수색구역을 다시 반복하여 수색하는 비효율성이 지적', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0283'};
MATCH (a:ResponseActor {name: '88수중개발'}), (b:ResponseAction {name: '수중수색 실시간 촬영(헬멧 카메라)'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '헬멧 카메라 장착 수색', effectiveness: 'High', timing: '2014-05-28', specialNote: '후속 잠수사가 이전 수색상황 숙지 후 입수, 효율성 제고', evidence: '88수중개발의 잠수팀은 헬멧에 카메라를 장착하고 수색작업에 임하여 선상에서 모니터를 통해 수색작업을 육안으로 확인할 수 있었다...후속 잠수사가 입수하기 전에 이전 잠수사의 수색상황을 모니터를 통해 숙지하고 입수하므로 수색의 효율성이 제고', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0284'};
MATCH (a:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}), (b:ResponseAction {name: '민관군 합동구조팀 실시간 촬영장비 전면 도입'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '실시간 촬영장비 도입 요구', timing: '2014-06-10~06-12', effectiveness: 'High', evidence: '6월 10일 수색구조TF에서 범대본 잠수안전지원단의 조광현 단장과 이청관 부단장 역시...실시간 촬영장비 도입이 요청된다는 의견을 제시하고, 6월 12일 실종자 가족 대표와 언딘 잠수사들의 간담회를 통해...민관군 합동구조팀의 잠수수색 전체에 실시간 촬영장비가 도입', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0285'};
MATCH (a:RiskFactor {name: '세월호 격실 다수 및 동영상 분류 미비'}), (b:ResponseAction {name: '세월호 수색 모니터링 시스템 구축'}) MERGE (a)-[r:TRIGGERS]->(b) SET r += {mechanism: '동영상 체계적 분류 필요로 모니터링 시스템 구축', directCause: '동영상 증가 및 격실별 확인 곤란', timing: '2014-06-14~06-16', evidence: '세월호 격실은 총 111개로...실종자 가족들은 동영상을 통한 격실별 확인을 어렵게 하고 혼란을 초래하기도 하였다...6월 16일부터 세월호 수색 동영상 모니터링 시스템을 구축하기 시작하여, 6월 18일 수색구조TF에서 이를 시연', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0286'};
MATCH (a:RiskFactor {name: '부유물 및 영상 판독 곤란'}), (b:ResponseAction {name: '동영상 검증팀 구성'}) MERGE (a)-[r:TRIGGERS]->(b) SET r += {mechanism: '동영상 검증 전문가팀 구성 필요', directCause: '영상 판독 애로 및 신뢰 미형성', evidence: '제공된 수색영상이 계획된 격실에 대한 영상이 맞는지에 대해서도 확인하기가 어려워 실종자 가족은 동영상 판독에 애로를 호소하였다...수색영상을 검증하기 위한 별도의 전문가의 도움이 필요하게 되었다...이주영 장관은 별도의 팀을 구성하여', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0287'};
MATCH (a:ResponseActor {name: '이주영 장관'}), (b:ResponseAction {name: '동영상 검증팀 구성'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '검증팀 구성', phase: 'response', specialNote: '변호사 법대본 참석 보장 약속도 수행', evidence: '범대본부장인 이주영 장관은 별도의 팀을 구성하여 수색', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0288'};
MATCH (a:Resilience {name: '세월호 수색 모니터링 시스템'}), (b:Damage {name: '수색·구조 의사결정 지연'}) MERGE (a)-[r:OFFSETS]->(b) SET r += {effectiveness: 'Med', mechanism: '수색 신뢰성 제고로 수색팀-가족 불신 완화', evidence: '세월호 수색 모니터링 시스템\'을 통해 당일의 수색 작업을 다음 날...확인할 수 있게 되었고, 그로 인하여 수색의 신뢰성도 제고되었다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0289'};
MATCH (a:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}), (b:ResponseActor {name: '해양수산부'}) MERGE (a)-[r:COORDINATES_WITH]->(b) SET r += {role: '해양수산부-해경-해군 사이 가교·중재', effectiveness: 'Med', objective: '실종자 가족 뜻에 부합하는 결정 중재', evidence: '세월호 특위는 실종자 가족의 관점에서 수색·구조와 관련된 해양수산부-해경-해군 사이의 가교 역할을 하며...중재하는 활동을 지원하였다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0290'};
MATCH (a:ResponseActor {name: '세월호 수색구조·장비기술연구TF'}), (b:ResponseAction {name: '수색방안 연구 활동'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '수색방안 연구·도출', phase: 'preparedness', effectiveness: 'Med', evidence: '수색구조TF는 최선의 수색방안을 도출하기 위해 매주 화요일과 금요일 2차례씩 회의를 개최하여...수색 지원을 위한 다방면의 활동을 전개', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0291'};
MATCH (a:Resilience {name: '실시간 촬영장비 도입 시스템'}), (b:Damage {name: '수색·구조 의사결정 지연'}) MERGE (a)-[r:OFFSETS]->(b) SET r += {effectiveness: 'High', mechanism: '중복수색 방지 및 잠수사 안전 확보', evidence: '후속 잠수사가 입수하기 전에 이전 잠수사의 수색상황을 모니터를 통해 숙지하고 입수하므로 수색의 효율성이 제고되었고 잠수사의 안(전)', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0292'};
MATCH (a:Event {name: '세월호 침몰사고'}), (b:Damage {name: '세월호 실종자 발생'}) MERGE (a)-[r:CAUSES]->(b) SET r += {mechanism: '선체 침몰로 실종자가 선내 격실에 갇힘', scale: '대형', evidence: '수색팀이 촬영한 영상을 판독 가능하도록 재편집하여 실종자 가족에게 제공', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0293'};
MATCH (a:Event {name: '세월호 침몰사고'}), (b:Event {name: '세월호 실종자 수중수색'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {mechanism: '침몰 후 선내 실종자 수습을 위한 장기 수중수색 작업이 필요해짐', timing: '사고 이후 수개월', evidence: '실종자 수색작업이 장기화되면서 선체 내부의 격벽 붕괴현상이 심화되고', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0294'};
MATCH (a:Event {name: '세월호 실종자 수중수색'}), (b:Event {name: '선체 내부 격벽 붕괴 및 선체 균열'}) MERGE (a)-[r:TRIGGERS_SECONDARY]->(b) SET r += {mechanism: '장기 수색으로 선체 내부 구조물이 시간 경과에 따라 붕괴·균열', directCause: '수색 장기화', evidence: '실종자 수색작업이 장기화되면서 선체 내부의 격벽 붕괴현상이 심화되고 선체의 균열도 발생하였으며, 선체 내부의 각종 장애물, 부유물', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0295'};
MATCH (a:Event {name: '선체 내부 격벽 붕괴 및 선체 균열'}), (b:RiskFactor {name: '수중수색 시야·접근 곤란'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {mechanism: '장애물·부유물 뒤엉킴으로 잠수사 수색이 더욱 어려워짐', reason: '수색 난이도 증가', evidence: '선체 내부의 각종 장애물, 부유물이 뒤엉켜 잠수사의 가장 핵심적인 과제는 \'잠수시간을 혁신적으로 증가\'시키는 것이었다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0296'};
MATCH (a:RiskFactor {name: '부유물로 인한 수색영상 판독 곤란'}), (b:Damage {name: '수색팀-실종자가족 신뢰 저하'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {mechanism: '영상 판독 곤란으로 수색팀과 실종자 가족 간 신뢰 형성 저해', effectiveness: 'Low', evidence: '부유물로 인하여 수색 영상 역시 판독이 용이하지 아니하였다... 수색팀과 실종자 가족 사이에 수색 완료에 대한 공감대 형성이 어려워', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0297'};
MATCH (a:Resilience {name: '세월호 선내 수중수색 모니터링 시스템'}), (b:Damage {name: '수색팀-실종자가족 신뢰 저하'}) MERGE (a)-[r:OFFSETS]->(b) SET r += {effectiveness: 'Med', mechanism: '수색 영상 공유로 신뢰성 일부 제고', reason: '다만 부유물로 판독 한계', evidence: '모니터링 시스템을 통해 당일의 수색 작업을 다음 날 진도체육관이나 팽목항에서 확인할 수 있게 되었고, 그로 인하여 수색의 신뢰성도 제고되었다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0298'};
MATCH (a:ResponseActor {name: '세월호 특별조사위원회'}), (b:ResponseAction {name: '뻘 제거방안 수립 및 영상검증팀 구성 요청'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', role: '수색구조TF 통한 요청', evidence: '세월호 특위는 수색구조TF에 수중수색 시야 확보를 위한 뻘의 제거방안을 수립해 줄 것과 수중수색 촬영 동영상을 검증할 전문가로 구성된 검증팀의 구성을 요청하였고', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0299'};
MATCH (a:ResponseActor {name: '이주영 범대본부장(해양수산부 장관)'}), (b:ResponseAction {name: '동영상 검증팀 구성'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', timing: '요청 직후', evidence: '범대본부장인 이주영 장관은 별도의 팀을 구성하여 수색 영상 판독을 지원하고 수색과정 영상에 대한 설명회를 개최할 것을 지시하였다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0300'};
MATCH (a:ResponseActor {name: '수색구조TF'}), (b:ResponseAction {name: '동영상 검증팀 구성'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', timing: '2014-06-19', evidence: '6월 19일 수색구조TF는 수중 촬영 전문가, 영상 분석 전문가, 선체 구조 전문가 등을 포함한 동영상 검증팀을 구성하여 운영하기로 결정하였다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0301'};
MATCH (a:ResponseActor {name: '동영상 검증팀(구재모 교수팀)'}), (b:ResponseAction {name: '수색영상 재편집 및 수중 특수촬영'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', effectiveness: 'Med', evidence: '구재모 교수팀이 담당하여 수색팀이 촬영한 영상을 판독 가능하도록 재편집하여 실종자 가족에게 제공하였고 구재모 교수팀은 판독이 불가능한 구역에 대해 수중 특수촬영 장비를 도입하여 직접 입수 촬영하기도 하였다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0302'};
MATCH (a:ResponseActor {name: '동영상 검증팀(구재모 교수팀)'}), (b:Resilience {name: '실종자가족 수색완료 결정 참여 체계'}) MERGE (a)-[r:BUILDS]->(b) SET r += {mechanism: '사전 검증된 영상을 가족에게 제공하여 완료/재검토 결정에 참여', effectiveness: 'Med', evidence: '사전 검증이 완료된 영상을 실종자 가족에게 제공하여 완료/재검토 여부를 결정하도록 하여 수색 완료의 최종 결정과정에 실종자 가족이 참여할 수 있도록 지원하였다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0303'};
MATCH (a:ResponseActor {name: '해양경찰청'}), (b:ResponseAction {name: '팽목항 수색상황 브리핑'}) MERGE (a)-[r:FAILS]->(b) SET r += {phase: 'response', reason: '구두 브리핑 내용이 가족 질문에 답변 못하고 브리핑 때마다 내용이 달라짐', effectiveness: 'Low', evidence: '매일 17:00 가족상황실에서 해경의 수색상황 브리핑이 열렸으나... 구두로 진행되는 설명의 내용이 브리핑 때마다 달라지기도 하였다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0304'};
MATCH (a:ResponseAction {name: '팽목항 수색상황 브리핑'}), (b:Damage {name: '실종자가족 불신·분노 증대'}) MERGE (a)-[r:CAUSES]->(b) SET r += {mechanism: '답변 못하는 상황·내용 변동으로 가족 분노 증대', directCause: '브리핑 부실', evidence: '실종자 가족의 질문에 대해 답변을 하지 못하는 상황이 발생하면서 가족들의 분노는 커져갔고', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0305'};
MATCH (a:RiskFactor {name: '체계적 장단기 수색계획 부재 및 평가 부재'}), (b:Damage {name: '실종자가족 불신·분노 증대'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'High', mechanism: '수색관리 부실이 가족 불신과 수색 비효율 초래', evidence: '현재의 문제점들이 체계적인 장단기 수색계획이 존재하지 아니하고 계획대비 실적의 확인과 평가가 부재한 데에서 비롯되는 것이라는 결론을 내렸다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0306'};
MATCH (a:ResponseActor {name: '세월호 특별조사위원회'}), (b:ResponseAction {name: '수색실적·수색계획서 제출 요청'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'preparedness', timing: '2014-06-13', role: '수색구조TF 통한 요청', evidence: '세월호 특위는 6월 13일 수색구조TF를 통해... 그 동안의 수색실적과 향후 수색계획서를 작성하여 실종자 가족에게 제공하여 줄 것을 요청하였다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0307'};
MATCH (a:Event {name: '단원고 윤 모 학생 발견(6월 24일)'}), (b:Damage {name: '수색작업 신뢰 곤란 상황'}) MERGE (a)-[r:CAUSES]->(b) SET r += {mechanism: '20차례 이상 수색완료 강조했던 구역에서 실종자 발견되어 수색 신뢰 붕괴', directCause: '수색 부실 입증', evidence: '다음 날인 6월 24일 참사 70일 만에 단원고 윤 모 학생이 선체 4층 중앙 통로(해군 수색 구역)에서 발견된 것이... 이 구역은 20차례 이상 드나들어 실종자가 없는 것이 확실하다고 반복해 강조해 온 반면', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0308'};
MATCH (a:ResponseActor {name: '범대본 잠수안전지원단'}), (b:ResponseAction {name: '기존 수색방식 재점검 의견 제기'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', role: '재점검 의견 피력', evidence: '범대본 잠수안전지원단 역시 기존 수색방식을 재점검해야 한다는 의견을 피력함에 따라', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0309'};
MATCH (a:ResponseActor {name: '세월호 특별조사위원회'}), (b:ResponseAction {name: '수색평가·자문위원회 구성 제안'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'preparedness', timing: '2014-06-27', evidence: '세월호 특위는 6월 27일 수색구조TF를 통해 『수색평가·자문위원회』의 구성을 제안하고, 6월 30일 정밀수색 종합 설명회를 개최할 것과 현장지휘본부에서 7월 수색 대안을 수립하여', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0310'};
MATCH (a:ResponseActor {name: '범정부사고대책본부'}), (b:ResponseAction {name: '수색자문위원회 구성·운영'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'preparedness', role: '특위·가족 제안 수용', evidence: '실종자 가족 및 세월호 특위의 제안에 따라 범대본은 수색자문위원회를 구성하여 운영하... (구성) 수색·구인 전문가 중 실종자 가족이 신청한 전문가로 구성(위원 5명, 고문 2명)', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0311'};
MATCH (a:ResponseActor {name: '범정부사고대책본부'}), (b:Resilience {name: '수색자문위원회(가족참여 평가체계)'}) MERGE (a)-[r:BUILDS]->(b) SET r += {mechanism: '가족 주도 자문위원회로 수색방식 점검 역량 확보', effectiveness: 'Med', evidence: '실종자 가족이 수색점검 및 업무 절차를 이해하고, 수색방식에 대해 의견을 제시 할 수 있도록 지원하는 「수색자문위원회」구성', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0312'};
MATCH (a:RiskFactor {name: '후카 잠수방식(압축공기잠수, Air Diving)'}), (b:Damage {name: '잠수 수색시간 부족으로 인한 수색 비효율'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'High', mechanism: '짧은 잠수 수색시간으로 격실 내부 정밀수색이 물리적으로 불가능', reason: '하강·감압상승시간 고려 시 실질 수색시간 1시간 미만', evidence: '기존 후카 잠수방식에 의하면... 실제 선내에서 실종자를 수색하는 시간은 10분∼15분 내외에 불과하였고... 격실 내부를 구석구석 수색하는 것은 물리적으로 불가능하다는 판단을 내렸다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0313'};
MATCH (a:ResponseActor {name: '세월호 특별조사위원회'}), (b:ResponseAction {name: '나이트록스 일원화 수색구조 전면개편 요구'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'mitigation', objective: '실종자 조기 수습', evidence: '수색구조 체계를 장시간 잠수가 가능한 나이트록스 방식으로 일원화 하는 수색구조 전면개편을 단행하는 것이 실종자의 조기 수습을 위한 핵심이라고 판단... 수색체계의 전면 개편을 범대본에 요구하였다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0314'};
MATCH (a:Resilience {name: '나이트록스 잠수방식(혼합기체잠수, Mixed Gas Diving)'}), (b:Damage {name: '잠수 수색시간 부족으로 인한 수색 비효율'}) MERGE (a)-[r:OFFSETS]->(b) SET r += {effectiveness: 'High', mechanism: '잠수시간 대폭 증가로 정밀 수색 가능', reason: '후카 대비 잠수시간 혁신적 증가', evidence: '88수중의 나이트록스 방식은 45m 수심에서 최대 1시간의 잠수시간을 확보하여 선체 내부의 정밀함과 정확한 수색이 가능했다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0315'};
MATCH (a:Resilience {name: '나이트록스 잠수방식(혼합기체잠수, Mixed Gas Diving)'}), (b:RiskFactor {name: '산소 중독 위험'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'Med', mechanism: '허용한계 수심(45m) 초과 시 산소 분압 상승으로 산소 중독 위험', reason: '산소함량 조절 방식의 한계', evidence: '허용한계 수심(45m)을 벗어나면 산소 분압이 높아져 산소 중독이 될 위험성이 상승하고 있기도 하다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0316'};
MATCH (a:ResponseActor {name: '김석균 해양경찰청장'}), (b:ResponseAction {name: '수색구조 전면 개편 및 수색대안 발표'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'mitigation', timing: '2014-07-10', evidence: '7월 10일 김석균 해양경찰청장의 기자회견을 통해 수색구조 전면 개편 및 수색 대안을 발표하게 되었다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0317'};
MATCH (a:ResponseActor {name: '범정부사고대책본부'}), (b:ResponseAction {name: '세월호 사고해역 기상정보 모니터링 체제 구축'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'preparedness', objective: '장마 등 기상여건 따라 수색체제 유지', evidence: '『세월호 사고해역 기상정보 모니터링 체제 구축(안)』을 추진하여 사고 해역 기상 전망을 정확히 분석하고 수색 여건을 예측하기 위해', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0318'};
MATCH (a:ResponseActor {name: '범정부사고대책본부'}), (b:ResponseAction {name: '언딘 배제·88수중개발 나이트록스 전면 개편'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'mitigation', objective: '잠수시간 증가 및 잠수인력 충원', evidence: '민간 잠수팀의 수색체제를 후카 잠수방식으로 수색을 하던 언딘을 배제하고 88수중개발의 나이트록스 방식으로 전면 개편하기로 하였다... 이현화된 민간업체가 단일화되어 지휘통제력이 강화되었다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0319'};
MATCH (a:ResponseAction {name: '언딘 배제·88수중개발 나이트록스 전면 개편'}), (b:Resilience {name: '단일화된 민관군 합동구조팀 지휘통제력'}) MERGE (a)-[r:BUILDS]->(b) SET r += {mechanism: '민간업체 단일화로 지휘통제력 강화 및 수색팀 추가 운용', effectiveness: 'High', evidence: '이현화된 민간업체가 단일화되어 지휘통제력이 강화되었다. 한편 피로도가 쌓인 잠수사들의 휴식을 취하고 수색 성과를 제고하기 위하여 수색팀을 추가 운용하기로 하였다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0320'};
MATCH (a:ResponseActor {name: '범정부사고대책본부'}), (b:ResponseAction {name: '수중재호흡기(리브리더) 검증잠수'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'preparedness', timing: '2014-07-11', effectiveness: 'Low', evidence: '새로운 수색기법으로 수중재호흡기(Rebreather, 리브리더) 방식에 대한 검증잠수를 실시하여 투입 여부를 결정하기로 하였다... 미국 GAVI사가 7월 12일 검증잠수에 참여하지 않겠다는 포기의사를 전달함에 따라 리브리더 방식은 도입되지 못하였다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0321'};
MATCH (a:ResponseActor {name: '미국 GAVI사'}), (b:ResponseAction {name: '수중재호흡기(리브리더) 검증잠수'}) MERGE (a)-[r:FAILS]->(b) SET r += {phase: 'preparedness', reason: '기존 민관군 협동구조팀 바지선 2척·수중하강 철수 및 국내 민간잠수사 투입 금지 요구가 받아들여지지 않자 7월 12일 포기 통보', effectiveness: 'Low', evidence: '미국 GAVI사에는 기존 민관공 협동구조팀의 바지선 2척 및 수중하강 등을 모두 철수하고 국내 민간잠수사의 투입을 금지할 것을 요구하였다... 미국 GAVI사가 7월 12일 검증잠수에 참여하지 않겠다는 포기의사를 전달', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0322'};
MATCH (a:ResponseActor {name: '범정부사고대책본부'}), (b:ResponseAction {name: '전면 교차수색 실시'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'mitigation', objective: '실종자 존재 예상구역 면밀 수색', evidence: '선수, 중앙, 선미의 수색구역을 상호 교차하여 기존 잠수팀이 수행하던 수색에 대해 다른 잠수팀이 재수색하여 수색 성과를 교차 점검할 수 있도록 하였다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0323'};
MATCH (a:ResponseActor {name: '범정부사고대책본부'}), (b:ResponseAction {name: '전자코 시스템·수중다방향 카메라 첨단장비 도입'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'mitigation', objective: '효과적 수색 전개', evidence: '수색을 위한 새로운 기술인 전자코 시스템을 활용한 수색방법과 360도 전방향 수중 촬영이 가능한 수중다방향 카메라 등 첨단 장비를 도입', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0324'};
MATCH (a:ResponseActor {name: '범정부사고대책본부'}), (b:ResponseAction {name: '민간잠수사 성과급제 전환'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'mitigation', objective: '수색작업 책임의식 제고', evidence: '98만원의 일당을 잠수사에게 항시 지급하는 기존의 방식에서 수색팀의 성과에 따라 비용을 지급하는 성과급제 방식으로 전환하였다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0325'};
MATCH (a:ResponseActor {name: '민관군 합동구조팀'}), (b:ResponseAction {name: '3층 중앙 주방 추가 실종자 발견'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', effectiveness: 'High', timing: '잠수방식 변경 후 1주일', evidence: '수색체계를 전면 개편해 수색작업에 나선 민관군 합동구조팀은 잠수방식을 바꾼 지 1주일 만에 추가 실종자를 3층 중앙 주방에서 발견하였다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0326'};
MATCH (a:ResponseAction {name: '나이트록스 일원화 및 교차수색 개편'}), (b:Damage {name: '잠수 수색시간 부족으로 인한 수색 비효율'}) MERGE (a)-[r:MITIGATES]->(b) SET r += {effectiveness: 'High', mechanism: '새 잠수기법 채택과 수색구역 교차 재점검이 효과를 내어 추가 실종자 발견', evidence: '범대본은 새로운 잠수기법을 채택하고 수색구역을 서로 맞바꾸어 재점검한 것이 효과를 낸 것으로 보았고, 추가 실종자의 발견은', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0327'};
MATCH (a:ResponseActor {name: '세월호 특별조사위원회'}), (b:ResponseAction {name: '해수 냄새 화학분석 방안 연구 요청'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'mitigation', timing: '2014-06-18', mechanism: '잠수사들이 실종자 발견 격실 냄새가 판이하다는 청취 내용 근거', evidence: '6월 18일 수색구조TF에서 이 점을 지적하였다... 수중의 해수를 채취하여 냄새의 화학적 성분을 분석할 수 있는 방안을 연구하여 수색에 활용할 수 있도록 필요한 조치를 취해줄 것을 요청하였다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0328'};
MATCH (a:ResponseActor {name: '범정부사고대책본부'}), (b:ResponseAction {name: '전자코 시스템 수색'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'mitigation', timing: '2014-06-20 명명', effectiveness: 'Med', evidence: '범대본은 6월 20일 수색구조TF에서 이를 \'전자코 시스템\'이라 명명하고... 해수를 채취하고 성분 분석을 통해 냄새의 종류를 시각적으로 패턴화하기로 하였다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0329'};
MATCH (a:ResponseAction {name: '전자코 시스템 수색'}), (b:Damage {name: '세월호 실종자 발생'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {effectiveness: 'Med', timing: '2014-06-29 시료분석', mechanism: '14개 채수 샘플 시료 분석결과 채수 위치별 시각적 데이터 그룹 형성 확인', evidence: '6월 29일 샘플 채수를 통해 14개 채수 샘플에 대한 시료 분석결과, 채수 위치 별로 시각적 데이터의 그룹이 형성되는 것을 확인하였으며', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0330'};
MATCH (a:ResponseAction {name: '전자코 시스템 수색'}), (b:Damage {name: '실종자 조은화 학생 추정구역 집중수색'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {effectiveness: 'Med', directCause: '4층 선미 다인실 2개 구역에서 표층수와 다른 냄새 검출', evidence: '실종자 조은화 학생이 있을 것으로 추정되는 4층 선미 다인실 2개 구역에서 표층수와 다른 냄새가 검출되어 4층 선미 다인실의 부유물을 걷어내는 작업에 집중하였으며', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0331'};
MATCH (a:ResponseAction {name: '전자코 시스템 수색'}), (b:Event {name: '세월호 침몰사고'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {effectiveness: 'Med', specialNote: '총 128개 격실 채수 완료, 177개 샘플 채취, 이상패턴 샘플 19개, 검출 구역 15개, 15개 구역 전체 재수색 완료', evidence: '범대본은 총 128개 격실 전체에서 채수를 완료하고, 177개의 샘플을 채취하여, 이 중 이상패턴을 보인 샘플수는 19개이며 검출 구역은 15개 구역이라고 브리핑하였다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0332'};
MATCH (a:RiskFactor {name: '전자코 시스템 채수 부정확성'}), (b:Damage {name: '4층 중앙 여자화장실 수색완료 오판'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'Med', mechanism: '부정확한 채수로 실종자 존재 구역을 오판하여 수색완료를 잘못 선언', directCause: '채수 위치·정확성 오류', evidence: '이 구역의 성분 분석 결과는 이상 패턴을 보이지 않고 표층수와 동일한 성분으로 분석되어 범대본이 13차례의 수색 후 4층 중앙 여자화장실에 대한 수색완료를 선언했었던 것이다. 그러나 황 모 학생이 발견된 후 4층 중앙 여자화장실에서 다시 채수를 하여 샘플을 분석한 결과... 이상패턴이 나타나게 된다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0333'};
MATCH (a:Event {name: '황 모 학생 수습(4층 중앙 여자화장실)'}), (b:Damage {name: '전자코 시스템 채수 부정확성 확인'}) MERGE (a)-[r:CAUSES]->(b) SET r += {mechanism: '기존 채수가 정확하지 않았거나 다른 격실에서 채수했음을 입증', directCause: '재채수 결과 이상패턴 검출', evidence: '황 모 학생의 수습으로 나타난 결과를 통해 실종자 가족의 주장이 타당한 것으로 판단하였다... 이는 기존 채수가 정확하지 않았거나, 다른 격실에서 채수를 하였다는 것을 의미하므로', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0334'};
MATCH (a:ResponseActor {name: '세월호 특별조사위원회'}), (b:ResponseAction {name: '이상패턴 구역 철저한 재수색·채수 정확성 제고 요청'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', effectiveness: 'Low', reason: '채수는 결국 잠수사 역할이라 잠수사를 믿고 맡길 수밖에 없는 한계', evidence: '세월호 특위는 이를 토대로 범대본에 전자코 시스템으로 이상패턴이 검출된 구역 및 그 주변 구역에 대한 철저한 재수색과 채수의 정확성을 높여줄 것을 요청하였으나', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0335'};
MATCH (a:Event {name: '세월호 실종자 수중수색'}), (b:Context {name: '현장지휘본부 수중수색 계획(2014-07-14~15일치)'}) MERGE (a)-[r:OCCURS_AT]->(b) SET r += {role: '수색 일정·계획', evidence: '세월호 수중수색 심직 및 계획 [7월 19일] 기간: 2014. 7. 14 이후부터 가용 15일', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0336'};
MATCH (a:Event {name: '세월호 실종자 수중수색'}), (b:Context {name: '세월호 수중수색 실적·계획(2014-08-14)'}) MERGE (a)-[r:OCCURS_AT]->(b) SET r += {role: '수색 실적', evidence: '세월호 수중수색 실적 및 계획(8월 14일) ... A팀 (SSU) 1차 15:26~16:25 ... B팀 (해경) ... C팀 (경항) ... D팀 (해경) ... E팀 (경항)', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0337'};
MATCH (a:ResponseAction {name: '수색·구조 선단 개편'}), (b:Other {name: '수색자문위원회 구성 및 운영방안'}) MERGE (a)-[r:GUIDED_BY]->(b) SET r += {role: '수색자문위원회 평가·자문에 근거', evidence: '세월호 특위는 수색자문위원회의 평가·자문을 통해 수색구조 체계를 장시간 잠수가 가능한 나이트록스 방식으로 일원화 하는 수색구조 전면개편을 단행', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0338'};
MATCH (a:Facility {name: '현대보령호(대형 바지선)'}), (b:Resilience {name: '단일화된 민관군 합동구조팀 지휘통제력'}) MERGE (a)-[r:HAS_RESILIENCE]->(b) SET r += {role: '수색 지원 인프라 강화', evidence: '2척급 대형 바지선인 현대 보령호가 투입되었으며 ... 수색구조개편으로 사고해역에 투입된 2천톤급 대형바지선 현대보령호', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0339'};
MATCH (a:ResponseAction {name: '전자코 시스템 수색'}), (b:Event {name: '4층 중앙 여자화장실 수색완료 오선언'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '기존 채수가 부정확하거나 다른 격실에서 채수하여 4층 중앙 여자화장실 이상패턴 미검출 후 수색완료 오선언', effectiveness: 'Low', specialNote: '황 모 학생 수습 후 재채수 시 이상패턴 검출되어 실종자 가족 지적의 정당성 확인', evidence: '범대본이 13차례의 수색 후 4층 중앙 여자화장실에 대한 수색완료를 선언했었던 것이다. 그러나 황 모 학생이 발견된 후 ... 이상패턴이 나타나게 된다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0340'};
MATCH (a:Population {name: '실종자 가족'}), (b:ResponseAction {name: '전자코 시스템 수색'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {timing: '수색 중', reason: '채수의 정확성에 의문, 형식적 채수 또는 다른 곳 채수 주장', evidence: '실종자 가족은 채수의 정확성에 대해 의문을 제기하며 형식적 채수 내지 다른 곳에서의 채수가 이루어졌다고 주장', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0341'};
MATCH (a:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}), (b:ResponseAction {name: '이상패턴 구역 재수색·채수 정확성 제고 요청'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', timing: '오선언 확인 후', evidence: '세월호 특위는 이를 토대로 범대본에 전자코 시스템으로 이상패턴이 검출된 구역 및 그 주변 구역에 대한 철저한 재수색과 채수의 정확성을 높여줄 것을 요청', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0342'};
MATCH (a:Event {name: '잠수수색(민간잠수사 긴급투입)'}), (b:Damage {name: '故 이광욱 민간잠수사 사망'}) MERGE (a)-[r:CAUSES]->(b) SET r += {directCause: '적응잠수 없이 긴급 투입, 바지선 전문의료진 미비', mechanism: '잠수 5분만에 의식 상실', probability: 'High', evidence: '5월 6일 6시 5분경 잠수수색에 첫 투입된 언딘의 이광욱 민간잠수사가 잠수 5분만에 의식을 잃고 결국 숨지는 사고가 발생', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0343'};
MATCH (a:Damage {name: '故 이광욱 민간잠수사 사망'}), (b:Event {name: '수색중단·선체인양 주장 제기'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {mechanism: '잠수사 안전 우려·여론 악화로 수색중단·선체인양 주장 촉발', reason: '\'죽은 사람을 찾기 위해 산 사람을 희생시켜서는 안된다\' 여론', spreadRisk: 'High', evidence: '수색을 중단하고 선체를 인양해야 한다는 주장도 제기되기 시작 ... 5월 인양에 대한 내부 논의는 부결된 채 ... 실종자 가족 대표는 그 직을 물러나게 된다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0344'};
MATCH (a:Event {name: '선체 외판 절단작업'}), (b:Damage {name: '88수중 잠수사 사망'}) MERGE (a)-[r:CAUSES]->(b) SET r += {directCause: '절단작업 중 잠수사 의식 상실', probability: 'High', timing: '2014-05-30', evidence: '5월 30일 선체 외판 절단작업 중 88수중의 잠수사가 의식을 잃고 숨지는 사고가 다시 발생', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0345'};
MATCH (a:ResponseActor {name: '범정부사고대책본부'}), (b:ResponseAction {name: '민간 잠수안전 지원단 발족'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'mitigation', timing: '잠수사 사망사고 후', effectiveness: 'Med', evidence: '범대본은 잠수사 안전관리 및 수색구조 협력체제 강화를 위해 『민간 잠수안전 지원단』을 발족하기로 하고 조광현 한국 UDT 전우회 명예회장을 단장으로, 이청관 잠수명장을 부단장으로', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0346'};
MATCH (a:ResponseAction {name: '민간 잠수안전 지원단 발족'}), (b:Resilience {name: '잠수사 안전관리 역량'}) MERGE (a)-[r:BUILDS]->(b) SET r += {effectiveness: 'Med', role: '잠수사 안전 완충역량 구축', evidence: '잠수사 안전수칙(잠수안전 10계명)을 마련하고 ... 철저한 안전 관리 및 범대본, 실종자 가족과의 소통·협력 체계를 강화', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0347'};
MATCH (a:RiskFactor {name: '격실 내부 붕괴현상'}), (b:Event {name: '잠수사 고립·인명사고 위험'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'High', mechanism: '입수 통로 붕괴로 잠수사 고립 위험 증가', spreadRisk: 'High', evidence: '세월호 내부의 격벽 등 붕괴현상 ... 수색 중 입수 통로가 붕괴되어 잠수사가 고립될 위험이 증가하였고, 이 경우 잠수사의 생명이 위험할 수도 있는 악조건', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0348'};
MATCH (a:Event {name: '잠수 중 내부붕괴'}), (b:Damage {name: '잠수사 인명사고·부상 위험'}) MERGE (a)-[r:CAUSES]->(b) SET r += {directCause: '공기공급·통신·영상 장비기능 장애 및 잠수사 퇴로 차단', probability: 'High', mechanism: '장비기능 장애 + 퇴로 차단 + 잠수복 손상', evidence: '내부붕괴는 i) 공기공급 라인과 통신 라인이 붕괴 장애물과의 엉킴으로 ... 잠수사 퇴로가 차단되어 인명사고가 발생할 가능성이 높으며 ii) 날카로운 목재, 못 등에 잠수복이 찢어지거나 부상 가능성이 상존', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0349'};
MATCH (a:Event {name: '4층 A/C 유니트룸 붕괴'}), (b:Damage {name: '잠수사 호흡호스 걸림·심리적 압박'}) MERGE (a)-[r:CAUSES]->(b) SET r += {directCause: '잠수사 호흡호스 걸림, 칠자재 지속 낙하', specialNote: '안전사고 없이 수색 종료되었으나 붕괴 심리적 압박감으로 잠수 집중 곤란 호소', evidence: '4층 A/C 유니트룸 출입문 개방과 동시에 내부 부유물(칠자재 및 부속류 등)이 쏟아져 잠수사 호흡호스가 걸렸으며 ... 붕괴에 대한 심리적 압박감으로 잠수에 집중할 수 없음을 호소', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0350'};
MATCH (a:Event {name: 'CR-14, 15 격실 붕괴'}), (b:Damage {name: 'No.1 잠수사 격벽 사이 갇힘(긴급상황)'}) MERGE (a)-[r:CAUSES]->(b) SET r += {directCause: 'No.1 잠수사가 바닥과 격벽 사이에 갇힘', specialNote: 'No.2 잠수사 도움으로 탈출, 수중감압 후 해보 도착', evidence: '출입문과 격벽 전체가 붕괴되어 No.1 잠수사가 바닥과 격벽 사이에 갇히는 긴급 상황 발생. No.2 잠수사의 도움을 받아 현장에서 탈출', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0351'};
MATCH (a:Event {name: 'DR-7, 8 격실 붕괴'}), (b:Damage {name: 'No.1 잠수사 부자재 붕괴 위험상황(DR-7,8)'}) MERGE (a)-[r:CAUSES]->(b) SET r += {directCause: '부자재가 No.1 잠수사에게 붕괴', specialNote: '잠수사가 팔과 다리 힘으로 버티며 장애물 제거 후 탈출', evidence: 'DR-7 격실 출입문을 막고 있는 판벨을 제거하는 과정에서 판벨에 끼어있던 부자재들이 No.1 잠수사에게 붕괴되는 위험 상황 발생', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0352'};
MATCH (a:Event {name: '잠수 중 격실 내부 붕괴로 안전헬멧 미도입 사고'}), (b:ResponseAction {name: '안전헬멧 도입'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {phase: 'mitigation', evidence: '잠수작업 중 격실 내부 붕괴현상으로 잠수사의 머리로 붕괴물이 떨어지는 일이 발생하면서 안전헬멧을 도입하여', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0353'};
MATCH (a:ResponseActor {name: '범정부사고대책본부'}), (b:ResponseAction {name: '잠수사 안전장비·관리 프로그램 운영'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'mitigation', effectiveness: 'Med', evidence: '안전줄을 설치·운용 ... 잠수병 전문의를 통해 잠수사별 잠수시간을 관리하고 ... 휴가를 의무화하는 등 관리 프로그램을 운영하고 ... 10명 이상의 예비 인력을 확보', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0354'};
MATCH (a:ResponseAction {name: '잠수사 안전장비·관리 프로그램 운영'}), (b:Resilience {name: '잠수사 안전관리 역량'}) MERGE (a)-[r:BUILDS]->(b) SET r += {effectiveness: 'Med', evidence: '잠수사의 피로 누적 및 부상 등에 따른 교체에 대비하여 10명 이상의 예비 인력을 확보하는 방안을 마련', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0355'};
MATCH (a:ResponseActor {name: '범정부사고대책본부'}), (b:ResponseAction {name: '내부붕괴 잠수사 사고예방 안전대책'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'preparedness', effectiveness: 'Med', evidence: '범대본은 이에 따른 안전대책으로 진입 전 예상통로 및 격실에 대한 사전 점검을 철저히 하며 ... 백업 잠수사 비상대응체계를 구축하고 대기 스쿠바 잠수사의 즉응태세를 유지', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0356'};
MATCH (a:ResponseAction {name: '내부붕괴 잠수사 사고예방 안전대책'}), (b:RiskFactor {name: '격실 내부 붕괴현상'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '수색 장기화로 격벽 붕괴현상 심화, 사전 안전조치로도 막을 수 없음', effectiveness: 'Low', evidence: '안전대책을 마련하여 시행함에도 불구하고 실종자 수색이 장기화되면서 필연적으로 발생하는 세월호 내부의 격벽 등 붕괴현상을 막을 수는 없었다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0357'};
MATCH (a:RiskFactor {name: '격실 내부 붕괴현상'}), (b:Event {name: '수중수색 중단 결단'}) MERGE (a)-[r:TRIGGERS]->(b) SET r += {mechanism: '심화된 격벽 붕괴현상이 잠수사 안전 최우선 판단 촉발', probability: 'High', reason: '잠수사 안전 문제가 최우선', evidence: '갈수록 심화된 격벽 붕괴현상은 결국 잠수사의 안전 문제가 최우선이라고 생각한 실종자 가족들로 하여금 11월 11일 수색중단을 결단하도록 하는 주된 요인', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0358'};
MATCH (a:ResponseActor {name: '이주영 장관(해양수산부)'}), (b:ResponseActor {name: '세월호 희생자 유실방지대책TF'}) MERGE (a)-[r:COMMANDS]->(b) SET r += {timing: '2014-04-26', role: '지시', evidence: '각 기관별로 추진해오던 희생자 유실방지 대책을 4월 26일 이주영 장관의 지시로 범정부적TF로 확대하게 됐다 ... 『세월호 희생자 유실방지대책TF』(이하 유실방지TF)', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0359'};
MATCH (a:RiskFactor {name: '자체부양 수습으로 인한 희생자 유실 위험'}), (b:ResponseAction {name: '유실방지TF 수색 활동'}) MERGE (a)-[r:PRECONDITIONS]->(b) SET r += {probability: 'Med', reason: '향후 희생자 유실 우려', evidence: '희생자 중 43명이 선내진입수습이 아닌 자체부양으로 수습되었으므로 향후 희생자 유실이 우려되었다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0360'};
MATCH (a:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}), (b:Event {name: '검경 합수부 유류 휴대폰 적법절차 위반'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '검경 합수부의 유류 휴대폰 적법절차 위반을 지적했으나 합수부의 임의 처리가 이미 이루어짐', effectiveness: 'Low', specialNote: '유심칩 정보 추출·메모리 이미징으로 형법 제316조 비밀침해, 정보통신망법, 개인정보보호법 위배 소지', evidence: '검경 합수부의 이와 같은 적법절차 위반을 분명히 지적하고 개선을 요구하였으며 ... 가족의 동의를 거치지 않은 채 대검찰청 디지털포렌식센터로 넘겨지고', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0361'};
MATCH (a:Event {name: '검경 합수부 유류 휴대폰 적법절차 위반'}), (b:Context {name: '유류 휴대전화 처리 현황'}) MERGE (a)-[r:QUANTIFIED_BY]->(b) SET r += {timing: '2014-06-04 제출자료 기준', evidence: '5월 25일까지 발견된 총 22점의 휴대전화 중 유가족에게 동의를 받은 휴대전화 포렌식 분석은 단 2점으로, 대검으로 인계하는 과정에 적법절차를 준수하지 않은 것이 확인', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0362'};
MATCH (a:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}), (b:ResponseAction {name: '휴대전화 처리절차 개선 및 디지털포렌식팀 신설'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', effectiveness: 'Med', timing: '적법절차 위반 지적 후', evidence: '특위 내에 \'디지털포렌식팀\'(팀장 전 한양대학교 컴퓨터공학과 교수 김인성)을 신설하고 ... 발견된 휴대전화를 직접 인계받았다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0363'};
MATCH (a:Context {name: '유류물 수습 현황'}), (b:Facility {name: '세월호 선내 유류물'}) MERGE (a)-[r:QUANTIFIED_BY]->(b) SET r += {role: '유류물 인계·보관 내역', evidence: '10월 25일까지 발견된 유류물 누계는 155종 2,123점으로 그 중 가족에게 인계된 것이 217점, 진도군으로 인계되어 팽목항 보관소에 관리된 것이 1,406점 ... 해군에게 인계된 것이 23점', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0364'};
MATCH (a:ResponseActor {name: '범정부사고대책본부'}), (b:ResponseAction {name: '선체 절단 희생자·유품 유실방지 대책'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'mitigation', timing: '선체 외판 절개 결정 후(5/27 기자회견)', evidence: '범대본은 선체 절단에 따른 희생자 및 유품 유실방지 대책으로 절단 부위에 탈부착식 유실방지망을 설치하는 것을 비롯, 출입문과 창문에 대한 유실방지 그물망을 설치한다는 계획을 수립', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0365'};
MATCH (a:ResponseAction {name: '선체 절단 희생자·유품 유실방지 대책'}), (b:Event {name: '유실방지 대책 지연·미흡 지적'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '유실방지 대책이 사고 직후 이미 시행됐어야 했으나 잠수 집중으로 소홀, 전면 그물 설치는 잠수사 안전 위험으로 곤란', effectiveness: 'Low', specialNote: '그물에 공기공급선 엉킴·잠수사 걸림 안전사고 우려에 범대본이 뚜렷한 해결책 미제시', evidence: '이와 같은 실종자 및 유품에 대한 유실방지 대책은 이미 시행되었어야 하는 것이었다 ... 전면 그물의 설치는 어렵다는 의견을 피력 ... 범대본은 뚜렷한 해결책을 제시하지 못하고 있었다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0366'};
MATCH (a:ResponseActor {name: '현장지휘본부'}), (b:ResponseAction {name: '창문 유실방지 차단봉·그물 설치'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'mitigation', timing: '2014-06-08', effectiveness: 'Med', evidence: '6월 8일 현장지휘본부는 창문 총 96개소 중 제외대상인 45개소를 제외하고 유실방지 조치가 필요한 51개소에 대해 유실방지 차단봉(46개소) 및 그물(5개소)의 설치를 완료', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0367'};
MATCH (a:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}), (b:ResponseAction {name: '항공점검 유실방지 활동 점검'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', effectiveness: 'Low', timing: '유실방지 활동 점검', evidence: '세월호 특위는 ... 항공점검을 정기적으로 할 것을 제안, 범대본의 선체 외곽 유실방지 활동에 대한 점검에 나섰다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0368'};
MATCH (a:ResponseAction {name: '항공점검 유실방지 활동 점검'}), (b:Event {name: '유실방지 조치 미흡 확인'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '광범위한 사고 해역 외곽 함정·저인망·어선 유실방지 조치가 육안 확인상 현저히 부족', effectiveness: 'Low', specialNote: '실종자 가족 \'이래서야 유실방지가 가능하겠는가\' 탄식·실의', evidence: '광범위한 사고 해역 외곽에 함정, 저인망 및 어선을 통한 유실방지 조치가 육안으로 확인하기에는 현저하게 부족하다는 것이었다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0369'};
MATCH (a:NaturalHazard {name: '장마·태풍 내습(2014 6월말~)'}), (b:Event {name: '희생자 유실 위험(기상악화)'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'Med', mechanism: '기상악화 시 안강망·낭장망 유실방지 기능 저하', spreadRisk: 'Med', evidence: '장마와 태풍이 6월말부터 시작되면서 기상악화 시 유실방지 보완대책도 필요했다. 즉 장마·태풍이 내습하면 안강망, 낭장망의 경우', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0370'};
MATCH (a:ResponseAction {name: '유실방지TF 수색 활동'}), (b:Context {name: '어망 동원 현황(2014-06-08)'}) MERGE (a)-[r:QUANTIFIED_BY]->(b) SET r += {timing: '2014-06-08 항공점검 기준', evidence: '6월 8일 항공점검을 기준으로 안강망은 8척, 낭장망은 총 273척, 닻자망은 12척이 동원되어 유실을 막고 있음', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0371'};
MATCH (a:Damage {name: '故 이광욱 민간잠수사 사망'}), (b:Context {name: '이광욱 잠수사 사망 시점'}) MERGE (a)-[r:QUANTIFIED_BY]->(b) SET r += {role: '사고 일시·경위', evidence: '5월 6일 6시 5분경 잠수수색에 첫 투입된 언딘의 이광욱 민간잠수사가 잠수 5분만에 의식을 잃고', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0372'};
MATCH (a:ResponseActor {name: '배의철 변호사'}), (b:ResponseAction {name: '사망 잠수사 가족 조력·범대본 안전방안 촉구'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', effectiveness: 'Med', role: '잠수사 사기 진작·법적 조력', evidence: '배의철 변호사가 ... 잠수사 가족과 면담하였을 뿐만 아니라 세월호 특위 이명숙 위원장과 박종운, 황필규 등 몇몇 위원들이 인천에 마련된 빈소에 조문 ... 범대본에는 잠수사 안전 문제에 대한 방안 마련을 촉구', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0373'};
MATCH (a:ResponseActor {name: '범정부사고대책본부'}), (b:ResponseAction {name: '기관 잠수사 사기 진작책 시행'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'mitigation', effectiveness: 'Med', timing: '해군·해경·소방 잠수사 사기 진작 요청 후', evidence: '기관별로 교대근무, 휴가, 포상 등을 실시하기로 하는 등 사기 진작책을 마련하여 시행', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0374'};
MATCH (a:Event {name: '세월호 침몰사고'}), (b:Event {name: '희생자 유해·유류품 유실 위험 발생'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {mechanism: '침몰한 선체에서 희생자 유해·유류품이 강한 조류로 사고해역 외곽으로 떠내려갈 위험', spreadRisk: 'High', specialNote: '유실방지가 수색의 핵심 과제로 부상', evidence: '범대본의 선체 외곽 유실방지 활동에 대한 점검에 나섰다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0375'};
MATCH (a:RiskFactor {name: '강한 조류(맹골수도)'}), (b:Event {name: '희생자 유해·유류품 유실 위험 발생'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'High', mechanism: '조류가 희생자 유해·유류품을 사고해역 외곽으로 운반', evidence: '설치구역은 조류의 흐름을 예측하여 일부 구역에 제한되었다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0376'};
MATCH (a:ResponseActor {name: '유실방지TF'}), (b:ResponseAction {name: '사고해역 어망 유실방지 활동'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', scale: '안강망 8척·낭장망 273척·닻자망 12척 동원', timing: '2014-06-08 항공점검 기준', evidence: '안강망은 8척, 낭장망은 총 273척, 닻자망은 12척이 동원되어 유실을 막고 있음', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0377'};
MATCH (a:ResponseAction {name: '사고해역 어망 유실방지 활동'}), (b:Event {name: '희생자 유해·유류품 유실 위험 발생'}) MERGE (a)-[r:MITIGATES]->(b) SET r += {effectiveness: 'Low', reason: '설치구역이 조류 예측에 따라 일부 구역에 제한되어 육안 확인상 현저히 부족', specialNote: '실종자 가족이 \'이래서야 유실방지가 가능하겠는가\' 탄식', evidence: '함정, 저인망 및 어선을 통한 유실방지 조치가 육안으로 확인하기에는 현저하게 부족하다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0378'};
MATCH (a:NaturalHazard {name: '장마·태풍 내습(2014 6월말~)'}), (b:ResponseAction {name: '사고해역 어망 유실방지 활동'}) MERGE (a)-[r:AFFECTS]->(b) SET r += {probability: 'High', mechanism: '안강망·낭장망 유실·파손으로 철거, 대형·중형기선 저인망 피항', reason: '기상악화 시 유실방지 조치 자체가 불가능해짐', evidence: '장마·태풍이 내습하면 안강망, 낭장망의 경우 유실 또는 파손으로 실효성이 없어 철거를 하고 대형기선·중형기선 저인망 역시 피항을 하기 때문에 유실이 우려되는 시기에 오히려 유실방지 조치가 어려운 문제점이 있었다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0379'};
MATCH (a:ResponseActor {name: '범정부사고대책본부'}), (b:ResponseAction {name: '저자망 25km 보강 설치'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', scale: '사고해점 북서·남서방향 25km 구역', objective: '상시 유실방지', effectiveness: 'Low', evidence: '범대본은 해결책으로 사고해점 북서 및 남서방향에 저자망을 보강하여 25km 구역에 설치하는 방안을 추진하였다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0380'};
MATCH (a:ResponseAction {name: '저자망 25km 보강 설치'}), (b:Event {name: '희생자 유해·유류품 유실 위험 발생'}) MERGE (a)-[r:MITIGATES]->(b) SET r += {effectiveness: 'Low', reason: '북서·남서방향 보강만으로는 장마·태풍 시기 유실 방지가 불가능', spreadRisk: 'High', evidence: '북서 및 남서방향에 저자망을 보강하는 것으로 장마·태풍 시기의 유실을 방지하는 것은 불가능했다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0381'};
MATCH (a:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}), (b:ResponseAction {name: '선체 외곽 원형 저자망 차단 제안'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', role: '선체 외곽 전 구역 원형 차단 제안', specialNote: '실종자 가족과 함께 보강조치 강하게 요구', evidence: '실종자 가족과 세월호 특위는 선체 외곽 전 구역을 원형으로 둘러쌀 것을 제안하였고', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0382'};
MATCH (a:ResponseActor {name: '유실방지TF'}), (b:ResponseAction {name: '선체 외곽 원형 저자망 차단 제안'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '비용 문제를 이유로 원형 설치에 난색, 실종자 가족 의견과 대립', phase: 'response', specialNote: '비용을 이유로 형식적 유실방지는 상시 대책으로 볼 수 없음', evidence: '비용 문제를 이유로 설치에 난색을 표하는 유실방지TF 어선 수색반의 의견과 대립이 발생하기도 하였다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0383'};
MATCH (a:ResponseActor {name: '유실방지TF'}), (b:ResponseAction {name: '40km 원형 저자망 공백구역 없는 설치'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', scale: '40km 원형 공백구역 없이 설치', timing: '실종자 가족·세월호 특위 강한 요구 수용 후', effectiveness: 'Med', evidence: '유실방지TF는 이를 받아들여 25km가 아닌 40km 에 걸쳐 사고해역 인근에 원형으로 저자망을 공백구역 없이 설치하기로 결정하였다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0384'};
MATCH (a:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}), (b:ResponseAction {name: '투·양망 해안수색 동영상·사진 자료 제공'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', objective: '태풍 내습 시 항공점검 불가에 대비해 투·양망 및 해안수색 활동을 동영상·사진으로 제공받아 신뢰성 제고', evidence: '투·양망 및 해안수색 활동을 동영상 및 사진자료로 제공하여 줄 것을 요청하였고 유실방지TF는 이를 제작하여 실종자 가족에게 전달, 유실방지 대책에 대해 신뢰성이 제고될 수 있게 되었다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0385'};
MATCH (a:ResponseActor {name: '범정부사고대책본부'}), (b:ResponseAction {name: '해저 영상탐사(사이드 스캔 소나)'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', composition: '민·관·연 합동(해양조사원·해양과학기술원·해양환경관리공단)', objective: '해저에 가라앉은 실종자 파악', scale: '총 탐사구역 856㎢', timing: '2014-04-29부터', effectiveness: 'Low', evidence: '해양조사선과 사이드 스캔 소나(Side Scan Sonar)를 활용하여 4월 29일부터 총 탐사 구역 856㎢ 에 대한 해저영상탐사를 실시하여 영상자료를 분석하였으나 희생자로 추정되는 영상은 발견되지 않았다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0386'};
MATCH (a:ResponseActor {name: '범정부사고대책본부'}), (b:ResponseAction {name: '멀티빔 음향측심 선체이동 정밀조사'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', objective: '기상으로 인한 선체 이동·변화 여부 파악', measures: '멀티빔 음향측심기 이용', scale: '총 4회(6월4일까지) + 7월11일', evidence: '멀티빔 음향측심기를 이용한 선체 이동 정밀조사를 실시하였는데, 6월 4일까지 4차례에 걸친 정밀조사 결과 세월호의 이동 및 침몰 진행은 없는 것으로 파악되었으나', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0387'};
MATCH (a:NaturalHazard {name: '태풍 내습(2014 7월)'}), (b:Event {name: '세월호 선미 남동쪽 3.5m 이동'}) MERGE (a)-[r:TRIGGERS]->(b) SET r += {probability: 'High', directCause: '태풍 내습 후 강해진 조류', mechanism: '기상변동·조류 심화로 선체 이동', evidence: '태풍이 내습한 후 실시된 7월 11일 정밀조사에서는 세월호의 선미가 남동쪽으로 약 3.5m 이동한 것으로 확인되었다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0388'};
MATCH (a:RiskFactor {name: '동절기 기상변동·강조류'}), (b:Event {name: '세월호 선미 남동쪽 3.5m 이동'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'Med', mechanism: '조류 거세짐으로 선체 이동', timing: '동절기', evidence: '수색이 장기화되고 동절기가 되면서 기상변동이 더욱 심하고 조류가 거세지면서 선체의 이동가능성이 부각되었고', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0389'};
MATCH (a:RiskFactor {name: '강한 조류(맹골수도)'}), (b:Event {name: '잠수 수색시간 제약(하루 최대 4시간)'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'High', mechanism: '선체 외부 강조류로 하루 4회 정조 시간에만 입수 가능, 수색시간 하루 최대 4시간(나이트록스) 한정', reason: '잠수 수색 가능시간 제약', evidence: '선체 외부의 강조류로 인해 하루 4회의 정조 시간에만 수색을 위해 입수를 하여 수색시간이 하루 최대 4시간에 - 나이트록스의 경우 - 한정될 수밖에 없었다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0390'};
MATCH (a:ResponseAction {name: '가이드터널 설치 수색방안'}), (b:Event {name: '잠수 수색시간 제약(하루 최대 4시간)'}) MERGE (a)-[r:MITIGATES]->(b) SET r += {effectiveness: 'Med', reason: '선체 진입로 가이드터널로 조류·정조시간 영향 없이 입수 가능', specialNote: '조기 설치 못한 데 대한 실종자 가족 아쉬움 제기', evidence: '세월호 선체에 가이드터널을 설치하여 이를 통해 진입하는 수색방안의 채택 여부를 두고 논쟁이 되는 주요인', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0391'};
MATCH (a:ResponseActor {name: '한국재난구호'}), (b:ResponseAction {name: '팽목항 가족식당 급식 지원'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '정부의 지원 부족 성토하며 철수의사 표명', phase: 'response', timing: '사고 99일째 2014-07-23', specialNote: '9월 1일 최종 철수', evidence: '팽목항 가족식당을 운영하여 급식을 지원하던 한국재난구호에서 정부의 지원 부족을 성토하며 사고 99일째인 7월 23일 철수의사를 표명', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0392'};
MATCH (a:ResponseActor {name: '대한적십자사'}), (b:ResponseAction {name: '자원봉사자 배식 급식 지원'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '배식 차량 철수, 항의에도 철수 번복하지 않음', phase: 'response', timing: '2014-08-12', specialNote: '50여명 자원봉사자에게 유일한 급식 지원차량이었음', evidence: '8월 12일에는 자원봉사자에 대한 급식을 담당하던 대한적십자사의 배식 차량마저 철수하면서 실종자 가족의 시름은 깊어졌다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0393'};
MATCH (a:Event {name: '급식 지원차량 철수 사건'}), (b:ResponseAction {name: '실종자 가족·세월호 특위 단식'}) MERGE (a)-[r:CAUSES]->(b) SET r += {directCause: '급식 지원차량 철수에 항의하며 실종자 가족·세월호 특위 단식 결정', timing: '2014-08-12 저녁부터', evidence: '봉사자에 대한 급식 지원이 이루어질 때까지 함께 식사를 하지 않기로 하고 8월 12일 저녁부터 단식을 하기로 결정했다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0394'};
MATCH (a:ResponseActor {name: '범정부사고대책본부'}), (b:ResponseAction {name: '하나님의 교회 봉사자 급식 지원'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', role: '전라남도·진도군 통해 \'하나님의 교회\'에 급식지원 요청', timing: '2014-08-13부터', evidence: '하나님의 교회가 봉사자에 대한 급식지원을 하기로 결정하면서 8월 13일 부터는 대한적십자사가 아닌 하나님의 교회에서 급식지원이 이루어지게 되었다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0395'};
MATCH (a:ResponseActor {name: '하나님의 교회'}), (b:ResponseAction {name: '하나님의 교회 봉사자 급식 지원'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '봉사 중단 결정', phase: 'recovery', timing: '2014-09-19', specialNote: '한국재난구호도 9월 1일 철수하며 복지지원 공백 심화', evidence: '하나님의 교회 또한 9월 19일에 봉사를 중단한다고 결정하였고, 팽목항 실종자 가족식당을 운영하던 한국재난구호 또한 9월 1일 철수하면서', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0396'};
MATCH (a:Event {name: '복지지원 중단·공백 현안'}), (b:ResponseAction {name: '세월호 특위 팽목항 가족식당 직접 운영'}) MERGE (a)-[r:CAUSES]->(b) SET r += {directCause: '급식지원 공백을 메우기 위해 세월호 특위가 팽목항 가족식당 직접 운영', timing: '9월 10일까지', evidence: '세월호 특위는 팽목항의 경우, 임시방편으로 단원고 교사 및 교육부 장학사 등과 함께 팽목항 가족식당을 9월 10일까지 직접 운영하면서 실종자 가족에게 식사를 제공하였다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0397'};
MATCH (a:RiskFactor {name: '특별교부세 유권해석 분쟁'}), (b:Event {name: '복지지원 중단·공백 현안'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'High', mechanism: '공무원 잦은 교체·감사 회피 관료주의로 논의가 쳇바퀴처럼 반복', reason: '예산 지원 2개월간 지연', evidence: '특별교부세 지원이 불가능하다는 논의만 쳇바퀴처럼 반복되고 있었다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0398'};
MATCH (a:ResponseActor {name: '안전행정부'}), (b:ResponseAction {name: '특별교부세 복지지원 예산 교부'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '지방교부세법 유권해석 문제 미해결로 예산 지원 불이행', phase: 'recovery', specialNote: '해양수산부는 적극적 태도였으나 안행부 유권해석 미해결', evidence: '중앙재난안전대책본부를 맡고 있는 안전행정부를 통한 지방교부세법의 유권해석 문제가 해결되지 않아 예산 지원은 이루어지지 않았다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0399'};
MATCH (a:ResponseActor {name: '이주영 해양수산부 장관(범대본 본부장)'}), (b:ResponseAction {name: '특별교부세 복지지원 예산 교부'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', timing: '2014-09-18 회의 주재', effectiveness: 'High', specialNote: '예산 지출 결의에 직접 서명, 모든 감사 책임 본인이 진다고 단호히 지시', legalBasis: '헌법 제34조 제6항 위배 가능성 지적', evidence: '예산국장에게 지출 결의를 받도록 지시를 내리고 확답을 받아 비로소 특별교부세 지원의 문제가 2개월 만에 해결될 수 있게 되었다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0400'};
MATCH (a:ResponseActor {name: '이주영 해양수산부 장관(범대본 본부장)'}), (b:ResponseActor {name: '예산국장'}) MERGE (a)-[r:COMMANDS]->(b) SET r += {role: '예산국장에게 지출 결의 지시', timing: '2014-09-18 회의', specialNote: '감사 책임을 본인이 진다고 단언', evidence: '그 자리에서 예산국장에게 지출 결의를 받도록 지시를 내리고 확답을 받아', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0401'};
MATCH (a:ResponseAction {name: '실종자 가족 복지지원 체계'}), (b:Event {name: '복지지원 중단·공백 현안'}) MERGE (a)-[r:MITIGATES]->(b) SET r += {effectiveness: 'High', reason: '특별교부세 지원 해결 후 운영주체·관리체계 정립', evidence: '진도군 세월호 지원과에서 진도체육관의 봉사자 식당 및 팽목항 가족식당을 운영하도록 하고 ... 복지지원이 원활히 이행될 수 있게 되었다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0402'};
MATCH (a:Event {name: '세월호 침몰사고'}), (b:Damage {name: '실종자 가족 건강 악화'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {mechanism: '수색 장기화로 실종자 가족이 트라우마·수면부족·열악한 진도체육관 환경에 노출', spreadRisk: 'High', timing: '수색 장기화 기간', evidence: '잠을 거의 자지 못하여 실종자 가족의 건강은 극도로 악화되어 갔다 ... 면역력이 약화되어 폐렴에 걸리는 것이 다반사였고', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0403'};
MATCH (a:Facility {name: '진도체육관'}), (b:Damage {name: '실종자 가족 건강 악화'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {mechanism: '환기 불량·휴식 여건 부족으로 피로 누적', reason: '거주환경 열악', evidence: '진도체육관에는 늘 등이 켜져 있었고 환기가 제대로 되지 않는 환경, 편하게 휴식을 취할 수 있는 여건이 조성되지 않았으므로', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0404'};
MATCH (a:ResponseAction {name: '실종자 가족 건강·트라우마 지원'}), (b:Damage {name: '실종자 가족 건강 악화'}) MERGE (a)-[r:MITIGATES]->(b) SET r += {effectiveness: 'Med', reason: '건강검진·영양제 수액·트라우마 치유 프로그램으로 병세 악화 예방', evidence: '병세가 악화되기 전, 이를 예방하는 정기적 건강진단이 중요하다고 판단하여', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0405'};
MATCH (a:ResponseActor {name: '정홍원 국무총리'}), (b:ResponseAction {name: '실종자 가족 건강·트라우마 지원'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', timing: '사고 100일 진도체육관·팽목항 방문', specialNote: '고가 영양제 수액 사비 구입해 진도체육관·팽목항 전달', evidence: '정홍원 국무총리는 실종자 가족을 위해 고가의 영양제 수액을 사비로 구입하여 진도체육관과 팽목항으로 보내주는', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0406'};
MATCH (a:ResponseActor {name: '여야 국회'}), (b:ResponseActor {name: '국회 세월호 국정조사 특별위원회'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', timing: '2014-05-21 국정조사 요구서 제출, 5-25 국조특위 인선, 5-26 첫 회의', composition: '여야 9명씩 18명', legalBasis: '세월호 침몰사고 진상규명을 위한 국정조사', evidence: '여야 9명씩 18명으로 구성되는 \'세월호 침몰사고 진상 규명을 위한 국정조사 특별위원회\'(이하 국조특위)의 인선을 마쳤다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0407'};
MATCH (a:ResponseActor {name: '세월호 가족대책위'}), (b:ResponseAction {name: '국회 철야농성'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', timing: '2014-05-26부터', objective: '여야의 조속한 국정조사 합의 촉구', scale: '150여명 국회 대회의실 철야농성', evidence: '세월호 가족대책위 150여명은 국정조사 특위가 합의를 도출해 가동을 시작할 때까지 국회를 떠날 수 없다며 국회 대회의실에 남아', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0408'};
MATCH (a:ResponseAction {name: '57시간 국회 농성'}), (b:ResponseAction {name: '세월호 국정조사'}) MERGE (a)-[r:MODIFIES_RISK_OF]->(b) SET r += {effectiveness: 'High', reason: '57시간 농성·진통 끝에 국정조사 계획서 5월29일 본회의 통과, 청와대 비서실 기관보고 명시', evidence: '세월호 특위 위원들과 유가족의 57시간에 걸친 국회 농성과 진통 끝에 세월호 진상규명을 위한 국정조사 계획서가 5월 29일 국회 본회의를 통과했다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0409'};
MATCH (a:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}), (b:ResponseAction {name: '국회 국조특위 공동선언문 채택'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', timing: '2014-06-08 발표', objective: '원활한 국조특위 활동·현장 중심 조사', measures: '총 10개항 공동선언문 채택, 진도체육관 국조특위 현장상황실 설치 추진', evidence: '세월호 특위가 제안한 총 10개항의 내용이 담긴 국조특위 공동선언문을 채택, 6월 8일 국회 정론관에서 유가족과 함께 이를 발표하였다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0410'};
MATCH (a:ResponseActor {name: '국회 행정실'}), (b:ResponseAction {name: '국조특위 현장상황실 설치'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '국조특위 위원 현장 상주·상황실 설치 요청에 \'기다리라\'는 답만 반복', phase: 'response', specialNote: '\'기다리라\'는 세월호 선내 방송과 다르지 않다고 비판', evidence: '국회 행정실에 국조특위 위원의 현장 상주와 상황실 설치를 직접 요청하였으나 돌아오는 대답은 \'기다리라\'는 것이었다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0411'};
MATCH (a:ResponseActor {name: '여야 국회'}), (b:ResponseAction {name: '진도 국조특위 현장본부 위원 파견·상주'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', timing: '2014-06-11', composition: '여야 위원 각 1인(새누리당 김명연·새정치연합 부좌현) 및 입법조사관 1인', objective: '진도 국조특위 상황본부 상주로 실종자 가족과 연계 활동', evidence: '6월 11일 여야 국조특위 위원 각 1인(새누리당 김명연 의원, 새정치연합 부좌현 의원) 및 입법조사관 1인을 진도로 파견하여 진도 국조특위 상황본부에 상주토록', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0412'};
MATCH (a:Facility {name: '세월호(여객선)'}), (b:Population {name: '세월호 승객'}) MERGE (a)-[r:AFFECTS]->(b) SET r += {role: '위험에 노출된 교통수단', specialNote: '침몰로 선내 승객이 사망·실종 위험에 노출', evidence: '세월호 선내 방송으로 죽음을 맞이해야 했던 현실', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0413'};
MATCH (a:RiskFactor {name: '세월호 무리한 증·개축'}), (b:Event {name: '세월호 침몰사고'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {reason: '선체 구조 변경으로 운항 위험성 증대 의혹', probability: 'Med', specialNote: '증·개축 과정에 국정원 개입 의혹 제기', evidence: '세월호의 증·개축 후 출항한 ... 100여건에 이르는 매우 상세한 작업내용이 기록', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0414'};
MATCH (a:Event {name: '세월호 대각도 변침'}), (b:Event {name: '세월호 CCTV/DVR 전원 차단'}) MERGE (a)-[r:TRIGGERS_SECONDARY]->(b) SET r += {mechanism: '변침하면서 DVR 장치가 바닥에 떨어져 전원 차단 가능성', probability: 'Med', specialNote: '고의 차단 가능성도 병존', evidence: '변침을 하면서 DVR 장치가 바닥에 떨어져 전원이 차단되었을 가능성도 유력하게 대두', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0415'};
MATCH (a:Event {name: '세월호 CCTV/DVR 전원 차단'}), (b:Damage {name: '세월호 사고 직전 CCTV 증거 단절'}) MERGE (a)-[r:CAUSES]->(b) SET r += {directCause: '전원 차단으로 변침 직전·직후 영상 소실', consequence: '사고 직전 선내 상황 증거 단절', specialNote: '낙하 또는 고의 차단 의혹', evidence: 'CCTV는 변침 시간인 08:49에 전원이 차단되었다는 결론 ... DVR 장치가 바닥에 떨어져 전원이 차단되었을 가능성', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0416'};
MATCH (a:Event {name: '세월호 대각도 변침'}), (b:Event {name: '세월호 CCTV/DVR 전원 차단'}) MERGE (a)-[r:CONCURRENT_WITH]->(b) SET r += {timing: '08:49 변침 시각과 CCTV 중단 시각 일치', specialNote: '변침 시점과 전원 차단 시점 동시성', evidence: 'CCTV는 변침 시간인 08:49에 전원이 차단되었다는 결론이 되어', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0417'};
MATCH (a:Facility {name: '세월호 DVR'}), (b:Facility {name: '세월호(여객선)'}) MERGE (a)-[r:LOCATED_IN]->(b) SET r += {role: '설치 위치', specialNote: '세월호 선내 CCTV 시스템 구성요소', evidence: '이것이 세월호 선내 CCTV 영상을 저장하는 장치라 추정', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0418'};
MATCH (a:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}), (b:ResponseAction {name: 'DVR 이동경로 추적 및 증거보전 조치'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', timing: '2014-06-23', effectiveness: 'High', role: 'DVR 증거 추적·보전 주도', evidence: '검경 합수부로 연락을 취해 DVR 장치의 이동경로를 추적하였다 ... 봉인 후 부식방지조치를 취하는 것', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0419'};
MATCH (a:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}), (b:ResponseAction {name: '광주지법 목포지원 긴급 증거보전 신청'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', dateTime: '2014-06-24 12:00', effectiveness: 'High', role: '긴급 증거보전 신청 접수', evidence: '광주지방법원 목포지원 ... 긴급 증거보전신청을 하기 위해 신청서를 작성하여 6월 24일 12시경 접수', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0420'};
MATCH (a:ResponseActor {name: '광주지방법원 목포지원'}), (b:ResponseAction {name: 'DVR 증거보전절차 개시 및 복구 명령'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', dateTime: '2014-06-24 19:30', effectiveness: 'High', specialNote: '신청 당일 이례적 개시', evidence: '목포지원은 증거보전신청을 받아들여 이례적으로 신청 당일인 6월 24일 19:30 증거보전절차의 개시', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0421'};
MATCH (a:ResponseActor {name: '광주지방법원 목포지원'}), (b:ResponseActor {name: '검경 합동수사본부'}) MERGE (a)-[r:COMMANDS]->(b) SET r += {timing: '2014-06-24 20:00', reason: '증거보전기일이 이미 개시되어 검사 압수수색 집행 불가', specialNote: '검사 퇴정 명령', evidence: '검사가 압수수색영장을 집행하기 위해 현장 법정에 들어올 수 없다고 판단한 재판부는 검사의 퇴정을 명하였다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0422'};
MATCH (a:ResponseActor {name: '검경 합동수사본부'}), (b:ResponseAction {name: 'DVR 압수수색영장 집행'}) MERGE (a)-[r:FAILS]->(b) SET r += {phase: 'response', reason: '30분 전 증거보전기일 개시로 현장 법정 진입 불가, 검사 퇴정', effectiveness: 'Low', timing: '2014-06-24 20:00', evidence: '그러나 30분 전인 19시 30분 목포부두 현장에서 증거보전기일이 개시되었으므로 ... 검사의 퇴정을 명하였다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0423'};
MATCH (a:ResponseActor {name: '검경 합동수사본부'}), (b:ResponseAction {name: 'DVR 하드디스크 부식방지 사전 준비'}) MERGE (a)-[r:FAILS]->(b) SET r += {phase: 'preparedness', reason: '부식방지조치 준비가 전혀 없었음', effectiveness: 'Low', specialNote: '하드디스크 부식 위험 방치', evidence: '검경 합수부에 부식방지조치를 취할 수 있는지를 질의하였으나 준비된 것은 전혀 없었다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0424'};
MATCH (a:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}), (b:ResponseAction {name: 'DVR·노트북·디지털카메라 부식방지 조치'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'mitigation', dateTime: '2014-06-24 15:00', effectiveness: 'High', role: '하드디스크 부식방지 조치 실행', evidence: '포렌식팀을 급파, 김인성 교수가 ... 부식방지를 위한 탈이온수 등의 장비를 갖추어 ... 부식방지조치가 취해졌다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0425'};
MATCH (a:Event {name: 'DVR 하드디스크 부식 진행'}), (b:Damage {name: 'CCTV 영상 복원 곤란 및 멸실 위험'}) MERGE (a)-[r:CAUSES]->(b) SET r += {directCause: '부식 진행 및 디스크 스크래치·흠', consequence: '복원 가능성 저하', spreadRisk: '증거 멸실 위험', evidence: '디스크에 스크래치와 흠이 발견되어 복원이 어려울 것이라는 예측 ... 이 증거가 멸실될 경우 ... 모든 것이 사라질', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0426'};
MATCH (a:Resilience {name: 'DVR 하드디스크 부식방지 조치'}), (b:Damage {name: 'CCTV 영상 복원 곤란 및 멸실 위험'}) MERGE (a)-[r:OFFSETS]->(b) SET r += {effectiveness: 'Med', mechanism: '부식방지·세척으로 복원 성공률 제고', specialNote: '최종 CCTV 복원 성공', evidence: '복구 성공률을 높이기 위해 하드디스크 세척작업은 반복에 반복을 거듭 ... CCTV의 영상이 ... 공개', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0427'};
MATCH (a:ResponseActor {name: '주식회사 명정보기술·김인성 교수'}), (b:ResponseAction {name: 'DVR/CCTV 하드디스크 복원'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', dateTime: '2014-06-25 01:00', effectiveness: 'High', role: 'CCTV 하드디스크 복원', evidence: '복구 담당자로는 청주에 위치한 데이터복원 전문업체 (주)명정보기술과 김인성 교수가 선정 ... 복원에 성공한 CCTV의 영상', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0428'};
MATCH (a:ResponseAction {name: 'DVR/CCTV 하드디스크 복원'}), (b:Event {name: '세월호 침몰사고'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {role: '진상규명·실종자 위치 확인 목적', effectiveness: 'High', specialNote: '선원·해경 과실 입증, 실종자 마지막 위치 확인 기대', evidence: '영상이 복원되면 세월호 침몰 과정에서의 선원과 해경의 과실 입증, 실종자의 마지막 존재 위치 확인 등', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0429'};
MATCH (a:Other {name: 'DVR 인양 해군 잠수기록지'}), (b:Event {name: '세월호 CCTV/DVR 전원 차단'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {role: 'CCTV 전원 고의차단 의혹 규명 단서', specialNote: '수색 촬영 영상 삭제로 직접 확인 불가, 본체 원위치 가능성 시사', evidence: '잠수기록지에는 ‘본체 전선분리’라고 적혀있어 DVR 본체가 원래 위치에 그대로 있었을 가능성이 높아 CCTV 전원 고의차단 여부', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0430'};
MATCH (a:Event {name: '실종자 가족의 진도 고립'}), (b:Damage {name: '실종자 가족 고립·탈진 및 트라우마 심화'}) MERGE (a)-[r:CAUSES]->(b) SET r += {directCause: '장기 수색 미완·언론·국민 관심 감소', consequence: '실종자 가족 심리적 고립·탈진', timing: '참사 100일 전후', evidence: '실종자 가족들의 고립은 점차 커져갔다 ... 탈진한 극소수의 실종자 가족들이 대응할 여력은 없었으므로', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0431'};
MATCH (a:Event {name: '복원 CCTV 영상 가족 공개(검증기일)'}), (b:Damage {name: '실종자 가족 고립·탈진 및 트라우마 심화'}) MERGE (a)-[r:CAUSES]->(b) SET r += {directCause: 'CCTV에 담긴 실종자의 마지막 모습 확인', consequence: '실종자 가족 트라우마 심화', timing: '2014-08-22', evidence: 'CCTV의 확인으로 실종자 가족들의 트라우마는 더욱 심해졌으며', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0432'};
MATCH (a:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}), (b:Resilience {name: '국민·시민사회 연대(수색 지속 동력)'}) MERGE (a)-[r:BUILDS]->(b) SET r += {phase: 'recovery', effectiveness: 'High', mechanism: '국민 방문·연대로 정부 수색 지속 견인', evidence: '오직 국민의 힘만이 수색을 이어나갈 수 있는 원동력이라 판단하고 ... 연대를 형성하여 정부의 수색 지속을 견인', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0433'};
MATCH (a:Resilience {name: '국민·시민사회 연대(수색 지속 동력)'}), (b:Damage {name: '실종자 가족 고립·탈진 및 트라우마 심화'}) MERGE (a)-[r:OFFSETS]->(b) SET r += {effectiveness: 'Med', mechanism: '연대 형성으로 가족의 고립감·불안 완화, 안도감·희망 회복', evidence: '국민들이 세월호를 잊지 않고 있다는 안도감과 함께 국민들과 함께 수색을 이어나갈 수 있다는 희망을 가지게 되었다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0434'};
MATCH (a:Damage {name: '세월호 참사 진도군 피해'}), (b:Context {name: '참사 피해 약 900억원'}) MERGE (a)-[r:QUANTIFIED_BY]->(b) SET r += {role: '피해 규모 정량화', specialNote: '참사로 인한 진도군 피해액', evidence: '진도군 역시 세월호 참사로 입은 피해가 약 900억원에 달하는 등', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0435'};
MATCH (a:Event {name: '세월호 침몰사고'}), (b:Damage {name: '세월호 참사 진도군 피해'}) MERGE (a)-[r:CAUSES]->(b) SET r += {directCause: '참사로 인한 지역경제 충격', consequence: '진도군 약 900억원 피해', scale: '지역경제', evidence: '진도군 역시 세월호 참사로 입은 피해가 약 900억원에 달하는 등 참사로 인한 고통을 겪고 있었던', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0436'};
MATCH (a:ResponseActor {name: '국회 세월호 국정조사 특별위원회'}), (b:ResponseAction {name: '국조특위 현장상황실 설치'}) MERGE (a)-[r:FAILS]->(b) SET r += {phase: 'preparedness', reason: '현장상황실 설치 의지 없음, ‘기다리라’는 대답', effectiveness: 'Low', evidence: '국회 행정실에 국조특위 위원의 현장 상주와 상황실 설치를 직접 요청하였으나 돌아오는 대답은 ‘기다리라’는 것', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0437'};
MATCH (a:ResponseActor {name: '여야 국조특위 위원(김명연·부좌현 의원)'}), (b:ResponseAction {name: '진도 현장 수색구조 현안 토의·개선 촉구'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', effectiveness: 'Med', role: '현장 감시·수색구조 개편 촉구', timing: '매일 저녁 9시 국조특위 회의', evidence: '매일 저녁 9시 국조특위 회의를 통해 실종자 수색구조에 관한 현안문제를 토의하고 범대본에 개선을 촉구하는 활동', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0438'};
MATCH (a:ResponseActor {name: '여야 국조특위 위원(김명연·부좌현 의원)'}), (b:ResponseActor {name: '범정부사고대책본부'}) MERGE (a)-[r:COORDINATES_WITH]->(b) SET r += {role: '현안 전달·공동 토의', specialNote: '실종자 가족 요청사항 전달 및 공동 활동', evidence: '국회의원들이 범대본 회의 및 수색구조TF, 유실방지TF 회의에 참여하면서 정부도 더욱 긴장하며 문제를 서둘러 해결', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0439'};
MATCH (a:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}), (b:ResponseAction {name: 'CCTV 영상 활용 실종자 위치 확인 지원'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', effectiveness: 'Med', role: 'CCTV 영상으로 수색구역 이해 지원', evidence: '세월호 민관군 합동구조팀에도 CCTV 영상파일을 전달하여 ... 실종자의 마지막 위치를 확인하는 참고가 되도록', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0440'};
MATCH (a:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}), (b:Other {name: '법원 증거보전절차·유실물 처리 절차'}) MERGE (a)-[r:GUIDED_BY]->(b) SET r += {role: '법적 절차 준수', specialNote: '유실물 처리·증거보전 절차에 따라 인계 대신 봉인 후 부식방지', evidence: '적법 절차를 거치지 않은 채 인계를 받을 경우 유실물 처리 절차에 위배 ... 법원의 증거보전절차를 통하는 것이 타당', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0441'};
MATCH (a:Other {name: '국정원 세월호 증·개축 개입 의혹'}), (b:Event {name: '세월호 침몰사고'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {role: '진상조사 쟁점', specialNote: '국정원은 국가보호선박 지정 보안측정이라 해명', evidence: '‘국정원 지적사항’ 문건 ... 국정원이 세월호의 실소유주이거나 ... 의문을 제기 ... 국정원은 ... 보안측정에 참여해 7가지 문제를 지적', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0442'};
MATCH (a:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}), (b:ResponseAction {name: '검증기일 119 구급대·군의관 비상대비'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'preparedness', effectiveness: 'High', role: '가족 실신 대비 의료 준비', dateTime: '2014-08-22', evidence: '가족들이 실신할 것에 대비하여 119 구급대를 준비시키고 ... 해군 군의관 및 간호장교가 비상상황에 대비', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0443'};
MATCH (a:ResponseActor {name: '정홍원 국무총리·안전행정부 장관'}), (b:ResponseAction {name: '진도군민 보상·지원 약속'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', effectiveness: 'Med', role: '진도군민 지원책 약속', evidence: '참사 100일째인 7월 24일 정홍원 총리가 진도를 찾아 ... 진도군민들에게 정부의 적극적인 지원을 약속', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0444'};
