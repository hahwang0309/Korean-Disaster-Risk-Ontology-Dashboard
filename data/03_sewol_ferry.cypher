MATCH (a:Event {name: '조도 주민 고립(뱃길 차단)'}), (b:Damage {name: '조도 주민 생활 피해'}) MERGE (a)-[r:CAUSES]->(b) SET r += {mechanism: '병원 방문 시기 놓침, 생필품 반입 지연', scale: '주민 생활 피해', evidence: '조도 주민들은 병원 방문 시기를 놓쳐 병세가 악화되기도 하고, 생필품도 제때 섬으로 들여오지 못했다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0456'};
