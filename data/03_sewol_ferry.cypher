MATCH (a:ResponseAction {name: '팽목항 항구 일부 개방 결정'}), (b:Event {name: '조도 주민 고립(뱃길 차단)'}) MERGE (a)-[r:MITIGATES]->(b) SET r += {effectiveness: 'High', timing: '2014-05-30 항구 개방', mechanism: '출입로 개방으로 조도 뱃길 회복', evidence: '이에 따라 5월 30일 팽목항 항구가 열리게 되었다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0459'};
MATCH (a:Event {name: '세월호 침몰사고'}), (b:Damage {name: '진도 어업 피해(어장 황폐화)'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {mechanism: '사고해역 유실방지용 대형·중형 저인망어선 집중 조업으로 어장 황폐화', timing: '참사 이후~10월', spreadRisk: 'Med', evidence: '대형·중형기선저인망이 사고지점 외곽에서 집중적으로 그물을 끌고 있어 어장이 황폐화되고 어족자원이 고갈되고 있다고 호소했다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0460'};
MATCH (a:ManmadeHazard {name: '사고해역 유실방지 저인망·채낚기 어선 조업'}), (b:Damage {name: '진도 어업 피해(어장 황폐화)'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'High', mechanism: '어장 생태계 혼란·어족자원 고갈', evidence: '채낚기어선(8척)도 사고지점에서 야간에 집중적으로 불을 밝히고 있어 어장 생태계의 혼란 우려 등 장기적으로 어업 피해가 우려되므로', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0461'};
MATCH (a:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}), (b:ResponseAction {name: '어민-실종자가족 어업갈등 중재'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', role: '갈등 중재', effectiveness: 'High', evidence: '세월호 특위는 동원 저인망 어선을 통한 유실물 실적을 점검한 결과 ... 어민들의 요청을 수용하도록 하여 어민과의 갈등 발생 상황을 중재·해결하였다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0462'};
MATCH (a:Event {name: '세월호 침몰사고'}), (b:Damage {name: '진도체육관 사용 차질(군 행사 취소)'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {mechanism: '진도체육관을 실종자 가족 거처로 장기 점유하여 군 행사·도민체전 차질', timing: '참사 이후 장기화', spreadRisk: 'Med', evidence: '진도체육관에서 개최예정이던 모든 행사가 줄줄이 취소되는 등 일상으로의 회복에 어려움을 겪고 있었다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0463'};
MATCH (a:Damage {name: '진도체육관 사용 차질(군 행사 취소)'}), (b:Event {name: '진도체육관 이전 갈등'}) MERGE (a)-[r:CAUSES]->(b) SET r += {mechanism: '거처 이전 요구 vs 도민체전 연기 요구의 입장차, 언론 보도로 여론 악화', timing: '2014-09-25 표면화', evidence: '9월 25일에는 진도군민 30여명이 진도체육관에 방문하여 실종자 가족과 직접 대화하겠다고 하는 과정에서 유가족과의 언쟁으로 갈등이 표면화되기에 이르렀다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0464'};
MATCH (a:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}), (b:ResponseAction {name: '진도체육관 문제 3자 협의 제안·개최'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', role: '3자 중재 제안', timing: '2014-10-01', evidence: '진도체육관 이전문제를 정부, 진도군민, 실종자 가족의 3자 협의를 통해 해결하고자 하였다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0465'};
MATCH (a:ResponseAction {name: '진도체육관 문제 3자 협의 제안·개최'}), (b:Event {name: '진도체육관 이전 갈등'}) MERGE (a)-[r:MITIGATES]->(b) SET r += {effectiveness: 'High', mechanism: '수임기구(TF) 구성 합의로 갈등을 대안 마련 논의로 전환', evidence: '수임기구(TF) ... 대책을 마련하기로 하면서 진도체육관을 둘러싼 갈등은 해결 국면을 맞이하게 된다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0466'};
MATCH (a:ResponseActor {name: '이주영 해양수산부 장관'}), (b:ResponseAction {name: '진도체육관 문제 3자 협의 제안·개최'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', role: '3자 협의 주재', timing: '2014-10-01', evidence: '진도군청에서 이주영 장관의 주재로 정부, 실종자 가족, 진도군민 3자가 함께 만나', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0467'};
MATCH (a:ResponseActor {name: '3자(정부·실종자가족·진도군민)'}), (b:Resilience {name: '진도체육관 대안마련 수임기구(TF)'}) MERGE (a)-[r:BUILDS]->(b) SET r += {timing: '2014-10-01', effectiveness: 'High', evidence: '3자는 \'진도체육관 대안마련을 위한 수임기구(TF)\' 구성에 합의하였으며', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0468'};
MATCH (a:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}), (b:ResponseAction {name: '정홍원 국무총리·정종섭 안행부 장관에 진도군 지원책 요청'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', role: '정부 지원 요청', evidence: '정홍원 국무총리, 정종섭 안전행정부 장관에게 진도군민에 대한 지원책을 마련할 것을 요청하여, 진도 현안사업에 대한 국비지원이 대거 반영되는 등', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0469'};
MATCH (a:ResponseActor {name: '정홍원 국무총리'}), (b:Damage {name: '진도지역 경제적 손실'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {phase: 'recovery', consequence: '진도 현안사업 국비지원 대거 반영', evidence: '정홍원 국무총리, 정종섭 안전행정부 장관에게 ... 진도 현안사업에 대한 국비지원이 대거 반영되는 등', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0470'};
MATCH (a:ResponseActor {name: '정종섭 안전행정부 장관'}), (b:Damage {name: '진도지역 경제적 손실'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {phase: 'recovery', evidence: '정홍원 국무총리, 정종섭 안전행정부 장관에게 진도군민에 대한 지원책을 마련할 것을 요청', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0471'};
MATCH (a:ResponseActor {name: '세월호 참사 국민대책회의'}), (b:ResponseAction {name: '기다림의 버스 운행'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', role: '국민 정기방문 지원', timing: '2014-06-05 첫 운행 이후 매주 금요일', evidence: '\'세월호 참사 국민대책회의\'가 운영하는 『기다림의 버스』는 매주 금요일마다 국민들을 태우고 팽목항으로 향해 실종자 가족과 본격적으로 함께하였다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0472'};
MATCH (a:ResponseAction {name: '기다림의 버스 운행'}), (b:Damage {name: '실종자 가족 심리적 고통'}) MERGE (a)-[r:MITIGATES]->(b) SET r += {effectiveness: 'High', mechanism: '지속적 방문·위로로 실종자 가족 심리적 버팀목 제공', evidence: '국민들이 실종자 가족을 부둥켜안고 흘리는 눈물은 실종자 가족이 고통을 이겨내는 가장 든든한 버팀목이 되었으며', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0473'};
MATCH (a:Event {name: '세월호 침몰사고'}), (b:Damage {name: '실종자 가족 심리적 고통'}) MERGE (a)-[r:CAUSES]->(b) SET r += {mechanism: '실종자 미수습·장기 수색으로 가족의 심리적 고통·고립', scale: '지속', evidence: '우리 실종자 가족들과 잃어버린 10명과의 마지막 만남을 위해 기도해주실 것을 간절히 청한다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0474'};
MATCH (a:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}), (b:ResponseAction {name: '시민사회 연대 활동반경 확대(광주·목포·해남)'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', role: '시민사회 연대 확대', evidence: '세월호 특위는 시민사회가 실종자 가족의 버팀목이 될 수 있도록 활동반경을 진도에서 광주, 목포, 해남 등지로 넓혀나갔다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0475'};
MATCH (a:ResponseActor {name: '세월호 광주대책위'}), (b:ResponseAction {name: '광주지역 실종자 가족 연대·조력'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', role: '실종자 가족 조력', evidence: '세월호 광주대책위는 실종자 가족의 가장 든든한 조력자가 되었다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0476'};
MATCH (a:ResponseActor {name: '해남군민·목포시민'}), (b:ResponseAction {name: '실종자 가족 건강·트라우마 지원'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', role: '복지 지원·특산물 판매', evidence: '해남군민과 목포시민들은 ... 실종자 가족 및 자원봉사자들의 복지를 헌신적으로 지원하였다. 광주, 목포, 해남 지역은 진도지역 특산물 판매 등 진도군민들의 어려움도 덜어 주고자 노력하며', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0477'};
MATCH (a:ResponseActor {name: '프란치스코 교황'}), (b:ResponseAction {name: '교황의 세월호 유가족·실종자가족 위로'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', role: '위로·치유 메시지', timing: '2014-08-14~17 방한', evidence: '교황은 8월 14일 서울공항에 도착하자마자 ... 세월호 유가족들에게 다가가 손을 맞잡고 ... 위로의 메시지를 전한 것을 비롯하여', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0478'};
MATCH (a:ResponseAction {name: '교황의 세월호 유가족·실종자가족 위로'}), (b:Damage {name: '실종자 가족 심리적 고통'}) MERGE (a)-[r:MITIGATES]->(b) SET r += {effectiveness: 'High', mechanism: '교황의 편지·묵주 전달과 위로로 실종자 가족 심리 회복', timing: '참사 126일째', evidence: '실종자 가족들은 저녁 내내 \'교황이 직접 내려와 위로해주신 것처럼 마음이 환해졌다\'고 말했으며 ... 통곡과 고통의 땅 팽목항에 오랜만에 평안과 치유의 시간이 찾아온 것이다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0479'};
MATCH (a:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}), (b:ResponseAction {name: '교황에게 실종자 가족 서신 작성·전달'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', role: '교황 서신 전달 매개', timing: '2014-08-14', evidence: '세월호 특위는 교황에게 전하고 싶은 실종자 가족의 목소리를 수렴하여 \'교황에게 보내는 실종자 가족의 서신\'을 8월 14일 한글본과 영문본으로 작성하여 ... 교황에게 전달하였다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0480'};
MATCH (a:ResponseActor {name: '이성효 주교·김건태 신부'}), (b:ResponseAction {name: '교황 편지·묵주 전달식(팽목항)'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', role: '교황 편지·묵주 전달식', timing: '2014-08-19', evidence: '8월 19일 진도 팽목항 천주교 천막교회에는 교황의 기도와 위로가 울려 퍼졌다. ... \'교황 편지·묵주 전달식\'을 통해 교황의 당부를 전했다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0481'};
MATCH (a:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}), (b:ResponseAction {name: '기자회견·언론 대응 활동'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', role: '여론 조성·언론 대응', effectiveness: 'Med', evidence: '진도군청 및 팽목항에서의 기자회견 횟수는 51회에 달한다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0482'};
MATCH (a:Event {name: '세월호 유가족-대리기사 사건(2014.09.16)'}), (b:Event {name: '세월호 특별법 여론 악화·수색 중단 우려'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {mechanism: '사건으로 세월호 특별법 여론 급격 악화, 진도 수색 중단 우려로 파급', spreadRisk: 'High', timing: '2014-09-16 이후', evidence: '9월 16일 세월호 유가족과 대리기사 간의 불미스러운 사건이 벌어져 세월호 특별법에 대한 여론이 급격히 악화되면서, 실종자 가족들은 진도까지 그 여파가 미쳐 수색 중단으로 이어지는 것은 아닌지 불안해하였고', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0483'};
MATCH (a:ResponseActor {name: '진도군 민주시민단체'}), (b:ResponseAction {name: '실종자 가족 옹호 기자회견(10.01)'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', role: '실종자 가족 입장 옹호 기자회견', evidence: '진도군 민주시민단체는 실종자 가족의 입장을 이해하고 더 기다려 줄 것을 진도군민들에게 호소하는 기자회견을 10월 1일 오전에 개최하면서', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0484'};
MATCH (a:Facility {name: '진도체육관'}), (b:Damage {name: '진도체육관 사용 차질(군 행사 취소)'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {mechanism: '유일 종합시설이라 대체 불가, 실종자 가족 거처 점유로 행사 차질 가중', scale: '지역 서비스 마비', evidence: '진도체육관은 진도군의 각종 행사가 개최되는 진도군의 유일한 종합시설이므로 참사 이후 진도체육관에서 개최예정이던 모든 행사가 줄줄이 취소되는 등', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0485'};
MATCH (a:Population {name: '조도 주민'}), (b:Damage {name: '조도 주민 생활 피해'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {mechanism: '섬 주민이라 화물 뱃길 차단 시 병원·생필품 접근 차단으로 피해 가중', scale: '고립 취약', evidence: '조 도 주민들은 병원 방문 시기를 놓쳐 병세가 악화되기도 하고, 생필품도 제때 섬으로 들여오지 못했다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0486'};
MATCH (a:ResponseAction {name: '교황에게 실종자 가족 서신 작성·전달'}), (b:Other {name: '참고자료 2-26 교황께 드리는 세월호 실종자 가족들의 서신'}) MERGE (a)-[r:GUIDED_BY]->(b) SET r += {role: '참고자료 근거', evidence: '49) 참고자료 2-26. 교황께드리는세월호실종자가족들의서신(2014.08.14.)', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0487'};
MATCH (a:Population {name: '실종자 가족'}), (b:Facility {name: '진도체육관'}) MERGE (a)-[r:LOCATED_IN]->(b) SET r += {role: '거처', evidence: '진도체육관에서 머무르고 있는 실종자 가족들의 거처를 이전해 줄 것을', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0488'};
MATCH (a:Event {name: '세월호 실종자 수중수색'}), (b:Event {name: '세월호 수색중단 결정(2014-11-11)'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {mechanism: '동절기 수색환경 악화·잠수사 안전 위협으로 수색중단 결정', timing: '2014-11-11', reason: '잠수사 안전 위험, 동절기 수색환경 악화', evidence: '11월 11일 오전 실종자 가족 전체회의에서 수색중단을 결정하는 기자회견에 어느 누구도 반대하지 않았다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0489'};
MATCH (a:RiskFactor {name: '동절기 수색환경 악화'}), (b:Event {name: '세월호 수색중단 결정(2014-11-11)'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {mechanism: '잠수사 안전 위험 증대→민간수색팀 철수 발언·수색중단 압력', probability: 'High', evidence: '11월 동절기로 넘어가면서 수색환경이 악화되는 수색 막바지에 이르러 제기되는 민간구조팀 내부의 철수 발언 / 수색상황과 잠수사 안전이 악화되면서', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0490'};
MATCH (a:RiskFactor {name: '잠수사 안전 위험'}), (b:Event {name: '잠수사 인명사고 우려'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {mechanism: '잠수 인력·장비 축소 및 안전 악화가 추가 인명사고 위험 증대', probability: 'Med', evidence: '동절기 수색을 지속하면서 잠수사의 안전과 생명에 대한 큰 사고가 발생했다면', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0491'};
MATCH (a:Event {name: '잠수 인력 및 장비 축소'}), (b:Damage {name: '수색 차질'}) MERGE (a)-[r:TRIGGERS_SECONDARY]->(b) SET r += {mechanism: '수색 자원 축소가 수색역량 약화→수색 차질', reason: '수색 인력·장비 감소', spreadRisk: 'Med', evidence: '잠수 인력 및 장비 축소,57) ... 수색에 차질을 초래할 수 있는 현안 / 57) 참고자료 2-31. 잠수인력및장비축소에대한입장(2014.06.29.)', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0492'};
MATCH (a:Event {name: '세월호 실종자 수중수색'}), (b:Damage {name: '실종자 가족 건강 악화'}) MERGE (a)-[r:CAUSES]->(b) SET r += {mechanism: '수면 부족·탈진 반복으로 실종자 가족 건강 악화', scale: '지속적', evidence: '늘 실종자 가족의 팔에는 링거가 꽂혀있었다 / 입·퇴원을 반복하는 등으로 실종자 가족의 건강은 항시 탈진과 회복의 연속이었다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0493'};
MATCH (a:Damage {name: '실종자 가족 건강 악화'}), (b:Event {name: '실종자 가족 내부 갈등·의사결정 곤란'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {mechanism: '육체적·정신적 소진으로 가족 내 의사결정·의견통일 곤란', reason: '탈진·예민화', evidence: '실종자 가족들이 육체적, 정신적으로 지쳐있는 상태에서의 토론은 10분을 넘기지 못하고 종종 감정의 대립으로 격화되어 극단적 갈등으로 나타나기도', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0494'};
MATCH (a:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}), (b:ResponseAction {name: '기자회견·언론 대응(진도)'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '대언론 활동·기자회견', effectiveness: 'High', phase: 'response', evidence: '진도군청 및 팽목항에서의 기자회견 횟수는 51회에 달한다 / 세월호 특위의 적극적인 대언론활동 및 기자회견은 ... 국민의 지지를 이어나가고', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0495'};
MATCH (a:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}), (b:ResponseAction {name: '실종자 가족-정부 간 가교·조율·중재'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '가교·조율·중재', effectiveness: 'Med', phase: 'response', evidence: '세월호 특위는 실종자 가족과 해경 중심의 현장지휘본부, 해양수산부 중심의 범대본 사이의 가교 역할을 담당하면서 ... 상호 간의 입장을 조율·중재', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0496'};
MATCH (a:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}), (b:ResponseAction {name: '실종자 가족 대표 선출'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '실종자 가족 누구도 대표직을 원하지 않음, 책임 전가 우려', effectiveness: 'Low', phase: 'response', evidence: '세월호 특위는 지속적으로 실종자 가족 대표를 선출하고자 하였으나 실패하였고', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0497'};
MATCH (a:Event {name: '실종자 가족 대표 선출 실패'}), (b:Damage {name: '수색 의사결정 적기 상실'}) MERGE (a)-[r:CAUSES]->(b) SET r += {mechanism: '대표 부재로 모든 가족 의견을 개별 면담으로 결정→적절한 시점 상실', reason: '의사결정 지연', evidence: '모든 가족의 의견을 개별 면담을 통해 결정하는 과정에서 적절한 시점을 놓치는 경우가 잦았다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0498'};
MATCH (a:ResponseActor {name: '세월호 특위 변호사'}), (b:ResponseAction {name: '실종자 가족 의견수렴·설득·중재(변호사)'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '법률대리·의견수렴·중재', effectiveness: 'Med', phase: 'response', specialNote: '중립적 제3자 위치 유지 불가, 가족 일원화', evidence: '변호사는 실종자 가족에게 보고사항을 작성하여 나누어 주면서 개별 가족들과 대화하고 의견을 수렴하였다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0499'};
MATCH (a:ResponseActor {name: '세월호 특위 변호사'}), (b:Event {name: '세월호 수색중단 결정(2014-11-11)'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {role: '고통스러운 결단 지원', timing: '2014-11-11', phase: 'response', evidence: '수색중단결정은 가족 간의 갈등이 최고조에 이르는 순간이었다 ... 실종자 가족들은 눈물을 머금고 고통스런 결단을 내려야 했다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0500'};
MATCH (a:Event {name: '실종자 가족 내부 갈등·의사결정 곤란'}), (b:Damage {name: '유가족의 변호사 폭행'}) MERGE (a)-[r:CAUSES]->(b) SET r += {mechanism: '극단적 갈등·울분이 변호사 폭행으로 표출', reason: '대참사 유가족 특수 상황', evidence: '결국 갈등이 극단적으로 표출되어 울분이 쌓인 한 유가족이 세월호 특위 변호사를 폭행하는 일도 일어났다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0501'};
MATCH (a:RiskFactor {name: '유가족과 실종자 가족 간 입장 차이'}), (b:Event {name: '유가족-실종자 가족 마찰'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {mechanism: '근본적 입장 차이가 가족 간 마찰·비판 증대', probability: 'High', evidence: '유가족은 정부와 싸워야 한다는 입장인 반면, 실종자 가족은 정부가 수색의 주체인 상황에서 정부와의 대립보다는 보완과 중재, 조율을 원하였다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0502'};
MATCH (a:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}), (b:ResponseAction {name: '수색 차질 현안 적극 대응'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '현안 적극 대응', effectiveness: 'Med', phase: 'response', evidence: '수색에 차질을 초래할 수 있는 현안에 대해서는 적극적으로 대응하였다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0503'};
MATCH (a:Event {name: '청와대 대변인 발언(잠수사 사기 저하)'}), (b:Damage {name: '잠수사 사기 저하'}) MERGE (a)-[r:TRIGGERS_SECONDARY]->(b) SET r += {mechanism: '정부측 발언이 잠수사 사기·수색 동력 저하', reason: '부적절 발언', spreadRisk: 'Med', evidence: '잠수사의 사기를 떨어뜨리는 청와대의 발언,56) / 56) 참고자료 2-30. 청와대대변인의발언에대한입장(2014.05.27.)', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0504'};
MATCH (a:Event {name: '민간구조팀(언딘) 철수 발언'}), (b:Damage {name: '실종자 가족 불안감 증폭·언론 불신'}) MERGE (a)-[r:TRIGGERS_SECONDARY]->(b) SET r += {mechanism: '철수 발언 보도가 실종자 가족 불안감 증폭·기자 불신 심화', spreadRisk: 'Med', evidence: '민간구조팀의 철수 입장에 대한 보도가 늘어났고, 이에 실종자 가족의 불안감이 증폭되면서 기자들에 대한 가족의 불신은 커져갔다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0505'};
MATCH (a:ResponseActor {name: '범정부사고대책본부'}), (b:ResponseAction {name: '수색계획 입장 발표·소통'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '수색계획 입장 발표 않고 침묵하는 태도로 기자 질타', effectiveness: 'Low', phase: 'response', evidence: '수색계획과 관련한 입장을 발표하지 않고 침묵하는 범대본의 태도를 질타하기도 하였다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0506'};
MATCH (a:ResponseActor {name: '범정부사고대책본부'}), (b:ResponseActor {name: '이주영 해양수산부 장관'}) MERGE (a)-[r:BELONGS_TO]->(b) SET r += {role: '지휘 책임자', specialNote: '이주영 해양수산부 장관·김석균 해경청장', evidence: '수색을 지휘하는 범대본 이주영 장관 및 김석균 해경청장 / 세월호 인양TF를 구성한다는 이주영 장관의 약속', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0507'};
MATCH (a:ResponseActor {name: '이주영 해양수산부 장관'}), (b:ResponseAction {name: '세월호 인양TF 구성'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '인양TF 구성 약속', phase: 'recovery', timing: '수색중단 결정 전후', evidence: '세월호 인양TF를 구성한다는 이주영 장관의 약속이 있은 후', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0508'};
MATCH (a:ResponseAction {name: '세월호 선체 인양'}), (b:Damage {name: '세월호 미수습 실종자'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {role: '잔여 실종자 수습', phase: 'recovery', evidence: '세월호의 남은 실종자 9명이 모두 가족의 품으로 돌아갈 수 있기를 / 정부가 세월호 선체 인양을 통해 \'실종자를 마지막 한 명까지 찾겠다\'', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0509'};
MATCH (a:ResponseActor {name: '정홍원 국무총리'}), (b:Population {name: '실종자 가족'}) MERGE (a)-[r:COORDINATES_WITH]->(b) SET r += {role: '유임 입장 대립', specialNote: '실종자 가족은 유임 찬성, 유가족은 책임 회피로 비판', evidence: '정홍원 총리의 유임, 이주영 장관의 유임에 대해서도 기본적으로 찬성의 입장을 보이며 기자회견을 열었던 반면, 유가족들은 정 총리의 유임이 ... 강하게 비판', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0510'};
MATCH (a:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}), (b:ResponseActor {name: '언론(기자)'}) MERGE (a)-[r:COORDINATES_WITH]->(b) SET r += {role: '재난보도 원칙 vs 알 권리 마찰', specialNote: '피해자 가족 배려 vs 국민 알 권리 간 간격', evidence: '세월호 특위는 피해자 가족에 대한 배려라는 재난보도의 원칙을 강조한 반면, 언론은 국민들의 알 권리와 사실을 그대로 보도하는 입장을 견지', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0511'};
MATCH (a:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}), (b:Resilience {name: '2/3 찬성 의사결정 기준'}) MERGE (a)-[r:BUILDS]->(b) SET r += {role: '의사결정 회복력 구축', effectiveness: 'Med', specialNote: '만장일치 불가→2/3 찬성 기준 마련', evidence: '변호사의 진도 파견을 해제하고 나서야 2/3 찬성이라는 의사결정의 기준이 마련되어 변호사가 다시 진도로 재파견되었다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0512'};
MATCH (a:Event {name: '진도체육관 갈등(가족 거점 이전)'}), (b:ResponseAction {name: '진도체육관 대안마련 TF 구성'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {role: '갈등 해결 국면 전환', timing: '2014-10-01 3차 협의', phase: 'response', evidence: '10월 1일 회동으로 3차는 \'진도체육관 대안마련을 위한 수입기구(TF)\' 구성에 합의하였으며 ... 진도체육관을 둘러싼 갈등은 해결 국면을 맞이', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0513'};
MATCH (a:Event {name: '9월 16일 세월호 유가족-대리기사 사건'}), (b:Damage {name: '세월호 특별법 여론 악화'}) MERGE (a)-[r:TRIGGERS_SECONDARY]->(b) SET r += {mechanism: '사건 발생이 세월호 특별법 여론 급격 악화→수색 중단 우려 확산', spreadRisk: 'High', evidence: '9월 16일 세월호 유가족과 대리기사 간의 불미스러운 사건이 벌어져 세월호 특별법에 대한 여론이 급격히 악화', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0514'};
MATCH (a:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}), (b:ResponseAction {name: '변협 현장조사단 1차 진도 방문'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '현장조사단 파견', phase: 'preparedness', timing: '2014-04-17~04-21', evidence: '4/19-4/21 법렘 현장조사단 1차 진도 방문, 진도실내체육관 & 팽목항 상황 파악 / 2014년 4월 18일 밤 현장에 파견된 변호사들은 진도실내체육관, 팽목항을 오가며', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0515'};
MATCH (a:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}), (b:ResponseAction {name: '법률지원단 제안(진도)'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '법률지원단 제안', phase: 'preparedness', timing: '2014-04-20', evidence: '4/20 법렘 현장조사단, 진도실내체육관 피해가족 대표에 법률지원단 제안 / 법률지원단의 역할로는 ① 대표단의 단순 실무, ② 대정부 협상 ... 자문 및 조언', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0516'};
MATCH (a:ResponseActor {name: '진도실내체육관 피해가족 대표'}), (b:ResponseAction {name: '법률지원단 제안 수용'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '내부 회의에서 법률지원 안건 부결, 정부 파견 공무원 의심·불신', effectiveness: 'Low', timing: '2014-04-21', evidence: '4/21 진도실내체육관 피해가족 대표, 법률지원단 제안 거부 의사 / 피해가족 대표는 내부 회의에서 법률지원 안건이 부결되었음을 알려왔고', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0517'};
MATCH (a:RiskFactor {name: '언론의 오보·정부 초기 부실 대응'}), (b:Event {name: '피해가족 변호사 접근 거부·지원 지연'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {mechanism: '분노·불신 극대화가 변호사 접근 거부·지원 지연으로 이어짐', probability: 'High', evidence: '언론의 오보, 정부의 초기 부실 대응 등으로 인해 분노와 불신이 극에 달한 상황이었고 ... 변호사의 접근도 극도로 꺼리고', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0518'};
MATCH (a:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}), (b:ResponseAction {name: '변협 세월호 참사 장단기 활동 제안'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '장단기 활동 제안', phase: 'preparedness', timing: '2014-04-21', evidence: '변협에 세월호 참사 관련 장단기 활동을 제안했다 ... ① 단기적으로는 현장 법률지원, 중기적으로는 국가배상청구 등 공익소송, 장기적으로는 관련 법령의 개폐', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0519'};
MATCH (a:ResponseAction {name: '변협 세월호 참사 장단기 활동 제안'}), (b:Resilience {name: '변협 재난긴급대응 법률지원 매뉴얼·재난대응단위'}) MERGE (a)-[r:BUILDS]->(b) SET r += {role: '재난대응 역량 제도화', effectiveness: 'Med', specialNote: '태안 기름유출·세월호 경험 및 외국 사례 연구', evidence: '② 변협내 재난대응단위 임시 구성 및 재난대응단위의 임시 근거 규정 마련, ③ ... 변협 차원의 재난긴급대응 법률지원 매뉴얼 제작', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0520'};
MATCH (a:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}), (b:ResponseAction {name: '변협 현장조사단 안산 방문(1-4차)'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '안산 현장조사·면담', phase: 'preparedness', timing: '2014-04-21~04-24', location: '안산', evidence: '4/21-4/24 법렘 현장조사단, 1-4차 안산 방문, 안산 상황 파악', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0521'};
MATCH (a:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}), (b:ResponseAction {name: '변협 세월호 공익법률지원단 구성'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '공익법률지원단 모집·워크샵', phase: 'preparedness', timing: '2014-04-30~05-03', evidence: '4/30 변협 세월호 참사 공익법률지원단 모집 안내 / 5/03 변협 세월호 참사 공익법률지원단 워크샵 개최 / ② 1 피해자 가족 1 변호사 제도', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0522'};
MATCH (a:ResponseActor {name: '세월호 가족대책위'}), (b:Event {name: '세월호 침몰사고'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {role: '피해가족 조직화', phase: 'response', specialNote: '직접 관련 피해가족 천명 이상, 조직 운영 난항', evidence: '다수의 피해자가 발생하였고, 직접적인 관련 피해가족만 천명이 넘은 상황에서 하나의 조직을 구성하고 운영', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0523'};
MATCH (a:Event {name: '세월호 침몰사고'}), (b:Damage {name: '세월호 피해가족(천명 이상)'}) MERGE (a)-[r:CAUSES]->(b) SET r += {mechanism: '다수 피해자 발생', scale: '천명 이상', evidence: '직접적인 관련 피해가족만 천명이 넘은 상황에서', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0524'};
MATCH (a:ResponseAction {name: '정부 초기 대응 미비(생계지원·진상규명)'}), (b:Damage {name: '피해가족 자력 활동 내몰림'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '정부·여당 준비 부족·소극적 태도', effectiveness: 'Low', phase: 'response', evidence: '생계 지원에 있어서도 통합적이고 체계적인 정부 대응이 미비하였다. 진상규명을 위한 활동에 있어서도 정부 및 여당의 소극적인 태도로 인하여 피해가족들이 ... 내몰렸다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0525'};
MATCH (a:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}), (b:ResponseAction {name: '피해가족 조직 안정화·운영 자문'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '피해가족 조직 안정화·자문', phase: 'response', evidence: '조직의 구성, 운영 등에 대한 지속적인 자문을 수행하였다 / 나. 피해가족 조직 안정화, 유지 지원', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0526'};
MATCH (a:Context {name: '맹골수도'}), (b:Event {name: '세월호 실종자 수중수색'}) MERGE (a)-[r:OCCURS_AT]->(b) SET r += {role: '수색 작전 지점', timing: '2014년 수색기간', evidence: '해경정을 타고 사고해역에 나가 바지선에서 수중수색상황을 지켜보고, 유실방지 항공점검을 하는 등', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0527'};
MATCH (a:RiskFactor {name: '세월호 선령 연장'}), (b:Event {name: '세월호 침몰사고'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {mechanism: '노후 선박 구조 취약성 증가', probability: 'High', reason: '침몰 원인 중 하나로 지목', evidence: '선령(船齡) 연장, 불법 증개축, 과적, 운항 ... 침몰 과정', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0528'};
MATCH (a:ManmadeHazard {name: '세월호 부실 운항'}), (b:Event {name: '세월호 침몰사고'}) MERGE (a)-[r:TRIGGERS]->(b) SET r += {probability: 'High', mechanism: '운항 과실이 전복·침몰을 직접 유발', directCause: '운항', evidence: '선령 연장, 불법 증개축, 과적, 운항 ... 침몰 과정', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0529'};
MATCH (a:Facility {name: '세월호(여객선)'}), (b:Event {name: '세월호 침몰사고'}) MERGE (a)-[r:AFFECTS]->(b) SET r += {role: '위해 발현 대상 시설', mechanism: '여객선이 해저로 침몰', evidence: '세월호는 해저로 침몰해갔으며', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0530'};
MATCH (a:Event {name: '세월호 침몰사고'}), (b:Context {name: '2014-04-16 세월호 참사 발생일'}) MERGE (a)-[r:OCCURS_AT]->(b) SET r += {timing: '2014-04-16', evidence: '2014년 4월 16일, 세월호 참사가 발생한 후', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0531'};
MATCH (a:Event {name: '세월호 침몰사고'}), (b:Event {name: '세월호 대형참사'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {mechanism: '사후 인명 구조 및 대처 과정의 치명적 문제점으로 인해 대형참사로 확대', directCause: '인명 구조 및 대처 과정 실패', probability: 'High', spreadRisk: 'High', specialNote: '단순 사고→대형참사 전이의 핵심 연쇄', evidence: '단순한 \'사건\'에 머물렀을 수도 있는 이 사고는 사후 인명 구조 및 대처 과정에서 치명적인 문제점을 드러내면서 \'대형참사\'로 번지게 되었다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0532'};
MATCH (a:ResponseAction {name: '세월호 구조·구난 대응'}), (b:Event {name: '세월호 침몰사고'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {effectiveness: 'Low', reason: '치명적 문제점을 드러냄', timing: '침몰 직후', evidence: '사후 인명 구조 및 대처 과정에서 치명적인 문제점을 드러내면서', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0533'};
