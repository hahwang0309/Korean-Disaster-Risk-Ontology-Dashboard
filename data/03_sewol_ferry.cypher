MATCH (a:ResponseActor {name: '세월호 특위 특별법 제정팀'}), (b:ResponseAction {name: '여야 협상 모니터링 및 의견제출'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '협상 모니터링 및 찬반 의견 제출', timing: '2014-07-13~15', mechanism: '전문위원 정리내용·대안에 찬성/반박 의견 제출, 2+2 회담·원내대표 회담 모니터링', effectiveness: 'Med', evidence: '여/야 협상 과정에서 나온 결과물, 특히, 특별법안에 대하여 전문위원이 정리한 내용과 제시된 대안에 대하여 찬성 혹은 반박하는 의견 제출 작업을 꾸준히 진행', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0606'};
MATCH (a:Population {name: '단원고 생존학생'}), (b:ResponseAction {name: '안산~국회 특별법 제정 촉구 1박2일 행진'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {role: '특별법 제정 촉구 도보행진', timing: '7월 중순', scale: '안산~국회 1박 2일 행진', evidence: '단원고 생존학생들로부터 안산에서 국회까지 특별법 제정을 촉구하는 1박 2일 행진을 하겠다는 소식이 들려왔다', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T0607'};
