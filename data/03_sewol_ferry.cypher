MATCH (a:Event {name: '세월호 구조 실패'}), (b:Event {name: '가족들의 2차 피해 발생'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {probability: 'High', mechanism: '구조 실패 및 정부 대응 부실로 유가족에게 추가 피해 발생', spreadRisk: 'Med', evidence: '정부의 부실한 대응 및 혼선 ... 으로 인한 실종자 구조 실패, 가족들의 2차 피해와 관련 법적 문제를 확인할 수 있었다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1119'};
MATCH (a:Event {name: '가족들의 2차 피해 발생'}), (b:Damage {name: '세월호 피해자·유가족 2차 피해'}) MERGE (a)-[r:CAUSES]->(b) SET r += {directCause: '2차 피해', mechanism: '신체·정신적 상처 및 법적 문제', evidence: '가족들이 입은 몸과 마음의 상처 치유가 시급하고 ... 가족들의 2차 피해와 관련 법적 문제', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1120'};
MATCH (a:Population {name: '세월호 화물 적재 사업자(물적 피해)'}), (b:Damage {name: '세월호 화물 물적 피해'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {role: '물적 피해 대상', mechanism: '화물 적재 후 침몰로 물적 피해', evidence: '정부는 세월호에 화물을 적재하여 물적 피해를 받은 사업에 대한 지원 대책을 마련할 수 있으며', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1121'};
MATCH (a:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}), (b:ResponseAction {name: '진도 현장 변호사 파견 및 현장조사'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', timing: '2014-04-17~', role: '현장조사 파견', evidence: '4·16 참사 발생 바로 다음날 대한변협은 변호사 1명을 사건 현장인 진도로 파견 ... 4월 18일에는 변협 대표단 자격으로 7명의 변호사를 진도에 파견해 현장 상황을 기록 및 녹취, 공권력 등 인권침해 행위 등 감시', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1122'};
