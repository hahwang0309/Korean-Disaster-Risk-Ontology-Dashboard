MATCH (a:ResponseAction {name: '세월호 초기 구조 대응'}), (b:Event {name: '세월호 침몰사고'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {effectiveness: 'Low', timing: '사고 직후', evidence: '정부의 부실한 대응 및 혼선 ... 으로 인한 실종자 구조 실패', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1117'};
