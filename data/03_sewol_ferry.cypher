MATCH (a:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}), (b:ResponseAction {name: '세월호 특별위원회 및 공익법률지원단 구성'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'preparedness', timing: '2014-04-28', role: '특별위원회·지원단 구성', evidence: '대한변협은 사건발생 직후부터 총 17차(2014. 4. 21. ~ 5. 22.)에 걸쳐 세월호 피해대책 TF 회의를 열었다. ... 특별위원회를 구성하고, 공익법률지원단을 모집하기로 결의하였다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1124'};
MATCH (a:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}), (b:ResponseAction {name: '세월호 참사에 대한 대국민 성명 발표'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', timing: '2014-04-30', role: '대국민 성명 발표', evidence: '4월 30일 대한변협은 \'세월호 참사에 대한 대국민성명\'을 발표하였다. ... 참사의 원인 및 구조과정의 문제점, 책임소재를 철저히 규명하여 관련 법률의 제·개정, 위기관리와 재난대응시스템의 실질적인 변화를 이끌어', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1125'};
MATCH (a:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}), (b:ResponseAction {name: '변협-가족대책위 업무협약(MOU) 체결'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', timing: '2014-05-16', role: 'MOU 체결·법률지원 약속', evidence: '2014. 5. 16. ... 대한변협은 ... 가족대책위와 업무협약을 체결하고, ... 상담 및 자문 등 법률지원, 신청·고소·고발·소송 등 법률절차 대리, 관련 정책 및 제도 개선을 포함한 대책 마련', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1126'};
MATCH (a:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}), (b:ResponseAction {name: 'KBS·청와대 항의방문 동행 및 협상 지원'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', timing: '2014-05-08~2014-05-09', role: '항의방문 동행·협상 지원', evidence: 'KBS 보도국장의 ... 발언에 대하여 유가족들이 KBS와 청와대를 항의 방문하는 동안 변협 세월호 특위 위원들이 1박 2일간 동행하며 현장 인권침해를 방지하고 협상과정을 지원하였다.', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1127'};
MATCH (a:ResponseActor {name: '대한변협 세월호참사대응 특별위원회'}), (b:ResponseAction {name: '언론 대응 및 모니터링 활동'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', role: '언론대응·법적대응', effectiveness: 'Med', evidence: '언론 대응, 언론 모니터링 등을 통해서 고소, 고발 등 법적 대응을 했지만 ... 악성 댓글을 남기는 등 악의적 행동을 하는 것에 경각심을 심어준 것은 성과', sourceDoc: '4·16 세월호참사 백서(대한변협 2015)', tripleId: 'T1128'};
