MATCH (a:RiskFactor {name: '방화구획 미적용(단일 22,000㎡ 구획)'}), (b:Event {name: '화재 지하층 전체 연소확대'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {mechanism: '방화구획 부재로 화염 급속확산, 작업자 대피시간 미확보', effectiveness: 'High', reason: '완화규정 취지(컨베이어벨트 등) 오적용', evidence: '전체적으로 22,000㎡를 하나의 구획으로 보고 방화구획기준을 적용치 아니하였음 ... 화재의 확산을 빠르게 진행시키는 데 크게 일조하여 ... 작업자가 대피할 시간을 주지 않은 것', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0009'};
MATCH (a:RiskFactor {name: '피난 직통계단 부족(1개소)'}), (b:Damage {name: '코리아2000 화재 인명피해(사망40·부상10)'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {mechanism: '피난동선 부족·과대 보행거리로 탈출 곤란', effectiveness: 'High', evidence: '직통계단이 2개소에서 1개소로 변경 ... 거실의 각 부분에서 직통계단과의 보행거리가 30m를 초과하여 설치됨', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0010'};
MATCH (a:RiskFactor {name: '냉동창고 내부 동시 마무리공사(57명 작업)'}), (b:Damage {name: '코리아2000 화재 인명피해(사망40·부상10)'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {mechanism: '다수 작업자 밀폐공간 재실 중 화재 발생', effectiveness: 'High', evidence: '냉동설비 담당 34명, 전기설비 담당 17명, 에어컨설비 담당 3명, 관리자 3명 등 모두 57명의 작업자가 있었으므로', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0011'};
MATCH (a:Event {name: '코리아2000 냉동창고 화재(2008)'}), (b:Event {name: '13호 냉동실 발화'}) MERGE (a)-[r:TRIGGERS]->(b) SET r += {probability: 'High', mechanism: '발화 열원이 유증기·우레탄폼에 착화', timing: '2008-01-07 10:45', evidence: '화재의 시작은 오전 10시 45분경 지하 냉동창고 코너 끝 쪽에 있는 13호 냉동실에서 일어난 것으로 목격', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0012'};
MATCH (a:Event {name: '13호 냉동실 발화'}), (b:Event {name: '급격연소 및 폭발'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {probability: 'High', mechanism: '잔존 유증기·우레탄폼 착화로 순식간 화재확대·폭발', spreadRisk: 'High', timing: '발화 직후', evidence: '잔존하는 유증기로 인해 순식간에 화재가 확대되어 폭발이 일어나 작업자 대부분이 사망', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0013'};
MATCH (a:Event {name: '급격연소 및 폭발'}), (b:Event {name: '화재 지하층 전체 연소확대'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {probability: 'High', mechanism: '방화구획 없는 밀폐 지하공간으로 화염 급속확산', spreadRisk: 'High', evidence: '삽시간에 2만 4천㎡ 면적인 냉동창고 지하층을 전체로 연소 확대되어 ... 화물하역장 방향으로 화염을 분출', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0014'};
MATCH (a:Event {name: '화재 지하층 전체 연소확대'}), (b:Event {name: '유독가스·농연 확산'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {probability: 'High', mechanism: '우레탄폼·유증기 연소로 유독가스·농연 다량 발생', spreadRisk: 'High', evidence: '엄청난 농연이 하늘을 뒤덮은 모습 ... 50m 떨어진 현장지휘소까지 농연으로 뒤덮인 모습 ... 유독가스로 인하여 인체에 치명적인', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0015'};
MATCH (a:Event {name: '유독가스·농연 확산'}), (b:Damage {name: '코리아2000 화재 인명피해(사망40·부상10)'}) MERGE (a)-[r:CAUSES]->(b) SET r += {mechanism: '질식 및 화상', directCause: '유독가스 흡입 저산소증 후 2차 화상', evidence: '40명은 순식간에 퍼진 화염과 유독가스에 질식되어 빠져 나오지 못하고 숨졌다 ... 40명이 사망하고 10명이 부상당하는 등 총 50명의 사상자', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0016'};
MATCH (a:Event {name: '화재 지하층 전체 연소확대'}), (b:Damage {name: '화재 재산피해(78억여원)'}) MERGE (a)-[r:CAUSES]->(b) SET r += {mechanism: '건물·구조물 소실', evidence: '재산피해는 29,519.86m² 중 지하층 22,338.35m², 지상층 60m²가 소실되어 총 78억 8천여만원 상당의 재산피해', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0017'};
MATCH (a:Event {name: '코리아2000 냉동창고 화재(2008)'}), (b:Population {name: '냉동창고 내부 작업자(57명)'}) MERGE (a)-[r:AFFECTS]->(b) SET r += {role: '노출 인구', evidence: '모두 57명의 작업자가 있었으므로 ... 탈출하거나 구조되었고(17명) ... 40명은 ... 숨졌다', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0018'};
MATCH (a:Population {name: '냉동창고 내부 작업자(57명)'}), (b:Damage {name: '코리아2000 화재 인명피해(사망40·부상10)'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {mechanism: '다수 인원 밀폐공간 재실로 대량 사상', effectiveness: 'High', evidence: '냉장실에서 냉매공급파이프 보온작업이나 전기실과 기계실에서 작업 중이던 40명은 순식간에 ... 숨졌다', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0019'};
MATCH (a:Facility {name: '코리아2000 방동물류창고(5호동)'}), (b:Region {name: '이천시 호법면 유산리'}) MERGE (a)-[r:LOCATED_IN]->(b) SET r += {detail: '동일 단지 내 7개 창고 중 하나', evidence: '동일 단지내에도 6개의 다른 물류창고가 있다 ... 동일 단지내 위치한 7개의 창고 중 냉동 물류창고(연면적 29,519㎡)의 지하 1층(바닥면적 22,338.4m²)에서 발생', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0020'};
MATCH (a:Event {name: '코리아2000 냉동창고 화재(2008)'}), (b:Facility {name: '코리아2000 방동물류창고(5호동)'}) MERGE (a)-[r:AFFECTS]->(b) SET r += {role: '노출 시설', evidence: '방동 물류창고(연면적 29,519 m²)의 지하 1층(바닥면적 22,338.4m²)에서 발생', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0021'};
MATCH (a:RiskFactor {name: '인허가·감독 부실(이천시·중소기업창업지원)'}), (b:Event {name: '코리아2000 냉동창고 화재(2008)'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'Med', mechanism: '안전 미고려 건축의 인허가 통과', reason: '제도적·사회적 부실요인', evidence: '2007년 4월 착공 신고까지도 허가가 취소되지 않은 ... 유사업종의 회사를 보유하고 있지 않는 것으로 허위 기재하여 창업지원 혜택을 받은 ... SP설비 없이 허가', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0022'};
MATCH (a:Event {name: '유사 냉동창고 화재(부산·익산·제주)'}), (b:Event {name: '코리아2000 냉동창고 화재(2008)'}) MERGE (a)-[r:CONCURRENT_WITH]->(b) SET r += {detail: '동일 유형 선행사고 — 재발 맥락', specialNote: '원인규명·백서 부재로 동일사고 반복', evidence: '1998년 부산 암남동의 냉동창고 신축공사 현장에서 ... 27명이 사망하고 16명이 중상 ... 2003년 전북 익산, 2006년 제주에서 비슷한 냉동창고 화재가 거듭 발생', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0023'};
MATCH (a:Event {name: '이천 CJ제일제당 공장 화재(2007.11.27)'}), (b:RiskFactor {name: '가연성 샌드위치패널(EPS) 벽체'}) MERGE (a)-[r:CONCURRENT_WITH]->(b) SET r += {detail: '샌드위치 패널 위험 선례', specialNote: '동일 위험요인(샌드위치 패널) 사고', evidence: '지난해 11월 27일 소방관 1명이 사망한 이천 CJ 제일제당 공장 화재가 바로 이 샌드위치 패널 때문 ... 무너지는 패널 더미에 깔려', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0024'};
MATCH (a:ResponseActor {name: '선착대(이천소방서)'}), (b:ResponseAction {name: '초기 화재진압·사면포위 진압'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', timing: '2008-01-07 10:53~', evidence: '10:53경으로 선착대 화재진압 ... 11:10경으로 화재현장 사면을 포위하여 연소확대 저지', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0025'};
MATCH (a:ResponseAction {name: '초기 화재진압·사면포위 진압'}), (b:Event {name: '화재 지하층 전체 연소확대'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {effectiveness: 'Med', reason: '샌드위치 패널·우레탄폼으로 진화 곤란, 천공 통한 방수·폼 방수 시도', evidence: '13:00경으로 포크레인을 이용 진공(강제배연) 확보 ... 13:20경 진압대원이 천공 내로 방수 ... 13:30경 천공 내로 폼 방수', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0026'};
MATCH (a:ResponseActor {name: '긴급구조통제단'}), (b:ResponseAction {name: '긴급구조통제단 설치·인명검색·구조'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', timing: '2008-01-07 11:20 설치', evidence: '11:20경으로 긴급구조통제단 설치 및 가동 ... 16:00경 건물내로 구조대원 투입 ... 22:00경 야간 인명검색 작업진행', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0027'};
MATCH (a:ResponseActor {name: '중앙119구조대·경기소방 구조대'}), (b:ResponseAction {name: '건물 진입 인명구조·사체 운반'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', timing: '2008-01-07 16:00~', evidence: '16:20경 중앙119구조대원 사체 운반 ... 16:30경 경기소방 구조대원 사체 운반 ... 공중보건의사가 사체 확인', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0028'};
MATCH (a:ResponseActor {name: '현장 응급의료소·식사 지원(의용소방대·자원봉사)'}), (b:ResponseAction {name: '현장 응급의료소 운영·급식 지원'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', timing: '2008-01-07 22:00~', evidence: '전면에 설치된 현장 응급의료소 운영 ... 안성소방서 급식차량과 의용소방대원들의 식사 배식', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0029'};
MATCH (a:Facility {name: '코리아2000 지하냉동창고'}), (b:Region {name: '이천시 호법면 유산리'}) MERGE (a)-[r:LOCATED_IN]->(b) SET r += {evidence: '장 소 : 이천시 호법면 유산리 769-5; 187M x 121M; 2만 4천㎡ 냉동 창고 지하층', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0030'};
MATCH (a:RiskFactor {name: '샌드위치 패널 내장재(우레탄)'}), (b:Event {name: '코리아2000 냉동창고 화재(2008)'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {mechanism: '가연성 패널·우레탄이 급속 연소 확대 및 유독가스 발생 유발', probability: 'High', spreadRisk: 'High', evidence: '샌드위치 패널 칸막이로 구획된 여러 실; 센드위치 패널로 만들어진 지하창고의 유독가스; 내부병면 우레탄품 하자부분 보수작업', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0031'};
MATCH (a:RiskFactor {name: '동시작업(다수 업종 밀집 작업)'}), (b:Damage {name: '코리아2000 화재 인명피해(사망40·부상10)'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {mechanism: '지하 밀폐공간 동시작업으로 대피 곤란, 인명피해 확대', probability: 'High', evidence: '냉동설비 담당 34명, 전기설비 담당 17명, 에어컨설비 담당 3명, 관리자 3명 등 모두 57명의 작업자가 있었으므로', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0032'};
MATCH (a:ManmadeHazard {name: '발화(13호 냉동실 인터쿨러팬 부근)'}), (b:Event {name: '냉동창고 화재 급속 연소확대'}) MERGE (a)-[r:TRIGGERS]->(b) SET r += {scale: '대형', probability: 'High', directCause: '13호 냉동실 발화', timing: '2008-01-07 10:45경', evidence: '화재의 시작은 오전 10시 45분경 13호 방동실에서 일어난 것; 삼시간에 2만 4천㎡ 냉동 창고 지하층을 전체로 연소 확대; 불과 4~5조 만에 불길이 전체 장고를 순식간에 뒤덮어', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0033'};
MATCH (a:Event {name: '냉동창고 화재 급속 연소확대'}), (b:Event {name: '폭발성 화염 분출·연쇄폭발'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {mechanism: '급속 연소로 가연물·우레탄 동시 발화, 화물하역장 방향 화염 분출 및 폭발성 화염 비산', spreadRisk: 'High', timing: '발화 직후', evidence: '잠시 후 급격한 폭발성 화염이 분출,비산 되면서 전면 공터에 주차된 차량 등에 연소; 연쇄폭발과 함께 화염이 분출; 지진으로 착각할 정도의 쿵쿵쿵 하는 굉음과 진동', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0034'};
MATCH (a:Event {name: '냉동창고 화재 급속 연소확대'}), (b:Event {name: '유독가스(유독성 연기) 확산'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {mechanism: '급속 연소로 다량의 유독가스(유독성 연기)가 건물 외부를 둘러쌈', spreadRisk: 'High', evidence: '유독성 연기가 건물의부를 가싸 본격적인 구조 작업에 나지지 못했다; 검은 농연이 버섯구름 형태를 보이며; 다량의 검은 연기가 호염면 유산리 입대를 완전히 덮고', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0035'};
MATCH (a:Event {name: '폭발성 화염 분출·연쇄폭발'}), (b:Event {name: '상층부 연쇄폭발(3·4층·옥상)'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {mechanism: '초기 폭발 후 3·4층·옥상으로 폭발 전파', timing: '10:50~12:30', spreadRisk: 'High', evidence: '10:50 프로판 가스 충공연(2차 폭발); 12:10 3.4층 폭발; 12:30 옥상 폭발', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0036'};
MATCH (a:Event {name: '유독가스(유독성 연기) 확산'}), (b:Damage {name: '코리아2000 화재 인명피해(사망40·부상10)'}) MERGE (a)-[r:CAUSES]->(b) SET r += {mechanism: '지하 밀폐공간 작업자가 급속 화염과 유독가스에 질식, 대피 시간 없이 사망', scale: '대량인명피해', probability: 'High', evidence: '40명은 순식간에 피치 화염과 유동가스에 질식되어 빠져 나오지 못하고 숨졌다; 작업자 57명 중 사망 40명, 부상 10명; 사망자 중 성비로는 남자 35명 여자 5명', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0037'};
MATCH (a:RiskFactor {name: '화재경보·대피방송 미작동'}), (b:Damage {name: '코리아2000 화재 인명피해(사망40·부상10)'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {mechanism: '조기 경보 부재로 대피 지연·불가', effectiveness: 'Low', probability: 'High', evidence: '사고 당시 화재 경보음은 물론 대피를 알리는 방송도 없었기에', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0038'};
MATCH (a:RiskFactor {name: '지하 밀폐구조(단일 출구·지하층)'}), (b:Damage {name: '코리아2000 화재 인명피해(사망40·부상10)'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {mechanism: '지하 밀폐·출구 거리로 대피 실패, 소방 진입 곤란', probability: 'High', evidence: '불이 난 냉동실이 지하에 위치해 소방관들은 건물 진압에 상당한 어려움; 33명의 시신은 발화지점에서 출구 쪽으로 향해 위치한 전기실과 기계실 등 발화지점과 상당히 떨어져 있는(약 40m에서 80m)', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0039'};
MATCH (a:Damage {name: '코리아2000 화재 인명피해(사망40·부상10)'}), (b:Context {name: '사망자 발견장소 분포'}) MERGE (a)-[r:QUANTIFIED_BY]->(b) SET r += {detail: '사망자 발견장소', evidence: '사망자 40명 중 7명의 시신은 발화지점으로 추정되는 13호실 전면 냉장실 주변에서 발견된 반면에 나머지 33명의 시신은 ... 출구와 비교적 가까운 위치', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0040'};
MATCH (a:Event {name: '구조작업 지연(유독가스·화염)'}), (b:Damage {name: '코리아2000 화재 인명피해(사망40·부상10)'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {mechanism: '구조 지연으로 인명피해 확대', reason: '유독가스·거센 화염으로 구조 작업 지연', probability: 'High', evidence: '유독가스와 거센 화염으로 인해 구조 작업이 늦어지면서 인명 피해가 더 커진 것이다', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0041'};
MATCH (a:Event {name: '소방진입 곤란(지하 밀폐)'}), (b:Event {name: '냉동창고 화재 급속 연소확대'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {timing: '화재 방제 4시간 후 오후 3시경 구조 개시', evidence: '지하1층 창고 상부의 아스팔트 주차장 바닥에 5m가량의 구멍을 뚫고 포소화약제를 포함한 살수 작업; 화재 방제 4시간에 만인 오후 3시 무렴부터 구조 작업', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0042'};
MATCH (a:ResponseActor {name: '이천소방서 상황실'}), (b:ResponseAction {name: '화재신고 접수 및 출동지령'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {effectiveness: 'High', timing: '2008-01-07 10:45 접수', evidence: '최초 접보된 시각은 2008.01.07 오전 10시 45분경; 소방교 정학진은 직감적으로 대형화재임을 인식, 예보방송을 작동; 신고에 대한 상황실의 대응은 화재의 긴급성에 대하여 신속하고 효율적인 대응', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0043'};
MATCH (a:ResponseActor {name: '경기도 소방재난본부'}), (b:ResponseAction {name: '광역 소방력 동원 진압'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {effectiveness: 'Med', scale: '광역3호 동원', evidence: '경기도 소방재난본부는 인근 8개 소방서의 소방관 440여명, 경찰 2개 중대 등을 투입; 화재를 완전히 진압하는데 8시간이 소요; 광역3호 발령', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0044'};
MATCH (a:ResponseAction {name: '광역 소방력 동원 진압'}), (b:Event {name: '냉동창고 화재 급속 연소확대'}) MERGE (a)-[r:MITIGATES]->(b) SET r += {effectiveness: 'Low', reason: '지하 밀폐·유독가스·연쇄폭발로 진화활동 한계', timing: '초진 14:55, 완진 18:30', evidence: '화재초기부터 공간적체로 확산된 뿐만아니기 인화가 매우 빨아 소방대의 진화활동에 한계가 있을 수밖에 없었다; 14:55 초진; 18:30 완진', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0045'};
MATCH (a:ResponseAction {name: '소방 진압·구조 전개'}), (b:Context {name: '이천 냉동창고 화재 진압 타임라인'}) MERGE (a)-[r:OCCURS_AT]->(b) SET r += {phase: 'response', evidence: '10시45분 신고접수; 10시51분 소방대 도착; 14시30분 수색작업 개시; 14시55분 초기진화; 18시30분 완전 진화; 23시18분 실종자 40명 시신 수습 종료', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0046'};
MATCH (a:RiskFactor {name: '소방 선착대 출동 지연'}), (b:ResponseAction {name: '소방 진압·구조 전개'}) MERGE (a)-[r:MODIFIES_RISK_OF]->(b) SET r += {reason: '도로공사 구간으로 출동시간 영향', effectiveness: 'Med', evidence: '이천소방서에서 약 6Km 정도 멀어져 있어 최소한 5분 이내 출동이 가능한 상황이었으나 약 3Km 구간에 걸쳐 도로공사 구간이 있어, 10시 45분에 화재 접수 신고를 받고 현장에 도착한 시간이 10시 51분', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0047'};
MATCH (a:ResponseActor {name: '김문수 경기도지사'}), (b:ResponseAction {name: '지사 현장지휘 및 가용자원 총동원'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {timing: '현장 도착 13:30(1차 보도 13:20경)', effectiveness: 'Med', evidence: '김문수 지사는 ... 1시간여 동안 화재진압을 위한 현장 지시에 직접 나선 것; 중앙정부와 서울시, 강원도까지 연락하여 가용한 모든 교정능 장비를 총동원해 보내 줄 것을 요청', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0048'};
MATCH (a:ResponseActor {name: '조병돈 이천시장'}), (b:ResponseAction {name: '응급의료지원 조치'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {effectiveness: 'Med', evidence: '관할시장인 조병도 이천시장은 ... 이천병원, 지역 의료봉사단 등에 긴급히 연락을 취해 가능한 모든 응급의료지원이 신속히 이루어지도록', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0049'};
MATCH (a:Event {name: '유독가스(유독성 연기) 확산'}), (b:Damage {name: '소방관 2차 피해 위험'}) MERGE (a)-[r:CAUSES]->(b) SET r += {mechanism: '유독가스가 진화·구조하는 소방관에게도 위해, 소방관 2차 피해 우려', probability: 'Med', evidence: '센드위치 패널로 만들어진 지하창고의 유독가스는 진화에 전념하는 소방관들에게도 많은 피해를 주므로; 소방관들이 2차 피해를 입지 않도록 개인안전장구를 철저히 착용하도록 지시', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0050'};
MATCH (a:ResponseActor {name: '이천소방서'}), (b:ResponseAction {name: '화재신고 접수 및 출동지령'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {effectiveness: 'High', evidence: '이천소방서 안장철 서장 또한 화재발생 정보와 동시에 출동하여 소방팀지원 요청 및 현장상황을 수시로 상부기관에 보고; 사고 당일 이천소방서 총원은 136명; 장비 보유현황은 30대', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0051'};
MATCH (a:ResponseAction {name: '광역 소방력 동원 진압'}), (b:Context {name: '화재 발생 일시·장소'}) MERGE (a)-[r:OCCURS_AT]->(b) SET r += {evidence: '가. 일 시 : 2008. 1. 7. 10:45 / 나. 장 소 : 이천시 호법면 유산리 769-5', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0052'};
MATCH (a:Event {name: '코리아2000 냉동창고 화재(2008)'}), (b:Event {name: '코리아2000 냉동창고 화재 확산'}) MERGE (a)-[r:TRIGGERS]->(b) SET r += {scale: '대형', probability: 'High', mechanism: '지하물류창고 내부 발화 후 연소확대', evidence: '화재가 발생한 코리아2000 냉동창고는 바닥면적 약 22,000㎡의 대형지하물류창고로 ... 소방대 도착전에 이미 빨간 불기등 및 심한 농연이 지상으로 노출되어', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0053'};
MATCH (a:RiskFactor {name: '가연성 샌드위치패널(EPS) 벽체'}), (b:Event {name: '코리아2000 냉동창고 화재 확산'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {mechanism: '가연성 단열재가 급속 연소·농연 발생 유발', probability: 'High', reason: '샌드위치패널 가연성 단열재', evidence: '차량하역장의 모든 벽체는 물에 아주 잘 타는 가연성 단열재를 가진 샌드위치패널로 이루어져 있는 것으로 보아 ... 빨간 불기등 및 심한 농연이 지상으로 노출', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0054'};
MATCH (a:RiskFactor {name: '지하물류창고 3면 매립·1면 노출 구조'}), (b:Event {name: '코리아2000 냉동창고 화재 확산'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {mechanism: '노출된 1면(하역장 출구)으로 화염·농연 집중 분출, 내부 진입 사실상 불가', probability: 'High', evidence: '지하물류창고가 3면이 지표면 아래에 있지만 1면은 외부로 노출된 구조로 되어 있어 모든 화염이 노출된 차량하역장 출구 쪽으로 분출되고 있는 상황', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0055'};
MATCH (a:Event {name: '코리아2000 냉동창고 화재 확산'}), (b:Event {name: '지상 1·2층 건물 연소확대'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {mechanism: '지하층 → 지하계단·배관피트를 통해 지상 1·2층 건물로 연소확대', spreadRisk: 'High', timing: '소방대 도착 전후', evidence: '지하층으로 통하는 지하계단에서 지상 1, 2층 건물로 연소확대 되는 것을 지지하였고 ... 지상층으로 설치된 우측한 배관 피트를 통해 지상1, 2층 건물로의 연소확대', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0056'};
MATCH (a:Event {name: '코리아2000 냉동창고 화재 확산'}), (b:Event {name: '주차차량 연쇄 화재'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {mechanism: '하역장 입구 정면 주차장의 화재차량 및 인접 약 20여대 차량으로 연소확대', spreadRisk: 'High', evidence: '건물 바로 옆에 주차 되어 있던 20여대의 차량도 연쇄중이었고 진화 후 지게차를 이용 이동조치 함', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0057'};
MATCH (a:Event {name: '코리아2000 냉동창고 화재 확산'}), (b:Event {name: '지하공간 연쇄 폭발'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {mechanism: '밀폐 지하공간 내 가연성 자재 연소로 간헐적·연이은 폭발 발생', spreadRisk: 'High', specialNote: '12:30경 세 번의 강한 추가 폭발 등 수차례 폭발', evidence: '내부에서는 간헐적으로 폭발이 연이어 발생하고 있었다 ... 이때에도 내부에서 세 번의 강한 추가 폭발이 있었다', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0058'};
MATCH (a:Event {name: '지하공간 연쇄 폭발'}), (b:Damage {name: '코리아2000 화재 인명피해(사망40·부상10)'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {mechanism: '폭발·고열·농연으로 소방대원 내부 진입 차단, 진압·구조 지연', effectiveness: '악화', evidence: '뜨거운 열기가 외부로 빨아나와 방화복을 입은 소방대라 할지라도 현장 가까이 접근 할 수도 없었으며 내부에서는 간헐적으로 폭발이 연이어 발생', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0059'};
MATCH (a:Event {name: '코리아2000 냉동창고 화재 확산'}), (b:Damage {name: '코리아2000 화재 인명피해(사망40·부상10)'}) MERGE (a)-[r:CAUSES]->(b) SET r += {directCause: '화염·고열·농연(유독가스)으로 내부 작업자 고립·소사', scale: '대형', evidence: '22시경 사망자 총 30구를 발견하였고 ... 23시 18분경 사망자 3명을 추가 발견함으로써, 총 40구에 대한 검색활동을 종료', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0060'};
MATCH (a:ResponseActor {name: '이천소방서 119안전센터(선착대)'}), (b:ResponseAction {name: '주차차량·건물 전면 우선 화재진압'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', timing: '10:51 현장도착(신고 후 6분)', effectiveness: 'Med', detail: '신고 10:45, 도착 10:51, 거리 7km', evidence: '신고 접수 후 6분 후인 10시 51분에 선착대인 이천소방서 ... 불타고 있는 화재차량에 대해 우선 화재진압활동 ... 차량의 폭발 등의 위험에 노출되어 소방관의 안전과 활동에 위협을 줄 수 있기 때문', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0061'};
MATCH (a:ResponseActor {name: '이천소방서 119안전센터(선착대)'}), (b:ResponseAction {name: '지하물류창고 내부 진입'}) MERGE (a)-[r:FAILS]->(b) SET r += {phase: 'response', reason: '고열·심한 농연·연이은 폭발로 지하물류창고 내부 진입 사실상 불가능', effectiveness: 'Low', evidence: '선착대 지하물류창고의 내부 진입이 사실상 불가능한 상태이었다 ... 방화복을 입은 소방대라 할지라도 현장 가까이 접근 할 수도 없었으며', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0062'};
MATCH (a:ResponseAction {name: '방화수 하역장 방수'}), (b:Event {name: '코리아2000 냉동창고 화재 확산'}) MERGE (a)-[r:MITIGATES]->(b) SET r += {effectiveness: 'Low', reason: '건물내부 화세를 저하시킬 수 없어 별도 진화방법 결정', evidence: '초기 현장 진화활동은 하역장 입구에서 주로 실시하였으나 화열의 세기가 커 하역장 우위에서 방수하는 방화수는 건물내부의 화세를 저하시킬 수 없어 별도의 진화방법을 사용하기로 결정', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0063'};
MATCH (a:ResponseAction {name: '천공 후 포소화약제 투입 진화'}), (b:Event {name: '코리아2000 냉동창고 화재 확산'}) MERGE (a)-[r:MITIGATES]->(b) SET r += {effectiveness: 'High', mechanism: '천공 배연 + 포소화약제 심입으로 내부온도 급격 저하', timing: '초기진화 14:55', evidence: '지하건물 내부 깊숙한 곳으로 폭소화약제를 심입하기 위해 지상으로 노출된 지하층 지붕을 브레이커로 천공하여 연기를 빼고 폭소화약제를 투입하였다 ... 내부온도가 급격히 저하된 것으로 판단', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0064'};
MATCH (a:ResponseAction {name: '천공 후 포소화약제 투입 진화'}), (b:Event {name: '코리아2000 냉동창고 화재 확산'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {phase: 'response', consequence: '초기진화 14:55(도착 후 4시간10분), 진화완료 18:30(총 7시간45분)', evidence: '초기진화(14:55)에 걸리는 시간은 소방대 현장 도착 후 총 4시간 10분이 걸렸으며, 진화완료에 걸린 시간(18:30)은 총 7시간 45분이 소요', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0065'};
MATCH (a:ResponseActor {name: '119구조대(인명검색)'}), (b:ResponseAction {name: '내부 인명검색 및 시신 수습'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', timing: '14:55 본격 인명검색, 14:58 최초 사망자 3명 발견', effectiveness: 'Med', detail: '5m·10m·20m 순차 확대 검색, 열상카메라·매몰자 탐지카메라 등 특수장비 사용', evidence: '14시 55분경 ... 인명검색을 본격적으로 시작하였고, 14시58분에 기계실 입구 부근에서 3명의 사망자를 최초로 발견 ... 당시 구조대는 26개대 193명이 동원', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0066'};
MATCH (a:ResponseActor {name: '긴급구조통제단'}), (b:ResponseAction {name: '현장지휘소 운영'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', objective: '통합지휘·자원배치·통신·자원관리 체계 운영', timing: '10:56 광역3호 발령', evidence: '화재발생당일 10:56분 광역3호가 발령되면서 ... 현장지휘소를 설치 운영 하였다 ... 긴급구조통제단(소방재난분부장) 등 4부 1대 가동', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0067'};
MATCH (a:ResponseActor {name: '총괄지휘부'}), (b:ResponseAction {name: '상판 붕괴우려 통제선 설치 및 인근주민 대피방송'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'mitigation', reason: '지하층 상판 붕괴우려 및 농연 확산 대응', evidence: '지하층 상판 붕괴우려에 따른 통제선 설치 및 전차량 분산배치 ... 농연확장에 따른 인근주민(유산리) 대피방송실시', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0068'};
MATCH (a:RiskFactor {name: '지하층 상판 붕괴우려'}), (b:ResponseAction {name: '내부 인명검색 및 시신 수습'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {mechanism: '상판 붕괴 우려로 구조대 내부 진입·검색 중단·퇴각 유발', probability: 'Med', evidence: '용인구조대는 지하 1층 하역장 12시 방향으로 진입, 1차 인명검색 실시함 (진묙 붕괴 우려와 농연으로 인하여 전체 퇴각)', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0069'};
MATCH (a:Event {name: '코리아2000 냉동창고 화재 확산'}), (b:Damage {name: '하역장 캐노피 상판 붕괴 및 소화활동설비 파손'}) MERGE (a)-[r:CAUSES]->(b) SET r += {directCause: '선착대 도착 전 하역장 캐노피 좌측 상판 붕괴 및 소화활동설비 파손', category: 'infra', evidence: '선착대 도착 전에 하역장 캐노피 좌측 상판이 이미 무너져 있었고, 연결충수구등의 소화활동설비 또한 모두 사용할 수 없을 정도로 파손이 된 상태', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0070'};
MATCH (a:ResponseAction {name: '화재진압·인명구조 동원 인력·장비'}), (b:Event {name: '코리아2000 냉동창고 화재 확산'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {phase: 'response', scale: '대형', composition: '16개 유관기관 동원(경기소방재난본부, 서울·인천·강원·충남·충북 소방)', evidence: '화재발생 당일 동원된 인원은 1215명(소방 678명, 의용소방대 150명, 경찰 등 387명), 장비로는 223대 ... 인력 동원 총 5,000명 ... 장비 동원 총 792대', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0071'};
MATCH (a:Event {name: '농연 확산에 따른 가시거리 저하'}), (b:ResponseAction {name: '내부 인명검색 및 시신 수습'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {mechanism: '농연·가시거리 저하로 진입·검색·방수 활동 곤란, 활동 위치 이동 반복', effectiveness: '악화', evidence: '연기로 인한 가시거리가 10M 정도였고 ... 검은 연기가 화재현장 앞을 모두 덮어 한치 앞을 볼수가 없을 정도가 되어', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0072'};
MATCH (a:Event {name: '코리아2000 냉동창고 화재(2008)'}), (b:Event {name: '지하층 화염 급속 확산'}) MERGE (a)-[r:TRIGGERS]->(b) SET r += {probability: 'High', mechanism: '용접불꽃 추정 발화 후 우레탄 등 가연재로 급속 연소', scale: '대형', evidence: '지하층의 바닥면적이 22,000㎡를 넘는 대형 공간인데도 불구하고 방화구획이 없어 삼시간에 전체 공간으로 화염이 확산되었으며 특히, 내부에 우레탄을 등의 폭염성 가연재가 많아', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0073'};
MATCH (a:RiskFactor {name: '방화구획 부재(지하 22,000㎡ 대공간)'}), (b:Event {name: '지하층 화염 급속 확산'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {mechanism: '구획이 없어 화염이 전 공간으로 즉시 확산', probability: 'High', evidence: '지하층의 바닥면적이 22,000㎡를 넘는 대형 공간인데도 불구하고 방화구획이 없어 삼시간에 전체 공간으로 화염이 확산되었으며', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0074'};
MATCH (a:RiskFactor {name: '우레탄 등 가연성 내장재'}), (b:Event {name: '내부 폭발 연소'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {mechanism: '폭발성 가연재가 급속 연소·폭발 유발', probability: 'High', evidence: '내부에 우레탄을 등의 폭염성 가연재가 많아 소방대의 외부실수가 나내 연소표면에 도달하지 못할 정도의 대형공간', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0075'};
MATCH (a:Event {name: '지하층 화염 급속 확산'}), (b:Event {name: '내부 폭발 연소'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {mechanism: '소방대 도착 전 후레쉬오버/폭발연소로 분출화염 발생', timing: '소방대 도착 전', spreadRisk: 'High', evidence: '소방대 도착 전에 후레지오며 또는 폭발연소가 발생하여 분출화염이 ... 둘째, 진화활동 중에 내부 연소에 따른 폭발음이 ... 건물 잔해물이(천판 등) ... 전방 50～100m 이상 뭉거져 나옴', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0076'};
MATCH (a:Event {name: '내부 폭발 연소'}), (b:Event {name: '내부 구조물 파손·붕괴'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {mechanism: '폭발로 천판 등 내부 구조물 파손·붕괴', spreadRisk: 'High', evidence: '폭발로 인하여 내부 구조물이 심하게 파손되어 진입 및 인명 검색 활동에도 지장을 조래하였다. 내부구획에 사용되었던 샌드위치 패널 및 구조물이 뒤엉켜져 있어', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0077'};
MATCH (a:Event {name: '내부 구조물 파손·붕괴'}), (b:Event {name: '내부 근로자 고립'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {mechanism: '구조대 내부진입·인명검색 불가로 내부 고립자 구조 시도 자체 불가', timing: '진화 중', evidence: '구조대는 내부진입이 불가능하였기 때문에 내부에 간접 사람들을 구하기 위한 시도조차 못하고 외부로 뭉거져 나온 부상자만 구조 이송할 수', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0078'};
MATCH (a:Event {name: '내부 근로자 고립'}), (b:Damage {name: '코리아2000 화재 인명피해(사망40·부상10)'}) MERGE (a)-[r:CAUSES]->(b) SET r += {mechanism: '고온·유독가스·진입불가로 다수 인명 사망', directCause: '화염·고온·유독가스', evidence: '이번 이천 냉동창고 화재는 사망 40명, 부상 10명으로 사회적으로 이목이 집중된 대형 참사였다 ... 사상자 중 20명이 외국인', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0079'};
MATCH (a:RiskFactor {name: '비상구 부족(1개소)'}), (b:Damage {name: '코리아2000 화재 인명피해(사망40·부상10)'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {mechanism: '대피 및 진입 곤란으로 인명피해 가중', reason: '비상구 2개만 더 있었다면 하는 아쉬움', evidence: '내부가 30개실(냉동실 25, 사무실 2, 기계실, 전기실, 화장실 등)으로 ... 비상구가 1개소 밖에 없어 대피 및 진입에 어려움을 겪었다', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0080'};
MATCH (a:Population {name: '냉동창고 내부 근로자'}), (b:Damage {name: '코리아2000 화재 인명피해(사망40·부상10)'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {mechanism: '다수 근로자 동시 작업 중 고립', scale: '약 40명', evidence: '화재 현장 앞에는 40여명이라는 근로자들이 생사도 모른 채 건물 앞에 있다는 이야기', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0081'};
MATCH (a:RiskFactor {name: '소방시설 기동스위치 수동전환(오작동 방지)'}), (b:Damage {name: '코리아2000 화재 인명피해(사망40·부상10)'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {mechanism: '화재정보설비·방화셔터 미작동으로 일부 작업자 대피 기회 상실 및 연소확대', reason: '가장 큰 문제점으로 지적', probability: 'High', evidence: '현장작업을 하면서 소방시설 요작동을 이유로 기동 스위치를 수동으로 전환해 놓은 점이 가장 큰 문제점 ... 화재정보설비나 방화셔터만 제대로 작동되었더라도 ... 일부는 대피했을수도', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0082'};
MATCH (a:RiskFactor {name: '냉동·냉장창고 소방시설 설치면제'}), (b:Event {name: '지하층 화염 급속 확산'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {mechanism: '소화·경보설비 부재로 초기진화·경보 실패', probability: 'High', evidence: '방동·냉장창고에 제반 소방시설 설치가 면제되고 있는데 최소한의 소방 시설은 설치 해야 된다', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0083'};
MATCH (a:RiskFactor {name: '소방용수시설(소화전) 부족'}), (b:Event {name: '지하층 화염 급속 확산'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {mechanism: '급수지원에 상당 시간 소요, 초기 소화용수 부족으로 다수 소방력 동원 원인', reason: '도·농 복합지역 소방 취약지대', evidence: '소방용수시설은 지무한 상태로 ... 거리도 약 5km정도 떨어져 있어 금수지원에도 상당한 시간이 경과 ... 초기 소화용수 부족으로 다우 소방력이 동원된 일부 원인', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0084'};
MATCH (a:RiskFactor {name: '이천시 도·농 복합 소방력 취약'}), (b:Event {name: '지하층 화염 급속 확산'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {mechanism: '초기진화·자체진화 실패 시 대형화재로 이어질 가능성 큼', probability: 'High', evidence: '이천시는 도·농 복합도시로 ... 소방력이 빈약 ... 대형창고나 공장에서 화재가 발생했을 경우 초기진화 및 자체진화에 실패하면 대형 화재로 이어질 가능성이 크다', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0085'};
MATCH (a:Event {name: '내부 폭발 연소'}), (b:Event {name: '소방대 진화 불가능 상황'}) MERGE (a)-[r:CAUSES]->(b) SET r += {mechanism: '유독가스·고열·화염이 모든 외부출구 차단, 소방대 접근로 봉쇄', directCause: '분출화염·고온·유독가스', evidence: '화염, 고온의 열기, 연기(유독가스) 등이 모든 외부출구를 막아 현재의 소방력으로는 진화가 불가능한 불가항력적인 상황이 조기에 초래', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0086'};
MATCH (a:ResponseActor {name: '이천소방서'}), (b:ResponseAction {name: '긴급구조통제단 현장지휘 운영'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', role: '현장 총괄지휘', evidence: '◎ 총괄지휘부 ... 현장활동 총괄지휘 ... 화재진화 및 인명구조·검색작업실시 ... 농연창장에 따른 인근주민(유산리) 대피방송실시', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0087'};
MATCH (a:ResponseAction {name: '긴급구조통제단 현장지휘 운영'}), (b:Event {name: '코리아2000 냉동창고 화재(2008)'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {timing: '화재 당일~수습완료', effectiveness: 'Med', reason: '진화 불가항력 상황에서 외부 부상자 구조·확산 통제 위주', evidence: '긴급구조통제단이 가동되면서 ... 화재진화 및 인명구조·검색작업실시', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0088'};
MATCH (a:ResponseActor {name: '이천시 보건소'}), (b:ResponseAction {name: '현장 응급의료소 운영'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', role: '현장 응급의료', evidence: '응급의료소는 ... 이천시 보건소장을 소장으로 ... 사상자 확인 및 이송조치(50명) ... 경상(찰과상 등)환자 및 고통(무통 등)호소자 응급처치(28명)', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0089'};
MATCH (a:ResponseAction {name: '현장 응급의료소 운영'}), (b:Damage {name: '코리아2000 화재 인명피해(사망40·부상10)'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {phase: 'response', effectiveness: 'Med', measures: '화상환자 서울 이송, 시신 40구 이송관리', evidence: '11:30 : 화상환자 10명 응급치지 후 서울로 이송 ... 사상자 확인 및 시신 40구 이송관리', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0090'};
MATCH (a:ResponseActor {name: '의용소방대(이천소방서)'}), (b:ResponseAction {name: '의용소방대 현장보조·급식 지원'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', role: '현장 보조·급식', evidence: '의용(여성)소방대 ... 주변 교통정리 및 기타 보조 활동 ... 화재발생 후 9일 동안 주야 2교대로 따뜻한 물과 식사(3식)를 준비', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0091'};
MATCH (a:ResponseActor {name: '대한적십자 경기도지사 동부봉사관'}), (b:ResponseAction {name: '적십자 급식·물품 지원'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', role: '자원봉사 급식지원', evidence: '대한적십자 경기도지사 동부봉사관 ... 금식지원과 각종음료 및 간식을 제공 ... 계 209명 1,540,870원', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0092'};
MATCH (a:ResponseActor {name: '이천시 사고수습대책본부'}), (b:ResponseAction {name: '사고수습대책본부 운영'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', role: '수습 총괄', evidence: '2008년 01월 07일 13:10분경 이천시 사고수습대책본부를 설치하고 5개 반 45명으로 ... 2차 ... 10개 반 120명으로 재편성', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0093'};
MATCH (a:ResponseActor {name: '외국인지원반(기업지원과 지역경제팀)'}), (b:ResponseAction {name: '외국인 사망자 유족 입국지원'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', role: '외국인 유족 지원', evidence: '외국인근로자(사망자)에 대한 전담팀을 ... 외국인지원반을 구성 운영 ... 외국인 사망자(13명)의 유족 ... 유족 46명중 39명 입국완료', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0094'};
MATCH (a:Facility {name: '현장 합동분향소(이천시민회관)'}), (b:Damage {name: '유족 집단 설사 발생'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {mechanism: '유족 인근 모텔 숙박 중 섭취 음식·물·극도 스트레스로 집단 설사 발생', timing: '2008-01-10', evidence: '유증상자 6명은 모두 망, 엄○○ 氏 유족으로 ... 아○○모텔에서 섭취한 물과 술, 기타음식물로 인해 일시적으로 발생된 설사증상으로 추정', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0095'};
MATCH (a:Damage {name: '코리아2000 화재 인명피해(사망40·부상10)'}), (b:Damage {name: '유족 집단 설사 발생'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {mechanism: '사망자 유족 충격·스트레스·모텔 음식이 2차 건강피해로 이어짐', timing: '사고 3일 후', evidence: '유증상자 모두가 화재피해 유족들로 습품에 잠겨있고 ... 극도의 스트레스와 ... 음식물로 인해 일시적으로 발생된 설사증상', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0096'};
MATCH (a:ResponseActor {name: '보건소 전염병 역학조사팀'}), (b:ResponseAction {name: '집단설사 역학조사'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', role: '역학조사·검체채취', evidence: '2008. 1. 10일 : 보건소 전염병 역학조사팀 1개조 4명 추적조사 ... 2008. 1. 11일 2차 역학조사 실시', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0097'};
MATCH (a:ResponseActor {name: '국립과학수사연구소'}), (b:ResponseAction {name: '화재원인 정밀감식'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', role: '화재원인 감식', evidence: '소방방재청, 경기도 소방재난본부, 이천소방서 화재조사 요원 ... 10일간 ... 국립과학수사 연구소에서도 7차례에 걸처 61명이 동원되어 정밀 감식', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0098'};
MATCH (a:ResponseAction {name: '화재원인 정밀감식'}), (b:Event {name: '발화원인 규명 실패'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '1000℃ 초과 고열로 가연물·발화원 전소·변형, 목격자 부재', effectiveness: 'Low', evidence: '강한 폭빨 및 1000℃가 넘는 고열로 인하여 ... 결정적인 발화원을 찾지 못하였다. 또한, 현장 목격자가 없어 화재의 직접적인 원인을 밝히지 못하는', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0099'};
MATCH (a:Event {name: '소방대 진화 불가능 상황'}), (b:Damage {name: '소방·구조대원 부상'}) MERGE (a)-[r:CAUSES]->(b) SET r += {mechanism: '근접 진화 곤란, 신체일부 노출로 구조대원 화상', directCause: '유독가스·고열·화염', evidence: '진입 및 구조대원의 신체일부 노출(목, 얼굴 부위 노출로 인한 화상)등으로 인하여 근접하여 화재진압이 곤란', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0100'};
MATCH (a:Damage {name: '코리아2000 화재 인명피해(사망40·부상10)'}), (b:Damage {name: '사망자 보상금 합의'}) MERGE (a)-[r:CAUSES]->(b) SET r += {mechanism: '가해자(코리아냉동) 측 손해배상 책임, 4차례 협의 후 합의', timing: '2008-01-14 최종합의', evidence: '1월 14일(월) 보상금 최종합의가 이루어져 ... 총 4,400,000천원의 보상금을 지급하게 되었다', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0101'};
MATCH (a:ResponseActor {name: '코리아냉동(가해 사업자)'}), (b:Damage {name: '사망자 보상금 합의'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', role: '손해배상', evidence: '인명피해 보상책임은 가해자 및 사고발생 원인 제조자인 「코리아 냉동 창고」 측 ... 코리아냉동 측 : 코리아냉동 대표 공○○ ... 총 4,400,000천원의 보상금', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0102'};
MATCH (a:ResponseAction {name: '119안전센터 신설·소방력 보강'}), (b:Resilience {name: '초기대응 역량(소방력·소방용수)'}) MERGE (a)-[r:BUILDS]->(b) SET r += {effectiveness: 'High', reason: '초기대응 시간 단축', evidence: '도롱 복합지역에 대한 소방력이 보강되어야 한다 ... 119안전센터 신설을 추진 ... 상수도 설치를 서둘러야 하며, 소화전도 적정장소에 설치', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0103'};
MATCH (a:ResponseAction {name: '방화구획·비상구·시각경보장치 보강'}), (b:Event {name: '지하층 화염 급속 확산'}) MERGE (a)-[r:PREVENTS]->(b) SET r += {effectiveness: 'High', reason: '방화구획·경보로 연소확대 억제 및 대피 유도', evidence: '비상구 확보라던지, 대형건물에 있어 방화구획만이라도 ... 안전을 고려해서 시공 ... 시각 경보장치를 보완하여 설치하는 것은 가능', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0104'};
MATCH (a:ResponseAction {name: '작업자 안전교육·위험물품 반입금지'}), (b:Event {name: '코리아2000 냉동창고 화재(2008)'}) MERGE (a)-[r:PREVENTS]->(b) SET r += {effectiveness: 'Med', reason: '발화원·유증기 위험 사전 통제', evidence: '작업자 투입전 안전교육 ... 소지품 검사를 실시하여 라이터, 담배 등 화재 발생 원인이 될 수 있는 물품의 반입 금지 ... 유증기가 발생될 수 있는 위험물질 작업 시 가스능도를 사전에 확인', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0105'};
MATCH (a:ResponseAction {name: '소방관 외상후스트레스(PTSD) 관리체계'}), (b:Resilience {name: '소방관 회복 역량(심리치료)'}) MERGE (a)-[r:BUILDS]->(b) SET r += {effectiveness: 'Med', phase: 'recovery', evidence: '전국소방관 4,597명이 설문에 응한 자료 ... 35.9%가 심리치료가 필요하다고 응답 ... 소방병원을 설립하여 ... 전문치료사로 하여금 출장 치료', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0106'};
MATCH (a:Damage {name: '코리아2000 화재 인명피해(사망40·부상10)'}), (b:Context {name: '사상자 50명(사망 40·부상 10)'}) MERGE (a)-[r:QUANTIFIED_BY]->(b) SET r += {role: '사상자 수치', evidence: '사망자 40명, 부상자 10명의 「총50명」의 사상자 ... 「쌍렌드 청소년 우편의 집」화재사고 이 후 가장 많은 사상자', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0107'};
MATCH (a:Event {name: '코리아2000 냉동창고 화재(2008)'}), (b:Damage {name: '코리아2000 화재 인명피해(사망40·부상10)'}) MERGE (a)-[r:CAUSES]->(b) SET r += {scale: '대형참사', consequence: '근무 중 다수 근로자 사망', evidence: '사고로 사망한 39명(고 ○○○ 개별합의); 사망자 40명의 유족들과의 보상합의', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0108'};
MATCH (a:Damage {name: '코리아2000 화재 인명피해(사망40·부상10)'}), (b:Context {name: '사망자 국적 구성(내국인·중국·우즈베키스탄)'}) MERGE (a)-[r:QUANTIFIED_BY]->(b) SET r += {detail: '보상 대상 사망자 39명, 1명(신○○)은 개별 협의로 제외', evidence: '외국인에 대하여는 법률자문을 통한 지급절차; 국제사법 제49조에 의하면 상속은 본국법에 의하도록', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0109'};
MATCH (a:ResponseActor {name: '코리아냉동(가해 사업자)'}), (b:ResponseAction {name: '유가족 보상합의 및 보상금 지급'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', role: '보상금 지급', effectiveness: 'High', detail: '4차례 회의 끝 최종 합의', evidence: '코리아냉동 측에서 적극 보상협의에 임하였고; 총 4,400,000천원의 보상금을 지급하게 되었다', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0110'};
MATCH (a:ResponseActor {name: '코리아냉동(가해 사업자)'}), (b:Resilience {name: '코리아냉동 LIG손해보험 가입 및 보유 부동산'}) MERGE (a)-[r:HAS_RESILIENCE]->(b) SET r += {role: '배상 재원 확보 수단', detail: '배상능력 확인 근거', evidence: 'LIG손해보험(주)에 약 15,290,208천원을 구급할 수 있는 보험에 가입; 채권 최고액을 40억원으로 한 근저당권을 설정', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0111'};
MATCH (a:ResponseActor {name: '이천시(사고수습대책본부)'}), (b:ResponseAction {name: '이천시 보상금 대행 지급'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', role: '보상금 대행 지급 및 중재', effectiveness: 'Med', timing: '2008-01-14 보상금 지급팀 구성', evidence: '보상금 지급에 대하여 유가족 측에서는 이천시에서 보상금을 받아 개별 지급을 원하는 바; 회사측으로부터 이천시사고수습대책본부 개설 계좌로 1,560,000천원 입금 확인 후', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0112'};
MATCH (a:ResponseActor {name: '유가족 대책위원회'}), (b:ResponseAction {name: '유가족 보상합의 및 보상금 지급'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {phase: 'recovery', role: '보상 요구·협상', timing: '2008-01-08~01-14', evidence: '유족대표자 측 : 허○○ 외 38인; 모든 협상 및 타결은 유가족 대책 위원회로 일원화', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0113'};
MATCH (a:ResponseAction {name: '유가족 보상합의 및 보상금 지급'}), (b:Context {name: '보상합의금 산정 원칙(2008-01-14)'}) MERGE (a)-[r:GUIDED_BY]->(b) SET r += {detail: '보상합의금 산정 원칙', evidence: '사망자 1인당 최소 보상금액이 금75,000,000원이 되도록한다; 위자료... 사망자 1인당 50,000천원; 할인율 16%를 적용', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0114'};
MATCH (a:ResponseAction {name: '유가족 보상합의 및 보상금 지급'}), (b:Context {name: '보상금 3차 분할 지급 내역'}) MERGE (a)-[r:QUANTIFIED_BY]->(b) SET r += {detail: '3단계 분할 지급 절차', evidence: '1차보상금 : 10,000천원/1인(총액 390,000천원); 2차보상금 : 40,000천원/1인(총액 1,560,000천원, 이천시 대행 지급); 3차보상금... 기 지급액(50,000천원)을 제외한 금액', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0115'};
MATCH (a:ResponseActor {name: '이천시(사고수습대책본부)'}), (b:ResponseActor {name: '유가족 대책위원회'}) MERGE (a)-[r:COORDINATES_WITH]->(b) SET r += {role: '보상 중재 회의', timing: '2008-01-08~01-10', detail: '유가족 요구사항(합동분향소 확대·상황실 설치·진상규명·차별없는 보상·정부 사과 등) 협의', evidence: '유가족 측과 이천 시와 회의 결과; 유가족 요구사항 처리 과정... 시장면담 요청', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0116'};
MATCH (a:ResponseActor {name: '국무총리(한덕수)'}), (b:ResponseAction {name: '관계장관회의 사태수습 지시'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', role: '사태수습·사고원인 조사·신속 보상 지시', timing: '2008-01-09 16:00', evidence: '국무총리(한덕수) 방문시... 관계 장관 회의를 통하여 사태주습, 사고원인 철저사, 신속한 보상노력을 지시', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0117'};
MATCH (a:ResponseAction {name: '선지급·구상권 청구 요청(좌절)'}), (b:ResponseActor {name: '이천시(사고수습대책본부)'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '대위변제 법적 근거 미비, 개인 인·허가 사업장 사고로 대구 지하철 사건과 상황 상이', effectiveness: 'Low', evidence: '보상금을 해정당국에서 선 지급하고 구상청을 청구하는 것을 요청하기도 하였지만 대위 변제를 할 수 있는 법적 근거가 미아하여 추진할 수가 없었고', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0118'};
MATCH (a:ResponseAction {name: '보상금 지급 보장 근저당권 설정'}), (b:Resilience {name: '보상금 지급 이행 담보(근저당권)'}) MERGE (a)-[r:BUILDS]->(b) SET r += {role: '보상금 지급 이행 담보', effectiveness: 'High', evidence: '근저당권자를 이천시, 채권 최고액을 40억원으로 한 근저당권을 설정하고 이천 시는 보상합의에 따른 이행이 완료될 때까지 이를 해지하지 않는 것으로 한다', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0119'};
MATCH (a:ResponseActor {name: '코리아냉동(가해 사업자)'}), (b:ResponseAction {name: '외국인 유가족 입국·신원확인 협조'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', role: '외국인 유가족 지원·DNA 신원확인 협조', timing: '2008-01-08', evidence: '외국인 사망자에 대한 유가족 입국절차 이전시 및 유관기관 협조 요청; DNA조사에 필요한 의료기관 자료 요청 역시 행정당국에 요청', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0120'};
MATCH (a:Event {name: '코리아2000 냉동창고 화재(2008)'}), (b:Event {name: '냉동실13~14호 최초 발화 및 폭발적 급속연소'}) MERGE (a)-[r:TRIGGERS]->(b) SET r += {mechanism: '13호 냉동실에 인화성 증기(유증기) 체류 상태에서 미상의 불꽃 등이 튀며 폭발', probability: 'High', specialNote: '착화→급속연소 발현', evidence: '냉동실-13과 냉동실-14를 포함한 공간에서 최초 발화 및 폭발적인 급속한 연소가 발생한 것으로 추정됨. 이천 지하 냉동창고 화재의 원인은 13호 냉동실에 인화성 증기가 체류되어 있는 상태에서 미상의 불꽃 등이 뛰면서 폭발해 발생', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0121'};
MATCH (a:RiskFactor {name: '폴리우레탄폼·스티로폼 보냉단열재'}), (b:Event {name: '플래쉬오버에 의한 화염 급속확산'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {mechanism: '착화시 산소와 결합해 전면적으로 빠르게 확산연소, 복사열 큰 플래쉬오버 형성 온도에 쉽게 도달', probability: 'High', reason: '1차적 화염확산 원인으로 분석', evidence: '방동창고의 단열재로 사용되는 풀리우레탄의 연소시 빠른 화염확산속도가 1차적인 원인으로 분석되었다 … 폴리우레탄과 같은 유기질 단열재는 … 순간간에 플래쉬오버가 발생한다', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0122'};
MATCH (a:Event {name: '냉동실13~14호 최초 발화 및 폭발적 급속연소'}), (b:Event {name: '플래쉬오버에 의한 화염 급속확산'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {mechanism: '상부 체류 미연소 가스·열분해 가스 점화, 우레탄폼 작업시 유증·분진이 급속연소 매개체로 작용', spreadRisk: 'High', timing: '착화 직후', evidence: '초기 발화 이후 폭발적인 연소가 발생 … 상부에 체류된 미연소된 가스나 열분해 가스가 급속한 연소의 매개체로 작용 … 착화가 발생한 후 일순간에 화염이 뒤덮여', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0123'};
MATCH (a:Event {name: '플래쉬오버에 의한 화염 급속확산'}), (b:Event {name: '하역장 출구 외부 화염분출'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {mechanism: '산소 유입통로인 하역장 출구로 벤트 후 훼손된 외부 샌드위치패널(EPS) 방향으로 분출', spreadRisk: 'High', timing: '착화 후 3분 이내 하역장 출구 도달', specialNote: '착화 지점(냉동실13호)에서 약 190m 떨어진 하역장 출구까지 화염 도달 3분 이내', evidence: '착화는 하역장 출구에서 가장 먼 떨어져 있는 방동실 창고 13호실에서 시작되었지만 190m 정도 떨어진 하역장 출구까지 화염이 도달하는데 걸리는 시간이 불과 3분 이내로 확인', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0124'};
MATCH (a:Event {name: '플래쉬오버에 의한 화염 급속확산'}), (b:Damage {name: '코리아2000 화재 인명피해(사망40·부상10)'}) MERGE (a)-[r:CAUSES]->(b) SET r += {mechanism: '소방대 도착 이전 전 공간 화염 뒤덮임, 작업인원 대피 불가', scale: '대형인명피해', directCause: '급속 플래쉬오버 진행', evidence: '코리아 2000 방동창고 화재로 인하여 50명(사망 40, 부상자 10)의 사상자가 발생 … 대형인명피해를 일으킬 수밖에 없는 상황이 초래된 특수화재', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0125'};
MATCH (a:RiskFactor {name: '무(無)구획 단일대형 공간구조'}), (b:Damage {name: '코리아2000 화재 인명피해(사망40·부상10)'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {mechanism: '화재가 인접구역으로 확산되는 것을 막지 못해 플래쉬오버 빠르게 진행, 작업인원 대피·소방대 화점접근 불가', reason: '방화벽 부재로 화재 확산을 하나의 구획에 국한 못함', effectiveness: 'High', evidence: '방화구획(면적)의 완화규정의 확대해석에 의한 무(無)구획 단일대형 공간구조 형성으로 인해 플래쉬오버가 빠르게 진행되어 작업인원의 대피가 불가능하였고 … 인명피해를 심화시켰고', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0126'};
MATCH (a:RiskFactor {name: '가연성 샌드위치패널(EPS) 외부벽체'}), (b:Damage {name: '코리아2000 화재 인명피해(사망40·부상10)'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {mechanism: '가연성 자재 조기 붕괴로 화염 외부 분출경로·산소 접촉공간 형성, 소방대 진압활동 불가·구조대 투입귀환 곤란', reason: '지상 노출부가 화염분출경로로 변질', effectiveness: 'High', evidence: '가연성 샌드위치패널 벽체의 설치로 인해 지상 노출부가 화염분출경로로 변질되어 소방대의 진압활동에 막대한 장애를 주어 심대한 피해 조래함. (위법사항)', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0127'};
MATCH (a:RiskFactor {name: '피난시설 부족(보행거리 기준 위반·일방향 단일출구)'}), (b:Damage {name: '코리아2000 화재 인명피해(사망40·부상10)'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {mechanism: '생존자 피난의지 상실, 출구 조기 오염으로 피난 불가', effectiveness: 'High', reason: '대형창고 피난기준 미준수', evidence: '보행거리 기준(30m 이내)을 위반하여 하나의 피난계단과 하나의 출구만을 두어 보행거리가 최대 150m 되도록 구축함에 따라 … 생존자의 피난의지 상실 초래', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0128'};
MATCH (a:RiskFactor {name: '냉동창고 스프링클러·제연설비 설치의무 면제'}), (b:Damage {name: '코리아2000 화재 인명피해(사망40·부상10)'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {mechanism: '착화시 조기진화·화세 저감 불가, 플래쉬오버 발생 지연 실패', effectiveness: 'High', reason: '고위험 냉동창고에 자동소화·제연설비 면제', evidence: '스프링클러 설치의무 대상에서 냉동(냉장)창고를 제외시켜는데 … 제연설비를 설치하도록 의무화하고 있으나 창고용도이가 때문에 적용하지 않아 … 인명피해를 심화', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0129'};
MATCH (a:RiskFactor {name: '소방 설비 작동 조작(차단)'}), (b:Damage {name: '코리아2000 화재 인명피해(사망40·부상10)'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {mechanism: '화재 감지·경보·초기진화 기능 무력화', effectiveness: 'High', reason: '인명피해 심화 근본 원인', evidence: '방화묵, 경보장치, 자동소화시설의 스프링쿨러 등의 소방 설비들이 … 모두 작동하지 못하도록 조작해 놓고 작업을 하였다 … 인명피해를 심화시킨 근본 원인은 … 화재방호시스템의 고의적이고 편법적인 누락', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0130'};
MATCH (a:RiskFactor {name: '건축주 시행·시공·설계·감리 겸업 구조'}), (b:Event {name: '코리아2000 냉동창고 화재(2008)'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {mechanism: '설계·시공·감리 상호견제 기능 무너져 안전 감독 미이행', probability: 'High', reason: '경제적 이익 추구 설계로 변질', evidence: '사고가 난 이 현장은 건축주가 시행자, 건설사이며 설계, 감리자 역할을 함께 해 왔기에 감독을 이행할 수 없었기 때문이다. 회사 이름조차도 모두 똑같은 코리아2000이다', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0131'};
MATCH (a:Event {name: '우레탄폼 발포·냉매주입 등 마무리 추가공사'}), (b:Event {name: '냉동실13~14호 최초 발화 및 폭발적 급속연소'}) MERGE (a)-[r:PRECONDITIONS]->(b) SET r += {mechanism: '발포작업 불충분한 환기 상태에서 유증기 형성·체류, 밀폐 냉동실에 인화성 증기 축적', probability: 'High', timing: '착화 직전', evidence: '건물의 준공 후 보냉단열재 도포 및 냉동실비작업을 무리하게 시행 하던 중 원인불명의 점화원에 의해 착화 … 발포 후에 … 회발성 증기(유증기)가 냉동실의 밀폐공간에서 빠져 나오지 못하고 잔존하는 특성', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0132'};
MATCH (a:RiskFactor {name: '밀폐 무개구부 지하 냉동창고 구조'}), (b:Event {name: '플래쉬오버에 의한 화염 급속확산'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {mechanism: '미연소 가스·열분해 우레탄폼 가연성 분해가스가 상부 체류해 착화시 폭발적 급속연소 유발, 농연 미배출로 소방대원 진입 곤란', probability: 'High', evidence: '낭동실의 구조는 … 개구부(환기 및 창문)가 없고 … 미연소된 가스나 … 열분해된 우레탄폼의 가연성 분해가스가 상부에 체류 … 폭발적인 급속한 연소를 유발할 것으로 추정', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0133'};
MATCH (a:ResponseActor {name: '이천소방서 화재조사팀'}), (b:ResponseAction {name: '화재원인 조사 및 발화지점 감정'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', detail: '생존자 증언·진압후 조사로 기계실 유증기 발화 감정 발표(초기), 후 국과수 감식으로 발화지점 정정', evidence: '이천 소방서 화재조사자들은 … 기계실에서 원인 불명의 불꽃이 유증기에 뛰어 화재가 난 것으로 감정 발표했지만, 국립과학수사연구소 등이 주심이 된 경찰수사본부가 3차례의 정밀감식을 거치고', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0134'};
MATCH (a:ResponseActor {name: '국립과학수사연구소'}), (b:ResponseAction {name: '화재원인 조사 및 발화지점 감정'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', detail: '총 7차례 현장조사·발굴, 케이블 단락흔·벽체 파손방향성 분석', evidence: '코리아2000 냉동창고 화재사건에 대하여 총 7자레의 현장조사를 실시하였으며 … 냉동실-13과 냉동실-14를 포함한 공간에서 최초 발화', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0135'};
MATCH (a:ResponseActor {name: '이천119구조대'}), (b:ResponseAction {name: '초기 인명구조 및 응급이송'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', timing: '화재발생 직후 급파', evidence: '화재발생과 동시에 이천구조대를 현장에 급파하여 사상자 10명을 인명구조 하여 응급 의료소에 이송', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0136'};
MATCH (a:ResponseActor {name: '이천119구조대'}), (b:ResponseAction {name: '내부 진입 추가 인명구조 시도'}) MERGE (a)-[r:FAILS]->(b) SET r += {phase: 'response', reason: '프레온 가스통 폭발과 강한 화재로 내부 진입 불가, 일시 후퇴', effectiveness: 'Low', specialNote: '외부소방대 신속 출동(신고 접수 후 약 6분 도착)에도 추가 인명구조 실패', evidence: '및 차례 인명구조를 하기 위해 내부로 짐근을 시도하였으나 폭발(프레온 가스통 등)과 함께 화재가 강하여 일시 후퇴 … 추가 인명구조를 하지 못한 아쉬움을 남기었다', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0137'};
MATCH (a:ResponseActor {name: '긴급구조통제단'}), (b:ResponseAction {name: '합동 정밀 인명검색 및 사체 발굴'}) MERGE (a)-[r:COMMANDS]->(b) SET r += {role: '지휘', detail: '경기119·중앙119·서울특별구조대·삼성119구조대 지원 요청, 열화상카메라·라이트라인·매몰자탐지기 등 동원', evidence: '경기119구조대 및 중앙119구조대 … 도 긴급구조 통제단장인 소방재난본부장의 지시로 지원 요청하여 … 40명의 사망자를 발견 수습 … 화재당일 23:15분경 중 40명의 사체를 발굴', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0138'};
MATCH (a:ResponseAction {name: '지상1층 천공 굴착 및 포클레인 폭액 방사 진압'}), (b:Event {name: '코리아2000 냉동창고 화재(2008)'}) MERGE (a)-[r:MITIGATES]->(b) SET r += {phase: 'response', effectiveness: 'Med', mechanism: '냉동창고 무창 구조로 농연 미배출 환경에서 천공·협공 진압', reason: '무장중 구조로 대원 진입 곤란', evidence: '지상1층에 대하여 천공 7개를 포크레인을 활용하여 과다 폭액을 방사하여 신속히 진압 … 여주, 양명, 구리 등 소방시장에게 구역별로 책임 지정하여 화점 주위를 협공', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0139'};
MATCH (a:ResponseAction {name: '화재방어검토회의 및 긴급구조활동 평가'}), (b:Resilience {name: '재난대응 제도개선 역량'}) MERGE (a)-[r:BUILDS]->(b) SET r += {phase: 'recovery', objective: '현장활동 문제점 분석 및 개선안 마련', effectiveness: 'Med', evidence: '『코리아 2000방능창고』관련 화재방어검토회의는 2008년 3월 5(수)일 … 논의된 사항에 대해 빠른 시일내 개선책 및 법적제도를 마련', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0140'};
MATCH (a:ResponseActor {name: '도 재난안전대책본부 및 이천시 사고수습대책본부'}), (b:ResponseAction {name: '유가족 보상·장례 및 합동분향소 운영'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', timing: '사고 직후 신속 운영', evidence: '도 재난안전대책본부 및 이천시 사고수습대책본부를 신속 운영하여 보상금 접 및 장례절차 등 대책을 논의 … 합동분상소를 운영', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0141'};
MATCH (a:Event {name: '건축물 내장재 우레탄폼·샌드위치패널 연소'}), (b:Damage {name: '코리아2000 화재 인명피해(사망40·부상10)'}) MERGE (a)-[r:CAUSES]->(b) SET r += {directCause: '유독가스로 인한 시야화 및 질식', mechanism: '내장재 연소 유독가스', evidence: '건축물 내장재로 많이 사용되는 우레탄 폼 및 샌드위치 패널이 연소되면서 유독가스로 인한 시아화 및 입숨으로 질투되면서', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0142'};
MATCH (a:Event {name: '프레온 가스통 폭발'}), (b:Event {name: '코리아2000 냉동창고 화재(2008)'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {reason: '폭발과 함께 화세 강화로 구조대 일시 후퇴', spreadRisk: 'High', specialNote: '내부 진입 인명구조 시도 좌절', evidence: '폭발(프레온 가스통 등)과 함께 화재가 강하여 일시 후퇴하여 대응 작전회의를 하였으며', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0143'};
MATCH (a:RiskFactor {name: '용접·시너 공사 시 감독규정 미비'}), (b:Event {name: '코리아2000 냉동창고 화재(2008)'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'High', reason: '작업장 관리·감독시스템 미비로 안전사고 유발', evidence: '용집작업, 시너 등 공사 시 감똑 규정이 미비하여 화재발생이 우려되며 평소 방화시설, 자동화재 탐지설비 등 소방시설 작동기능 차단 시 관리 단속에 어려움', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0144'};
MATCH (a:RiskFactor {name: '불법 제3자 재하청 관행'}), (b:Event {name: '코리아2000 냉동창고 화재(2008)'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'High', reason: '저가 공사금액 부실공사로 대형 재난 개연성 상승', evidence: '제3자 제하청은 관련법규에 의거 금지되어 있으나 관행화된 불법 하청으로 저가의 공사금액으로 공사 시 부실공사가 우려되어 향상 대형 재난으로 이어질 개연성이 높음', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0145'};
MATCH (a:ResponseActor {name: '경기119구조대'}), (b:ResponseAction {name: '코리아2000 화재 인명구조·사체발굴'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', role: '사체 발굴·인명검색', timing: '화재 당일 23:15경', detail: '중앙119·서울특별시구조대·삼성3119구조대 합동, 화재 당일부터 10일간 유골·유품 수습', evidence: '고열과 농연이 내 뿜는 여건 속에서도 화재당일 23:15분경 중 40명의 사체를 발굴하였음', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0146'};
MATCH (a:ResponseActor {name: '긴급구조통제단'}), (b:ResponseAction {name: '통합 긴급구조대응(코리아2000 화재)'}) MERGE (a)-[r:COMMANDS]->(b) SET r += {phase: 'response', role: '재난현장 총괄 조정·통제', detail: '서울·인천·강원·충남 등 인근 시도 긴급구조기관 통합 대응', evidence: '인근 시·도의 긴급구조기관이 통합적으로 대응하여 총체적, 효율적 운영하였으며 도 긴급구조 통제단장은 소방재난부부장이 되어 재난현장을 총괄 조정·통제를 하였음', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0147'};
MATCH (a:ResponseAction {name: '포크레인 동원 천공 후 폼 방사 진화작전'}), (b:Event {name: '코리아2000 냉동창고 화재(2008)'}) MERGE (a)-[r:MITIGATES]->(b) SET r += {effectiveness: 'High', phase: 'response', reason: '천공·폼방사로 18:00경 완전진화', evidence: '지상1층에 천공(7개)을 내어 베열과 동시에 풀액을 방사하여 18:00경 최종 화재를 완전진화', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0148'};
MATCH (a:ResponseAction {name: '내부 직접 진입 화재진압 시도'}), (b:Event {name: '코리아2000 냉동창고 화재(2008)'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '강력한 유동가스와 화염', phase: 'response', effectiveness: 'Low', evidence: '화재진압 시 강력한 유동가스와 화염으로 질룬 내 진압을 및 차량 시도 하였으나 실패하였고', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0149'};
MATCH (a:RiskFactor {name: '소방용수시설(소화전) 부족'}), (b:ResponseAction {name: '코리아2000 화재 진압작전'}) MERGE (a)-[r:MODIFIES_RISK_OF]->(b) SET r += {reason: '소방용수시설 부족으로 진압에 많은 어려움', effectiveness: 'Low', phase: 'response', evidence: '소방용수시설 부족으로 많은 어려움이 있었으며 차후 관내 상수도망 가설 시 대규모 물류센터 주변 소화전 우선 설치가 요구됨', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0150'};
MATCH (a:ResponseActor {name: '이천경찰서'}), (b:ResponseAction {name: '코리아2000 화재 현장통제·과학수사'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', role: '현장통제·교통통제·2차 안전사고 방지', detail: '폴리스라인 설치, 10일간 기동대 28대·연인원 2179명, DNA 감식 위해 국과수 요청', evidence: '이천경찰서장을 중심으로 경비과장 등이 현장에 출동하여 ... 시민의 2차 안전사고를 방지 / 사망사의 시신이 많이 훼손되어 ... 유전자(DNA) 감식을 위해 국립과학수사연구소에 신속 요청', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0151'};
MATCH (a:ResponseActor {name: '중앙119구조대'}), (b:ResponseAction {name: '코리아2000 화재 인명구조·사체발굴'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', role: '시신·유품 수습', detail: '차량 8대·헬기, 장비 95종 650점, 4일간 연인원 91명 투입', count: 20, unit: '구', evidence: '8대의 차량 및 헬기 구조장비 등 95중 650점을 이용하여 20구의 시신과 다량의 유품을 수습하고, 화재발생이후 4일간 연인원 91명을 투입하여 인명구조와 정밀수색 실시', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0152'};
MATCH (a:ResponseActor {name: '서울소방방재본부'}), (b:ResponseAction {name: '코리아2000 화재 인명구조·사체발굴'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', role: '시신 수습·인명검색', detail: '장비 22대·인원 107명, 2일간 인명검색', count: 18, unit: '구', evidence: '장비 22대, 인원 107명을 현장으로 투입하여 18구의 시진을 수습하고 2일에 걸쳐 인명검색과 정민수색을 실시', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0153'};
MATCH (a:ResponseActor {name: '삼성3119구조대'}), (b:ResponseAction {name: '코리아2000 화재 인명구조·사체발굴'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', role: '사체 인양·유품 발굴', detail: '인원 16명, 중앙119구조대와 합동, 3일간 정밀수색', count: 7, unit: '구', evidence: '인원 16명을 포함한 특수구조장비 ... 중앙119구조대와 합동으로 ... 사재 7구를 우하하고 이후 3일간 정발수색', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0154'};
MATCH (a:RiskFactor {name: '지원기관 연락관 현장지휘소 미상주'}), (b:ResponseAction {name: '통합 긴급구조대응(코리아2000 화재)'}) MERGE (a)-[r:MODIFIES_RISK_OF]->(b) SET r += {reason: '연락관 미상주로 긴급 대외회의 등 현장지휘소 운영 차질', effectiveness: 'Low', phase: 'response', evidence: '현장지휘소 내 연락관이 상주하지 않아 긴급 대외회의 등의 현장지휘소 운영에 다소 문제가 있었음', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0155'};
MATCH (a:RiskFactor {name: '지원기관·단체장 역할 인지 미흡(평소 훈련 미흡)'}), (b:ResponseAction {name: '통합 긴급구조대응(코리아2000 화재)'}) MERGE (a)-[r:MODIFIES_RISK_OF]->(b) SET r += {reason: '지원기관·단체장이 현장 장악·기관별 지휘소 운영 못함', effectiveness: 'Low', evidence: '동원된 긴급구조지원기관·단체장이 재난현장을 장악하고 기관별 현장지휘소를 운영하여야 하나 평소 훈련 등 미흡으로 역할을 제대로 인지하지 못하고 운영', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0156'};
MATCH (a:Damage {name: '소방공무원 외상후스트레스장애(PTSD) 위험군'}), (b:Context {name: '소방공무원 PTSD 실태조사(2008)'}) MERGE (a)-[r:QUANTIFIED_BY]->(b) SET r += {reason: '사건충격척도(IES-R) 위험군 선별 결과', evidence: '사건중격척도(IES-R) 총점 25점을 기준으로 위험군을 선별한 결과 응답자 4090명중 1504명(36.8%)가 외상후 스트레스 장애 증상 호소군으로 분류', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0157'};
MATCH (a:RiskFactor {name: '누적 외상경험·만성 스트레스·잦은 출동빈도'}), (b:Damage {name: '소방공무원 외상후스트레스장애(PTSD) 위험군'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'High', reason: '누적 외상경험·만성 스트레스가 PTSD 발현과 관련', evidence: '근무한지 10-19년 되는 경우가 가장 많았고, 연령상 40-50세가 가장 많다 ... 누적된 외상경험 및 만성적인 스트레스가 외상후 스트레스 장에 발현과 관련이 있음을 시사', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0158'};
MATCH (a:RiskFactor {name: '건축주·시공자와 연관 건축사의 감리 겸업 가능'}), (b:Event {name: '코리아2000 냉동창고 화재(2008)'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'Med', reason: '이해상충 감리로 부실시공 등 문제 발생 우려', evidence: '서로 연관된 업체가 건축주이면서 시공·감리까지 모두 할 경우 ... 부실시공 등 여러 가지 문제점 발생이 우려됨', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0159'};
MATCH (a:ResponseAction {name: '설계·시공·감리제도 개선(연관 건축사 감리 금지)'}), (b:RiskFactor {name: '건축주·시공자와 연관 건축사의 감리 겸업 가능'}) MERGE (a)-[r:PREVENTS]->(b) SET r += {phase: 'prevention', reason: '감리 이해상충 차단으로 부실공사 예방', effectiveness: 'Med', evidence: '건축주 및 공사시공자와 계열관계 등으로 연관된 건축사 등은 당해 건축물에 대하여 감리업무를 수행할 수 없도록 개선', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0160'};
MATCH (a:RiskFactor {name: '방화관리자 선임 공백(최장 44일)'}), (b:Event {name: '코리아2000 냉동창고 화재(2008)'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'Med', reason: '공백기간 시설 개조·공사 중 방화안전사고 위험 노출', evidence: '최장 44일간 방화관리자 공백 사태 발생 - 방화관리자 공백기간의 시설 개조·공사에 대한 방화안전사고 위험 노출', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0161'};
MATCH (a:ResponseAction {name: '건축·소방 준공검사에 방화관리자 참여(선임 시기 앞당김)'}), (b:RiskFactor {name: '방화관리자 선임 공백(최장 44일)'}) MERGE (a)-[r:PREVENTS]->(b) SET r += {phase: 'prevention', reason: '방화관리 공백 제거', effectiveness: 'Med', evidence: '방화관리자를 소방완공검사필증 교부 이전에 선임토록 개선', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0162'};
MATCH (a:RiskFactor {name: '소방재원 국가부담 1%(재원조달 어려움)'}), (b:Event {name: '코리아2000 냉동창고 화재(2008)'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'Med', reason: '부족한 소방안전 인프라로 대형 화재 시 적절한 대처 곤란', evidence: '소방요금 급증, 제원준단의 어려움은 부족한 소방안전 인프라로 이어져 대형 화재사고 발생시 적절한 대처를 어렵게 함', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0163'};
MATCH (a:Event {name: '이천 농수산물유통센터 공사장 화재(1993)'}), (b:Damage {name: '농수산물유통센터 화재 인명피해(1993)'}) MERGE (a)-[r:CAUSES]->(b) SET r += {directCause: '급격한 연소 확대·유독가스', mechanism: '내부공사 중 보온재(스티로폼·우레탄) 연소', evidence: '○ 원 인 | 전기합선 추정 / ○ 인명피해 | 사망 2명', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0164'};
MATCH (a:RiskFactor {name: '보온재(스티로폼·우레탄)·방호구획 미비·소방시설 사용불능'}), (b:Event {name: '이천 농수산물유통센터 공사장 화재(1993)'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'High', reason: '급격한 연소 확대 및 유독가스 대량 방출로 초기대응 곤란', evidence: '방호구획 미비, 1~2층간 대형 엘리베이터, 닥트 등이 개방 ... 보온재료(스티로폼, 우레탄 스프레이)등이 산재해 있어 급격한 연소 확대 및 유독가스가 대량 방출', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0165'};
MATCH (a:Event {name: '인천 인현동 호프집·노래방 화재(1999)'}), (b:Damage {name: '인현동 화재 인명피해(1999)'}) MERGE (a)-[r:CAUSES]->(b) SET r += {directCause: '유독가스·연기 상층 확산으로 대피 불가', mechanism: '지하 노래방 유증기에 라이터 점화→시너통 인화→건물 전체 확산', evidence: '인명피해 | 137명(사망 56명, 부상 81명) ... 종업원 2명이 청소중 ... 라이터를 켜자 ... 유증기에 붙이 붙고 옆에 있던 시너통으로 옮겨 붙으며 화재가 건물 전체로 확산', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0166'};
MATCH (a:RiskFactor {name: '밀폐공간 시너 유증기·우레탄폼 내장재·비상탈출구 부족'}), (b:Damage {name: '인현동 화재 인명피해(1999)'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {spreadRisk: 'High', reason: '유독가스·연기 내부계단으로 상층 확산, 탈출구 부족으로 다수 인명피해', evidence: '내장재의 유독가스 및 연기가 내부계단을 통하여 상층으로 상승, 확산되어 대피할 기회가 없었던 ... 발화장소인 지하노래방 내부벽과 출입구 계단벽에 가연성 내장재인 우레탄폼으로 장식', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0167'};
MATCH (a:Context {name: '방화구획 설치 기준(연면적 1,000㎡ 초과)'}), (b:Event {name: '코리아2000 냉동창고 화재(2008)'}) MERGE (a)-[r:PREVENTS]->(b) SET r += {phase: 'prevention', reason: '방화구획으로 연소 확대 차단', effectiveness: 'Med', evidence: '주요구조부가 내화구조 또는 불연재료로 된 건축물로서 연면적이 1,000㎡를 넘는 것은 ... 방화구획 ... 하여야 한다', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0168'};
MATCH (a:ManmadeHazard {name: '우레탄·유성접착제 작업 유증기(HCFC-141b·톨루엔·아세톤)'}), (b:Event {name: '코리아2000 냉동창고 화재(2008)'}) MERGE (a)-[r:TRIGGERS]->(b) SET r += {probability: 'High', directCause: '유증기 급격 발화', mechanism: '밀폐 공간에 가득 찬 유증기가 발화원에 의해 폭발적 연소', specialNote: '구체적 발화원인은 현장소실로 미규명', evidence: '약 283톤의 우레탄 발포작업이 이루어졌고 ... 약 150kg 이상의 유성접착제를 이용한 보온작업을 하는 과정에서 발생한 다량의 HCFC-141b 유증기, 톨루엔·아세톤 등이 급격한 화재화산의 원인으로 작용하였음', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0169'};
MATCH (a:RiskFactor {name: '냉동창고 밀폐구조 및 환기조치 미흡'}), (b:Event {name: '코리아2000 냉동창고 화재(2008)'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'High', mechanism: '유증기 축적으로 폭발성 화재 확률 증대', reason: '환기 미실시로 밀폐공간에 유증기 정체', evidence: '밀폐된 공간에 갇은 유증기를 그 대로 방치하였음 ... 각 냉동실에 옥내용·배출용·2대의 환풍기만을 사용하였을 뿐 환기조치를 하지 아니함', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0170'};
MATCH (a:Event {name: '코리아2000 냉동창고 화재(2008)'}), (b:Event {name: '기계실·전기실로의 화재 급격 확산'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {probability: 'High', mechanism: '13·14층 냉동실 화재가 폭발적 연소로 통로를 통해 기계실·전기실로 급격 확산', spreadRisk: 'High', directCause: '폭발성 연소', evidence: '13, 14층 냉동실에서 발생한 화재가 폭발적인 연소에 의하여 통로를 통해 다층의 인부들이 작업 중이던 기계실, 진기실 까지 급격히 확산', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0171'};
MATCH (a:Event {name: '코리아2000 냉동창고 화재(2008)'}), (b:Event {name: '우레탄 원료 연쇄 폭발 및 내부 붕괴 위협'}) MERGE (a)-[r:TRIGGERS_SECONDARY]->(b) SET r += {probability: 'High', mechanism: '우레탄 원료(200ℓ 15동) 연쇄 폭발로 내부 붕괴 위협', spreadRisk: 'High', evidence: '창고 내부에 깔아놓은 우레탄 원료들이 연쇄 폭발을 일으켜 내부 붕괴 위협이 커지자', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0172'};
MATCH (a:RiskFactor {name: '샌드위치 패널 냉동창고 및 인화성 물질 다량 상존'}), (b:Event {name: '기계실·전기실로의 화재 급격 확산'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'High', mechanism: '가연물 다량 상존으로 화재 확산·폭발 위험 증대', evidence: '벽면과 천장이 샌드위치 패널로 돼 있어서 화재 위험이 높지만 ... 시너와 LPgas통 같은 방화성 물질도 창고 곳곳에 놓여 있었습니다', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0173'};
MATCH (a:Event {name: '방화셔터·스프링클러 수동조작(작동 불능)'}), (b:Damage {name: '코리아2000 화재 인명피해(사망40·부상10)'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {probability: 'High', mechanism: '소방시설 미작동으로 화재 확산 지연·소멸 실패, 방화셔터 바깥 약 33명 인부 대피 기회 상실', effectiveness: 'High', reason: '정상 작동 시 작업인부 외부 대피·생존 가능성 극히 높았음', evidence: '방화서터와 스프링클러를 수동으로 조작하여 둔 후 자동으로 전환하지 아니함으로써 화재발생 시 위 시설들이 전혀 작동 하지 아니하였음 ... 약 33명의 인부들이 작업 중이었는바, 위 시설들이 정상 작동되었다면 ... 생존하였을 가능성이 극히 높은 상황', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0174'};
MATCH (a:RiskFactor {name: '안전관리자 미배치(사용승인 후 안전관리 공백)'}), (b:Event {name: '코리아2000 냉동창고 화재(2008)'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'High', mechanism: '안전관리 공백으로 폭발적 화재 예방 실패', reason: '안전관리자 배치 시 급격한 폭발적 화재 예방 가능했을 것', evidence: '안전관리자를터 현장으로 전출조치함으로써 안전관리 실무자가 없게 됨으로 인하여 안전관리 상의 공백을 야기 ... 안전관리자를 배치하여 그 직무를 수행하도록 하였다면 금격한 폭발적인 화재를 예방할 수 있었을 것', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0175'};
MATCH (a:RiskFactor {name: '안전교육·화재대피훈련 미실시'}), (b:Damage {name: '코리아2000 화재 인명피해(사망40·부상10)'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {probability: 'High', mechanism: '최초 목격자가 화재발신기 미조작·119 전화에 약 37초 허비, 작업인부 대피 지연', effectiveness: 'Med', reason: '안전교육·신속대응 시 일부나마 피해 감소 가능', evidence: '누구도 작업인부들을 상대로 화재대피훈련을 직접 실시하지 아니하였음 ... 약 37초간 119에 전화를 하는 동으로 시간을 허비 ... 일부나마 피해를 줄일 수 있었을 것', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0176'};
MATCH (a:RiskFactor {name: '공기단축 위한 50명 이상 동시 투입 무리한 공사'}), (b:Event {name: '코리아2000 냉동창고 화재(2008)'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'High', mechanism: '다수 하청 인부가 한 공간에서 용접·배선·냉방설비 등 다양 작업 동시 수행하여 화약고에 불 붙이는 상황', reason: '안전관리·감독 곤란', evidence: '공기단축을 위하여 동시에 50명 이상의 각종 공사인력을 한계번에 투입하여 무리하게 공사를 진행 ... 한 공간에서 용접과 배선, 냥방설비 설치 등의 다양한 작업이 한깨번에 이뤄질 화약고에 불을 붙이는 꼴', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0177'};
MATCH (a:RiskFactor {name: '냉동창고 스프링클러 설치의무 제외 법령'}), (b:Event {name: '코리아2000 냉동창고 화재(2008)'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'High', mechanism: '냉동창고가 자동소화설비 설치의무 대상에서 제외되어 화재 시 자동소화 불가', reason: '고위험 가연성 적재물 다량 상존에도 스프링클러 미설치 허용', evidence: '냉동창고는 고 위험도를 가진 가연성 직재물이 다량 상존하나 소방법상 자동소화설비 설치의무 대상에서 제외 ... \'냇동장고를 제외한다\'고 규정', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0178'};
MATCH (a:RiskFactor {name: '허위 감리·사용승인 후 계속 공사 진행'}), (b:Event {name: '코리아2000 냉동창고 화재(2008)'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'High', mechanism: '사용승인 후 안전관리·감독 부재 상태로 위험작업 지속', evidence: '건축공사가 완료되지 아니한 상태에서 허위 감리보고를 하고 이천시청의 사용승인을 받았음 ... 시공자와 실질적으로 동일한 업체에서 건축설계 및 감리업무를 동시에 수행', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0179'};
MATCH (a:ResponseActor {name: '방화관리자 김○○'}), (b:ResponseAction {name: '방화셔터·스프링클러 정상작동 확인·점검'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '스프링클러 오작동 방지 명목으로 방화셔터·스프링클러 수동조작 후 자동전환 미실시, 소방시설 작동여부 확인·점검 미이행', phase: 'prevention', evidence: '방화관리자 김○○은 평소 방화서터. 스프링클러를 수동 조작해 두는 등 소방시설 작동여부를 확인·점검하지 아니함', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0180'};
MATCH (a:ResponseActor {name: '최초 목격자 채○○'}), (b:ResponseAction {name: '화재발신기 조작·내부 인부 대피경보'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '13호 냉동실 앞 화재발신기 미조작으로 내부 작업인부 대피조치 미흡, 안전교육 부재로 대처 미숙', phase: 'response', timing: '화재 직후', evidence: '약 37초간 119에 전화를 하는 동으로 시간을 허비하였을 뿐 ... 화재발신기를 조작하여 내부 작업인부들이 대피할 수 있도록 조치하는 등의 대처가 미숙', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0181'};
MATCH (a:ResponseActor {name: '이천소방서 등 소방대'}), (b:ResponseAction {name: '코리아2000 화재 진압 및 인명구조'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', scale: '대규모', effectiveness: 'Med', specialNote: '유독가스·붕괴위험으로 조기 진화 곤란, 일부 생존자 구조', evidence: '소방차 230여대·소방대원 900여명 투입 ... 화재를 진압하고 한 사람의 생명이라도 더 구하려 동분서주하는 소방대원 900여명, 경찰 370여명', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0182'};
MATCH (a:Event {name: '유독가스·붕괴위험에 따른 구조작업 중단·철수'}), (b:ResponseAction {name: '코리아2000 화재 진압 및 인명구조'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {probability: 'Med', mechanism: '구조작업 지연으로 수습 장기화', effectiveness: 'High', evidence: '내부 붕괴 위협이 커지자 오후5시께 구조대원을 모두 철수시키고 1시간 여 가량 수색 작업을 중단해야 했다', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0183'};
MATCH (a:ResponseAction {name: '지하1층 천공·연기배출 후 구조 재개'}), (b:Event {name: '기계실·전기실로의 화재 급격 확산'}) MERGE (a)-[r:MITIGATES]->(b) SET r += {effectiveness: 'Med', mechanism: '연기 배출·시야 확보로 구조 진입 가능', phase: 'response', evidence: '지하1층 천장을 10여 군데 구멍을 뜷 뒤 기름으로 내부를 제거 폭발위험을 줄이고 베련자를 이용해 연기를 빼낸 뒤 오후8시 다시 구조에 들어갔다', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0184'};
MATCH (a:Population {name: '냉동창고 인근 주민(호법면)'}), (b:Damage {name: '주변 건물 손상 및 주민 긴급대피'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {probability: 'Med', mechanism: '주변 건물 손상·유독가스 확산으로 주민 대피 필요', specialNote: '노출 인구', evidence: '주변 건물도 심하게 손들려 주민 600명 건금대피 ... 냉동창고 구별 200여 가구 주민 600여명도 ... 호텔면사무소 등으로 긴급 대피', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0185'};
MATCH (a:ResponseAction {name: '냉동창고 인근 주민 긴급대피'}), (b:Event {name: '코리아2000 냉동창고 화재(2008)'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {phase: 'response', timing: '화재 당일', effectiveness: 'Med', evidence: '냉동창고 구별 200여 가구 주민 600여명도 마을 방충음 듣고 호텔면사무소 등으로 긴급 대피', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0186'};
MATCH (a:ResponseActor {name: '수원지검 여주지청 수사전담팀'}), (b:ResponseAction {name: '코리아2000 화재 책임자 수사 및 기소'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', actionType: '사고원인 수사·책임자 기소', evidence: '수사전담팀을 편성하고 ... 냉동창고 소유자 검 시공업체 대표이사 공○○ 등 3명을 구속기소하고, 건기안전관리자 등 6명을 불구속기소하였으며, 소방공사감리 업체 등 5명을 약식기소', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0187'};
MATCH (a:ResponseAction {name: '스프링클러 설치의무 예외조항 삭제(법령 개정)'}), (b:RiskFactor {name: '냉동창고 스프링클러 설치의무 제외 법령'}) MERGE (a)-[r:PREVENTS]->(b) SET r += {effectiveness: 'High', phase: 'prevention', mechanism: '예외조항 삭제로 자동소화설비 설치 의무화하여 화재 확산 방지', evidence: '사람들의 이용에 제공되는 공간에 대해서는 스프링클러 등 각종 소방시설이 실치될 수 있도록 위 시행령상 예외조항을 삭제하는 방향으로 개정할 필요가 있음', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0188'};
MATCH (a:ResponseAction {name: '공사감리 지정제도 개선(건축법 제21조 개정)'}), (b:RiskFactor {name: '허위 감리·사용승인 후 계속 공사 진행'}) MERGE (a)-[r:PREVENTS]->(b) SET r += {effectiveness: 'High', phase: 'prevention', mechanism: '시공·감리 분리로 감리감독 부실 구조 차단', evidence: '공사 시공자 본인 및 ... 계열회사를 공사감리자로 지정하지 못하도록 위 제도가 개선 ... 코리아2000건축사사무소는 (주)코리아2000의 계열회사로서 그 직원인 권○○가 공사감리자로 지정될 수 없었음', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0189'};
MATCH (a:ResponseAction {name: '우레탄 작업 위험성 실험적 연구'}), (b:ManmadeHazard {name: '우레탄·유성접착제 작업 유증기(HCFC-141b·톨루엔·아세톤)'}) MERGE (a)-[r:MODIFIES_RISK_OF]->(b) SET r += {effectiveness: 'Med', phase: 'prevention', mechanism: '우레탄 작업 안전기준 마련으로 유사 화재 예방', specialNote: '1997년 부산 냉동창고 화재(44명 사상)로도 위험성 알려졌으나 연구 미흡', evidence: '우레탄 작업시 발생하는 HCFC-141b 유증기의 인화성·가연성 성질유무, 위험성 등에 대한 실험적인 연구를 진행하여 ... 1997년 44명의 사상자를 발생케 한 부산 냉동창고 화재사건', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0190'};
MATCH (a:Damage {name: '코리아2000 화재 인명피해(사망40·부상10)'}), (b:Context {name: '화재 당시 작업인부 현황'}) MERGE (a)-[r:QUANTIFIED_BY]->(b) SET r += {detail: '화재 당시 창고 내 근로자 57명 중 40명 사망', evidence: '당시 창고 안에 있던 근로자는 모두 57명 ... 40명이 회생했습니다 ... 방화서터 바깥쪽에 위치한 기계실, 냉동실 및 23호 냉동실 앞 통로에 약 33명의 인부들이 작업 중', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0191'};
MATCH (a:RiskFactor {name: '건축법상 창고시설 규정 미비(용도변경 악용)'}), (b:Event {name: '코리아2000 냉동창고 화재(2008)'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'Med', mechanism: '용도변경 악용으로 소방·안전기준 회피', reason: '물류회사들의 창고 허가 후 개조 관행', evidence: '현행 건축법에는 창고시설에 대한 명확한 규정이 없어 물류 회사들이 일단 창고로 건축 허가를 받은 뒤 냉동·냉장 물류시설로 개조 ... 제1종 근린생활시설 소매점으로 건축허가를 받아놓고 실제로는 \'창고 용도\'로 불법 입대', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0192'};
MATCH (a:RiskFactor {name: '하청·재하청 구조 및 안전책임자 미신고'}), (b:Event {name: '코리아2000 냉동창고 화재(2008)'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'Med', mechanism: '하청 다단계로 안전관리 책임 불명확, 저소득층 미숙련공 안전교육 미비', evidence: '하청에 재하청 구조가 늘은 관리 허술, 저소득층 미숙련공들의 안전교육 미비 ... 유성에너지랑은 ... 재하청업체를 두고 작업했다. 하지만 ... 현장 안전관리 책임자를 노동부 관할지청에 신고하지 않았다', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0193'};
MATCH (a:RiskFactor {name: '비상업용 건축물 비상구·제연설비 미의무화 소방법'}), (b:Damage {name: '코리아2000 화재 인명피해(사망40·부상10)'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {probability: 'Med', mechanism: '비상구·제연설비 미비로 화재 시 대피·연기배출 곤란', effectiveness: 'Med', evidence: '공장이나 창고 같은 비상업용 건축물에 대해 비상구 설치를 의무로 규정하지 않은 소방법도 문제 ... 소방법상 재연설비 설치를 의무화하는 것이 바람직', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0194'};
MATCH (a:RiskFactor {name: '자동화재탐지설비·소화기 노후·미작동'}), (b:Damage {name: '코리아2000 화재 인명피해(사망40·부상10)'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {probability: 'Med', mechanism: '자동경보·초기진화 설비 미작동으로 초기대응 실패', effectiveness: 'Med', evidence: '자동경보장치조차 꺼져있는 만큼 ... 소화기도 10년 전에 만들어져 ... 가스 압력이 떨어져 초기 진화는 엄두조차 날 수 없습니다', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0195'};
MATCH (a:Event {name: '1997년 부산 냉동창고 화재'}), (b:Event {name: '코리아2000 냉동창고 화재(2008)'}) MERGE (a)-[r:CONCURRENT_WITH]->(b) SET r += {specialNote: '선행 유사사례 — 우레탄 작업 위험성을 알렸으나 연구·대책 미흡으로 이천 화재 재발', mechanism: '동일 우레탄 작업 위험 메커니즘', evidence: '1997년 44명의 사상자를 발생케 한 부산 냉동창고 화재사건을 통하여서도 우레탄 작업의 위험성이 널리 알려졌음에도 그 이후로 이에 대한 연구가 미흡', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0196'};
MATCH (a:ManmadeHazard {name: '용접·발화 작업(불티)'}), (b:Event {name: '유증기 폭발(2008 이천 냉동창고)'}) MERGE (a)-[r:TRIGGERS]->(b) SET r += {probability: 'High', directCause: '용접 불티가 밀폐공간에 깔린 유증기에 점화', mechanism: '집화원(불티) 발생 → 유증기 점화', scale: '초대형', evidence: '벽면 단열재인 \'우레탄폼\' 발포 작업 과정에서 정전기 가연성 증기가 냉동창고 안에 들어차 있다가 폭발한 것으로 사고 원인을 추정', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0197'};
MATCH (a:RiskFactor {name: '밀폐된 지하 작업공간'}), (b:Event {name: '유증기 폭발(2008 이천 냉동창고)'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'High', reason: '밀폐공간에서 인화성 유증기 농축 → 대형폭발·화재 위험 증대', mechanism: '환기 불가로 유증기 축적', evidence: '지하층 냉동창고는 탈출구가 부족한 사실상 밀폐된 공간인데도 소방점검을 통과했고', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0198'};
MATCH (a:RiskFactor {name: '인화성 화학물질 다량 적재(시너·우레탄폼·프레온·암모니아)'}), (b:Event {name: '유증기 폭발(2008 이천 냉동창고)'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'High', reason: '가연성 물질이 작업공간에 산재해 폭발·연소 규모 증대', mechanism: '용접작업 중 인화성 물질 동시 연소', evidence: '밀폐된 코리아2000 냉동 창고 지하 1층 작업장에는 시너 유증기와 프레온 가스, 암모니아 가스, 우레탄폼 등 인화성이 강한 화학물질이 가득 차 있었다', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0199'};
MATCH (a:RiskFactor {name: '환기시설 부재'}), (b:Event {name: '유증기 폭발(2008 이천 냉동창고)'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'High', reason: '환기 부재로 유증기가 빠져나가지 못하고 농축', evidence: '화재원인으로 지목되는 시너 유증기에 대한 환기대책도 없었다 … 사고 현장에는 제대로 된 환기시설조차 설치되지 않았으며', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0200'};
MATCH (a:Event {name: '유증기 폭발(2008 이천 냉동창고)'}), (b:Event {name: '냉동창고 대형 화재 확산(2008 이천)'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {probability: 'High', mechanism: '폭발에 이어 대형 화재로 확산', spreadRisk: 'High', directCause: '밀폐공간 내 인화성 물질 연쇄 연소', evidence: '창고 내부에서 마감공사 등의 건축공사가 계속되던 중 폭발에 이어 화재가 발생하게 된 것', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0201'};
MATCH (a:Event {name: '냉동창고 대형 화재 확산(2008 이천)'}), (b:Event {name: '근로자 고립·대피 실패(2008 이천 냉동창고)'}) MERGE (a)-[r:TRIGGERS_SECONDARY]->(b) SET r += {mechanism: '유독가스·연기 발생 및 출입문 변형으로 대피 불가', spreadRisk: 'High', evidence: '화재 발생 초기 17명이 탈출했던 출입문은 어디가 문이고 어디가 벽인지 알 수 없게 완전히 짜그러져 있었다 … 건물 구조가 미로 같아서', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0202'};
MATCH (a:RiskFactor {name: '비상구 1곳 설치(규정 2곳 위반)'}), (b:Event {name: '근로자 고립·대피 실패(2008 이천 냉동창고)'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'High', reason: '탈출로 부족으로 인명피해 확대', mechanism: '화재시 대피로 차단', evidence: '냉동창고의 비상구가 규정(2곳 이상 설치)과 다르게 1곳만 설치된 점 … 탈출구가 전면과 후면 2곳뿐(실제 1곳만 가능)', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0203'};
MATCH (a:Event {name: '근로자 고립·대피 실패(2008 이천 냉동창고)'}), (b:Damage {name: '코리아2000 화재 인명피해(사망40·부상10)'}) MERGE (a)-[r:CAUSES]->(b) SET r += {scale: '초대형', directCause: '유독가스 흡입·소사', probability: 'High', evidence: '40명의 목숨을 앗아간 이천 냉동창고 화재 참사 … 40명이 숨지고 10명이 다쳤다', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0204'};
MATCH (a:Event {name: '냉동창고 대형 화재 확산(2008 이천)'}), (b:Damage {name: '코리아2000 화재 인명피해(사망40·부상10)'}) MERGE (a)-[r:CAUSES]->(b) SET r += {scale: '초대형', probability: 'High', evidence: '7일 오전 발생한 경기 이천 코리아2000 냉동물류창고 화재 참사 현장에서 탈출하지 못한 채 숨진 근로자들', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0205'};
MATCH (a:Event {name: '냉동창고 대형 화재 확산(2008 이천)'}), (b:Damage {name: '냉동창고 건물 전소(2008 이천)'}) MERGE (a)-[r:CAUSES]->(b) SET r += {scale: '대형', directCause: '건물·시설 전소', evidence: '냉동창고는 폐허로 변했다 … 건물을 떠받치던 \'H\'모양의 철재 빔은 불에 엿가락처럼 휘어 있었고', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0206'};
MATCH (a:ResponseAction {name: '이천 화재 진화 작업(소방관 출동)'}), (b:Event {name: '냉동창고 대형 화재 확산(2008 이천)'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {timing: '화재 직후~수일간', scale: '대규모', evidence: '소방관 120여 명은 이날 오전 추가 희생자가 있는지 정밀 수색작업에 나섰다', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0207'};
MATCH (a:ResponseAction {name: '이천 화재 진화 작업(소방관 출동)'}), (b:Damage {name: '소방관 뇌출혈 공상(이우호 진압대장)'}) MERGE (a)-[r:CAUSES]->(b) SET r += {directCause: '연속근무·과로', mechanism: '비번 동원→72시간 연속근무→뇌출혈', reason: '소방 인력부족', evidence: '살인적 피로가 뇌출혈을 일으킨 것이다 … 이천 화재를 진압하던 장면조차 뇌리에서 사라졌다', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0208'};
MATCH (a:RiskFactor {name: '소방 인력부족·열악한 근무여건'}), (b:Damage {name: '소방관 뇌출혈 공상(이우호 진압대장)'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'Med', reason: '과로·연속근무로 소방관 2차 피해 반복', mechanism: '인력부족→과중근무', evidence: '인력부족으로 인한 소방관들의 사고는 매년 반복되고 있지만 상황은 나아지지 않고 있습니다', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0209'};
MATCH (a:ResponseAction {name: '스프링클러·소화기 미작동'}), (b:Event {name: '냉동창고 대형 화재 확산(2008 이천)'}) MERGE (a)-[r:FAILS]->(b) SET r += {effectiveness: 'Low', reason: '소방설비 부실시공·작동불량', consequence: '초기 진화 실패로 화재 급속 확산', evidence: '화재 당시 스프링클러 등도 제대로 작동하지 않았다 … 스프링클러와 소화기도 작동되지 않았다', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0210'};
MATCH (a:ResponseActor {name: '소방서(소방점검 담당)'}), (b:ResponseAction {name: '밀폐공간 소방점검 통과'}) MERGE (a)-[r:FAILS]->(b) SET r += {effectiveness: 'Low', reason: '서류상 감리보고서만 검토, 화재 전력에도 실질점검 부재, 설계변경 1주일만에 소방완비 검사 통과', timing: '준공 전', evidence: '소방서의 역할은 코리아2000에서 고용한 소방시설 감리로부터 보고서를 받아 서류상 이상이 있는지 판단하는 것뿐 … 어떻게 소방점검을 통과했는지 궁금증을 불러일으킨다', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0211'};
MATCH (a:RiskFactor {name: '안전보건 총괄책임자 미선임·미신고'}), (b:Event {name: '유증기 폭발(2008 이천 냉동창고)'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'High', reason: '안전관리 공백으로 위험작업 통제 불가', mechanism: '정부 관리감독 부재→안전의식 이완', evidence: '안전보건 책임자를 두고 신고해야 하는데 신고를 하지 않았다 … 해당 공사는 노동부의 관리감독에서 아예 벗어나 있었다', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0212'};
MATCH (a:RiskFactor {name: '복잡한 원·하청 구조'}), (b:Event {name: '유증기 폭발(2008 이천 냉동창고)'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'High', reason: '총괄 안전관리 부재, 하청별 분절작업으로 전체 위험상태 무관심', mechanism: '동시다발 작업+화기작업 병행', evidence: '복잡한 원·하청 구조 탓에 총괄적인 안전관리가 이뤄지지 않은 점도 문제점 … 화약고에 불을 붙이는 꼴', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0213'};
MATCH (a:RiskFactor {name: '미숙련 일용직 근로자 투입·안전교육 부재'}), (b:Damage {name: '코리아2000 화재 인명피해(사망40·부상10)'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {probability: 'Med', reason: '위험인지 부족·보호장비 부재로 인명피해 확대', mechanism: '안전교육 부재', evidence: '저소득층 미숙련공을 고용해 안전교육조차 시키지 않은 채 공사를 강행 … 마스크와 보호장비도 안 주고서 일하라고 했다', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0214'};
MATCH (a:Population {name: '지하 작업 근로자(일용직·하청)'}), (b:Damage {name: '코리아2000 화재 인명피해(사망40·부상10)'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {reason: '밀폐 지하공간 다수 근로자 밀집 작업으로 폭발·화재시 대규모 인명피해', probability: 'High', evidence: '현장에 있던 57명은 지하 1층에서 … 작업 등을 진행하고 있었다', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0215'};
MATCH (a:RiskFactor {name: '용도변경 사후관리 미흡한 건축법'}), (b:Event {name: '냉동창고 대형 화재 확산(2008 이천)'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'Med', reason: '화재 위험 높은 냉동창고에 강화된 소방기준 미적용', mechanism: '허가용도와 실제용도 불일치', evidence: '업체는 일반창고 허가를 받은 후 냉동창고로 편법 개조 … 현행 건축법은 용도변경 시 엄격한 기준을 적용하지 않는 데다 사후관리도 미흡', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0216'};
MATCH (a:ResponseAction {name: '건축법·소방기준 연계 강화 및 정기점검'}), (b:Event {name: '냉동창고 대형 화재 확산(2008 이천)'}) MERGE (a)-[r:PREVENTS]->(b) SET r += {effectiveness: 'Med', timing: '재발방지', reason: '유사 화재사고 예방 목적', evidence: '건축 허가 단계부터 소방, 보건 등 관련 부서와의 협력을 강화하고 준공 후에도 정기적인 점검을 실시해야 한다 … 유사 사고를 예방할 방침', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0217'};
MATCH (a:RiskFactor {name: '방화문 미작동'}), (b:Damage {name: '코리아2000 화재 인명피해(사망40·부상10)'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {probability: 'Med', reason: '방화구획 작동 실패로 화재 인접실 확산', mechanism: '방화문 미작동', evidence: '방화문 작동안돼 참사 키웠다 … 화재당시 자동닫힌 인접실 인명피해 가능 … 방화벽 설치 미흡, 불연재 사용 부족 등이 화재 확산의 주요 원인', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0218'};
MATCH (a:RiskFactor {name: '화재 전력(과거 용접 화재 반복)'}), (b:Event {name: '유증기 폭발(2008 이천 냉동창고)'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'Med', reason: '반복된 화재 경고에도 안전대책 부재', mechanism: '전조사건 무시', evidence: '지난해 8월에도 \'코리아 2000\'이 신축하던 또 다른 냉동창고에서 용접작업 중 불이 났다. 이런 경고에도 불구하고 안전대책은 없었다', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0219'};
MATCH (a:Damage {name: '코리아2000 화재 인명피해(사망40·부상10)'}), (b:Context {name: '2008-01-07 10:45 이천 호법면 유산리'}) MERGE (a)-[r:QUANTIFIED_BY]->(b) SET r += {detail: '사망 40명·부상 10명, 외국인 근로자 13명 포함, 신원확인 16명(1월11일 기준)', evidence: '코리아2000 냉동창고에서 폭발과 함께 발생한 대형 화재로 인해 지하층에서 작업중이던 인부 40명이 숨지는 참사', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0220'};
MATCH (a:Event {name: '유증기 폭발(2008 이천 냉동창고)'}), (b:Context {name: '2008-01-07 10:45 이천 호법면 유산리'}) MERGE (a)-[r:OCCURS_AT]->(b) SET r += {timing: '사고발생', evidence: '지난달 7일 오전 경기 이천시 호법면 \'코리아2000\' 냉동창고에서 폭발과 함께 발생한 대형 화재', sourceDoc: '이천 코리아2000 냉동창고 화재사고 백서 (경기소방, 2008)', tripleId: 'T0221'};
