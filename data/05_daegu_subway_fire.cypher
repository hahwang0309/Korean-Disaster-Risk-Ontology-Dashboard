MATCH (a:Event {name: '1080호 전동차 화재'}), (b:Damage {name: '대구 지하철 참사 인명피해'}) MERGE (a)-[r:CAUSES]->(b) SET r += {mechanism: '반대방향 운행 중 화재 확산되어 많은 사상자 발생', reason: '1079호 승객 대부분 대피한 반면 1080호 다수 사상', evidence: '반대방향으로 운행중이던 1080호 전동차로 화재가 확산되어 많은 사상자가 발생되었다.', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0012'};
MATCH (a:Damage {name: '대구 지하철 참사 인명피해'}), (b:Context {name: '사상자 현황표(성별·연령별)'}) MERGE (a)-[r:QUANTIFIED_BY]->(b) SET r += {evidence: '지하철 화재사고 사상자 현황 ... 사망자 192 ... 부상자 151 ... 343명 / 0 성 별 ... 0 연령별', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0013'};
MATCH (a:ManmadeHazard {name: '방화범 김대한'}), (b:Population {name: '1079·1080호 전동차 승객'}) MERGE (a)-[r:AFFECTS]->(b) SET r += {role: '노출 대상', mechanism: '전동차 내 승객 대피·고립', evidence: '승객들이 전동차에서 지상의 출구까지 피난하기 위해서는 지하 3층 승강장, 개찰구가 있는 지하 2층 ... 지상출구로 나올 수 있었다.', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0014'};
MATCH (a:Event {name: '유독가스·농연 확산'}), (b:Event {name: '승객 피난 곤란'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {mechanism: '상당량의 연기와 정전으로 시야장애·방향감각 상실, 좁은 승강장 폭, 기둥 장애물로 피난 곤란', spreadRisk: 'High', evidence: '상당량의 연기와 정전으로 승객들의 피난에 어려움을 주었고 ... 시야장애로 방향감각을 상실한 피난자들이 엉키면서 피난에 어려움이 가중', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0015'};
MATCH (a:Event {name: '중앙로역 일대 정전'}), (b:Damage {name: '대구 지하철 참사 인명피해'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {mechanism: '정전+연기로 시야 확보 불가, 피난 지연', effectiveness: 'High', evidence: '화재의 발생지점과 같은 층에서 탈출해야 하므로 상당량의 연기와 정전으로 승객들의 피난에 어려움을 주었고', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0016'};
MATCH (a:ResponseActor {name: '1079호 전동차 기관사'}), (b:ResponseAction {name: '초기 화재신고·보고'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '화재발생 사실을 종합사령실에 보고하지 않은 채 역사 밖으로 대피, 소화기 진화 실패', mechanism: '초기 보고 누락으로 사고확대 방지 기회 상실', timing: '09:53경', evidence: '1079호 기관사는 소화기로 불을 끄려고 시도하였으나 실패하였으며, 화재발생 사실을 종합사령실에 보고하지 않은 채 역사 밖으로 대피', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0017'};
MATCH (a:ResponseActor {name: '종합사령실(대구지하철공사)'}), (b:ResponseAction {name: '1080호 전동차 진입통제·운행중단 지시'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '화재경보 미확인, 사태 심각성 미인식으로 119 미신고, 1080호에 중앙로역 진입금지·무정차 통과 지시 대신 막연한 All Call만 통보', mechanism: '1080호 진입 차단 실패로 2차 화재 확산', timing: '09:53~09:55:36', evidence: '종합사령실에서는 ... 1080호 전동차에 중앙로역에 진입하지 말도록 지시하거나 ... 무정차 통과하도록 지시하지 않고 ... 막연하게 지시하였다.', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0018'};
MATCH (a:ResponseActor {name: '종합사령실(대구지하철공사)'}), (b:ResponseAction {name: '화재경보 확인·119 신고'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '기계설비사령 주컴퓨터에 화재경보 문구·경보음 발생했으나 확인하지 못함, 역무원 신고에도 심각성 미인식해 119 미신고', timing: '09:53~09:55', evidence: '종합사령실 기계설비사령 주컴퓨터에 중앙로역 화재경보 문구가 뜨고 경보음이 울렸으나, 종합사령실에서는 확인하지 못하였음', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0019'};
MATCH (a:ResponseActor {name: '1080호 전동차 기관사 최상열'}), (b:ResponseAction {name: '1080호 승객 대피 조치'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '사태 심각성 미인식, 승객 대피보다 전동차 출발에 집착해 대피시기를 놓침, 대기 안내방송 반복', mechanism: '출발 집착으로 대형 인명피해 발생', timing: '09:57~10:10', evidence: '1080호의 기관사는 ... 승객대피에는 손을 쓰지 못하고 전동차를 출발시키는 데만 집착한 결과, 승객들의 대피시기를 놓쳐 대형 인명피해가 발생하였다.', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0020'};
MATCH (a:ResponseActor {name: '종합사령실(대구지하철공사)'}), (b:ResponseAction {name: '1080호 승객 대피 조치'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '1080호 기관사의 조치 요구에 상황판단 못하고 \'대기하고 안내방송하라\'고 지시, 대피 지시 지연', timing: '09:57:32', evidence: '운전사령은 상황판단을 하지 못한 채 \'대기하고 승객들에게 안내방송하라\'고 지시', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0021'};
MATCH (a:ResponseActor {name: '중앙로역 역무원'}), (b:ResponseAction {name: '역무원 초기소화·신고·대피유도'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', timing: '09:55~09:57:40', effectiveness: 'Low', detail: '초기 소화 시도 실패, 종합사령실 신고 후 09:57:40 직접 119 신고, 일부 직원 승객 대피 유도', evidence: '중앙로역 역무원이 초기 소화를 시도하였으나 실패하고 일부직원이 승객 대피 유도 ... 09:57:40 중앙로역 역무원이 화재 사실을 119 신고', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0022'};
MATCH (a:ResponseActor {name: '1079호 승객(40대 남자)'}), (b:ResponseAction {name: '소방본부 화재 최초신고'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', timing: '09:53:35~09:54:40', detail: '화재 발생을 소방본부 종합상황실에 최초 신고', evidence: '1079호 전동차의 40대 남자승객이 ... 화재가 발생되었다는 내용을 소방본부 종합상황실에 최초 신고', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0023'};
MATCH (a:ResponseActor {name: '대구소방본부'}), (b:ResponseAction {name: '화재진압 및 인명구조 작업'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', timing: '09:54:40~13:38', mechanism: '삼덕파출소 등 8개 출동대 출동명령, 16개 파출소·구조대 추가 동원, 경북소방본부 지원요청', effectiveness: 'Med', evidence: '경찰관과 소방관이 긴급 출동하여 현장지휘소를 설치 ... 소방인력과 장비를 동원하여 화재진화와 구조작업을 펼쳤으나, 화염과 유독가스로 현장접근이 힘들어 구조가 지연', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0024'};
MATCH (a:ResponseAction {name: '화재진압 및 인명구조 작업'}), (b:Event {name: '1080호 전동차 화재'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {timing: '09:54~13:38', effectiveness: 'Med', consequence: '화염·유독가스로 구조 지연', evidence: '소방인력과 장비를 동원하여 화재진화와 구조작업을 펼쳤으나, 화염과 유독가스로 현장접근이 힘들어 구조가 지연', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0025'};
MATCH (a:Resilience {name: '방화셔터(지하 1층 지하상가 통로)'}), (b:Damage {name: '지하상가 피해'}) MERGE (a)-[r:OFFSETS]->(b) SET r += {effectiveness: 'High', mechanism: '방화셔터 작동으로 상가쪽 연기·열 차단', evidence: '상가쪽 통로 입구에는 방화셔터가 설치되어 있어 ... 방화셔터의 작동으로 상가쪽의 피해는 연기에 의한 약간의 피해 이외에는 없었다.', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0026'};
MATCH (a:Event {name: '지하 2층 대합실 화재·농연 확산'}), (b:Damage {name: '중앙로역 역사시설 재산피해'}) MERGE (a)-[r:CAUSES]->(b) SET r += {mechanism: '고온 열기·농연으로 시설 손상', scale: '중', evidence: '고온의 열기는 상승기류를 만들면서 지하 2층 대합실의 상부에 설치된 안내표지판, 제연경계벽 등의 플라스틱류 제품을 녹일 정도였다.', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0027'};
MATCH (a:ResponseAction {name: '전 전동차 운행중단·승객하차 조치'}), (b:Event {name: '1080호 전동차 화재'}) MERGE (a)-[r:MITIGATES]->(b) SET r += {effectiveness: 'Med', timing: '사고확대 후 시점', reason: '추가 전동차 진입 차단', evidence: '종합사령실에서는 다른 전동차의 운행을 통제하면서 모든 전동차의 운행을 정지시켰고 ... 전 전동차 운행중지 및 승객하차 지시', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0028'};
MATCH (a:Event {name: '대구 지하철 중앙로역 화재(2003)'}), (b:Damage {name: '중앙로역 화재 인명피해'}) MERGE (a)-[r:CAUSES]->(b) SET r += {scale: '대형', directCause: '화재로 인한 높은 열과 연기', mechanism: '지하 밀폐공간 내 유독가스·고열 확산', evidence: '186 / 125 사망자 / 신원미확인 6명 제외; 지하철 화재사고는 화재로 인한 높은 열과 연기가 발생하면서 인명피해 규모가 커졌을 뿐만 아니라', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0029'};
MATCH (a:Context {name: '사고 발생시간(2003-02-18 09:53)'}), (b:Damage {name: '중앙로역 화재 인명피해'}) MERGE (a)-[r:UNDER_CONDITION]->(b) SET r += {reason: '이용객 많은 시간대로 인명피해 규모 확대', effectiveness: 'High', evidence: '사고 발생시간이 오전 09:53경으로 비교적 많은 사람들이 이용하는 시간이었기 때문에 인명피해의 규모가 컸다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0030'};
MATCH (a:Population {name: '지하철 이용 승객(중앙로역 화재)'}), (b:Damage {name: '중앙로역 화재 인명피해'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {reason: '대중교통 이용객이 많아 노출 인구 규모 큼', scale: '대형', evidence: '지하철이 대중교통수단이기 때문에 많은 사람들이 이용하고 있을 뿐 아니라 ... 인명피해의 규모가 컸다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0031'};
MATCH (a:Population {name: '1080호 전동차 탑승객(동구 주민 다수)'}), (b:Damage {name: '중앙로역 화재 인명피해'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {reason: '1080호 탑승객 인명피해가 커 동구 주민 사상자 최다', specialNote: '1079호에도 동구지역 주민 다수 탑승', evidence: '사상자 가운데 동구 주민이 가장 많았던 것은 안심역에서 출발한 1080호 전동차에 탑승한 승객들의 인명피해가 컸고', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0032'};
MATCH (a:Damage {name: '중앙로역 화재 인명피해'}), (b:Context {name: '사망자 인구통계 분포(연령·지역·직업)'}) MERGE (a)-[r:QUANTIFIED_BY]->(b) SET r += {detail: '연령별: 청·장년층(20~59세) 집중; 지역별: 동구 92명 최다; 직업별 다양', category: 'human', evidence: '청 장년층에서 사상자가 많이 발생한 것은 시기적으로 봄방학 기간이었던 점과 사고 당일 계명대학교 졸업식에 참석하기 위해 일가족이 함께 탑승하였다가 ... 18가족; 1가구에 2명 이상의 가족이 동시에 참변 ... 12가구', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0033'};
MATCH (a:Event {name: '중앙로역 화재로 인한 실종자 발생'}), (b:Damage {name: '실종자 처리·인정사망 문제'}) MERGE (a)-[r:TRIGGERS_SECONDARY]->(b) SET r += {reason: '고열로 시신 훼손·신원확인 곤란', specialNote: '실종자 처리문제가 가장 큰 문제로 대두', evidence: '신원 확인이 어려운 시신들이 많이 발견되어 ... 실종자 신고를 접수한 결과 619명이 신고하여 실종자 처리문제가 가장 큰 문제로 대두', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0034'};
MATCH (a:ResponseActor {name: '대구시 사고대책본부'}), (b:ResponseAction {name: '실종자 인정사망 심사'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', reference: '1995년 삼풍백화점 사고 사례 참조', evidence: '실종자인정사망심사위원회를 구성하기로 ... 위원회는 전문가 15명 내외로 구성 ... 3월 10일 구성하여 10차례 위원회를 개최 ... 121명에 대해 심사 ... 사망인정 1명, 판단유보 1명, 인정사망 불인정 20명으로 판정', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0035'};
MATCH (a:Event {name: '대구 지하철 중앙로역 화재(2003)'}), (b:Damage {name: '중앙로역 화재 재산피해(지하철·역사)'}) MERGE (a)-[r:CAUSES]->(b) SET r += {scale: '대형', directCause: '전동차 전소 및 역사 설비 소실', evidence: '전동차 2편성(12량)이 전소되었고, 중앙로역의 시설·전기·통신·신호분야 등도 소실 ... 총 570억원의 재산피해가 발생', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0036'};
MATCH (a:Event {name: '대구 지하철 중앙로역 화재(2003)'}), (b:Damage {name: '중앙로역 화재 인근상가 피해'}) MERGE (a)-[r:CAUSES]->(b) SET r += {scale: '대형', directCause: '역사와 연결된 인근 지하상가·점포 피해', evidence: '인근상가 피해신고는 총 174건 8,340백만원이 접수 ... 최종 피해액은 167건 4,477백만원으로 확인', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0037'};
MATCH (a:RiskFactor {name: '전동차 가연성 내장재'}), (b:Event {name: '대구 지하철 중앙로역 화재(2003)'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {reason: '화재 시 급속 연소·유독가스 발생으로 인명피해 확대', probability: 'High', spreadRisk: 'High', evidence: '내장재로 사용한 재료 ... 폴리에스터계 FRP 벽체 및 천장판 두께 2.3mm, 폴리에틸렌 폼 52mm, 염화비닐(PVC), 폴리에스테르 모켓트, 폴리우레탄 폼+펠트', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0038'};
MATCH (a:RiskFactor {name: '전동차 1인 운전(ATC/ATO) 운영방식'}), (b:Damage {name: '중앙로역 화재 인명피해'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {reason: '1인 승무로 비상대응·대피유도 역량 제약', probability: 'Med', evidence: '운전방식 ATC/ATO, 1인 운전', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0039'};
MATCH (a:RiskFactor {name: '지하 밀폐구조(지하철 화재 취약성)'}), (b:Damage {name: '중앙로역 화재 인명피해'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {reason: '밀폐 지하공간 연기 정체 및 복잡 동선으로 대피 곤란', probability: 'High', spreadRisk: 'High', evidence: '지하 1층은 인근 중앙지하상가와 연결되어 통로가 다소 복잡한 구조로 되어 있다; 역사는 지하 3층 ... 심도는 18.16m', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0040'};
MATCH (a:Resilience {name: '중앙로역 환기·연기배출 설비'}), (b:Damage {name: '중앙로역 화재 인명피해'}) MERGE (a)-[r:OFFSETS]->(b) SET r += {reason: '화재 시 자동 연기배출로 피해 완화 설계', effectiveness: 'Low', specialNote: '정전 등으로 실제 작동 한계 가능성', evidence: '화재발생시 역사 및 본선환기설비는 자동으로 연기 배출을 한다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0041'};
MATCH (a:ResponseActor {name: '대구광역시지하철공사'}), (b:ResponseAction {name: '무료 셔틀버스 운행'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', timing: '사고 이후', evidence: '지하철 화재사고 이후 대곡~교대(12개역), 동대구~안심(12개역)으로 나누어 구간운행을 하고, 미운행구간 6개역에 대해서는 무료셔틀버스를 운행 ... 2003년 12월 31일부터 1호선 전구간을 정상운행', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0042'};
MATCH (a:Resilience {name: '중앙로역 화재발생시 자동 연기배출 환기설비'}), (b:Resilience {name: '유독가스 확산 완화 역량'}) MERGE (a)-[r:BUILDS]->(b) SET r += {role: '연기 배출로 유독가스 피해 완충 의도', effectiveness: 'Low', specialNote: '실제 사고시 수동 가동 지연·정전 등으로 효과 제한', evidence: '화재발생시 역사 및 본선환기설비는 자동으로 연기 배출을 한다.', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0043'};
MATCH (a:Facility {name: '중앙로역'}), (b:Region {name: '대구광역시'}) MERGE (a)-[r:LOCATED_IN]->(b) SET r += {role: '위해 노출 시설의 행정구역', evidence: '지하철 중앙로역 화재 / 대구지하철 화재사고 대책본부', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0044'};
MATCH (a:Facility {name: '중앙로역'}), (b:Resilience {name: '중앙로역 소방·방재설비'}) MERGE (a)-[r:HAS_RESILIENCE]->(b) SET r += {role: '역사 내 소방·방재 설비 보유', specialNote: '분말소화기·옥내소화전·스프링클러·제연설비·자동탐지설비·CO2소화설비 등 설치', evidence: '소방설비 현황 ... 분말소화기 ... 옥내소화전 ... 스프링클러 ... 제연설비 ... 자동탐지설비', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0045'};
MATCH (a:Facility {name: '중앙로역 전기설비'}), (b:Facility {name: '중앙로역'}) MERGE (a)-[r:LOCATED_IN]->(b) SET r += {role: '전력공급 계통 소속 역사', evidence: '전차선(전동차전력) 직류 1500V(반월당, 신천변전소에서 병렬 공급)', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0046'};
MATCH (a:Event {name: '1079호 전동차 화재'}), (b:Context {name: '사고 발생시간(2003-02-18 09:53)'}) MERGE (a)-[r:OCCURS_AT]->(b) SET r += {role: '최초 착화 시각', evidence: '09:53경 1079호 전동차의 방화로 인하여 화재경보기가 울리자', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0047'};
MATCH (a:RiskFactor {name: '지하 밀폐 역사구조'}), (b:Event {name: '유독가스·농연 확산'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'High', mechanism: '밀폐공간에서 연기·유독가스 농축 및 배출 곤란', reason: '지하공간 화재시 피난·진압 곤란', evidence: '지하에 가득 찬 농연 ... 지하공간 화재 / 매연과 유독가스가 급속히 번지며 주변이 암흑상태', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0048'};
MATCH (a:Event {name: '1080호 전동차 중앙로역 진입·정차'}), (b:Event {name: '1080호 전동차 출발 불능·승객 고립'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {probability: 'High', directCause: '화재역 진입 후 출입문 개방으로 객실에 유독가스 유입', mechanism: '유독가스가 극심한 승강장에서 출입문 개방', reason: '기관사가 큰 화재가 아닐 것으로 오판', evidence: '전동차는 자동으로 중앙로역 상선승강장에 정차한 후 출입문이 개방되었다. 승강장 상태를 확인하려고 ... 유독가스가 극심하여', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0049'};
MATCH (a:RiskFactor {name: '기관사의 화재 오판(큰 화재 아닐 것)'}), (b:Event {name: '1080호 전동차 중앙로역 진입·정차'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'High', reason: '선제 정차·대피 미실시', evidence: '진입하기 전 상당거리 전방에서 역구내에 매연이 가득한 것을 발견하였으나 큰 화재가 아닐 것이라고 생각하고 별다른 조치없이 승강장으로 진입', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0050'};
MATCH (a:Event {name: '1080호 전동차 출발 불능·승객 고립'}), (b:Event {name: '중앙로역 전차선 단전'}) MERGE (a)-[r:CONCURRENT_WITH]->(b) SET r += {timing: '09:57:07경', mechanism: '전차선 단전으로 1080호 출발 불능', evidence: 'FMC모드로 전환하여 출발하려 하였으나 09:57:07경 전차선 단전이 발생되어 출발하지 못하였다.', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0051'};
MATCH (a:Event {name: '1079호 전동차 화재'}), (b:Event {name: '중앙로역 전차선 단전'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {probability: 'High', directCause: '화재열·회로이상으로 변전소 HSCB 개방', mechanism: '영대병원·신천변전소 반월당측 HSCB 개방, 반월당변전소 직류급전계통 차단기 개방', timing: '09:57경', evidence: '0957경에 영대병원~신천변전소 구간 전차선로 상·하선이 ... HSCB가 개방되고 반월당변전소 직류 급전계통의 모든 차단기가 개방되며 단전됨을 확인', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0052'};
MATCH (a:Event {name: '중앙로역 전차선 단전'}), (b:Event {name: '1080호 전동차 출발 불능·승객 고립'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {probability: 'High', directCause: '단전으로 출발 불능, 급전·단전 반복으로 재기동 실패', mechanism: '자동재폐로 실패, 수동 HSCB 투입 실패', evidence: '급전과 단전이 반복되어 ... 전동차를 기동하여 출발을 시도하였으나 실패 / 짧은 시간(17초,33초)동안 급전 후 다시 단전 ... 급전에 실패', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0053'};
MATCH (a:Event {name: '자동재폐로·수동투입 급전 복구 실패'}), (b:Event {name: '1080호 전동차 출발 불능·승객 고립'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {role: '복구 실패가 고립 장기화', mechanism: '전동차 출발·대피 수단 상실', evidence: '신천변전소 반월당측 상선은 자동재폐로가 ... 실패하여 수동으로 HSCB를 투입할 것을 ... 지시하였으나 급전에 실패하였다.', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0054'};
MATCH (a:Event {name: '1080호 전동차 출발 불능·승객 고립'}), (b:Damage {name: '대구 지하철 참사 인명피해'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {probability: 'High', directCause: '출입문 폐쇄·정전 속 객실 내 고립으로 유독가스 흡입', specialNote: '1080호 기관사가 10:03 지시 받기까지 출입문 닫은 채 대기', evidence: '출입문을 닫습니다 ... 곧바로 객실출입문을 닫고 / 사상자 209명 ... 사망추정 ... 사망 ... 부상', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0055'};
MATCH (a:Event {name: '유독가스·농연 확산'}), (b:Damage {name: '대구 지하철 참사 인명피해'}) MERGE (a)-[r:CAUSES]->(b) SET r += {directCause: '유독가스·매연 흡입으로 질식·고립', mechanism: '지하 밀폐공간 시계 차단 및 호흡 곤란', evidence: '유독가스로 인한 피해를 줄이기 위해 ... / 매연과 유독가스가 극심하여 견딜 수가 없어 ... 실신', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0056'};
MATCH (a:Event {name: '중앙로 신호기계실 직원 고립'}), (b:ResponseAction {name: '기계설비사령 수동 송풍기·에어컨 가동'}) MERGE (a)-[r:TRIGGERS_SECONDARY]->(b) SET r += {role: '고립이 추가 구조·환기 대응 유발', timing: '10:03 이후', evidence: '중앙로 신호기계실에 직원 10여명이 고립되어 있다는 통보를 받고, 중앙로역사 팩키지 에어컨을 수동 가동하고 본선급기 송풍기도 수동으로 가동', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0057'};
MATCH (a:ResponseActor {name: '1079호 전동차 기관사'}), (b:ResponseAction {name: '1079호 기관사 초기 소화기 진화 시도'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', effectiveness: 'Low', timing: '09:52~화재초기', reason: '소화기 분사로 진화 시도했으나 확산', evidence: '운전실에 있는 소화기를 가지고 1호 객실로 뛰어가 ... 분사하였으나 소화액을 전부 분출하여도 불길이 진화되지 않고 확산', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0058'};
MATCH (a:ResponseActor {name: '1079호 전동차 기관사'}), (b:ResponseAction {name: '운전사령 화재위치·규모 보고'}) MERGE (a)-[r:FAILS]->(b) SET r += {phase: 'response', reason: '당황하여 화재위치·규모를 운전사령에 보고하지 못한 채 대피', specialNote: '초기 상황전파 실패로 사령부 상황인식 지연', evidence: '당황한 나머지 운전사령에게 화재위치, 규모 등에 대하여 보고하지 못한 채 역사 밖으로 대피', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0059'};
MATCH (a:ResponseActor {name: '1080호 전동차 기관사 최상열'}), (b:ResponseAction {name: '1080호 기관사 승객대피 유도'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', effectiveness: 'Med', timing: '10:03 이후', reason: '운전사령 지시 후 출입문 개방·대피 유도', evidence: '출입문 열림 스위치로 출입문을 개방하고 ... 전호등을 꺼내어 객실로 들어가 승객들에게 대피하라고 ... 3~4명이 대피시켜 줄 것을 요청하여 계단입구까지 유도', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0060'};
MATCH (a:ResponseActor {name: '종합사령실(대구지하철공사)'}), (b:ResponseAction {name: '전동차 선제 정차·진입 차단 조치'}) MERGE (a)-[r:FAILS]->(b) SET r += {phase: 'response', reason: '화재원인·규모 파악 전 전동차 정차 없이 \'주의 운전\' 지시로 1080호 진입 허용', specialNote: '검은 연기로 CCTV 확인 불가, 큰 화재 아닐 것으로 오판', evidence: '일단 중앙로역 부근을 운행중인 전동차를 정차시키고 ... 조치를 취하여야 함에도 큰 화재가 아닐 것으로 생각하고 ... 주의 운전하라고 지시', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0061'};
MATCH (a:ResponseActor {name: '종합사령실(대구지하철공사)'}), (b:ResponseAction {name: '전동차 운행중단·승객 하차 지시'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', timing: '10:17~10:28', effectiveness: 'Med', evidence: '10:17경 전구간 전동차운행이 곤란하여 전 전동차에 운행대기를 지시 / 10:28경 종합사령팀장은 전 전동차와 각 역에 전동차 운행중단 및 승객을 하차하도록 지시', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0062'};
MATCH (a:ResponseActor {name: '중앙로역 조책임자'}), (b:ResponseAction {name: '운전사령 화재위치·규모 보고'}) MERGE (a)-[r:FAILS]->(b) SET r += {phase: 'response', reason: '1079호 전동차 화재임을 상세히 보고하지 못함', specialNote: '정확한 발화지점 미전달로 소방·사령 대응 지연', evidence: '중앙로역 실제 화재입니다 ... 신고 좀 부탁드립니다라고 화재발생을 보고하였으나 1079호 전동차에서 화재가 발생되었다고 상세하게 보고하지 못하였다.', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0063'};
MATCH (a:ResponseActor {name: '중앙로역 조책임자'}), (b:ResponseAction {name: '119 최초 화재신고'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', timing: '09:57', effectiveness: 'Med', evidence: '09:57경 119에 중앙로역 대합실에 실제 화재 상황을 신고하였고', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0064'};
MATCH (a:ResponseActor {name: '매표소 근무자'}), (b:ResponseAction {name: '비상게이트 개방·승객대피 안내방송'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', effectiveness: 'Med', timing: '화재초기', evidence: '매표실안에 있는 비상버튼을 눌러 개집표기 및 게이트를 모두 개방시키고, 매표실 방송장치로 승객대피 안내방송을 2~3회 실시', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0065'};
MATCH (a:ResponseActor {name: '최초 화재신고자(전동차 승객)'}), (b:ResponseAction {name: '119 최초 화재신고'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', timing: '09:53:35', effectiveness: 'High', evidence: '09:53:35경 ... 소방본부 119종합상황실에 최초신고를 하였고', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0066'};
MATCH (a:ResponseActor {name: '대구소방본부 119종합상황실'}), (b:ResponseAction {name: '출동지령·상황관리'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', timing: '09:54~09:55', effectiveness: 'High', evidence: '09:54경 소방본부 상황실에서 119신고 접보를 받아 09:55경 사전 편성된 5개대(구조 2, 파출소 3)에 대한 출동지령', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0067'};
MATCH (a:ResponseActor {name: '대구소방본부 119종합상황실'}), (b:ResponseActor {name: '19개 유관기관·단체'}) MERGE (a)-[r:COORDINATES_WITH]->(b) SET r += {role: '유관기관 동원 요청', timing: '10:10~', measures: '대구지방경찰청 교통통제, 한국전력 출동요청, 1339·병원 구급차 동원요청', evidence: '대구지방경찰청에 교통통제를 요청 ... 한국전력에 출동요청 ... 1339 및 대구시내 병원 구급차 동원요청 ... 19개 관련 유관기관 단체를 동원', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0068'};
MATCH (a:ResponseActor {name: '대구소방본부 등 소방력'}), (b:ResponseAction {name: '소방력 동원·현장 수습활동'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', timing: '09:57~18:00 약 8시간', effectiveness: 'Med', evidence: '1,046명의 소방공무원과 158대의 차량 및 관련장비를 투입 / 중앙로역 현장활동에 인력 906명과 차량 158대를 투입', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0069'};
MATCH (a:ResponseActor {name: '대구소방본부 등 소방력'}), (b:ResponseAction {name: '중앙로역 화재진압 활동'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', timing: '09:57~13:38', effectiveness: 'Med', specialNote: '고열·농연으로 조기진압 곤란', evidence: '소방공무원 154명과 차량 38대를 동원하여 사고발생 당일 09:57경 진화활동에 임하여 13:38경에 진화를 완료', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0070'};
MATCH (a:ResponseAction {name: '중앙로역 화재진압 활동'}), (b:Event {name: '1079호 전동차 화재'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {role: '1079호 화재 진압 대상', effectiveness: 'Med', timing: '13:38 완전진압', evidence: '11:30경 환기구 및 내부를 통해 화재진압 소방력이 지하 3층으로 진입하여 ... 13:38경 화재를 완전히 진압', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0071'};
MATCH (a:RiskFactor {name: '고열·농연으로 인한 진입 곤란'}), (b:ResponseAction {name: '중앙로역 화재진압 활동'}) MERGE (a)-[r:MODIFIES_RISK_OF]->(b) SET r += {role: '진압 지연·인명구조 지장', mechanism: '조기진압 곤란으로 피해 확대', evidence: '전동차의 급격한 연소확대에 수반된 고열로 인해 지하 3층에서 연소중인 전동차에 접근이 불가능 / 발생하는 고열과 소요시간의 한계로 조기진압에 많은 어려움', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0072'};
MATCH (a:ResponseActor {name: '소방본부 소속 인명구조대'}), (b:ResponseAction {name: '중앙로역 인명구조 활동(소방·직원)'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', timing: '09:57~17:30', effectiveness: 'High', evidence: '소방공무원 261명을 동원하여 ... 09:57~17:30까지 구조활동을 전개하여 사상자 209명(실제 소방공무원이 구조한 인원은 190명으로 추정됨)을 구조', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0073'};
MATCH (a:ResponseAction {name: '중앙로역 인명구조 활동(소방·직원)'}), (b:Damage {name: '대구 지하철 참사 인명피해'}) MERGE (a)-[r:MITIGATES]->(b) SET r += {role: '유독가스 피해 경감·생명 구조', effectiveness: 'High', consequence: '209명 구조', evidence: '유독가스로 인한 피해를 줄이기 위해 ... 구조활동을 전개하여 사상자 209명 ... 구조', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0074'};
MATCH (a:Damage {name: '현장활동 부상 소방공무원'}), (b:Context {name: '소방공무원 부상 현황(설문·집계)'}) MERGE (a)-[r:QUANTIFIED_BY]->(b) SET r += {role: '소방공무원 부상 집계', evidence: '현장활동을 하다가 부상을 당한 소방공무원은 23명으로 그 중 10명은 화상, 과로 질식 등으로 입원치료 ... 의료기관 진료자는 68명', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0075'};
MATCH (a:Event {name: '유독가스·농연 확산'}), (b:Damage {name: '현장활동 부상 소방공무원'}) MERGE (a)-[r:CAUSES]->(b) SET r += {role: '구조작업 중 소방공무원 부상', mechanism: '고열·농연·질식', evidence: '현장활동을 하다가 부상을 당한 소방공무원은 23명으로 그 중 10명은 화상, 과로 질식 등', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0076'};
MATCH (a:Event {name: '1079호 전동차 화재'}), (b:Damage {name: '중앙로역 시설물 소실 피해'}) MERGE (a)-[r:CAUSES]->(b) SET r += {directCause: '화재로 중앙로역 주요시설물 소실', scale: '심각', evidence: '13:38경 화재가 진화되었으나 중앙로역 주요시설물이 소실되는 등 화재피해가 심각하고 사고복구에 많은 기간이 소요될 것이 예상', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0077'};
MATCH (a:Damage {name: '중앙로역 시설물 소실 피해'}), (b:Damage {name: '1호선 6개역 운행중단·구간운행'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {probability: 'High', directCause: '복구 완료까지 전동차 운행 불가', mechanism: '전차선 급전구간·회차 제약으로 6개역 운행중단', evidence: '1호선 30개 역사 가운데 ... 명덕역에서 신천역까지 6개역은 운행을 중단하고 나머지 24개역을 ... 2개 구간으로 나누어 운행하기로 하고 사고 다음날인 2월 19일 05:20부터 구간운행', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0078'};
MATCH (a:ResponseActor {name: '대구광역시'}), (b:ResponseAction {name: '무료 셔틀버스 운행'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', timing: '3월 8일~10월 20일', effectiveness: 'Med', evidence: '3월 8일부터 10월 20일까지 지하철 운행중단 구간인 교대역~동대구역 구간에 무료 셔틀버스(시내버스) 14대를 투입하여 6분간격으로 운행', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0079'};
MATCH (a:ResponseAction {name: '무료 셔틀버스 운행'}), (b:Damage {name: '1호선 6개역 운행중단·구간운행'}) MERGE (a)-[r:MITIGATES]->(b) SET r += {role: '운행중단 서비스피해 완화', effectiveness: 'Med', evidence: '지하철 이용승객들의 불편을 해소하기 위해 ... 무료 셔틀버스 ... 운행', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0080'};
MATCH (a:Event {name: '대구 지하철 중앙로역 화재(2003)'}), (b:Event {name: '유독가스·농연 확산'}) MERGE (a)-[r:TRIGGERS]->(b) SET r += {scale: '대형', probability: 'High', mechanism: '1079열차 화재 발생 후 유독가스·고열 확산', directCause: '방화', evidence: '지하철역 입구에서 뿜어져 나오는 화염과 유독가스 등으로 호흡이 곤란할 정도였고', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0081'};
MATCH (a:Event {name: '유독가스·농연 확산'}), (b:Event {name: '중앙로역 일대 정전'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {mechanism: '화재로 인한 전력 차단', probability: 'High', spreadRisk: 'High', evidence: '현장은 정전으로 지하철 중앙로역(지하) 일대가 암흑천지로 변하고', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0082'};
MATCH (a:Event {name: '중앙로역 일대 정전'}), (b:Event {name: '지하층 요구조자 고립'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {mechanism: '암흑·농연 속에서 요구조자 탈출·구조 지연', probability: 'High', evidence: '지하층 내에 있는 요구조자에 대한 구조활동을 지속적으로 펼쳐 고열•농연 등 악조건 하에서도 상당수의 생명을 구할 수 있었다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0083'};
MATCH (a:Event {name: '지하층 요구조자 고립'}), (b:Damage {name: '중앙로역 화재 인명피해'}) MERGE (a)-[r:CAUSES]->(b) SET r += {directCause: '고열·유독가스·정전으로 인한 탈출 실패', scale: '대형', evidence: '층별 인명구조 현황 ... 계 209 ... 부상 147 / 화재로 인한 높은 열과 연기가 발생되어 신원을 확인하기 어려운 시신들이 많이 발견', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0084'};
MATCH (a:Event {name: '유독가스·농연 확산'}), (b:Damage {name: '중앙로역 화재 인명피해'}) MERGE (a)-[r:CAUSES]->(b) SET r += {directCause: '유독가스 흡입(호흡기 내상)', mechanism: '부상자 대부분이 호흡기 등 내상 환자', evidence: '부상자들 모두가 호흡기 등 내상 환자인 점을 감안하', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0085'};
MATCH (a:Facility {name: '1079열차'}), (b:Damage {name: '중앙로역 화재 인명피해'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {mechanism: '전동차 내장재 가연성으로 화재·유독가스 확산 가중', reason: '선진국 수준 불연성 재료 미적용', evidence: '안심행 1079열차가 반월당에서 중앙로역으로 진입 중 화재가 발생 ... 대구지하철 전차량(204량)을 선진국 수준의 불연성 재료로 교체하는 작업', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0086'};
MATCH (a:RiskFactor {name: '전동차 가연성 내장재'}), (b:Event {name: '유독가스·농연 확산'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {mechanism: '가연성 내장재가 화재 규모·유독가스 증대', probability: 'High', evidence: '대구지하철 전차량(204량)을 선진국 수준의 불연성 재료로 교체하는 작업은 4월부터 착수', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0087'};
MATCH (a:Facility {name: '1080호 전동차'}), (b:Damage {name: '중앙로역 화재 인명피해'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {mechanism: '정전·고립 구간 내 다수 희생자 발생 차량', scale: '20여구', evidence: '1080호 전동차에서 수습해 신원 확인작업을 끝낸 20여 구', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0088'};
MATCH (a:ResponseActor {name: '대구광역시 소방본부'}), (b:ResponseAction {name: '지하층 인명구조활동'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', effectiveness: 'Med', scale: '다수 생명 구조', specialNote: '악조건 하 구조', evidence: '지하층 내에 있는 요구조자에 대한 구조활동을 지속적으로 펼쳐 ... 상당수의 생명을 구할 수 있었다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0089'};
MATCH (a:ResponseAction {name: '지하층 인명구조활동'}), (b:Event {name: '지하층 요구조자 고립'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {effectiveness: 'Med', timing: '사고 당일 오전~오후', specialNote: '층별 구조 시간대 09:57~16:00', evidence: '층별 인명구조 현황 ... 09:57~10:37 지하 1층 ... 10:10~16:00 지하 2~3층', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0090'};
MATCH (a:ResponseActor {name: '중앙119구조대 및 경북·경남소방본부'}), (b:ResponseActor {name: '대구광역시 소방본부'}) MERGE (a)-[r:COORDINATES_WITH]->(b) SET r += {phase: 'response', reason: '다수 요구조자 발생으로 소방응원 요청', timing: '사고 당일', evidence: '다수의 요구조자가 발생되어 중앙119구조대, 경북•경남소방본부 등의 소방응원 요청과 더불어 진압대원 및 비상소집된 소방공무원들도 현장에 투입', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0091'};
MATCH (a:ResponseActor {name: '대구광역시 소방본부'}), (b:ResponseAction {name: '현장 구급활동 및 환자이송'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', scale: '구급차 45대 중 42대 투입, 소방공무원 48명 추가 투입', count: 117, specialNote: '10:02~18:00 117명 응급처치', evidence: '소방본부 소속 구급차량 45대중 42대가 사고현장에 투입 ... 10:02 18:00까지 117명의 사상자를 응급처치하고 시내 15개 병원에 65회 이송', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0092'};
MATCH (a:ResponseAction {name: '현장 구급활동 및 환자이송'}), (b:Damage {name: '중앙로역 화재 인명피해'}) MERGE (a)-[r:MITIGATES]->(b) SET r += {effectiveness: 'Med', reason: '초기 구급수요 폭주로 이송 곤란했으나 추가 구급대·의료기관 구급대 확보로 해소', evidence: '사고발생 초기에는 많은 구급수요가 일시에 발생하여 이송에 곤란을 겪기도 했으나 추가 구급대 편성과 의료기관 소속 구급대의 확보로 장애요인을 해소', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0093'};
MATCH (a:ResponseActor {name: '1339 응급의료정보센터'}), (b:ResponseAction {name: '응급의료 정보전파 및 환자 분산배치'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', timing: '10:04 상황접수 후', specialNote: '중증도 분류(긴급·비응급·지연)로 후송병원 선정', evidence: '응급의료정보센터요원들은 ... 중증도 분류에 의한 환자 분산배치를 위한 활동을 실시 ... 긴급환자는 경북대학교병원, 동산병원으로 ... 후송병원을 선정하여 후송', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0094'};
MATCH (a:Event {name: '지하철역 입구 화염·유독가스 분출'}), (b:ResponseAction {name: '응급의료 정보전파 및 환자 분산배치'}) MERGE (a)-[r:MODIFIES_RISK_OF]->(b) SET r += {reason: '현장 악조건으로 사상자 구조 지연', effectiveness: 'Low', specialNote: '구조 지연 야기', evidence: '지하철역 입구에서 뿜어져 나오는 화염과 유독가스 등으로 호흡이 곤란할 정도였고, 역사내부 상황도 파악하기 어려운 실정으로 사상자 구조가 지연', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0095'};
MATCH (a:ResponseActor {name: '대구광역시'}), (b:ResponseAction {name: '긴급 사고대책상황실 설치'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', timing: '2003-02-18 10:04 통보 직후', composition: '기획관리실장 상황실장, 6개반 83명', evidence: '기획관리실장을 상황실장으로 6개반 83명으로 긴급 사고대책상황실을 설치하여 사고상황 파악에 착수', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0096'};
MATCH (a:ResponseActor {name: '대구광역시'}), (b:ResponseActor {name: '중앙정부'}) MERGE (a)-[r:COORDINATES_WITH]->(b) SET r += {phase: 'response', reason: '재난 상황보고 및 연락체계도에 의한 지휘체계 보고·지원요청', specialNote: '행정자치부·건설교통부·국무총리실 보고, 유관기관 지원요청', evidence: '행정자치부, 건설교통부, 국무총리실 등 지휘체계에 따른 상황보고를 함과 동시에 소방본부, 대구지방경찰청 등 유관기관에 상황통보와 지원요청', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0097'};
MATCH (a:ResponseAction {name: '긴급 사고대책상황실 설치'}), (b:Event {name: '대구 지하철 중앙로역 화재(2003)'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {phase: 'response', specialNote: '상황실 체제→대책본부 체제로 확대 개편 기반', evidence: '2003년 2월 18일 10:04경 안심행 1079열차가 ... 화재가 발생했다는 소식을 ... 통보받은 대구시에서는', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0098'};
MATCH (a:ResponseActor {name: '대구광역시'}), (b:ResponseAction {name: '사고대책본부 체제 운영'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', timing: '2003-02-18 22:00', composition: '초기 6개반 205명→9개반 274명 확대', specialNote: '이후 수습 단계별 축소 개편', evidence: '2월 18일 22:00경 대구시는 ... 긴급 사고대책상황실 체제에서 ... 6개반(각 3개조) 205명으로 사고대책본부 체제로 확대 개편', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0099'};
MATCH (a:ResponseAction {name: '사고대책본부 체제 운영'}), (b:Damage {name: '중앙로역 화재 인명피해'}) MERGE (a)-[r:MITIGATES]->(b) SET r += {phase: 'recovery', effectiveness: 'Med', reason: '장례·보상·실종자확인·시설복구 등 단계별 수습', evidence: '본격적인 사고수습에 임하였다 ... 수습의 1단계인 장례와 2단계인 법적보상이 마무리', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0100'};
MATCH (a:Event {name: '중앙로역 일대 정전'}), (b:Event {name: '대구 도심 지상교통 마비'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {mechanism: '정전·연기 분출+시민 운집으로 도심 지상교통 마비', probability: 'Med', evidence: '방송을 통해 사고소식을 접한 많은 시민들이 가족들의 생사확인을 위해 사고현장으로 몰려 들어 중앙로역을 중심으로 대구도심의 지상교통은 마비상태에 이르게 되었다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0101'};
MATCH (a:RiskFactor {name: '현장 정전·암흑 및 지휘통제 곤란'}), (b:ResponseAction {name: '지하층 인명구조활동'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {reason: '통합 지휘체계 미비로 초기 대응 혼란', effectiveness: 'Low', evidence: '긴급 출동하여 인명구조 및 화재진압 활동이 숨가쁘게 이루어지고 있었으나, 일사분란한 지휘 및 통제는 어려운 상황이었다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0102'};
MATCH (a:ResponseActor {name: '대구광역시'}), (b:ResponseAction {name: '특별재난지역 지정 건의 및 선포'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', timing: '2003-02-18 24:00 건의', legalBasis: '재난관리법', specialNote: '2/19 15:30 중앙사고대책본부 협의로 선포 결정', evidence: '당일 24:00경에는 중앙로역 피해지역을 특별재난지역으로 지정하여 줄 것을 건설교통부에 건의 ... 중앙로역 일원을 특별재난지역으로 선포하기로 결정', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0103'};
MATCH (a:ResponseAction {name: '현장 잔재물 정리 및 전동차 견인'}), (b:Event {name: '실종자 신원확인 갈등'}) MERGE (a)-[r:MODIFIES_RISK_OF]->(b) SET r += {reason: '현장훼손으로 실종자 가족과 갈등 야기, 실종자 확인 차질', effectiveness: 'Low', specialNote: '수습 갈등 증폭', evidence: '전동차 견인과 다음날 지하철공사에서 중앙로역 현장 잔재물 정리 및 수거작업으로 인한 현장훼손 논란으로 실종자 가족들과 사고대책본부간에 심각한 갈등이 야기', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0104'};
MATCH (a:ResponseActor {name: '국립과학수사연구소'}), (b:ResponseAction {name: '사체 신원확인 절차'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', timing: '2003-03-10 이후', mechanism: '유전자 감식·신체특징, 대검찰청 감식결과 비교', evidence: '국립과학수사연구소가 실시한 유전자 감식, 신체특징과 대검찰청 유전자 감식실의 유전자 감식결과를 비교하는 방법으로 사체 신원을 확인키로 하였다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0105'};
MATCH (a:RiskFactor {name: '신원확인 곤란(고열·연기)'}), (b:Event {name: '실종자 신원확인 갈등'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {reason: '신원확인 지연이 실종자 처리·수습 갈등 증폭', probability: 'High', evidence: '화재로 인한 높은 열과 연기가 발생되어 신원을 확인하기 어려운 시신들이 많이 발견되고 있으며, 시신을 찾지 못하는 희생자도 있을 수 있다는 우려', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0106'};
MATCH (a:ResponseActor {name: '고건 국무총리'}), (b:ResponseAction {name: '중앙특별지원단 파견'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', timing: '2003-03-01 파견', reason: '대구시 신뢰 상실로 수습 답보, 조기 수습 위해 중앙 지원 필요 판단', evidence: '차관급을 단장으로 하는 중앙특별지원단 파견을 약속하였다 ... 3월 1일 대구시에 파견된 중앙특별지원단(단장 김중양 소청심사위원장)', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0107'};
MATCH (a:ResponseActor {name: '중앙특별지원단'}), (b:ResponseActor {name: '대구시 사고대책본부'}) MERGE (a)-[r:COMMANDS]->(b) SET r += {phase: 'recovery', timing: '2003-03-03 이후', reason: '피해자 대화창구 일원화, 신뢰 회복', evidence: '중앙특별지원단장이 사고대책본부를 지휘하며, 중앙특별지원단이 사전에 대구시의 의견을 수렴하여 최종 의사결정권도 가지게 되었다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0108'};
MATCH (a:ResponseAction {name: '중앙특별지원단 파견'}), (b:Event {name: '실종자 신원확인 갈등'}) MERGE (a)-[r:MITIGATES]->(b) SET r += {phase: 'recovery', effectiveness: 'Med', reason: '피해자측 신뢰 회복으로 수습 진전', evidence: '실종자 가족 등 피해자측과의 대화를 통해 상호간 신뢰를 회복하는 일이 무엇보다도 급선무라고 판단', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0109'};
MATCH (a:Event {name: '유가족-대구시 수습 갈등'}), (b:Damage {name: '수습행정 마비 피해'}) MERGE (a)-[r:CAUSES]->(b) SET r += {directCause: '장례·보상·추모공원 부지 이견과 대구시 불신', scale: '8시간 감금', evidence: '수습대책본부를 점거하여 근무중인 공무원 30여명을 억류한 채 ... 사무실 기능이 마비되고 사실상 폐쇄 ... 행정부시장을 ... 8시간 동안 감금 ... 탈수증세를 보여 ... 입원하였다가 ... 퇴임', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0110'};
MATCH (a:ResponseAction {name: '추모묘역 조성(수성구 삼덕동)'}), (b:Event {name: '추모묘역 인근주민 반발'}) MERGE (a)-[r:MODIFIES_RISK_OF]->(b) SET r += {reason: '인근 주민 반발(집회·서명 진정서)로 신규 갈등 유발', effectiveness: 'Low', evidence: '추모묘역 조성을 결사적으로 반대 ... 묘역조성을 반대한다는 주민 7,962명이 서명한 진정서를 대구시에 제출 ... 집회 및 시위', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0111'};
MATCH (a:ResponseActor {name: '대구광역시지하철참사보상심의위원회'}), (b:ResponseAction {name: '피해보상 및 성금배분'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', timing: '2003-06-26 제1차 보상심의', specialNote: '법적보상 + 국민성금(특별위로금) 배분', evidence: '6월 26일 제1차 보상심의를 시작으로 보상금 지급이 본격적으로 개시 ... 사망자는 1인당 221백만원을 지급하고, 부상자는 노동능력 상실률에 따라 차등 지급', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0112'};
MATCH (a:ResponseAction {name: '피해보상 및 성금배분'}), (b:Damage {name: '중앙로역 화재 인명피해'}) MERGE (a)-[r:MITIGATES]->(b) SET r += {phase: 'recovery', effectiveness: 'Med', reason: '법적보상·성금배분으로 인적피해 수습', evidence: '수습의 2단계인 법적보상이 마무리 ... 보상심의를 거쳐 지급', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0113'};
MATCH (a:ResponseAction {name: '합동영결식'}), (b:Damage {name: '중앙로역 화재 인명피해'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {phase: 'recovery', effectiveness: 'High', specialNote: '수습 1단계(장례) 마무리', evidence: '6월 29일 10:00 시민회관 광장에서 희생자 192명의 합동영결식이 거행 ... 유해 63구는 ... 인도 ... 신원미확인 유해 6구를 시립공원묘지에 가매장함으로써 1단계 수습인 장례를 마무리', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0114'};
MATCH (a:ResponseAction {name: '중앙정부 재정지원'}), (b:Damage {name: '수습행정 마비 피해'}) MERGE (a)-[r:MITIGATES]->(b) SET r += {phase: 'recovery', effectiveness: 'Med', reason: '열악한 대구시 재정 보완 위한 국고지원', evidence: '중앙정부 차원의 대구지하철화재사고 수습관련 재정 지원방안에 대한 협의 ... 수습비용 종액의 70%는 정부예비비, 15%는 행정자치부 교부세, 15%는 대구시비', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0115'};
MATCH (a:Event {name: '지하철 전구간 운행중단'}), (b:Damage {name: '인근 상권 영업손실 피해'}) MERGE (a)-[r:CAUSES]->(b) SET r += {directCause: '중앙로 교통통제·지하철 운행중단', specialNote: '중앙지하상가 입주상인 영업손실 보상 요구', evidence: '중앙로 교통통제로 동성로, 중앙로 등 인근 상권이 위협받고 있는 상인 입장 ... 지하철 운행중단으로 인한 영업손실 보상', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0116'};
MATCH (a:ResponseAction {name: '지하철 전구간 안전점검 및 불연성 재료 교체'}), (b:Event {name: '대구 지하철 중앙로역 화재(2003)'}) MERGE (a)-[r:PREVENTS]->(b) SET r += {phase: 'prevention', effectiveness: 'Med', reason: '재발 방지 위한 차량 불연화·안전점검', evidence: '대구지하철 전차량(204량)을 선진국 수준의 불연성 재료로 교체하는 작업은 4월부터 착수하고, 대구지하철 전구간에 대한 안전점검(3.19~3.26)을 실시', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0117'};
MATCH (a:ManmadeHazard {name: '대구지하철 중앙로역 방화'}), (b:Event {name: '대구지하철 1호선 중앙로역 화재(2003)'}) MERGE (a)-[r:TRIGGERS]->(b) SET r += {scale: '대형', probability: 'High', directCause: '방화', mechanism: '전동차 1079호에서 화재 발화', evidence: '2003. 2. 18 09:55경 대구광역시 중구 남일동 143-1번지 대구지하철 1호선 「중앙로역』의 승강장에서 전동차 1079호(6량) 및 1080호(6량)에서 방화에 의한 화재가 발생하여 막대한 인적 • 물적 피해발생', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0118'};
MATCH (a:Event {name: '대구지하철 1호선 중앙로역 화재(2003)'}), (b:Damage {name: '대구지하철 화재 인적·물적 피해'}) MERGE (a)-[r:CAUSES]->(b) SET r += {scale: '막대한 인적·물적 피해', mechanism: '유독가스·고열로 인한 사상', evidence: '방화에 의한 화재가 발생하여 막대한 인적 • 물적 피해발생 / 희생자 192명의 합동영결식 / 수습대책본부에 접수된 실종자수도 619명', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0119'};
MATCH (a:Event {name: '대구지하철 1호선 중앙로역 화재(2003)'}), (b:Event {name: '실종자 신원확인 곤란 사태'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {mechanism: '높은 열과 연기 발생으로 시신 신원확인 곤란', consequence: '실종자 처리문제 최대 현안화', evidence: '화재로 인한 높은 열과 연기가 발생하면서 많은 사상자를 낸 사고로서 신원을 확인하기 어려운 시신들이 많이 발견되었으며, 시신을 찾지 못하는 희생자도 있을 수 있다는 우려 / 실종자수도 619명이나 되는 등 실종자 처리문제가 가장 큰 현안', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0120'};
MATCH (a:ResponseActor {name: '대구시 사고대책본부'}), (b:ResponseAction {name: '대구지하철 화재 사고수습 활동'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', objective: '사고수습·보상·추모', evidence: '대구시 행정부시장은 인적•물적피해에 대한 최종집계와 수습체계에 대한 보고를 하고 사망자 장례, 부상자 치료, 보상업무 추진, 국민성금 배분기준, 추모사업 추진, 중앙로역 복구사업, 안전운행 대책 등에 대해서도 보고', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0121'};
MATCH (a:ResponseAction {name: '합동영결식'}), (b:Damage {name: '대구지하철 화재 인적·물적 피해'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {timing: '사고 후 약 4개월', detail: '희생자 192명 합동영결식, 참석 1,500여명', evidence: '6월 29일 10:00 시민회관 광장에서 희생자 192명의 합동영결식이 거행되었다. 영결식에는 유가족들과 시민, 공무원 등 1,500여명이 참석', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0122'};
MATCH (a:ResponseAction {name: '국민성금 특별위로금 배분'}), (b:Damage {name: '대구지하철 화재 인적·물적 피해'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {detail: '국민성금 배분 협의 7차례, 2004-02-04 직접 지원경비 기준 확정으로 마무리', evidence: '사망자는 1인당 221백만원을 지급하고, 부상자는 노동능력 상실률에 따라 차등 지급할 계획 / 국민성금 배분이 마무리되었다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0123'};
MATCH (a:ResponseAction {name: '제17차 중앙안전대책위원회 회의'}), (b:Damage {name: '대구지하철 화재 수습 소요재원'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {detail: '수습대책비 총 1,605억원 확정(1차 국고지원 302억+2차 478억), 중앙정부 1,147억원 지원, 대구시 458억원 부담', evidence: '수습대책비로 지난 4월 1일 국무회의에서 의결한 1차 국고지원안(302억원)에 이어 2차 국고지원안(478억원)을 의결함으로써 수습대책비를 총 1,605억원으로 확정', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0124'};
MATCH (a:ResponseAction {name: '추모공원 조성 합의'}), (b:Damage {name: '대구지하철 화재 인적·물적 피해'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {reason: '유가족 추모사업 요구', specialNote: '장례를 추모공원 조성 문제와 연계 쟁점화하여 사고수습 답보상태 지속', evidence: '장례를 추모공원 조성 문제와 연계하여 쟁점화함으로써 사고수습의 답보상태가 계속되었다 / 묘역 위치는 수성구 삼덕동 118-1 일대로 하며', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0125'};
MATCH (a:Event {name: '추모공원 입지 갈등(수창공원 반대)'}), (b:Damage {name: '추모공원 갈등 인적 피해(의경 부상)'}) MERGE (a)-[r:CAUSES]->(b) SET r += {mechanism: '주민 항의·농성 중 의무경찰대 차량 돌진', directCause: '유가족 K씨 승합차 돌진', evidence: '유가족 K씨가 ... 의무경찰대(90여명)를 향해 돌진하여 ...의경 3명이 크게 다치는 상황 / H 공무원이 일부 유가족들로부터 폭행을 당해 병원에 입원치료', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0126'};
MATCH (a:ResponseAction {name: '특별재난지역 선포'}), (b:Damage {name: '대구지하철 화재 인적·물적 피해'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {detail: '응급대책·재해구호·복구에 행정·재정·세제·금융·의료 특별지원', timing: '사고 다음날', evidence: '김대중 대통령은 재난관리법 제51조의 규정에 의하여 2월 19일 16:30부로 대구지하철 화재사고 지역인 중앙로역 일원을 특별재난지역으로 선포(대통령 공고 제177호)', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0127'};
MATCH (a:ResponseActor {name: '중앙안전대책위원회'}), (b:ResponseAction {name: '특별재난지역 선포'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', role: '심의→대통령 선포 건의', evidence: '소관 부처의 장이 중앙재난대책본부장을 맡고 관련부처 장관들로 구성된 중앙안전대책위원회(위원장 국무총리)의 심의를 거쳐 대통령에게 특별재난지역 선포를 건의하는 절차', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0128'};
MATCH (a:RiskFactor {name: '지하 밀폐구조(지하철 화재 취약성)'}), (b:Event {name: '대구지하철 1호선 중앙로역 화재(2003)'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {mechanism: '화재 취약 내장재로 유독가스·확산 증대', probability: 'High', evidence: '기존 전동차 204량의 내장재 교체는 화재에 취약한 바닥재, 의자, 연결주름막 등을 교체하기로 하고 / 전동차 불연성 개조비', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0129'};
MATCH (a:ResponseAction {name: '전동차 불연성 개조'}), (b:RiskFactor {name: '지하 밀폐구조(지하철 화재 취약성)'}) MERGE (a)-[r:MODIFIES_RISK_OF]->(b) SET r += {effectiveness: 'High', mechanism: '화재 취약 내장재 제거로 재발 위험 저감', evidence: '기존 전동차 204량의 내장재 교체는 화재에 취약한 바닥재, 의자, 연결주름막 등을 교체하기로 하고 / 건설중인 지하철 2호선은 시설 및 차량에 대한 안전기준을 강화', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0130'};
MATCH (a:ResponseAction {name: '재난및안전관리기본법 제정'}), (b:Resilience {name: '국가 재난관리체계(예방·대응·복구)'}) MERGE (a)-[r:BUILDS]->(b) SET r += {objective: '국가 재난관리체계 확립·총괄조정 기능 보강', evidence: '대구지하철 화재사고에서 나타난 문제점을 보완하고 ... 재난관련 법령(자연재해법, 재해구호법, 재난관리법)의 주요내용을 통합하여 「재난및안전관리기본법』을 제정(2004.3.11)', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0131'};
MATCH (a:ResponseActor {name: '중앙특별지원단'}), (b:ResponseAction {name: '중앙특별지원단 사고수습 지원 활동'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', objective: '사고 조속 수습·중앙정부 차원 지원', evidence: '중앙특별지원단은 국무총리의 지휘를 받는 조직으로서 현지에 파견된 중앙사고대책본부의 Task-Force ... 임무는 사고를 조속히 수습하고 중앙정부차원에서 수습대책본부를 지원하는 일', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0132'};
MATCH (a:Event {name: '대구시 신뢰 상실·대화통로 단절 사태'}), (b:ResponseAction {name: '중앙특별지원단 사고수습 지원 활동'}) MERGE (a)-[r:CAUSES]->(b) SET r += {mechanism: '지역 협상력 한계로 중앙정부 개입 필요', reason: '현지 민심 악화', evidence: '사고수습과정에서 중앙로역 청소와 전동차 견인으로 인한 현장훼손 등을 둘러싸고 사건의 축소 및 은폐 의혹까지 제기되면서 피해자측은 대구시를 가해자로 간주 / 중앙특별지원단을 구성하여 파견하기로', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0133'};
MATCH (a:RiskFactor {name: '지방자치단체 열악한 재정여건'}), (b:Damage {name: '대구지하철 화재 수습 소요재원'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {mechanism: '지방 재정으로 수습 곤란→국비지원·기채 의존', reason: '구상권 대상 부재', evidence: '가용재원은 ... 87억원에 불과하였고, 과거 대형사고와는 달리 구상권 청구대상이 없어 사고수습비용을 모두 대구시에서 부담해야 하는 실정', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0134'};
MATCH (a:Damage {name: '대구지하철 화재 수습 소요재원'}), (b:Context {name: '총소요경비 195,207백만원'}) MERGE (a)-[r:QUANTIFIED_BY]->(b) SET r += {detail: '예산담당관실 잠정 산출액', evidence: '사고수습에 따른 총소요경비로 195,207백만원을 잠정적으로 산출하였다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0135'};
MATCH (a:ResponseAction {name: '중앙정부 국비지원'}), (b:Damage {name: '대구지하철 화재 수습 소요재원'}) MERGE (a)-[r:MITIGATES]->(b) SET r += {effectiveness: 'High', detail: '재정 취약 대구시 수습비 보전', evidence: '중앙정부로부터 지원받은 금액은 총114,689백만원으로 국고보조금 77,981백만원, 특별교부세 16,708백만원, 증액교부금 20,000백만원 / 소요액의 70%를 국비로 지원한다는 원칙', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0136'};
MATCH (a:ResponseAction {name: '대구시 자체 재원조달'}), (b:Resilience {name: '국가 재난관리체계(예방·대응·복구)'}) MERGE (a)-[r:BUILDS]->(b) SET r += {objective: '국비 지원 전 수습비 선집행 여력 확보', evidence: '8회에 걸쳐 예비비 30억 1천만원을 지출• 결정하여 ... 우선 집행 / 지방채 발행승인(400억원)을 받고, 11월 27일 재특자금 200억원을 ... 차입', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0137'};
MATCH (a:ResponseActor {name: '사체신원확인반'}), (b:Event {name: '실종자 신원확인 곤란 사태'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {phase: 'response', detail: '신원확인 곤란 시신 다수 대응', evidence: '법무부와 경찰에서는 국립과학수사연구소, 대검찰청, 경북대 법의학교실 등으로 「사체신원확인반』을 편성하여 사체 신원확인, 시신의 신속한 검시 및 유족인도 업무를 지원', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0138'};
MATCH (a:ResponseAction {name: '응급대책 및 재난구조 지원'}), (b:Damage {name: '대구지하철 화재 인적·물적 피해'}) MERGE (a)-[r:MITIGATES]->(b) SET r += {effectiveness: 'Med', detail: '사상자 위로금·의료지원', evidence: '보건복지부에서 사망자는 6천만원, 부상자는 5백만원 한도지원을 승인하였다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0139'};
MATCH (a:Event {name: '실종자 신원확인 곤란 사태'}), (b:Event {name: '인정사망심사 절차'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {mechanism: '신원미확인 시신에 대한 사망 인정 필요', detail: '인정사망심사위원회를 통한 사망인정판결', evidence: '수습대책본부에 접수된 실종자수도 619명 / 실종자 접수 및 처리 현황 ... 인정사망심사 ... 사망인정판결', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0140'};
MATCH (a:Event {name: '대구 지하철 중앙로역 화재(2003)'}), (b:Damage {name: '대구 지하철 화재 인명피해'}) MERGE (a)-[r:CAUSES]->(b) SET r += {mechanism: '화재로 인한 높은 열과 연기 발생', directCause: '화재 열·유독가스', scale: '유례없는 대형사고', evidence: '지하철 화재사고와 관련하여 신고된 실종자는 619명이었으나, 수사결과 ... 사고로 인한 사망 159명 ...', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0141'};
MATCH (a:Event {name: '대구 지하철 중앙로역 화재(2003)'}), (b:Damage {name: '시신 훼손에 따른 신원확인 곤란'}) MERGE (a)-[r:CAUSES]->(b) SET r += {mechanism: '화재 열로 시신 완전 훼손·전소', consequence: '육안 신원확인 불가능', evidence: '사고현장에서 발견된 상당수의 시신들이 화재로 인해 완전히 훼손되어 육안으로는 신원확인이 불가능한 상태였고', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0142'};
MATCH (a:Damage {name: '시신 훼손에 따른 신원확인 곤란'}), (b:Event {name: '대량 실종자 신고 접수(619명)'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {mechanism: '신원확인 불가 → 생사 불명 → 대량 실종신고 접수', reason: '연락 두절자 생사확인 필요', evidence: '수습대책본부에 접수된 실종자수도 619명이나 되는 등 실종자 처리문제가 가장 큰 현안이 되어 있었다.', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0143'};
MATCH (a:Event {name: '대량 실종자 신고 접수(619명)'}), (b:Event {name: '실종자 신고접수 업무 혼선'}) MERGE (a)-[r:TRIGGERS_SECONDARY]->(b) SET r += {mechanism: '사고 당일 3개소(지하철공사·소방본부·대구시 사고대책본부)에서 각각 신고 접수', reason: '접수창구 미일원화', evidence: '사고 당일 지하철공사, 소방본부, 대구시 사고대책본부 등 3개소에서 실종자를 신고•접수함으로써 중복신고 등으로 업무처리에 많은 혼선을 겪게 되었다.', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0144'};
MATCH (a:RiskFactor {name: '접수창구 미일원화(3개소 분산 접수)'}), (b:Event {name: '실종자 신고접수 업무 혼선'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {reason: '분산 접수로 명단 일괄관리 불가', probability: 'High', evidence: '사고 당일 ... 3개소에서 실종자를 신고•접수함으로써 중복신고 등으로 업무처리에 많은 혼선을 겪게 되었다.', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0145'};
MATCH (a:Damage {name: '허위·이중 실종신고(약 400여건)'}), (b:Context {name: '실종신고 619명 최종 조사결과'}) MERGE (a)-[r:QUANTIFIED_BY]->(b) SET r += {reason: '최종 조사결과 집계', evidence: '생존하고 있는 사람을 실종신고한 사례가 400여건으로 이는 1995년 서울의 삼풍백화점 붕괴사고시 허위신고자가 30~40명이었던 것에 비해 10배 이상 증가한 수치였다.', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0146'};
MATCH (a:ResponseActor {name: '관계장관회의(2003-02-28)'}), (b:ResponseAction {name: '중앙특별지원단 임무 설정 및 역할분담 결정'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', dateTime: '2003-02-28', evidence: '2월 28일 관계장관회의에서는 중앙특별지원단의 임무를 다음과 같이 정하였다.', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0147'};
MATCH (a:ResponseActor {name: '중앙특별지원단'}), (b:ResponseAction {name: '실종자가족대책위원회와의 협의·대화'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', timing: '발족 3일만에 대화 시작', effectiveness: 'High', objective: '상호 신뢰구축', evidence: '중앙특별지원단은 발족한 지 3일만에 실종자가족대책위원회와 대화를 시작할 수 있었고, ... 실종자인정사망심사위원회도 짧은 기간내에 구성할 수 있었다.', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0148'};
MATCH (a:ResponseActor {name: '중앙특별지원단'}), (b:ResponseAction {name: '부상자 치료대책 및 피해자 가족 의료지원'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', objective: '민심수습', effectiveness: 'Med', evidence: '중앙특별지원단은 입원환자 한사람 한사람을 모두 찾아가 위문하고 ... 무료종합검진을 실시하고, 사고 관련 질병에 대한 무상진료를 실시함으로써', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0149'};
MATCH (a:ResponseActor {name: '중앙특별지원단'}), (b:ResponseAction {name: '관계기관 공조체계 강화 및 민심수습'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', count: 5, detail: '5차례 기관 의견 조율', effectiveness: 'Med', evidence: '중앙특별지원단이 중심이 되어 5차례에 걸쳐 각 기관의 의견을 조율하고 ... 불교•기독교•천주교지도자와의 간담회 개최 및 각 언론사 방문 등을 통한 민심수습 노력으로', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0150'};
MATCH (a:RiskFactor {name: '중앙특별지원단 운영상 한계'}), (b:Event {name: '중앙특별지원단 활동 제약'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {reason: '사전 준비 없이 발족, 예산 미뒷받침', probability: 'Med', specialNote: '보완되어야 할 사항으로 지적', evidence: '조직의 법적 근거와 업무 영역이 명확하게 설정되어 있지 않았기 때문에 ... 운영예산이 편성되지 못하였기 때문에 어려움도 있었다.', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0151'};
MATCH (a:ResponseActor {name: '대구시 사고대책본부'}), (b:ResponseAction {name: '실종자 신고센터 설치 및 신고접수'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', duration: '사고 당일~2003-03-18', effectiveness: 'Low', reason: '초기 3개소 분산 접수로 혼선', evidence: '대구시에서는 「실종자 신고센터』를 설치하여 사고 당일부터 3월 18일까지 실종자 신고접수를 받았다.', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0152'};
MATCH (a:ResponseActor {name: '사고대책본부 실종자 확인반'}), (b:ResponseAction {name: '실종자 명단 일괄관리 및 자료수집'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', effectiveness: 'High', timing: '2003-02-20 설치', consequence: '실종자 처리문제 급진전 계기', evidence: '2월 20일 사고대책본부내 실종자 확인반을 설치하여 실종자 명단을 일괄 관리함으로써 ... 실종자 처리문제가 급진전하는 계기가 되었다.', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0153'};
MATCH (a:ResponseActor {name: '대구지방경찰청'}), (b:ResponseAction {name: '실종자 진위 확인수사'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', timing: '2003-02-27 31명 구성 → 2003-03-02 61명 확대', mobilizablePersonnel: 61, evidence: '대구지방경찰청에서는 2월 27일 경찰관 31명으로 실종자 전담수사반을 구성한 후, 3월 2일 경찰관 61명으로 확대 편성하여', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0154'};
MATCH (a:ResponseActor {name: '대구시 사고대책본부'}), (b:ResponseAction {name: '휴대폰 발신지 추적작업'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', objective: '전동차 탑승 개연성 확인 및 인정사망 물증 확보', evidence: '휴대폰 통화위치 및 시간확인 신청서를 제출한 299건 가운데 ... 239건에 대해 발신지 추적작업을 실시한 결과 중앙로역 구내 78건, 중앙로역 인근지역 9건 등 87건을 확인하였으며', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0155'};
MATCH (a:ResponseActor {name: '국립과학수사연구소 집단사망자관리단(KDMORT)'}), (b:ResponseAction {name: '희생자 개인식별 및 신원확인 작업'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', duration: '2003-02-18~2003-04-12', effectiveness: 'High', evidence: '지하철 화재사고에서 희생된 신원불상자에 대하여 2월 18일부터 4월 12일까지 개인식별의 모든 과정을 진행하여 총 136명의 신원을 확인하였다.', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0156'};
MATCH (a:Resilience {name: '전동차 정지상태 화재(운동에너지 미가해)'}), (b:Damage {name: '시신 훼손에 따른 신원확인 곤란'}) MERGE (a)-[r:OFFSETS]->(b) SET r += {reason: '시신이 비교적 형태 유지되어 발굴·식별 용이', effectiveness: 'Med', evidence: '전동차가 정지된 상태로 운동에너지가 가해지지 않은 상태에서 화재가 발생하여 탄화된 시신이 비교적 3차원적 형태를 유지한 상태로 보존되어 있었고', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0157'};
MATCH (a:ResponseActor {name: '중앙특별지원단'}), (b:ResponseAction {name: '실종자 인정사망 심사'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', timing: '2003-03-10 발족', effectiveness: 'High', consequence: '사고수습의 전환점', evidence: '3월 10일 실종자인정사망심사위원회를 구성•운영함으로써 사고수습의 전환점이 되었고', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0158'};
MATCH (a:ResponseActor {name: '실종자인정사망심사위원회'}), (b:ResponseAction {name: '실종자 인정사망 심사'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', count: 10, detail: '10차례 심사(2003.3.10~2004.3.4)', duration: '약 1년', evidence: '10차례에 걸친 실종자인정사망위원회 개최 결과 ... 최종적으로 사망인정 1명, 판단유보 1명, 인정사망 불인정 20명으로 판정되었다.', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0159'};
MATCH (a:ResponseActor {name: '실종자인정사망심사위원회'}), (b:ResponseAction {name: '유가족 포괄사망 선 인정 요구 대응'}) MERGE (a)-[r:FAILS]->(b) SET r += {phase: 'response', reason: '위원회 성격상 선 포괄 사망인정 불가, 장기가출자·행방불명자 포함 가능성', consequence: '유족 반발', specialNote: '유가족 \'포괄사망 선 인정\' 요구를 수용하지 못함', evidence: '유가족 대표들은 ... 실종자 전원에 대해 "포괄사망 선 인정"을 요구한 반면, 실종자인정사망심사위원회에서는 ... 선 포괄 사망인정은 수용할 수 없다고 맞섬으로써 유족들의 반발을 사기도 했다.', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0160'};
MATCH (a:Event {name: '현장청소·화재 전동차 견인'}), (b:Event {name: '유가족-사고대책본부 갈등 및 대화 중단'}) MERGE (a)-[r:TRIGGERS_SECONDARY]->(b) SET r += {mechanism: '현장훼손으로 유가족-사고대책본부 갈등 격화', consequence: '대화 중단', evidence: '사고수습과정에서 중앙로역 현장청소와 화재 전동차 견인으로 인한 현장훼손 문제 등을 놓고 유가족측과 사고대책본부 사이에 심각한 갈등이 야기되어 대화가 중단되는 등', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0161'};
MATCH (a:ResponseActor {name: '대구광역시'}), (b:ResponseAction {name: '사망자 장례지원'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', objective: '유가족 편의 도모', evidence: '대구시에서는 사망자별 장례지원반을 편성 ... 장례비(6백만원) 및 위로금(1백만원)을 지급하고', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0162'};
MATCH (a:RiskFactor {name: '장례식장 시신수용 시설 부족'}), (b:Event {name: '대량 사망자 시신보관·장례 처리 부담'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {reason: '대형사고 다수 시신 동시 발생 대비 수용능력 부족', probability: 'Med', evidence: '대다수 병원의 냉동고와 빈소는 10개 미만의 시체를 수용할 수 있어 대형사고 발생시 시신보관을 위한 시설이 열악한 실정이었다.', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0163'};
MATCH (a:ResponseActor {name: '대구광역시'}), (b:Resilience {name: '장례식장 일제조사·행정지도 기반 협조체계'}) MERGE (a)-[r:BUILDS]->(b) SET r += {phase: 'preparedness', timing: '2002년 11월(사고 전)', effectiveness: 'High', consequence: '지하철 화재사고 수습시 장례식장 협조 확보', evidence: '대구시에서는 2002년 11월 장례식장에 대한 일제조사와 ... 행정지시에 대한 공감대를 확보한 상태여서 지하철 화재사고 수습을 위한 대구시의 요청에 대한 많은 협조와 지원을 받았다.', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0164'};
MATCH (a:ManmadeHazard {name: '대구 지하철 중앙로역 방화'}), (b:Event {name: '1079호 전동차 화재'}) MERGE (a)-[r:TRIGGERS]->(b) SET r += {scale: '대형', probability: 'High', mechanism: '전동차내 화재 발생', evidence: '발생경위 : 전동차내 화재로 인한 사망 / 사고당일 ... 1079호 전동차를 탑승 ... 중앙로역 화재로 인하여', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0165'};
MATCH (a:Event {name: '유독가스·농연 확산'}), (b:Damage {name: '대구 지하철 화재 인명피해'}) MERGE (a)-[r:CAUSES]->(b) SET r += {mechanism: '유독가스 흡입에 의한 호흡기 병증', directCause: '농연·유독가스 흡입', evidence: '신원확인 사망자 186명과 신원미확인 사망자 6명 등 총 192명의 장례가 완료 / 확인된 시신수는 총 192구로 이 중 신원을 확인할 수 없는 시신은 6구', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0166'};
MATCH (a:Damage {name: '대구 지하철 화재 인명피해'}), (b:Context {name: '사망자 장례 처리 현황'}) MERGE (a)-[r:QUANTIFIED_BY]->(b) SET r += {detail: '장례유형별 분포', evidence: '장례유형별로는 매장 61기, 납골당 안치 106기, 산골 25기 등이었다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0167'};
MATCH (a:Damage {name: '신원미확인 사망 6구'}), (b:ResponseAction {name: '무연고 시신 처리'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {role: '무연고 시신 행정처리', specialNote: 'subject Damage가 아래 ResponseAction의 대상', evidence: '7월 16일 무연고 사망자 6명을 대구시립공동묘지에 안장 / 무연고 시신은 장사 등에 관한 법률 제11조 및 동법 시행령 제7조의 규정에 따라 10년간 안치후 화장', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0168'};
MATCH (a:ResponseActor {name: '대구광역시'}), (b:ResponseActor {name: '대구지하철참사 희생자대책위원회'}) MERGE (a)-[r:COORDINATES_WITH]->(b) SET r += {role: '합동장례 협의', specialNote: '묘역·추모공원 이견으로 4월19일·24일·5월22일 3차 무산 후 6월 29일 거행', evidence: '대구시와 희생자대책위원회는 ... 합동장례를 원칙으로 정하고 ... 합동장례가 1차 무산 ... 다시 합동장례식이 연기 ... 또 다시 합동장례가 이루어지지 못하였다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0169'};
MATCH (a:ResponseActor {name: '대구광역시'}), (b:ResponseAction {name: '합동영결식'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', timing: '2003-06-29 10:00~13:00', location: '시민회관 광장', evidence: '6월 29일 10:00 시민회관 광장에서 ... 63명을 제외한 129명의 합동영결식을 거행하였다. 이날 참석인원은 약 1,500여명', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0170'};
MATCH (a:ResponseActor {name: '대구광역시 부상자대책반'}), (b:ResponseAction {name: '부상자 확인·의료기관 공무원 배치'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', objective: '부상자 식별·관리', evidence: '피해자들이 후송된 12개 병원에 배치하였다 / 부상자대책반은 부상자 현황관리, 부상자 위문 및 가족지원 ...', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0171'};
MATCH (a:ResponseActor {name: '대구시 사고대책본부'}), (b:ResponseAction {name: '부상자 치료비 지급'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', objective: '부상자 치료비 전액 부담', evidence: '7차례에 걸쳐 총 953백만원의 치료비를 지급하였다 / 부상자 치료비 지급내역 ... 953,200,900', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0172'};
MATCH (a:ResponseAction {name: '부상자 치료비 지급'}), (b:Context {name: '부상자 치료 예산'}) MERGE (a)-[r:GUIDED_BY]->(b) SET r += {role: '예산 근거', detail: '예산 확정', evidence: '부상자 치료에 소요되는 예산은 1086백만원(국비 70%, 특별교부세 15%, 시비 15%)이 확정', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0173'};
MATCH (a:ResponseActor {name: '사고수습대책반'}), (b:ResponseAction {name: '부상자 위로금 지급'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', objective: '부상자 정신적·생활 안정 지원', evidence: '부상자 1인당 30만원씩 1차 위로금을 ... 145명에게 총 43,500천원을 전달 / 2차 특별위로금 ... 입원중인 부상자 125명에게 1인당 100만원씩 125백만원을 지급', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0174'};
MATCH (a:ResponseActor {name: '부상자가족대책위원회'}), (b:ResponseActor {name: '대구광역시'}) MERGE (a)-[r:COORDINATES_WITH]->(b) SET r += {role: '국민성금 선지급 합의', specialNote: '법적보상금 수령시 선지급금 공제', evidence: '이미 모금된 국민성금 중 일부를 미리 지급한 후 향후 법적보상금 수령시 선지급금을 공제한 후 지급하기로 부상자가족대책위원회와 합의', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0175'};
MATCH (a:RiskFactor {name: '허위·간접 부상자 신고'}), (b:Damage {name: '대구 지하철 화재 인명피해'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {role: '부상자 관리 교란', reason: '진짜 부상자·유가족 피해 우려', evidence: '보상금을 목적으로 지하철 화재사고와 관련이 없는 자가 피해를 호소하며 치료를 요청하는 사례 / 보상에 집착하는 경향이 나타나는 간접적인 피해자', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0176'};
MATCH (a:Population {name: '지하철공사 직원(구조 참여)'}), (b:Damage {name: '대구 지하철 화재 인명피해'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {role: '구조 과정 2차 부상', mechanism: '폭발음을 터널붕괴로 착각, 레일에서 넘어져 외상', evidence: '구조활동을 하다가 사고 전동차에서 나는 폭발음을 터널붕괴로 착각하여 ... 급히 달려나오다 레일에 넘어지면서 부상 / 지하철공사 직원 부상자(11명)와 동일한 부상자로 인정', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0177'};
MATCH (a:ResponseActor {name: '부상자가족대책위원회'}), (b:ResponseAction {name: '만성후유증 전문가 자문회의'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', objective: '만성후유증 평가·평생진료 보장 요구', evidence: '3월 17일 지역의 관련분야 전문가들에게 자문을 구하는 회의를 개최 / 4가지로 연구조사 분야를 최종 도출하였다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0178'};
MATCH (a:RiskFactor {name: '상인동 도시가스폭발참사 교훈 미흡'}), (b:ManmadeHazard {name: '대구 지하철 중앙로역 방화'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {role: '재난 반복 유발', reason: '안전에 대한 사회시스템 근본 개선 미흡', evidence: '상인동 도시가스폭발참사의 교훈을 깊이 새기고 ... 여전히 우리 주변에 크고 작은 사고들이 끊이지 않고 / 안전불감증이 깨끗이 사라지고', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0179'};
MATCH (a:ManmadeHazard {name: '대구 지하철 중앙로역 화재사고(2003)'}), (b:Damage {name: '부상자 만성후유증'}) MERGE (a)-[r:CAUSES]->(b) SET r += {mechanism: '고온·유독가스 노출', consequence: '부상자 만성후유증 발생', specialNote: '다이옥신 등 유해물질 노출', evidence: '동일 소재의 연소로 발생 가능한 모든 유해요인에 의한 건강상 장애의 가능성을 인정', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0180'};
MATCH (a:ResponseActor {name: '부상자가족대책위원회'}), (b:ResponseAction {name: '모의 화재실험·평생진료 보장 요구'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {timing: '사고 직후부터 지속', objective: '보상·평생진료 보장 요구', detail: '모의 화재실험 실시 및 평생진료증 발급 요구', evidence: '모의 화재실험을 실시하여 ... 보상과 평생진료를 보장하는 평생진료증 발급을 요구하였다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0181'};
MATCH (a:ResponseActor {name: '사고대책본부 부상자대책반'}), (b:ResponseAction {name: '전문가 자문회의(2003-03-17)'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', timing: '2003-03-17', objective: '모의 화재실험·유해물질 만성영향 평가 자문', evidence: '3월 17일 지역의 관련분야 전문가들에게 자문을 구하는 회의를 개최하였다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0182'};
MATCH (a:ResponseAction {name: '전문가 자문회의(2003-03-17)'}), (b:Damage {name: '부상자 만성후유증'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {consequence: '모의 화재실험 불필요 결론, 4개 연구조사 분야 도출', detail: '동일상황 재현 불가능·정량평가 오류 우려로 모의실험 대신 유해성 인정 방안', evidence: '모의 화재실험의 불필요성을 설득하기로 의견을 모았다 ... 4가지로 연구조사 분야를 최종 도출', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0183'};
MATCH (a:ResponseActor {name: '보건복지부'}), (b:ResponseAction {name: '중앙부처 대책회의(2003-04-15)'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', timing: '2003-04-15', objective: '후유증 진료보장·모의실험·추적연구 결론 도출', evidence: '보건복지부에서는 4월 15일 ... 대책회의를 개최하였다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0184'};
MATCH (a:ResponseAction {name: '중앙부처 대책회의(2003-04-15)'}), (b:Damage {name: '부상자 만성후유증'}) MERGE (a)-[r:MITIGATES]->(b) SET r += {effectiveness: 'Med', mechanism: '보상금에서 진료비 공제·심사위원회 진료보장, 일괄보상/지속진료 선택권 부여', specialNote: '예측불가 후유증은 별도 재원 확보 후 인과관계 인정시 진료보장', evidence: '일괄 보상이나 지속적 후유증 진료 가운데 하나를 선택하도록 선택권을 보장하고 ... 인과관계가 있다고 인정되는 후유증에 대하여는 진료를 보장', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0185'};
MATCH (a:ResponseActor {name: '중앙사고대책본부'}), (b:ResponseAction {name: '만성후유증 진료비·연구용역비 예산 확정'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', timing: '2003-06-18', objective: '만성후유증 진료비·연구용역비 예산 확정', evidence: '만성후유증 진료비로 3,550백만원과 만성후유증 관련 연구용역비로 600백만원의 예산이 결정되었다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0186'};
MATCH (a:ResponseAction {name: '만성후유증 연구용역'}), (b:Damage {name: '부상자 만성후유증'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {phase: 'recovery', objective: '만성후유증 인과관계 규명 및 진료보장 근거 마련', evidence: '만성휴유증 연구용역은 2004년 1월 16일에 경북대학교와 용역계약을 체결 ... 전문가 30명이 연구원으로 참여', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0187'};
MATCH (a:Population {name: '일부 부상자(평생진료권 희망)'}), (b:ResponseAction {name: '만성후유증 연구용역'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '평생진료권 희망 포기 못함, 부상자 단체 내부 갈등', consequence: '연구사업 참여 지연·검진 일정 미확정', specialNote: '차량 연소실험 미실시 설득에도 일부 대표 장기간 미납득', evidence: '평생진료권에 대한 희망을 포기하지 못한 일부 부상자들의 반발로 건강검진 일자와 검진병원은 결정하지 못한', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0188'};
MATCH (a:Resilience {name: '대구광역시지하철화재사고부상자만성후유증진료기금'}), (b:Damage {name: '부상자 만성후유증'}) MERGE (a)-[r:OFFSETS]->(b) SET r += {mechanism: '손해보상 미포함 유독물질 만성후유증 진료비 별도 재원 확보', effectiveness: 'Med', evidence: '손해보상시 포함되지 않은 유독물질로 인한 만성후유증을 관리하기 위하여 3,550백만원의 사업비가 확정', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0189'};
MATCH (a:ResponseActor {name: '대구광역시'}), (b:Resilience {name: '대구광역시지하철화재사고부상자만성후유증진료기금'}) MERGE (a)-[r:BUILDS]->(b) SET r += {phase: 'recovery', timing: '2004-02-05 조례제정방침~2004-12 기금 전출', mechanism: '기금운용조례 제정, 심의위원회 발족', evidence: '기금운용조례를 제정하기에 이르렀다 ... 2004년 5월 31일 공포', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0190'};
MATCH (a:ManmadeHazard {name: '대구 지하철 중앙로역 화재사고(2003)'}), (b:Damage {name: '중앙로역 일대 상가 물적피해'}) MERGE (a)-[r:CAUSES]->(b) SET r += {mechanism: '화재 매연·악취·열기 유입, 지하철 운행중단으로 유동인구 감소', consequence: '상가 물품 오손·영업손실', evidence: '물적피해 신고는 총 215건이 접수되었으며 ... 174건 8,340,213천원이 유효한 신고였다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0191'};
MATCH (a:Event {name: '지하철 전구간 운행중단'}), (b:Damage {name: '중앙로역 일대 상가 물적피해'}) MERGE (a)-[r:CAUSES]->(b) SET r += {mechanism: '유동인구 급감, 추모행사 빈발', consequence: '도심상권 영업손실', evidence: '지하철 운행중단으로 유동인구가 급격히 감소하였고 ... 막대한 영업피해를 입었다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0192'};
MATCH (a:ResponseActor {name: '사고대책본부 대외협력반'}), (b:ResponseAction {name: '물적피해 신고·조사'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', timing: '신고 2003-03-07~03-20, 조사 2003-03-05~04-11', objective: '물적피해 신고 접수 및 손해사정 조사', evidence: '피해접수 공고를 3월 6일 일간신문에 공고 ... 손해평가사정인이 피해신고한 장소를 일일이 확인, 조사', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0193'};
MATCH (a:ResponseAction {name: '물적피해 신고·조사'}), (b:Damage {name: '중앙로역 일대 상가 물적피해'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '간접피해·특별재난지역 외 보상범위 미확정 상태에서 접수, 3교대 근무자 매일 교체', consequence: '신고 거부/접수 혼선, 민원 야기, 이중·과다 신고', specialNote: '사고 15일 경과 후 조사 착수로 피해상태 보존 미흡', evidence: '피해 보상범위를 명확하게 결정하지 않은 상태에서 신고서를 접수함으로써 적지 않은 마찰이 발생', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0194'};
MATCH (a:ResponseAction {name: '금융지원상담센터'}), (b:Damage {name: '중앙로역 일대 상가 물적피해'}) MERGE (a)-[r:MITIGATES]->(b) SET r += {phase: 'recovery', effectiveness: 'Med', mechanism: '경영안정자금·생활안정자금 융자, 보험가입 조회, 금융거래 조회', evidence: '기관별로 각각 금융지원제도를 마련하여 금융지원상담센터를 운영하였다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0195'};
MATCH (a:ResponseAction {name: '금융지원상담센터'}), (b:Damage {name: '부상자 만성후유증'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {phase: 'recovery', consequence: '상담 174건(사망자 21·실종자 58·부상자 13·기타 82), 금융지원 실적 89건 3,203백만원', detail: '경영안정자금 75건 2,943백만원, 생활안정자금 14건 260백만원, 신용보증서 63업체 1,993백만원', evidence: '상담실적은 총 174건 ... 금융지원 실적은 총 89건 3,203백만원', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0196'};
MATCH (a:ResponseActor {name: '중앙특별지원단'}), (b:ResponseAction {name: '유가족·피해상가 금융지원 확대'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', timing: '2003-04-06~04-07, 신용보증 확대 2003-03-31', objective: '사망자 유가족 생활안정자금 무이자 융자, 신용보증 확대', evidence: '중앙특별지원단장은 ... 사망자 1인당 2천만원 한도내에서 생활안정자금을 무이자로 융자해 주기로 하였다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0197'};
MATCH (a:ManmadeHazard {name: '대구 지하철 중앙로역 화재사고(2003)'}), (b:Damage {name: '지역사회 심리적 충격·동요'}) MERGE (a)-[r:CAUSES]->(b) SET r += {mechanism: '미증유 대형참사로 가치관·도덕률 붕괴, 8년 간격 연이은 대형참사', consequence: '시민 정신적 공황·자괴심·지역정서 침체', evidence: '공동선, 가치관, 도덕률의 붕괴와 절망감으로 크게 술렁거렸다 ... 대구시민이 받은 충격과 좌절감은 대단한 것', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0198'};
MATCH (a:ManmadeHazard {name: '대구 지하철 중앙로역 화재사고(2003)'}), (b:Damage {name: '지역경제 침체·국제행사 차질'}) MERGE (a)-[r:CAUSES]->(b) SET r += {mechanism: '대구 이미지 추락, 차량통제·추모행사로 도심상권 위축', consequence: '지역경제 침체·국제행사 차질 우려', evidence: '외국인과 역외 투자자들의 투자기피, 2003하계유니버시아드 ... 등 국제행사의 차질 ... 지역경제의 현재와 미래를 암울하게', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0199'};
MATCH (a:Resilience {name: '2003 하계유니버시아드(U대회)'}), (b:Damage {name: '지역경제 침체·국제행사 차질'}) MERGE (a)-[r:OFFSETS]->(b) SET r += {mechanism: '시민 결집·성공적 국제대회 개최로 지역정서·경제 회복', effectiveness: 'High', evidence: '2003하계유니버시아드는 ... \'재도약의 기회\' 구실 ... 지역경제 회생의 발판이 되는 등 지역발전사의 중요한 전환점', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0200'};
MATCH (a:ResponseActor {name: '지역언론·경제원로·사회경제단체'}), (b:Resilience {name: '지역공동체 회복 역량'}) MERGE (a)-[r:BUILDS]->(b) SET r += {phase: 'recovery', mechanism: '기고·사설·중재, 재도약 시민 결집 호소', specialNote: '노희찬 대구상의회장 등 경제원로 중재자 역할', evidence: '지역의 경제 원로들도 지역경제 회복과 갈등 조정을 위한 중재자로 나섰으며 ... \'재도약을 위한 시민 결집\'을 호소', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0201'};
MATCH (a:Resilience {name: '지역공동체 회복 역량'}), (b:Damage {name: '지역사회 심리적 충격·동요'}) MERGE (a)-[r:OFFSETS]->(b) SET r += {mechanism: '공동체 회복 움직임·캠페인', effectiveness: 'Med', evidence: '지역공동체의 회복을 기원하는 움직임 또한 활발했다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0202'};
MATCH (a:ManmadeHazard {name: '방화범 김대한'}), (b:Event {name: '대구 지하철 중앙로역 화재(2003)'}) MERGE (a)-[r:TRIGGERS]->(b) SET r += {directCause: '방화', probability: 'High', mechanism: '전동차 내부 방화로 화재 발생', scale: '대형', evidence: '오늘 아침 9시 55분경 지하철 중앙로역 전동차 내에서 화재가 발생하여 다수의 인명 사상자가 발생했다. 사고경위는 방화로 추정되고 방화용의자는 정신병력이 있는 56세의 김대한으로 확인되고 있다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0203'};
MATCH (a:RiskFactor {name: '지하 밀폐구조(지하철 화재 취약성)'}), (b:Damage {name: '대구 지하철 중앙로역 화재 인명피해'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {mechanism: '밀폐 지하공간에서 화재로 다수 사상자 확대', reason: '좁고 밀폐된 지하공간에서 발생', effectiveness: 'High', evidence: '소방당국의 신속한 대처에도 불구하고 좁고 밀폐된 지하공간에서 일어난 사건이라 많은 사상자가 발생하게 되었습니다 / 지하 밀폐된 곳에서 사고가 발생하여 현재까지 중경상자가 130여명, 사망이 20여명이 넘는 것으로 확인', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0204'};
MATCH (a:Event {name: '대구 지하철 중앙로역 화재(2003)'}), (b:Event {name: '중앙로역 일대 정전'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {mechanism: '화재로 인한 전기 완전 단전', timing: '사고 직후', spreadRisk: 'High', evidence: '전기가 완전 단전되어 시신상태가 한 사람 한 사람 구별이 어려운 상태다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0205'};
MATCH (a:Event {name: '대구 지하철 중앙로역 화재(2003)'}), (b:Damage {name: '대구 지하철 중앙로역 화재 인명피해'}) MERGE (a)-[r:CAUSES]->(b) SET r += {directCause: '화재 및 유독가스', scale: '대형참사', timing: '사고 당시', evidence: '사망자 192명에 대한 합동영결식 / 사고당시 탑승객을 430명가량으로 추정, 사망자로 추정되는 133명과 부상자 140여명을 제외하면 150여명이 시신이 발견되지 않은 실종자', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0206'};
MATCH (a:RiskFactor {name: '차량 내장재 불연성 결함'}), (b:Damage {name: '대구 지하철 중앙로역 화재 인명피해'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {reason: '대구참사의 주원인으로 지적', mechanism: '가연성 내장재로 화재·유독가스 급속 확대', effectiveness: 'High', evidence: '이번 참사의 주요원인으로 지적된 차량 내장재와 비상조명 설계 / 대구참사의 주원인으로 지적된 차량 내장재의 불연성 등 안전성 문제', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0207'};
MATCH (a:RiskFactor {name: '지하상가 방화셔터 구조 결함'}), (b:Damage {name: '대구 지하철 중앙로역 화재 인명피해'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {mechanism: '방화셔터 작동 관련 대피·구조 지장 의혹', reason: '유족이 방화셔터 작동 수사 촉구', effectiveness: 'Med', evidence: '지하상가 방화셔터의 구조상 의문점 등에 대하여 설명하였으며, 유족들은 방화셔터 설치의 적법성을 따지고 ... 방화셔터 작동관련 수사를 촉구', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0208'};
MATCH (a:Event {name: '대구 지하철 중앙로역 화재(2003)'}), (b:Damage {name: '대구 지역경제 손실'}) MERGE (a)-[r:CAUSES]->(b) SET r += {mechanism: '참사로 시민발길 감소·국제행사 차질', scale: '대형', timing: '사고 이후', evidence: '경제적 손실 7천억, 도시 신뢰 추락.. 국제행사 차질 / U대회도 침울, 관광객 6천억 효과 타격', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0209'};
MATCH (a:ResponseActor {name: '대구광역시'}), (b:ResponseAction {name: '사고수습대책본부 설치 및 비상근무체제'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', timing: '사고 직후', role: '사고수습 컨트롤타워', evidence: '대구시는 사고직후 중앙로역 인근 우리은행 앞에 사고수습현장지휘소를 설치하고 신속한 사고수습에 나섰으며 / 사고대책본부를 구성하고 비상근무체제에 돌입', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0210'};
MATCH (a:ResponseActor {name: '대구광역시'}), (b:ResponseAction {name: '지하층 인명구조활동'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', timing: '사고 직후', objective: '인명구조', evidence: '사고직후 시는 경찰·소방·봉사단체를 동원하여 인명구조에 전력을 기울이고 있다 / 현재 전동차 외부는 구조가 완료되었으나, 전동차 내부에 상당수 미확인 사망자가 있는 것으로 확인', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0211'};
MATCH (a:ResponseActor {name: '중앙특별지원단'}), (b:ResponseAction {name: '중앙특별지원단 수습지원 활동'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', role: '지역 미해결 사항 해결', timing: '사고 후', evidence: '중앙특별지원단은 행자부 2명, 보건복지부 1명, 건교부 1명, 법무부 1명, 경찰청 1명 등 5개부처 6명으로 구성 / 지역에서 해결 못하는 사항 해결에 노력하겠다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0212'};
MATCH (a:ResponseActor {name: '고건 국무총리'}), (b:ResponseActor {name: '중앙특별지원단'}) MERGE (a)-[r:COMMANDS]->(b) SET r += {phase: 'response', timing: '2003-02-27 취임 직후', evidence: '차관급을 단장으로 하는 특별지원단을 구성, 파견하고 사고에 대한 객관적인 조사가 이뤄질 수 있도록 조치', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0213'};
MATCH (a:ResponseActor {name: '대구시 사고대책본부'}), (b:ResponseAction {name: '중앙로역 교통통제 및 안전보강공사'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'mitigation', timing: '2003-03-01 ~ 03-17', reason: '지하3층 상층부 구조물 안전 위험 긴급진단의견', evidence: '3월 1일부터 중앙로(반월당네거리~대구역간) 교통통제를 실시 / 3월 8일부터 16일까지 지하3층의 중앙기둥 28개소에 가받침을 설치하는 안전보강공사를 시행하고 3월 17일 재하시험', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0214'};
MATCH (a:ResponseAction {name: '중앙로역 교통통제 및 안전보강공사'}), (b:Damage {name: '중앙로·동성로 상가 영업손실'}) MERGE (a)-[r:CAUSES]->(b) SET r += {mechanism: '장기 교통통제로 상권 영업손실', timing: '통제 한달 가까이 지속', evidence: '교통통제 조치가 한달 가까이 계속되자 중앙로 및 동성로 일대 상인들은 영업손실에 따른 생계위협을 이유로 차량통행 재개를 요구하는 집단행동에 나서기에 이르렀다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0215'};
MATCH (a:ResponseActor {name: '건설교통부'}), (b:ResponseAction {name: '건교부 지하철 안전실태점검(35개 항목)'}) MERGE (a)-[r:FAILS]->(b) SET r += {phase: 'preparedness', reason: '차량 내장재 불연성·방재설비 등 소방안전 핵심항목 점검 누락', timing: '2003-03-19~03-25', effectiveness: 'Low', evidence: '차량 내장재와 비상조명 설계, 환풍기 작동여부, 소화전 설비점검, 열감지기센서 작동여부, 내연설계 여부 등 소방안전과 관련된 점검이 없었다 / 건교부 안전실태점검이 종합점검으로는 미흡했다고 인정', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0216'};
MATCH (a:RiskFactor {name: '1인 승무제 및 필수인력 부족'}), (b:Event {name: '대구 지하철 중앙로역 화재(2003)'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {reason: '지하철 안전 운영 필수인력 문제로 지적', probability: 'Med', mechanism: '1인 승무·인력부족으로 화재 초기대응 한계', evidence: '지하철 안전 운영을 위한 필수인력의 문제 - 역 상주인원의 적정성 여부, 1인 승무제 운영의 안전성 문제, 교육원 폐지에 따른 각종 교육 미비의 문제', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0217'};
MATCH (a:ResponseActor {name: '대구광역시'}), (b:Resilience {name: '방재·안전 거점도시 구상'}) MERGE (a)-[r:BUILDS]->(b) SET r += {phase: 'prevention', objective: '선진 방재시스템 구축 및 안전도시 이미지 제고', timing: '참사 후 1년', evidence: '방재·안전 거점도시 육성계획은 대형재난·재해 발생으로 팽배하고 있는 시민들의 심리적·사회적 불안감을 해소하고, 인간중심의 선진방재시스템 구축 / 추진내용: 소방방재청 대구 유치, 방재테마공원 조성, 방재산업단지 조성, 지역방재연구소 설립', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0218'};
MATCH (a:Event {name: '대구 지하철 중앙로역 화재(2003)'}), (b:Context {name: '특별재난지역(중앙로역 일대)'}) MERGE (a)-[r:OCCURS_AT]->(b) SET r += {role: '특별재난지역 선포 근거', evidence: '지난 2월 18일 지하철참사로 인해 특별재난지역으로 선포된 피해지역인 중앙로역 / 참사 즉시 특별재난구역으로 선포하고', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0219'};
MATCH (a:ManmadeHazard {name: '2003년 대구 지하철 중앙로역 방화'}), (b:Event {name: '1079호 전동차 화재'}) MERGE (a)-[r:TRIGGERS]->(b) SET r += {role: '직접원인', probability: 'High', mechanism: '방화로 1079호 전동차 발화', directCause: '방화', evidence: '사고발생의 직접 원인은 방화로 일찌감치 알려졌지만', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0220'};
MATCH (a:Event {name: '1079호 전동차 화재'}), (b:Event {name: '유독가스 확산(2003 대구지하철)'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {directCause: '화재에 취약한 객차 내장재', mechanism: '가연성 내장재 연소로 유독가스 발생', spreadRisk: 'High', specialNote: '작은 사고를 대형참사로 키운 2차적 요인', evidence: '화재에 취약한 객차 내장재 ... 작은 사고를 대형참사로 키운 2차적 사고원인 / 내장재 유독가스 / 가연성 마감재 유독가스', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0221'};
MATCH (a:RiskFactor {name: '화재에 취약한 객차 내장재'}), (b:Event {name: '유독가스 확산(2003 대구지하철)'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {role: '2차적 사고원인', mechanism: '유독가스 발생으로 인명피해 확대', effectiveness: 'High', evidence: '내장재 유독가스 / 방염처리 내장재 없었다 / 화재취약 내장재 및 유독가스', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0222'};
MATCH (a:Event {name: '1079호 전동차 화재'}), (b:Event {name: '중앙로역 정전(2003 대구지하철)'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {directCause: '마스컨키 분리로 인한 전동차 기능 마비·정전', mechanism: '화재로 단전 발생', timing: '1080호 진입 후', evidence: '단전대비책 수립 / 단전으로 출입문 미개방 / 마스컨키 분리로 인한 전동차 기능 마비', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0223'};
MATCH (a:Event {name: '중앙로역 정전(2003 대구지하철)'}), (b:Event {name: '1080호 전동차 출입문 잠김'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {directCause: '단전으로 전동차 출입문 미개방', mechanism: '전원 차단으로 자동 출입문 작동 불능', spreadRisk: 'High', evidence: '단전으로 출입문 미개방 / 전동차 출입문 수동조작 지연 / 출입문 수동조작 손쉽게', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0224'};
MATCH (a:Event {name: '1080호 전동차 출입문 잠김'}), (b:Event {name: '승객 고립'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {directCause: '출입문 미개방으로 승객 탈출 불가', mechanism: '출입문 잠김 + 탈출로 봉쇄로 승객 고립', spreadRisk: 'High', evidence: '단전으로 출입문 미개방 / 탈출구 봉쇄(방화벽 차단)', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0225'};
MATCH (a:Event {name: '승객 고립'}), (b:Damage {name: '대구 지하철 화재 인명피해'}) MERGE (a)-[r:CAUSES]->(b) SET r += {directCause: '유독가스 흡입 및 탈출 불가', mechanism: '고립 상태에서 유독가스 질식', scale: '대형참사', evidence: '대구참사 실종 228명으로 줄어 / 실종자 222명 전원 ... 인정사망심사위', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0226'};
MATCH (a:RiskFactor {name: '탈출구 봉쇄(방화셔터 차단)'}), (b:Event {name: '승객 고립'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {role: '대피 차단', mechanism: '탈출로 봉쇄로 고립·인명피해 가중', effectiveness: 'High', evidence: '탈출구 봉쇄(방화벽 차단) / 지하상가 피해 우려 탈출로 막았다 / 방화셔터 조기차단 의혹', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0227'};
MATCH (a:RiskFactor {name: '불합리한 중앙로역사 구조'}), (b:Damage {name: '대구 지하철 화재 인명피해'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {role: '2차적 사고원인', mechanism: '협소·심층 구조로 대피 지연', effectiveness: 'Med', evidence: '불합리한 중앙로역사 구조(타역보다 깊고 통로 협소) / 중앙로역 설계 졸속 - 계단, 출입구 협소 / 지하3층 구조', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0228'};
MATCH (a:RiskFactor {name: '지하철 직원 비상조치능력 부족'}), (b:Damage {name: '대구 지하철 화재 인명피해'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {role: '2차적 사고원인', mechanism: '초기·현장 대응 미흡으로 참사 확대', effectiveness: 'High', evidence: '지하철 직원의 비상조치능력 부족 / 지하철공사의 안일한 대처 / 직원안전교육훈련 형식적', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0229'};
MATCH (a:RiskFactor {name: '역사내 안전설비 미비'}), (b:Damage {name: '대구 지하철 화재 인명피해'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {role: '2차적 사고원인', mechanism: '초기 진화·배연·대피유도 실패', effectiveness: 'High', evidence: '역사내 안전설비 미비 / 소화장비 부족(소화기1대, 스프링클러 미설비) / 출구위치 야광표지판 미비', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0230'};
MATCH (a:RiskFactor {name: '종합사령실 화재경보 무시 및 통신체계 부실'}), (b:Damage {name: '대구 지하철 화재 인명피해'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {role: '2차적 사고원인', mechanism: '경보·통신 실패로 1080호 진입 및 대응 지연', effectiveness: 'High', evidence: '종합사령실, 화재경보 무시 / 종합사령실-전동차 통신체계 / 사령실 CCTV감시 소홀', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0231'};
MATCH (a:Event {name: '대구 지하철 화재'}), (b:Damage {name: '지역사회 정신적 충격 및 사회·경제 파장'}) MERGE (a)-[r:CAUSES]->(b) SET r += {scale: '상상을 초월', mechanism: '참사가 시민생활 전반에 충격', evidence: '엄청난 대형참사가 지역사회에 몰고 온 정신적 충격과 혼란, 그리고 산업, 경제, 교통, 문화 등 시민생활 전반에 미친 파장', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0232'};
MATCH (a:ResponseActor {name: '대구광역시'}), (b:ResponseAction {name: '사고현장 물청소(현장보존)'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: 'U대회(2003 대구하계유니버시아드) 차질 우려로 조속한 수습 추진, 현장보존 미흡', consequence: '유가족 불신·반발, 중앙정부 개입 초래', effectiveness: 'Low', evidence: '처음부터 ... 현장훼손의 당사자로 비판 / 중앙로역 3차례 물청소 / 신원단서 유류품 \'쓰레기\'처리, 현장훼손', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0233'};
MATCH (a:ResponseAction {name: '사고현장 물청소(현장보존)'}), (b:Damage {name: '사고현장 훼손 피해'}) MERGE (a)-[r:CAUSES]->(b) SET r += {directCause: '참사 다음날 물청소로 현장훼손', mechanism: '유류품·유해 유실로 신원확인·진상규명 곤란', evidence: '참사 다음날 물청소 \'사라진 현장\' / 치운 잔해더미서 유해조각 나와, 손·발등 14점', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0234'};
MATCH (a:Context {name: '2003 대구하계유니버시아드대회(U대회)'}), (b:ResponseAction {name: '사고현장 물청소(현장보존)'}) MERGE (a)-[r:UNDER_CONDITION]->(b) SET r += {role: '수습 압박 배경', mechanism: '대회준비 차질 우려로 현장 조기정리', evidence: '2003대구하계유니버시아드대회 개최(8월)를 앞두고 대회준비의 차질을 우려하여 조속한 사고수습 의지를 내비쳤던 대구시', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0235'};
MATCH (a:ResponseActor {name: '중앙정부'}), (b:ResponseAction {name: '특별재난지역 선포'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {timing: '2003-02-19', role: '신속 대응', evidence: '2월 19일 대구지하철 화재사고지역을 \'특별재난지역\'으로 선포하는 등 신속하게 대응', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0236'};
MATCH (a:ResponseActor {name: '중앙정부'}), (b:ResponseAction {name: '중앙특별지원단 구성'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '직접 수습 지원', reason: '대구시 수습능력 상실 비판 및 국가적 재난 인식', evidence: '중앙특별지원단을 구성하여 사고수습을 직접 지원 / 총리주재 관계장관회의를 대구 현지에서 열어', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0237'};
MATCH (a:ResponseActor {name: '중앙정부'}), (b:ResponseAction {name: '전국 대도시 지하철 특별 안전점검 및 긴급 시설보강'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'prevention', role: '전국 확산 방지', evidence: '전국 대도시 지하철에 대한 특별 안전점검 및 긴급 시설보강, 지하철 참사와 관련한 행정·재정 금융·세제상 지원대책을 발표', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0238'};
MATCH (a:ResponseActor {name: '대구지하철참사 시민사회단체대책위원회'}), (b:ResponseAction {name: '진상규명 및 사고수습 감시활동'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {timing: '2003-02-24', role: '진상조사·안전대책 촉구', evidence: '37개 시민·사회단체는 ... 대책위원회를 결성 ... 본격적인 진상 조사활동에 나섰다 / 현장훼손과 관련한 ... 사법처리 촉구', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0239'};
MATCH (a:ResponseActor {name: '인정사망심사위원회'}), (b:ResponseAction {name: '실종자 인정사망 심사'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '실종자 사망 확정', timing: '2003-03~04', mechanism: '탑승 증거물 활용 개별 심사', evidence: '\'인정사망심사위\' 오늘 발족, 15명으로 구성 / 1차 심사대상 실종자 76명 전원 사망 판정 / 실종자 35명 추가 인정사망', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0240'};
MATCH (a:ResponseActor {name: '대구광역시'}), (b:ResponseAction {name: '피해보상 및 추모공원 조성'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', role: '피해보상·추모', evidence: '지하철 피해보상조례안 가결 / 부상자 보상금 타결, 최고 3억3천만원 / 시-대책위 옛 연초제조창 부지에 추모공원 조성 합의', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0241'};
MATCH (a:ResponseActor {name: '검찰·경찰(수사기관)'}), (b:ResponseAction {name: '사고 수사 및 재판'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '책임자 사법처리', timing: '2003-03~08', evidence: '방화범·1079호 기관사 구속 / 대구지법 선고, 대구지하철 방화범 무기징역 / 조시장 무혐의, 윤 전사장 불구속기소', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0242'};
MATCH (a:ResponseActor {name: '정치권(여야)'}), (b:ResponseAction {name: '국회 재해특위 가동 및 한국지하철공사 설립 추진'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', role: '제도적 대응', evidence: '국회 재해특위 가동, 여야 대책반 구성 / (가칭)한국지하철공사를 설립하는 방안 / 설립 움직임은 ... 무산되고 말았지만', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0243'};
MATCH (a:RiskFactor {name: '지방자치단체 열악한 재정여건'}), (b:Event {name: '대구 지하철 화재'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {role: '근본원인', reason: '재정부족→안전설비·관리 소홀', probability: 'High', evidence: '이번 참사가 지방자치단체의 열악한 재정여건에 따른 부실공사와 관리소홀이 근본원인 / 저가낙찰이 품질저하 초래', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0244'};
MATCH (a:Event {name: '대구 지하철 중앙로역 화재(2003)'}), (b:Event {name: '중앙로역 지하구조물 손상'}) MERGE (a)-[r:TRIGGERS]->(b) SET r += {scale: '대형', probability: 'High', mechanism: '전동차 연소에 따른 고열·폭열로 철근콘크리트 구조물 손상', directCause: '화재 고열·폭열', evidence: '전동차 연소시 폭열을 직접받은 지하 3층(L=277m, B=18m) 시설물 등; 박리•박락 등 심각한 손상이 발생되어 있는 상태', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0245'};
MATCH (a:Event {name: '중앙로역 지하구조물 손상'}), (b:Damage {name: '중앙로역 구조물 E등급 손상평가'}) MERGE (a)-[r:CAUSES]->(b) SET r += {mechanism: '주요부재 결함 심각으로 즉각 사용금지·보강·개축 필요 등급 판정', severity: '심각', evidence: '구조물 상태는 E등급으로 평가; 정거장 구간은 E등급, 본선 구간은 C등급으로 나타났으나, 전체적으로는 E등급으로 판명; E: 주요부재의 결함이 심각하여 즉각 사용 금지하여 보강 또는 개축', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0246'};
MATCH (a:Event {name: '대구 지하철 중앙로역 화재(2003)'}), (b:Context {name: '화재 손상부위 최고온도 1,000°C 이상'}) MERGE (a)-[r:OCCURS_AT]->(b) SET r += {role: '화재손상 최고온도 추정', evidence: '전소된 선로 위의 스라브에서는 최고 1,000°C 이상의 고온; 승강장 상부 콘크리트 스라브는 200~500°C; 승강장 벽체는 100°C 미만으로 추정', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0247'};
MATCH (a:Damage {name: '중앙로역 구조물 E등급 손상평가'}), (b:Context {name: '콘크리트 압축강도 196.9~269kg/㎠ (설계기준 82~112%)'}) MERGE (a)-[r:QUANTIFIED_BY]->(b) SET r += {role: '콘크리트 압축강도 저하 정량', evidence: '구조물의 평균 압축강도는 196.9~269kg/mi로 나타나 구조물 설계기준강도(240kg/m)의 82~112%를 유지; 손상된 스라브에서의 압축강도는 100~150kg/ cri 정도', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0248'};
MATCH (a:Event {name: '중앙로역 지하구조물 손상'}), (b:ResponseAction {name: '중앙로역 지상부 도로 교통통제'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {mechanism: '지하구조물 손상으로 안전상 문제 발생→시민안전 확보 위해 지상부 도로 통행 통제', timing: '2003-02-26 시행', reason: '지하구조물 손상으로 지상 중차량 통행 위험', evidence: '중앙로 역사 지하구조물이 손상되어 안전상 문제가 있으므로 시민의 안전을 확보하기 위해 중앙로역 지상부 도로에 대한 교통통제; 2월 26일부터 승용차를 제외한 버스 등 중차량에 대한 통행을 제한', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0249'};
MATCH (a:ResponseAction {name: '중앙로역 지상부 도로 교통통제'}), (b:Damage {name: '중앙로 일대 상인 영업손실 피해'}) MERGE (a)-[r:CAUSES]->(b) SET r += {mechanism: '장기 차량통행 통제로 중앙로 상가 영업손실 발생', timing: '통제 장기화', evidence: '중앙로 교통통제가 장기화되면서 영업손실 등 큰 피해를 입고 있다는 이유로 강하게 반발; 17개 상가번영회 회원 500여명이...차량통행재개를 요구하는 시위', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0250'};
MATCH (a:ResponseActor {name: '실종자유가족대책위원회'}), (b:ResponseAction {name: '지하 1·2층 점거 및 현장보존 요구'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '현장보존 요구·점거', timing: '2003-02월', consequence: '가시설 보강공사 지연', evidence: '실종자 가족들이 중앙로역 지하 1, 2층을 점거하고, 현장보존을 요구함에 따라 지하 3층 기둥부분 가시설 보강공사가 지연되었다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0251'};
MATCH (a:ResponseAction {name: '지하 1·2층 점거 및 현장보존 요구'}), (b:ResponseAction {name: '구조물 가받침 보강공사'}) MERGE (a)-[r:MODIFIES_RISK_OF]->(b) SET r += {effectiveness: 'Low', reason: '현장보존 요구로 안전보강공사 지연', directCause: '출입 통제로 공사 착수 지연', evidence: '현장보존을 요구함에 따라 지하 3층 기둥부분 가시설 보강공사가 지연; 3월 17일까지 중앙로역 지하 3층에 있는 중앙기둥 28개에 가받침을 설치', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0252'};
MATCH (a:ResponseActor {name: '대구시 사고대책본부'}), (b:ResponseAction {name: '중앙로역 지상부 도로 교통통제'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', role: '교통통제 주관', evidence: '사고대책본부에서는...중앙로역 지상부 도로에 대해...통행을 제한하는 조치를 하였다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0253'};
MATCH (a:ResponseAction {name: '긴급안전진단'}), (b:Event {name: '중앙로역 지하구조물 손상'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {phase: 'response', role: '손상정도·붕괴위험 진단', effectiveness: 'Med', evidence: '철근콘크리트 구조물의 손상정도와 불안전 부위 존재여부를 신속하고 정확하게 진단하기 위하여...진단팀을 구성; 2월 19일부터 2월 21일까지...비파괴조사를 실시', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0254'};
MATCH (a:ResponseAction {name: '긴급안전진단'}), (b:Damage {name: '중앙로역 구조물 E등급 손상평가'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {role: '응급조치 권고', detail: '급작스런 붕괴위험은 없으나 추가손상 방지 위한 응급조치(가받침) 필요, 지하 2층 통행제한·지상도로 중차량 통제 권고', evidence: '급작스런 붕괴위험 등은 나타나지 않아...응급조치(가받침)가 필요하다는 의견과 함께, 피해가 심한 구간의 지하 2층은 통행을 제한하고...중차량의 통행을 통제할 필요가 있다는 의견을 제시', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0255'};
MATCH (a:ResponseAction {name: '중앙로역 구조물 정밀안전진단'}), (b:Damage {name: '중앙로역 구조물 E등급 손상평가'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {role: '구조물 안정성·보수보강방안 강구', effectiveness: 'High', evidence: '심각한 손상을 받은 구조물에 대한 안정성을 검토하고 보수•보강방법을 강구하기 위한 정밀안전진단을 실시; 한국시설안전기술공단과 용역계약을 체결하고 3월 10일부터 7월 21일까지 정밀안전진단을 실시', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0256'};
MATCH (a:ResponseAction {name: '중앙로역 재하시험'}), (b:ResponseAction {name: '구조물 가받침 보강공사'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {role: '가보강 구조물 안정성 검토·통행재개 판단', effectiveness: 'High', consequence: '차륜하중 진동·변위 거의 없음→안전성 확보, 통행재개 가능 판단', evidence: '가보강된 중앙로역 구조물의 안정성을 검토하기 위하여 3월 17일...구조물 내하력시험을 실시; 진동 및 변위가 거의 나타나지 않는 것으로 나타나...차량통행 재개가 가능하다고 판단', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0257'};
MATCH (a:ResponseAction {name: '구조물 변위 계측기 설치'}), (b:Resilience {name: '중앙로역 구조물 안정성 상시감시 역량'}) MERGE (a)-[r:BUILDS]->(b) SET r += {role: '구조물 이상 조기발견 역량 구축', effectiveness: 'High', evidence: '하중계 14대, 변형률계 28대, 경사계 13대, 균열계측기 9대 등 64대의 각종 계측기를 설치하여 자동계측 시스템을 구축; 매일 계측한 결과 관리기준치 이내로 안정적', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0258'};
MATCH (a:ResponseAction {name: '외국인 전문가 자문회의'}), (b:ResponseAction {name: '보수·보강방안(정거장구간)'}) MERGE (a)-[r:GUIDED_BY]->(b) SET r += {role: '보수·보강방안 결정 자문', detail: '지하 3층 상부 스라브 철거·재시공 불필요, 노출철근 재사용 가능, 보수범위 판단 기준 500°C(중성화시험)', evidence: '외국인 전문가...관련자 11명이 중앙로역 화재현장을 합동 점검하고...자문회의를 개최; 지하 3층 상부 스라브는 철거하여 재시공할 필요성이 없는 것으로 판단; 일반적으로 500°C가 기준', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0259'};
MATCH (a:ResponseActor {name: '중앙특별지원단'}), (b:ResponseActor {name: '대구시 사고대책본부'}) MERGE (a)-[r:COORDINATES_WITH]->(b) SET r += {role: '교통통행 재개 갈등 조율', timing: '2003-04-05 간담회', consequence: '4.10 00:00 차량통행 완전 재개 합의', evidence: '사고대책본부에서는 중앙특별지원단과 협의하여 4월 5일...간담회를 개최; 중앙특별지원단의 조기현 수습지원반장과 박승국 국회의원이 양측의 입장을 조율하는 역할을 하여 겨우 합의사항을 도출', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0260'};
MATCH (a:ResponseAction {name: '중앙로역 교통통제 대시민 사과문 발표'}), (b:Damage {name: '중앙로 일대 상인 영업손실 피해'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {role: '통행재개 보도자료 선배포에 대한 희생자대책위 반발 무마', reason: '최종 안전진단보고서 제출 전 통행재개 보도자료 배포에 대한 항의', evidence: '대구시 사고대책본부가 최종 안전진단보고서가 제출되기도 전에 통행재개 가능성에 대한 보도자료를 배포한 것에 대하여...사고대책본부에서는 3월 31일 5개 일간지에 \'중앙로 교통통제에 따른 대시민 사과문\'을 발표', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0261'};
MATCH (a:ResponseAction {name: '중앙로역 시설물 복구공사'}), (b:Damage {name: '중앙로역 구조물 E등급 손상평가'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {role: '손상 시설물 원상복구', effectiveness: 'High', specialNote: '수사본부 공사보류 요청으로 7.9 현장 인계 후 착수, 무정차 통과전까지 예정 공사기간 105일 추정', evidence: '화재사고로 손상된 지하철 시설물에 대한 긴급 복구공사; 화성산업(주)를 주관사로 선정하여 중앙로역 지하 3층 구조물(3,000m)과 건축시설물(10,400m)...7월 10일부터 10월 20일까지 시행', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0262'};
MATCH (a:ResponseAction {name: '복구설계'}), (b:Resilience {name: '승강장·대합실 피난유도시설'}) MERGE (a)-[r:BUILDS]->(b) SET r += {role: '재발방지 피난설비 확충', effectiveness: 'Med', evidence: '감사원 및 안전관리개선기획단의 안전점검 결과(승강장과 대합실 바닥에 피난유도시설 설치)를 실시설계에 반영', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0263'};
MATCH (a:Event {name: '대구 지하철 중앙로역 화재(2003)'}), (b:Facility {name: '중앙로역'}) MERGE (a)-[r:AFFECTS]->(b) SET r += {role: '복구 대상', mechanism: '역사 시설물 및 전동차 손상', evidence: '역사내 화재잔재물과 가받침(H빔 28조) 등 1,900톤을 ... 반출하였다.', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0264'};
MATCH (a:ResponseAction {name: '중앙로역 무정차 운행 복구공사'}), (b:Event {name: '대구 지하철 중앙로역 화재(2003)'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {phase: 'recovery', timing: '사고 후', consequence: '10월 21일 중앙로역 무정차 운행 시작', evidence: '10월 21일 중앙로역 무정차 운행을 시작하였다.', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0265'};
MATCH (a:ResponseActor {name: '한국철도공사(철도청)'}), (b:ResponseAction {name: '손상콘크리트 표면 제거 작업'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '장비 지원', phase: 'recovery', evidence: '철도청으로부터 Water Jet 장비 1대를 임대하여 천장 스라브 손상표면 깨기(2,751m)작업에 착수', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0266'};
MATCH (a:ResponseAction {name: '역사시설물 복구공사'}), (b:Event {name: '대구 지하철 중앙로역 화재(2003)'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {phase: 'recovery', consequence: '12월 31일부터 전구간 정상운행', evidence: '공사기간 : 2003년 10월 21일 ~ 2004년 1월 31일 ... 12월 31일부터 전구간 정상운행을 하였다.', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0267'};
MATCH (a:ResponseAction {name: '소방·제연설비 개선'}), (b:Resilience {name: '화재 연기·방사열 차단 역량'}) MERGE (a)-[r:BUILDS]->(b) SET r += {effectiveness: 'Med', mechanism: '연기·열·방사열 차단 설비 구축', evidence: '환기•제연방식을 변경하여 연기배출량을 증대시켰고, 승강장 출입구에 제연경계벽 ... 화재시 방사열 경감, 가스• 연기를 차단할 수 있도록 개선', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0268'};
MATCH (a:ResponseAction {name: '대피 유도·비상조명 개선'}), (b:Resilience {name: '정전시 대피 유도 역량'}) MERGE (a)-[r:BUILDS]->(b) SET r += {effectiveness: 'Med', mechanism: '정전 무관 대피유도 체계', evidence: '화재 및 정전시 신속하게 대피할 수 있도록 축광형 유도타일 및 입체안내도를 설치 ... 본선 터널에도 축전지 내장형 비상조명등을 설치', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0269'};
MATCH (a:RiskFactor {name: '전동차 내장재(가연성 합성수지)'}), (b:Damage {name: '중앙로역 화재 인명피해'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {role: '피해 확산 요인', probability: 'High', mechanism: '내장재가 불타며 유독가스(맹독가스) 발생 → 질식사', specialNote: '감사원: 인명피해에 가장 많은 영향을 준 요인이 전동차 내장재', evidence: '감사원 ... 인명피해에 가장 많은 영향을 준 요인이 전동차 내장재라고 지적했다. ... 사상자의 상당수는 ... 맹독가스에 의한 질식사', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0270'};
MATCH (a:RiskFactor {name: '전동차 내장재(가연성 합성수지)'}), (b:RiskFactor {name: '전동차 제작 저가입찰·출혈 덤핑'}) MERGE (a)-[r:DERIVES_FROM]->(b) SET r += {role: '근본 원인', mechanism: '저가입찰·덤핑으로 기술투자 외면, 합성수지 내장재 납품', evidence: '과도한 수주경쟁으로 저가입찰이 성행 ... 전동차 제작3사의 출혈 덤핑도 한 몫 했다 ... 대구지하철 1호선에 납품한 전동차는 7억원 선', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0271'};
MATCH (a:RiskFactor {name: '철도차량 화재안전기준 부재'}), (b:RiskFactor {name: '전동차 내장재(가연성 합성수지)'}) MERGE (a)-[r:PRECONDITIONS]->(b) SET r += {role: '구조적 원인', probability: 'High', mechanism: '안전기준 미비로 가연성 내장재 제작·납품 허용', evidence: '철도차량 화재안전기준에 대하여서는 국가차원에서 법, 제도적인 안전기준이 제정되지 않은 시기였다 ... 독성가스나 화염전파성, 연기밀도 등에 대한 안전기준은 없었다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0272'};
MATCH (a:ResponseActor {name: '감사원'}), (b:ResponseAction {name: '도시철도 안전관리실태 감사'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '감사 수행', phase: 'recovery', timing: '2003-02-24 ~ 2003-05-29', objective: '도시철도 안전관리실태 점검 및 원인 규명', evidence: '감사원 직원, 학계• 연구기관 등 전문인력 25명으로 감사팀을 구성하여 도시철도운영 전반에 대한 안전관리실태를 감사', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0273'};
MATCH (a:ResponseAction {name: '내장재 난연성능 시험'}), (b:RiskFactor {name: '전동차 내장재(가연성 합성수지)'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {role: '원인 규명', consequence: '난연성능이 부품규격서 기준에 미달 확인', evidence: '시험결과 난연성능이 부품규격서에 정해진 난연성능에 미달되게 제작 납품된 것으로 확인되었다.', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0274'};
MATCH (a:Damage {name: '내장판 난연성능 시험결과'}), (b:Context {name: '내장판 난연성 불합격률 56.3%'}) MERGE (a)-[r:QUANTIFIED_BY]->(b) SET r += {role: '시험 통계', evidence: '내장판 난연성능 시험결과 ... 계 165 ... 93 ... 56.3', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0275'};
MATCH (a:Damage {name: '단열재 난연성능 시험결과'}), (b:Context {name: '단열재 난연성 불합격률 59.3%'}) MERGE (a)-[r:QUANTIFIED_BY]->(b) SET r += {role: '시험 통계', evidence: '단열재 난연성능 시험결과 ... 계 123 ... 73 ... 59.3', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0276'};
MATCH (a:RiskFactor {name: '전동차 제작·검정 부실 관리'}), (b:RiskFactor {name: '전동차 내장재(가연성 합성수지)'}) MERGE (a)-[r:COMPOUNDS]->(b) SET r += {role: '복합 원인', mechanism: '관리감독 부실로 불에 잘 타고 유독가스 내뿜는 내장재 제작', evidence: '제도적 장치의 미비, 그리고 ... 도덕성 부재가 복합적인 원인으로 작용하여 불에 잘 타고 유독가스를 내뿜는 제품으로 만들어졌다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0277'};
MATCH (a:ResponseActor {name: '감사원'}), (b:ResponseAction {name: '내장재 안전기준 정비 및 교체 통보'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '제도 개선 통보', phase: 'recovery', mechanism: '건교부장관에 내장재 기준 정비·교체 통보, 시도지사에 구매규격서 개선·부정당업자 제재 통보', evidence: '감사원에서는 건설교통부장관에게 ... 우리나라의 기준을 구체적으로 정비하고 화재에 취약한 내장판, 단열재, 의자 등을 먼저 교체하도록 조치', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0278'};
MATCH (a:ResponseActor {name: '대구광역시지하철공사'}), (b:ResponseAction {name: '전동차 제작사 구상권 청구'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '변상 요구', phase: 'recovery', consequence: '(주)로템·(주)한진중공업 변상 거부 → 2004년 12월 상사중재 신청', evidence: '지하철건설본부와 지하철공사가 공동으로 ... (주)로템과 실제 납품업체인 (주)한진중공업에 변상을 요구하였다 ... 2004년 12월 중재신청을 하였다.', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0279'};
MATCH (a:ResponseAction {name: '전동차 내장재 난연성 시험(2003)'}), (b:RiskFactor {name: '전동차 내장재(가연성 합성수지)'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {role: '원인 확인', consequence: '내장판(FRP) 「가연성」, 단열재 「이상있음」 판정', evidence: '2003년 5월 7일 내장판은 「가연성」으로, 단열재는 「이상있음』이라는 시험결과를 통보받았다.', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0280'};
MATCH (a:ResponseAction {name: '전동차 내장재 교체 사업'}), (b:RiskFactor {name: '전동차 내장재(가연성 합성수지)'}) MERGE (a)-[r:PREVENTS]->(b) SET r += {role: '재발 방지', effectiveness: 'High', mechanism: '가연성 내장재를 불연성으로 교체', evidence: '전동차 내장재를 불연성 내장재로 전면적으로 교체한다는 목표 아래 ... 34편성(204량)에 대한 5개 품목 ... 전면 교체하여 줄 것을 건의', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0281'};
MATCH (a:Context {name: '서울지하철 1호선 전동차 발열량 분석(2001)'}), (b:RiskFactor {name: '전동차 내장재(가연성 합성수지)'}) MERGE (a)-[r:UNDER_CONDITION]->(b) SET r += {role: '발열량 근거', specialNote: '바닥판·의자가 발열량의 74% 차지', evidence: '서울지하철 1호선 전동차 발열량 분석결과(2001년) ... 바닥판 13,640(50%) ... 26,843 MJ(100%)', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0282'};
MATCH (a:Facility {name: '대구지하철 전동차 내장재'}), (b:Event {name: '전동차 화재 확산'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {mechanism: '가연성 내장재의 높은 발열량·유독가스 발생', reason: '기존 폴리에스테르계 FRP·PVC·폴리우레탄폼 등 가연성 재료 사용', probability: 'High', evidence: '전동차 1량 기준 총발열량은 26,843 MJ로 휘발유 81ℓ 정도가 연소될 때 발생하는 열량에 해당', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0283'};
MATCH (a:Facility {name: '대구지하철 전동차 내장재'}), (b:Context {name: '전동차 내장재 발열량(서울지하철 1호선, 2001)'}) MERGE (a)-[r:QUANTIFIED_BY]->(b) SET r += {specialNote: '내장재별 발열량 정량 근거로 화재위험성 평가의 기준', evidence: '서울지하철 1호선 전동차 발열량 분석결과(2001년) ... 26,843 MJ', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0284'};
MATCH (a:ResponseActor {name: '중앙정부'}), (b:ResponseAction {name: '소실 전동차 구입·불연성 내장재 개조비 지원'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', objective: '재난수습대책', evidence: '전동차 2개 편성 구입비, 전동차 불연성 내장재 개조비로 302억원을 지원하기로 결정하고 ... 총 243억원을 우선 지원하였으며', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0285'};
MATCH (a:ResponseAction {name: '전동차 내장재 교체 사업'}), (b:Resilience {name: '불연성 내장재 화재저항 역량'}) MERGE (a)-[r:BUILDS]->(b) SET r += {effectiveness: 'High', mechanism: '가연성 재료를 불연·난연 재료로 교체', evidence: '내장재 재료는 화재예방을 위하여 BS 6853의 Vehicle category Ia에 적합하여야 하며', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0286'};
MATCH (a:Resilience {name: '불연성 내장재 화재저항 역량'}), (b:Event {name: '전동차 화재 확산'}) MERGE (a)-[r:OFFSETS]->(b) SET r += {effectiveness: 'High', mechanism: '교체로 발열량 62%·연기발생량 76% 감소', specialNote: '철도기술연구원 재료시험 비교분석 결과', evidence: '내장재 교체로 발열량이 기존에 비해 62%, 연기 발생량이 76%가 줄어드는 효과가 있다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0287'};
MATCH (a:ResponseAction {name: '안전설비 개선 및 리모델링'}), (b:Event {name: '전동차 화재 확산'}) MERGE (a)-[r:MITIGATES]->(b) SET r += {phase: 'mitigation', effectiveness: 'Med', mechanism: '정전·통신두절·대피 지연 대비 비상설비 강화', evidence: '비상인터폰을 1개소에서 2개소로 증설 ... 정전시를 대비하여 비상용 객실 안내명판을 불연성 축광식 또는 야광식으로 개선', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0288'};
MATCH (a:ResponseActor {name: '대구지하철공사'}), (b:ResponseAction {name: '전동차 내장재 교체 사업'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', timing: '2003-11-29~2005-06', detail: '(주)로템과 계약 체결(2003-11-29), 월배차량기지에서 시제차 해체 시작(2004-01-14)', evidence: '2003년 11월 29일 (주)로템과 계약을 체결하고 ... 2005년 6월말까지 34편성 204량에 교체작업을 완료할 예정이다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0289'};
MATCH (a:Event {name: '대구지하철 화재사고'}), (b:Damage {name: '대구 지하철 화재 부상 피해'}) MERGE (a)-[r:CAUSES]->(b) SET r += {directCause: '화재로 인한 사상', consequence: '다수 사상자 발생', evidence: '지하철 화재사고로 인한 부상자는 대구시내 경북대학교병원 등 12개 병원에 분산 입원하였으며', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0290'};
MATCH (a:ResponseAction {name: '지하철 화재사고 자원봉사활동'}), (b:Event {name: '대구지하철 화재사고'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {specialNote: '사고수습을 위한 대규모 자원봉사 동원', timing: '사고 후 70여일간', evidence: '지하철 화재사고 이후 70여일간에 걸친 자원봉사활동에 71개 봉사단체 26,509명과 개인봉사자 546명이 헌신적으로 참여하여', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0291'};
MATCH (a:ResponseActor {name: '대구광역시'}), (b:ResponseAction {name: '지하철 화재사고 자원봉사활동'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', role: '자원봉사 총괄지원·체계화', evidence: '전국 지방자치단체 중에서 처음으로 자원봉사과를 신설하여 자원봉사 업무를 체계적으로 관리·지원', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0292'};
MATCH (a:ResponseActor {name: '대구시 사고대책본부'}), (b:ResponseAction {name: '실종자 유가족 숙식·급식 지원'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', actionType: '희생자 가족지원', evidence: '70여일간에 급식 연인원 204천명에게 식사를 제공하였으며, 소요경비만 해도 940여백만원에 달하였다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0293'};
MATCH (a:ResponseActor {name: '대구광역시의사회'}), (b:ResponseAction {name: '임시진료소 무료진료'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', actionType: '의료지원', timing: '2003-02-19~', evidence: '임시진료소 2개소를 설치하고 연인원 359명의 의료진이 ... 2,404명에게 무료 진료를 실시', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0294'};
MATCH (a:ResponseActor {name: '통신사 봉사단(SK텔레콤·KTF·LG텔레콤)'}), (b:ResponseAction {name: '실종자 휴대전화 발신지 추적·무료전화 설치'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', actionType: '통신서비스 봉사', evidence: 'SK텔레콤, KTF, LG텔레콤 등에서 실종자의 휴대전화 발신지 추적 확인작업과 무료이용 전화기를 설치하여', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0295'};
MATCH (a:ResponseActor {name: '지하철공사 직원·소방관 등 의인'}), (b:ResponseAction {name: '사고 직후 승객 대피·구조 활동'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', timing: '사고 직후', specialNote: '구조활동 중 다수 순직', evidence: '사고당시 중앙로역에 ... 구조활동 도중 순직 ... 사고 전동차(1080호)에 타고 있던 중 수동으로 출입문 개방후 승객대피', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0296'};
MATCH (a:Context {name: '재난·재해 법적 구분 체계'}), (b:Event {name: '대구 지하철 중앙로역 화재(2003)'}) MERGE (a)-[r:UNDER_CONDITION]->(b) SET r += {reason: '대구 화재는 인위적 사고이나 전국재해구호협회가 성금 모금한 최초 사례', specialNote: '특별재난사고 선례', evidence: '사고 당시의 관련법에 의하면, 태풍, 호우 등의 자연현상에 의한 피해는 재해로, 인위적인 사고에 의한 피해는 재난으로 구분 / 인위적인 사고이나 전국재해구호협회에서 성금을 모금한 최초의 사례', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0297'};
MATCH (a:ResponseActor {name: '보건복지부'}), (b:ResponseAction {name: '대구 지하철 화재 국민성금 모금'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', role: '주관', timing: '2003-02-20 모금 개시', specialNote: '전국재해구호협회와 공동 주관', evidence: '국민성금 모금 주무부서인 보건복지부와 전국재해구호협회가 주관하여 대구지하철 화재사고 희생자 유가족 및 부상자 구호를 위한 국민성금을 모금', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0298'};
MATCH (a:ResponseActor {name: '전국재해구호협회'}), (b:ResponseAction {name: '대구 지하철 화재 국민성금 모금'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', role: '모금주체', legalBasis: '기부금품모집규제법 제4조', evidence: '성금모금의 주체는 전국재해구호협회가 되어 기부금품모집규제법 제4조에 의거 행정자치부의 허가를 받아 2월 20일부터 모금활동에 들어갔다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0299'};
MATCH (a:ResponseAction {name: '대구 지하철 화재 국민성금 모금'}), (b:Damage {name: '대구 지하철 화재 인명피해'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {phase: 'recovery', effectiveness: 'High', detail: '목표액 200억→500억(2.28 1차)→700억(3.12 2차) 상향, 기간 20→40일 연장', consequence: '최종 672억원 모금', evidence: '당초 모금액은 200억원을 목표로 시작 / 1차(2.28)로 200억→500억 / 2차(3.12)로 기간 연장(20일->40일)하고 500억→700억으로 상향 조정', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0300'};
MATCH (a:ResponseAction {name: '대구 지하철 화재 국민성금 모금'}), (b:Damage {name: '대구 지하철 화재 국민성금 모금결과'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {phase: 'recovery', consequence: '사상 최대 국민성금', evidence: '3월 31일 모금 마감결과 4,000여개의 기업과 단체, 450만명의 국민이 참가 / 총 672억원이라는 사상 최대의 국민성금을 모금', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0301'};
MATCH (a:ResponseActor {name: '삼성그룹'}), (b:ResponseAction {name: '대구 지하철 화재 국민성금 모금'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', amount: '5000', unit: '백만원', role: '최고액 기탁(50억원)', evidence: '고액기탁자 현황(1억원 이상) ... 삼성그룹 5,000 / 적게는 500원부터 많게는 50억원에 이르는 성금이 답지', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0302'};
MATCH (a:ResponseActor {name: '대구시 사고대책본부'}), (b:ResponseAction {name: '국민성금 특별위로금 배분'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', role: '배분주체', detail: '정부 배분계획·권고안 기준 유가족·부상자 단체와 수차례 협의', evidence: '성금 배분주체는 대구지하철참사수습대책본부에서 ... 배분 / 총모금액 657억원중 모집비용 152백만원을 제외한 약 655억원을 대구시 사고대책본부로 조기에 이관', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0303'};
MATCH (a:ResponseAction {name: '국민성금 특별위로금 배분'}), (b:Damage {name: '대구 지하철 화재 인명피해'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {phase: 'recovery', effectiveness: 'Med', detail: '사망자 1인당 221백만원 확정(과거 상인동·삼풍 170백만원+물가상승률), 부상자는 노동능력상실률 차등', specialNote: '정부 권고안 사망자 1인당 2억원 제시, 희생자대책위는 250백만원 요구', evidence: '사망자 1인당 221백만원을 지급하며, 부상자 특별위로금의 경우 사망자 특별위로금을 기준으로 국가배상법에 의한 노동능력 상실률에 따라 차등 지급', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0304'};
MATCH (a:Context {name: '1인당 특별위로금 지급 사례'}), (b:ResponseAction {name: '국민성금 특별위로금 배분'}) MERGE (a)-[r:QUANTIFIED_BY]->(b) SET r += {reason: '대형사고 사례 비교로 대구 화재 위로금 기준 산정', evidence: '1인당 특별위로금 지급 사례 ... 삼풍백화점 170, 상인동 도시가스폭발 170, 화성씨랜드 123, 인천호프집 80, 아현동 80', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0305'};
MATCH (a:ResponseActor {name: '부상자가족대책위원회'}), (b:ResponseActor {name: '대구시 사고대책본부'}) MERGE (a)-[r:COORDINATES_WITH]->(b) SET r += {role: '협의 당사자', reason: '특별위로금 지급기준 이견', consequence: '부상자 위로금 지급 상당기간 지체, 직접지원경비 약 7개월 중단', evidence: '부상자가족대책위원회는 여전히 대구시의 특별위로금 지급기준을 거부하고 계속 협의를 요구 / 단체 내부에서 분쟁이 일어남으로써 부상자에 대한 특별위로금의 지급이 상당기간 지체', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0306'};
MATCH (a:ResponseAction {name: '법적보상 비대상 부상자 특별위로금 지급'}), (b:Damage {name: '대구 지하철 화재 대응인력 부상'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {phase: 'recovery', reason: '화재진화·인명구조 중 부상', effectiveness: 'Med', evidence: '사고현장에서 화재진화와 인명구조 과정에서 본연의 임무를 수행하다 부상을 당한 소방공무원과 전투경찰 등 법적보상 비대상자(15명)와 ... 16명', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0307'};
MATCH (a:ResponseActor {name: '대구광역시'}), (b:ResponseAction {name: '자원봉사자 격려·표창'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', detail: '46개 봉사단체 감사패, 개인봉사자 5명 표창, 감사서신 발송', evidence: '삼성사회봉사단 등 46개 봉사단체에 대하여는 감사패를 전달하고 개인봉사자 5명에 대해 표창 / 자원봉사단체 및 개인봉사자를 초청하여 간담회를 개최하고 그 간의 노고를 위로 격려', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0308'};
MATCH (a:ResponseActor {name: '자원봉사단체·개인봉사자'}), (b:ResponseAction {name: '지하철 화재사고 자원봉사활동'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', role: '구호·급식·의료·심리상담 등 노력봉사', evidence: '헌신적으로 봉사활동에 참여하여 사고수습에 크게 기여한 자원봉사단체 및 개인봉사자 / 대구시의사회 임시진료소 설치 ... 희생자가족 1,200여명 치료', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0309'};
MATCH (a:ManmadeHazard {name: '대구 지하철 중앙로역 화재사고(2003)'}), (b:Damage {name: '대구지하철 화재 인적·물적 피해'}) MERGE (a)-[r:CAUSES]->(b) SET r += {directCause: '방화로 시작된 사건이나 지하철공사 직원의 주의의무 해태 및 시설물 관리상의 하자 등이 결합', mechanism: '방화→화재→인적·물적 피해', reason: '지하철공사 직원 주의의무 해태 + 시설물 관리상 하자 결합', evidence: '이번 사고는 개인의 방화로 시작된 사건이나 지하철공사 직원의 주의의무 해태 및 시설물 관리상의 하자 등이 결합하여 손해를 발생하게 하였다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0310'};
MATCH (a:Damage {name: '대구 지하철 화재 사망 피해'}), (b:Context {name: '대구 지하철 화재 보상금 집행 실적'}) MERGE (a)-[r:QUANTIFIED_BY]->(b) SET r += {detail: '사망자 보상지급 46,475백만원(186명)', evidence: '사상자 및 물적피해에 대한 법적보상 대상은 총 492명이며, 이들 가운데 481명과 보상에 합의하여 지급된 보상금 총액은 64,079백만원... 사망자의 경우 보상대상 192명 중 신원 미확인자 6명을 제외하고 186명에 대하여 46,475백만원이 지급', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0311'};
MATCH (a:Damage {name: '대구 지하철 화재 부상 피해'}), (b:Context {name: '대구 지하철 화재 보상금 집행 실적'}) MERGE (a)-[r:QUANTIFIED_BY]->(b) SET r += {detail: '부상자 보상지급 13,215백만원(132명), 최고 341백만원 최저 6백만원', evidence: '부상자의 경우 151명 중에서 소방공무원(12명), 기자(2명), 전경(1명), 기소자(방화범 1명, 공사직원 2명) 등 18명을 제외한 법적보상 대상 133명 중 소송계류 중인 1명을 제외한 132명에 대하여 13,215백만원이 지급', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0312'};
MATCH (a:Population {name: '법적보상 비대상 부상 소방공무원·전투경찰'}), (b:Damage {name: '대구 지하철 화재 부상 피해'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {reason: '임무수행 중 부상하였으나 법적보상 비대상 → 별도 특별위로금 지급 필요', role: '보상 사각지대', evidence: '사고현장에서 화재진화와 인명구조 과정에서 본연의 임무를 수행하다 부상을 당한 소방공무원과 전투경찰 등 법적보상 비대상자(15명)와... 0%로 특별위로금을 지급받을 수 없는 부상자(1명) 등 16명이 있었다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0313'};
MATCH (a:ResponseActor {name: '대구광역시'}), (b:ResponseAction {name: '지하철 화재사고 피해보상 업무'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', role: '보상업무 추진 주체', detail: '지하철공사로부터 보상권한 일체를 위임받아 보상업무 추진', evidence: '대구시는 지하철공사로부터 지하철 화재사고의 피해에 대한 보상과 관련하여 보상액의 산정, 피해자와의 협의 및 합의 등 보상과 관련한 일체의 권한을 위임받아 보상업무를 추진하게 되었다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0314'};
MATCH (a:ResponseActor {name: '대구광역시지하철공사'}), (b:ResponseActor {name: '대구광역시'}) MERGE (a)-[r:COORDINATES_WITH]->(b) SET r += {role: '보상권한 위임자, 부진정 연대채무 관계', detail: '대구시에 보상권한 위임, 추후 손해분담비율에 따라 구상 가능', evidence: '지하철공사의 책임과 대구시의 책임은 부진정 연대채무의 관계라는 것이 고문변호사들의 판단... 대구시는 지하철공사로부터... 일체의 권한을 위임받아', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0315'};
MATCH (a:ResponseActor {name: '대구광역시'}), (b:Other {name: '대구광역시지하철화재사고피해보상에관한조례'}) MERGE (a)-[r:GUIDED_BY]->(b) SET r += {reference: '대구 상인동 도시가스 폭발사고(1995.4.28), 화성 씨랜드 화재사고(2001) 보상조례 선례', detail: '우리나라 세 번째 제정 보상조례', evidence: '「대구광역시지하철화재사고피해보상에관한조례』를 제정... 1995년... 2001년... 에 이어 세 번째로 제정된 조례로서... 5월 30일 동 조례를 공포', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0316'};
MATCH (a:Population {name: '실종자유가족대책위원회·실종자 가족'}), (b:ResponseAction {name: '지하철 화재사고 피해보상 업무'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {phase: 'recovery', reason: '피해보상 조례안 일방적 통과에 항의', consequence: '5시간 농성, 의원 11명 억류, 집기 파손, 23:25 일단락', timing: '2003-03-14', evidence: '실종자유가족대책위원회 위원 및 실종자 가족 100여명은 3월 14일... 일방적으로 통과시킨데 대하여 격렬하게 항의하며 5시간여 동안 농성... 의장 등 의원 11명을 억류한 채 사무실 집기를 부수는', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0317'};
MATCH (a:ResponseActor {name: '대구광역시지하철참사보상심의위원회'}), (b:ResponseAction {name: '보상금 심의·의결'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', detail: '6월26일 1차~2004년5월4일 12차, 총 12차례 개최, 법적보상금·특별위로금 심의·의결', evidence: '6월 26일 부상자 법적보상금 지급안 심의 의결을 시작으로 총 12차례에 걸쳐 보상심의위원회를 개최하였다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0318'};
MATCH (a:ResponseAction {name: '보상금 심의·의결'}), (b:Other {name: '법적보상금 산정기준'}) MERGE (a)-[r:GUIDED_BY]->(b) SET r += {reference: '민법, 국가배상법, 재난관리법, 법원 판례, 맥브라이드식 노동능력상실률, 호프만식 중간이자 공제', detail: '사망자 위자료 20세미만·60세이상 6,500만원, 20~60세 7,500만원; 생활비공제 33.33%', evidence: '사망자에 대한 법적보상금 산정의 기본원칙은 국가배상법과 법원의 판례를 참작... 위자료는... 20세미만과 60세이상은 6,500만원, 20세이상 60세미만은 7,500만원... 생활비 공제율은... 33.33%를 적용', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0319'};
MATCH (a:ResponseActor {name: '전국재해구호협회'}), (b:ResponseAction {name: '국민성금 모금·이관'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', detail: '5차에 걸쳐 대구시에 국민성금 67,017백만원 이관', evidence: '전국재해구호협회로부터 5차에 걸쳐 대구시(세입세출외 현금)에 이관된 국민성금 총액은 67,017백만원이다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0320'};
MATCH (a:ResponseAction {name: '국민성금 특별위로금 배분'}), (b:ManmadeHazard {name: '대구 지하철 중앙로역 화재사고(2003)'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {phase: 'recovery', detail: '사망자 1인당 특별위로금 221백만원(186명에 41,106백만원), 부상자 129명에 7,558백만원', timing: '2004-12-31 기준', evidence: '이관된 국민성금 67,017백만원은... 특별위로금으로 50,192백만원, ...직접 지원경비로 2,823백만원, 추모사업비로 14,002백만원이 배분... 사망자 1인당 221백만원씩 균등하게 지급', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0321'};
MATCH (a:Context {name: '사망자 특별위로금 221백만원'}), (b:Context {name: '대형사고 보상 선례(상인동·삼풍)'}) MERGE (a)-[r:QUANTIFIED_BY]->(b) SET r += {detail: '선례 대비 상향, 최고금액 기록', evidence: '사망자 특별위로금 221백만원은 대구 상인동 도시가스 폭발사고 및 서울 삼풍백화점 붕괴사고 당시의 170백만원보다 51백만원이 상향된 금액으로서 대형사고 사망자에게 지급된 특별위로금 중 최고금액이다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0322'};
MATCH (a:ResponseActor {name: '대구광역시 대외협력반'}), (b:ResponseAction {name: '구호물품·위문품 접수·배분'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', detail: '사고 직후~4월말 집중 접수, 총 259여종 108,330여점 접수·배분', evidence: '「대외협력반』을 두어 구호물품 및 위문품을 접수하도록 창구를 일원화하고... 총 259여종, 108,330여점의 물품이 접수되었다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0323'};
MATCH (a:Event {name: '신원확인·시신인도 지연'}), (b:Damage {name: '유가족 장기대기 생필품 소요'}) MERGE (a)-[r:CAUSES]->(b) SET r += {mechanism: '장기 대기에 따른 생필품 대량 소요', reason: '실종자 가족 장기 숙식 대기', evidence: '신원확인 이후에도 추모묘역 조성문제로 시신인도 및 장례절차가 지연되면서 실종자 가족 등 유가족들이 중앙로역 및 시민회관에서 숙식하면서 장기간 대기함에 따라 생수, 빵, 라면... 등이 많이 소요', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0324'};
MATCH (a:ResponseAction {name: '직접지원경비 배분·집행'}), (b:ManmadeHazard {name: '대구 지하철 중앙로역 화재사고(2003)'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {phase: 'recovery', detail: '사고대책본부-3개 단체(희생자대책위·2.18유족회·부상자가족대책위) 7차례 협의로 확정', timing: '2004-02-04 확정 통보', evidence: '직접 지원경비의 경우 총 소요액 2,823백만원 중... 2,521백만원이 집행... 실종자 확인 실비보상(137명)으로 840백만원, 유가족과 부상자의 급식 및 생필품 지원에 523백만원', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0325'};
MATCH (a:ResponseAction {name: '추모사업 추진'}), (b:Resilience {name: '안전교육관·위령탑 등 추모·안전 인프라'}) MERGE (a)-[r:BUILDS]->(b) SET r += {phase: 'recovery', detail: '재발방지·추모 역량 구축', evidence: '잔여성금 14,099백만원 정도는 추모사업 재원으로 배분... 추모묘역 조성 및 위령탑 건립, 추모벽 설치, 안전교육관 건립 등에 사용할 예정', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0326'};
MATCH (a:ManmadeHazard {name: '대구 지하철 중앙로역 방화'}), (b:Event {name: '대구 지하철 중앙로역 화재(2003)'}) MERGE (a)-[r:TRIGGERS]->(b) SET r += {probability: 'High', directCause: '방화', mechanism: '지하철 객차 방화로 화재 발생', scale: '대형', evidence: '한 사람의 어이없는 방화가 불러온 대구지하철 화재사고는 ... 총 192명이 희생된 유례없는 대형사고', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0327'};
MATCH (a:Event {name: '대구 지하철 중앙로역 화재(2003)'}), (b:Damage {name: '대구 지하철 화재 사망 피해'}) MERGE (a)-[r:CAUSES]->(b) SET r += {scale: '대형', mechanism: '화재로 인한 밀폐공간 열·연기', specialNote: '유례없는 대형사고', evidence: '총 192명이 희생된 유례없는 대형사고 ... 신원확인 사망자가 185명 ... 신원미확인 사망자 6명', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0328'};
MATCH (a:Event {name: '대구 지하철 중앙로역 화재(2003)'}), (b:Damage {name: '대구 지하철 화재 부상 피해'}) MERGE (a)-[r:CAUSES]->(b) SET r += {mechanism: '화재로 인한 인명 부상', evidence: '부상자의 경우 151명 중에서 소방공무원(12명), 기자(2명), 전경(1명), 기소자(방화범 1명, 공사직원 2명) 등 18명을 제외한 법적보상 대상 133명', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0329'};
MATCH (a:Event {name: '대구 지하철 중앙로역 화재(2003)'}), (b:Damage {name: '시신 소훼로 인한 신원확인 곤란'}) MERGE (a)-[r:CAUSES]->(b) SET r += {mechanism: '화재로 인한 시신 소훼', timing: '사고 직후', evidence: '화재로 인한 밀폐된 공간의 높은 열과 연기 등으로 대부분의 시신이 심각하게 소훼되어 신원확인이 어려운 시신들이 다수 발견', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0330'};
MATCH (a:Damage {name: '대구 지하철 화재 사망 피해'}), (b:Context {name: '대구 지하철 화재 보상금 총액'}) MERGE (a)-[r:QUANTIFIED_BY]->(b) SET r += {category: '보상금', evidence: '법적보상 대상은 총 492명이며, 이들 가운데 481명과 보상에 합의하여 지급된 보상금 총액은 64,079백만원', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0331'};
MATCH (a:Damage {name: '대구 지하철 화재 사망 피해'}), (b:Context {name: '사망자 법적보상금 지급내역'}) MERGE (a)-[r:QUANTIFIED_BY]->(b) SET r += {category: '보상금-사망자', evidence: '사망자의 경우 보상대상 192명 중 신원 미확인자 6명을 제외하고 186명에 대하여 46,475백만원이 지급 ... 1인당 평균지급액은 250백만원', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0332'};
MATCH (a:Damage {name: '대구 지하철 화재 부상 피해'}), (b:Context {name: '부상자 법적보상금 지급내역'}) MERGE (a)-[r:QUANTIFIED_BY]->(b) SET r += {category: '보상금-부상자', evidence: '132명에 대하여 13,215백만원이 지급 ... 부상자 1인당 평균지급액은 100백만원', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0333'};
MATCH (a:Event {name: '대구 지하철 중앙로역 화재(2003)'}), (b:Damage {name: '대구 지하철 화재 물적피해'}) MERGE (a)-[r:CAUSES]->(b) SET r += {mechanism: '화재로 인한 물적피해', evidence: '물적피해자의 경우 보상대상 167명 중 ... 163명에 대해 4,389백만원이 지급 ... 1인당 평균지급액은 27백만원', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0334'};
MATCH (a:ResponseActor {name: '대구광역시'}), (b:ResponseAction {name: '피해자 보상금 지급'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', role: '보상 주체', objective: '사상자·물적피해 보상', evidence: '합의된 보상금은 「대구지하철화재사고피해보상에관한조례」에 의한 보상심의위원회의 의결을 거친 후 ... 지급키로 결정', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0335'};
MATCH (a:ResponseActor {name: '성금배분위원회'}), (b:ResponseAction {name: '국민성금 특별위로금 배분'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', timing: '2004-08-08', evidence: '국민성금에서 지급되는 특별위로금 지급대상은 ... 총 340명으로서 이 중 330명에 대해 48,701백만원이 지급 ... 사망자 1인당 지급액은 221백만원', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0336'};
MATCH (a:ResponseActor {name: '대구광역시'}), (b:ResponseAction {name: '배상책임보험금 구상권 행사'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', role: '구상권 행사 주체', objective: '배상책임보험금 회수', evidence: '지방자치단체 배상책임보험금(보상한도액 10억원)에 대해 구상권을 행사하기로 하고 ... 배상책임보험금 10억원이 대구시 계좌로 입금', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0337'};
MATCH (a:ResponseActor {name: '대구광역시'}), (b:ResponseAction {name: '방화범 재산 구상권 행사'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', objective: '방화범 재산 구상', evidence: '지하철공사에 배당된 방화범의 가압류재산(부동산 및 자동차) 경매 배당금 총 60,207천원을 구상금으로 청구', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0338'};
MATCH (a:ResponseActor {name: '근로복지공단 대구지역본부'}), (b:ResponseAction {name: '지하철공사 직원 산재보상'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', actionType: '산재보상', evidence: '근로복지공단 대구지역본부에서는 사망자 4명에 대한 산업재해보상보험 급여신청을 받아 ... 산재보험급여 지급을 결정', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0339'};
MATCH (a:RiskFactor {name: '유가족대표단 분열 및 보상협상 견해차이'}), (b:Event {name: '보상협상 지연'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {mechanism: '신원확인 지연·추모사업 갈등·산정방식 대립으로 협상 장기화', reason: '양측 견해차이', evidence: '보상금 산정방식 등에 대한 양측의 견해차이로 5월 16일 1차 보상협상이 있기까지 3개월 이상이 소요되어 ... 불만과 조기보상을 요구하는 항의 등이 잇따랐다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0340'};
MATCH (a:ResponseActor {name: '대구광역시'}), (b:ResponseAction {name: '부상자 손해사정(평가·검증)'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', objective: '보상금 산정 객관성·합리성 확보', evidence: '유가족측 평가사정은 ... 184명으로 총 금액은 54,490백만원으로 사정 ... 검증사정에서는 8,441백만원이 감액된 46,049백만원으로 최종 결정', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0341'};
MATCH (a:RiskFactor {name: '추모공원 묘역부지 갈등'}), (b:Event {name: '보상협상 지연'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {mechanism: '묘역조성 반대 주민집회·유가족 항의방문', reason: '유가족측-지역주민 의견대립', evidence: '묘역조성 예정지를 둘러싼 유가족측과 지역주민들의 의견대립으로 협상이 진전을 보지 못하고 ... 보상협의가 지연되는 결과를 초래', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0342'};
MATCH (a:ResponseActor {name: '대구광역시'}), (b:ResponseActor {name: '유가족대표단(희생자대책위·유족연합회)'}) MERGE (a)-[r:COORDINATES_WITH]->(b) SET r += {role: '보상협상', count: '총 9차례(유족연합회 2회·희생자대책위 7회)', evidence: '5월 16일 유족연합회를 시작으로 ... 유족연합회와 2차례, 희생자대책위와 7차례 등 총 9차례의 보상협상을 실시', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0343'};
MATCH (a:Event {name: '대구 지하철 중앙로역 화재(2003)'}), (b:Event {name: '유독·유해가스 발생 및 확산'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {probability: 'High', mechanism: '전동차 내부 화학물질 연소로 유독·유해가스 발생', directCause: '화학물질 연소', evidence: '전동차 내부의 화학물질 연소에 따른 유해·유독가스와 고온에 부상자들이 노출', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0344'};
MATCH (a:Event {name: '유독·유해가스 발생 및 확산'}), (b:Damage {name: '부상자 후유증(호흡기·뇌·성대 질환)'}) MERGE (a)-[r:CAUSES]->(b) SET r += {mechanism: '유독가스 흡입', consequence: '호흡기질환·뇌손상·만성인후두염·성대장애', evidence: '유독가스 흡입으로 인한 호흡기 질환, 뇌 손상, 만성인후두염, 성대장애 등 질병경과', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0345'};
MATCH (a:Event {name: '대구 지하철 중앙로역 화재(2003)'}), (b:Damage {name: '중앙로역 인근 상가 물적·영업 피해'}) MERGE (a)-[r:CAUSES]->(b) SET r += {role: '물적·영업 피해', specialNote: '구역별 피해신고 168건', evidence: '구역별 보상대상 ... 168건', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0346'};
MATCH (a:ResponseActor {name: '대구시 보상심의위원회(사망자)'}), (b:ResponseAction {name: '사망자 보상금 결정(보상심의위원회)'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', timing: '2003-08-01~2003-12-10', count: '9회', evidence: '보상심의위원회를 8월 1일부터 12월 10일까지 9차례 개최하였으며 ... 총 192명에 대한 법적 손해배상금과 특별위로금이 결정되었다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0347'};
MATCH (a:ResponseAction {name: '사망자 보상금 결정(보상심의위원회)'}), (b:Damage {name: '대구 지하철 화재 사망 피해'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {phase: 'recovery', specialNote: '사망 피해 보상', evidence: '총 192명에 대한 법적 손해배상금과 특별위로금이 결정되었다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0348'};
MATCH (a:ResponseAction {name: '사망자 보상금 결정(보상심의위원회)'}), (b:Damage {name: '대구 지하철 화재 사망 피해'}) MERGE (a)-[r:MITIGATES]->(b) SET r += {phase: 'recovery', amount: 90277, unit: '백만원', breakdown: '법적손해배상금 47,845 + 특별위로금 42,432', evidence: '법적손해배상금 47845백만원과 ... 특별위로금 42,432백만원 등 총 90,277백만원으로 결정', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0349'};
MATCH (a:Context {name: '사망자 1인당 평균 보상액'}), (b:Damage {name: '대구 지하철 화재 사망 피해'}) MERGE (a)-[r:QUANTIFIED_BY]->(b) SET r += {detail: '사망자 192명 1인당 평균 보상액', evidence: '사망자 192명의 1인당 평균 보상액은 ... 470,194천원이며, 최고보상액은 ... 883,096천원 ... 최저보상액은 ... 321,279천원', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0350'};
MATCH (a:ResponseActor {name: '대구광역시'}), (b:ResponseAction {name: '신원확인 사망자 장례비 지급'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', timing: '2003-02-25~2003-06-28', amount: 1302, unit: '백만원', evidence: '1인당 7백만원씩 186명 전원에게 1,302백만원의 장례비를 지급', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0351'};
MATCH (a:ResponseActor {name: '대구시 부상자 보상심의위원회'}), (b:ResponseAction {name: '부상자 손해보상금 결정·지급'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', timing: '2003-06-26부터', count: '6회', evidence: '최종 손해보상금은 13,276,547,540원으로 확정 ... 평균 99,987,530원 ... 6차례의 보상심의위원회가 개최', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0352'};
MATCH (a:ResponseAction {name: '부상자 손해보상금 결정·지급'}), (b:Damage {name: '대구 지하철 화재 부상 피해'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {phase: 'recovery', specialNote: '손해보상 대상 133명', evidence: '손해보상 대상자 133명의 노동능력 상실률 ... 최종 손해보상금은 13,276,547,540원', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0353'};
MATCH (a:ResponseAction {name: '부상자 손해사정(평가·검증)'}), (b:Damage {name: '대구 지하철 화재 부상 피해'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {phase: 'recovery', specialNote: '손해보상 대상 133명 노동능력 상실률 산정', evidence: '4월 1일부터 본격적으로 부상자 개인별 손해보상을 위한 평가 및 검증작업이 착수 ... 맥브라이드식 신체장해율 산정 ... 호프만 방식에 의한 중간이자 공제', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0354'};
MATCH (a:ResponseAction {name: '부상자측 모의 화재실험 및 평생진료증 요구'}), (b:Damage {name: '부상자 후유증(호흡기·뇌·성대 질환)'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {phase: 'recovery', reason: '유독가스 장기 후유증 우려', effectiveness: 'Low', specialNote: '현 학문·기술로 해결 불가한 부분 포함, 합의 곤란', evidence: '모의 화재실험을 실시하고 ... 성분을 분석하는 실험을 즉각 실시할 것과 ... 평생진료증 발급을 요구', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0355'};
MATCH (a:ResponseAction {name: '만성후유증 연구용역'}), (b:Damage {name: '부상자 후유증(호흡기·뇌·성대 질환)'}) MERGE (a)-[r:MITIGATES]->(b) SET r += {phase: 'recovery', specialNote: '장기 후유증 대책', evidence: '3월 17일 대구시의 전문가 회의와 4월 15일 보건복지부의 전문가 회의를 통하여 대책이 마련 ... 만성후유증 관리기금을 설치할 수 있는 예산도 확보', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0356'};
MATCH (a:ResponseAction {name: '물적피해 보상범위 결정'}), (b:Damage {name: '중앙로역 인근 상가 물적·영업 피해'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {phase: 'recovery', specialNote: '간접피해 보상 불인정으로 민원 발생', evidence: '이용객 감소로 인한 간접피해에 대한 보상은 ... 인정하지 않기로 하였다 ... 직접적인 피해와 ... 휴업기간의 휴업손해만 보상', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0357'};
MATCH (a:ResponseActor {name: '중앙사고수습대책본부장(건설교통부장관)'}), (b:ResponseAction {name: '물적피해 보상범위 결정'}) MERGE (a)-[r:GUIDED_BY]->(b) SET r += {reference: '재난관리법 제52조 및 시행령 제49조, 회시 도철91140-256(2003-07-28)', detail: '교통통제 인한 피해보상은 재난관리법 보상과 무관', evidence: '건설교통부장관으로부터 ... 중앙로역 인근 교통통제로 인한 피해보상은 재난관리법에 의한 보상과는 관련이 없는 것으로 사료된다는 회시', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0358'};
MATCH (a:ResponseAction {name: '물적피해 손해사정·재사정·검증평가'}), (b:Damage {name: '중앙로역 인근 상가 물적·영업 피해'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {phase: 'recovery', specialNote: '이의신청 136건(5,969,880천원)', evidence: '피해신고가 접수된 174건에 대하여 손해사정평가 ... 이의 신청건수가 136건 ... 7월 9일 ... 검증사정인으로 선정하여 ... 검증사정을 실시', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0359'};
MATCH (a:Damage {name: '중앙로역 인근 상가 물적·영업 피해'}), (b:Context {name: '물적피해 재사정 결과(200건/4,482,401천원)'}) MERGE (a)-[r:QUANTIFIED_BY]->(b) SET r += {detail: '이의신청 재사정 결과 금액', evidence: '이의 신청에 대한 재사정 결과 ... 계 4,482,401 ... 직접손해 3,463,350 ... 휴업손해 1,019,051', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0360'};
MATCH (a:Damage {name: '대구 지하철 화재 물적피해'}), (b:Context {name: '물적피해 보상 검증평가 기준(2003)'}) MERGE (a)-[r:QUANTIFIED_BY]->(b) SET r += {detail: '보상대상자 167명, 합의 163명, 보상금 포기 1명, 보험 기수령 2명, 합의거부 1명', evidence: '물적피해 신고자중 보상기준에 의한 보상대상자 167명과의 합의서 작성 ... 보상대상 167명 가운데 163명과 합의서를 작성', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0361'};
MATCH (a:ResponseActor {name: '대구광역시'}), (b:ResponseAction {name: '물적피해 보상금 지급(2003)'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', actionType: '물적피해 보상금 지급', legalBasis: '대구광역시지하철화재사고피해보상에관한조례 제4조', evidence: '163건 4,389,431천원에 대하여 지급을 완료하였다 ... 대구광역시지하철화재사고피해보상에관한조례 제4조의 규정에 의하여', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0362'};
MATCH (a:ResponseActor {name: '대구광역시'}), (b:ResponseAction {name: '대구시민회관 합동분향소 설치(2003)'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', actionType: '합동분향소 설치·운영', evidence: '2월 19일 대구시민회관 소강당 2층에 합동분향소를 설치하고 ... 분향소를 방문한 참배객은 86,486명', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0363'};
MATCH (a:ResponseAction {name: '대구지하철참사 1주기 추모식(2004)'}), (b:Damage {name: '중앙로역 화재 인명피해'}) MERGE (a)-[r:QUANTIFIED_BY]->(b) SET r += {detail: '사고 사망 희생자 수', evidence: '192명의 희생자 위패를 안치하고 ... 사고당시 희생된 192명', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0364'};
MATCH (a:Damage {name: '중앙로역 화재 인명피해'}), (b:Damage {name: '사고 후 지병 사망(2주기 추가 위패)'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {timing: '사고 후', mechanism: '화재 부상자의 지병 악화로 추가 사망', reason: '후유증', evidence: '사고당시 희생된 192명과 사고후 지병으로 사망한 2명을 포함한 194명의 위패를 안치', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0365'};
MATCH (a:ResponseActor {name: '대구광역시'}), (b:ResponseAction {name: '전동차 안전개선과제(불연재 교체)'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'prevention', actionType: '전동차 내장재 불연재 교체 등 안전개선', objective: '재발 방지', evidence: '2007년까지 총 660억원을 투입하여 전동차 내장재를 불연재로 교체하는 등 75개 안전개선과제를 연차적으로 ... 추진', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0366'};
MATCH (a:RiskFactor {name: '전동차 내장재(가연성 합성수지)'}), (b:Event {name: '대구 지하철 중앙로역 화재(2003)'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {reason: '가연성 내장재가 화재 확산·유독가스 피해를 증폭', probability: 'High', evidence: '전동차 내장재를 불연재로 교체하는 등 ... 모든 전동차에 불연성 내장재를 갖추어', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0367'};
MATCH (a:ResponseActor {name: '대구지하철참사 희생자대책위원회'}), (b:ResponseAction {name: '수창공원 추모공원 조성 요구(2003)'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', actionType: '추모공원 조성 요구', timing: '2003-03-20 국무총리 면담, 2003-03-26 국무총리실 민원', evidence: '희생자대책위원회에서는 3월 20일 국무총리 면담시 추모공원 조성을 요구 ... 합동묘역(납골당 조성), 위령탑, 안전교육 위주의 추모기념관 건립', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0368'};
MATCH (a:RiskFactor {name: '수창공원 묘지공원 설치 법적 제약'}), (b:Event {name: '추모공원 부지 선정 난항'}) MERGE (a)-[r:PRECONDITIONS]->(b) SET r += {reason: '관련법령 개정 없이는 묘지공원·공설묘지 설치 불가능', mechanism: '거리제한(도로·철도·하천 300m, 인가밀집·학교 500m) 및 자연녹지 요건 미충족', evidence: '수창공원은 도심에 위치한 중심상업지역으로 관련법령 개정없이 묘지공원 설치가 불가능하며 ... 공설묘지 설치가 불가능한 것으로 판단', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0369'};
MATCH (a:ResponseAction {name: '추모묘역 조성(수성구 삼덕동)'}), (b:Event {name: '추모묘역 조성 반대 집단민원'}) MERGE (a)-[r:CAUSES]->(b) SET r += {mechanism: '도심 묘역 조성에 따른 영업손실·주거환경 훼손 우려로 주민 집단 반발', scale: '대규모', evidence: '추모묘역 조성반대 민간추진위원회 장영관 외 13,217명의 진정서가 접수되는 등 인근지역 주민들과 갈등이 증폭 ... 수성구민 7,962명의 날인을 받은 진정서를 제출', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0370'};
MATCH (a:ResponseActor {name: '추모사업추진위원회'}), (b:ResponseAction {name: '추모묘역 조성(수성구 삼덕동)'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', actionType: '추모묘역 조성지 최종 선정', timing: '제5차 회의(2004-06-02) 표결', evidence: '제5후보지(수성구 삼덕동 산 118-1번지 일원)를 상정하여 ... 제5후보지가 추모묘역 후보지로 최종 선정', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0371'};
MATCH (a:ResponseAction {name: '추모사업 추진'}), (b:Resilience {name: '방재테마공원·추모전시관(안전교육관)'}) MERGE (a)-[r:BUILDS]->(b) SET r += {effectiveness: 'Med', reason: '사고 교훈을 후손에 전승하는 안전교육 기반 마련', evidence: '대구를 방재거점도시로 육성하기 위해 27만평의 화원유원지에 방재테마공원의 조성을 추진하면서 그 공원내에 1만여평 규모의 추모전시관을 건립', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0372'};
MATCH (a:Facility {name: '화재 전동차 잔재물(12량)'}), (b:Resilience {name: '방재테마공원·추모전시관(안전교육관)'}) MERGE (a)-[r:HAS_RESILIENCE]->(b) SET r += {role: '사고 교훈 전승 자료', reason: '안전교육·추모 자료로 활용', evidence: '화재전동차 전량(12량)은 안전교육관 건립계획이 확정될 때까지 보존하고', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0373'};
MATCH (a:RiskFactor {name: '전동차 불량 내장재(가연성 FRP)'}), (b:Event {name: '1079호 전동차 화재'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {mechanism: '불에 잘 타는 내장재로 화재 급속 확산 및 맹독성 유독가스 발생', effectiveness: 'High', reason: '난연재 미사용', evidence: '객차내부는 불에 타기 어려운 난연재가 아닌 불에 잘 타는 내장재로 제작되어... 미처 진화할 틈도 없이 객차내부로 빠르게 확산되어 모든 객차를 전소시킨 것으로 추정된다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0374'};
MATCH (a:Event {name: '1079호 전동차 화재'}), (b:Event {name: '중앙로역 일대 정전'}) MERGE (a)-[r:TRIGGERS_SECONDARY]->(b) SET r += {timing: '화재발생 4분 후', mechanism: '급전장애 지속으로 반월당~신천역 구간 전차선 전기공급 차단', directCause: '화재로 인한 급전장애', evidence: '1079호 전동차에 화재가 발생한 지 4분후에 반월당~ 신천역 구간의 전차선 전기공급이 차단되어', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0375'};
MATCH (a:Event {name: '중앙로역 일대 정전'}), (b:Event {name: '1080호 전동차 출발 불능·승객 고립'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {mechanism: '전동차 동력전원 단전으로 1080호가 출발 불가', directCause: '전기공급 차단', specialNote: '자동재급전 시스템 작동 상황을 종합사령실·기관사가 판단 못함', evidence: '중앙로역에 도착한 1080호 전동차는 승강장에 연기가 가득차 있어 바로 출발하려고 하였으나 전동차에 전기공급이 끊어져 출발하지 못하고', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0376'};
MATCH (a:Event {name: '1080호 전동차 출발 불능·승객 고립'}), (b:Event {name: '1080호 전동차 출발 불능·승객 고립'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {mechanism: '출발 불능·출발시도 반복으로 승객 대피 지연 및 차내 고립', directCause: '출발 불능 + 출입문 미개방', specialNote: '승객이 출입문을 열지 못해 갇힘', evidence: '승객들이 전동차의 출입문을 열지 못하여 갇혀 있는 사실을 현장지휘본부에 알려주지 않는 등', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0377'};
MATCH (a:Event {name: '방화셔터 작동'}), (b:Damage {name: '대구지하철 화재 인명피해'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {mechanism: '대피통로 차단으로 피해 확대(의혹 제기·검찰 수사)', spreadRisk: 'Med', specialNote: '불법구조물 의혹은 검찰 판단상 불법 아님', evidence: '화재발생 당시 중앙지하상가 보호를 위해 지하 1층까지 연기가 올라오기 전에 미리 방화셔터를 내려 대피통로를 차단함으로써 피해를 확대시켰다는 의혹이 제기됨', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0378'};
MATCH (a:RiskFactor {name: '송풍효과'}), (b:Event {name: '1079호 전동차 화재'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {mechanism: '화염 전파 및 확산 급속화로 대형사고 야기', effectiveness: 'High', probability: 'High', evidence: '1079호 전동차에 화재가 발생한 상황에서 진입해 온 1080호 전동차의 송풍효과에 의해 대형사고를 야기시킨 것으로 추정... 화재의 급속한 전파를 초래하였다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0379'};
MATCH (a:RiskFactor {name: '지하 폐쇄공간 구조'}), (b:Damage {name: '대구지하철 화재 인명피해'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {mechanism: '대피 곤란 및 소방활동 애로 가중, 외부 소화·구조 기대 불가', effectiveness: 'High', evidence: '지하공간은 창이 없는 폐쇄된 공간이기 때문에 산소공급의 불충분으로 불완전 연소... 정전시 주간에도 암흑상태가 되기 때문에 피난방향과 피난통로에 대한 시야를 확보할 수 없게 된다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0380'};
MATCH (a:ResponseActor {name: '1079호 전동차 기관사'}), (b:ResponseAction {name: '화재발생 초기 상황보고'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '운전사령에 화재발생 보고 누락, 진화 시도 실패 후 당황하여 사고보고 누락', phase: 'response', effectiveness: 'Low', evidence: '화재가 발생된 1079호 기관사는 운전사령에 화재발생 사실을 보고하지 않은 채 화재를 진화하려다 실패하고 당황하여 사고보고를 누락하였으며', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0381'};
MATCH (a:ResponseActor {name: '중앙로역 역무원'}), (b:ResponseAction {name: '화재발생 초기 상황보고'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '전동차 화재임을 상세 보고하지 않고 단순히 중앙로역 화재로만 보고, 사령실의 심각성 인식 실패 초래', phase: 'response', effectiveness: 'Low', evidence: '화재발생을 최초로 보고한 중앙로역 역무원은 전동차에서 화재가 발생하였다고 자세히 보고하지 않고 단순하게 중앙로역에 화재가 발생하였다고 보고함으로서 사령실 근무자들이 사고의 심각성을 인식하지 못하여', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0382'};
MATCH (a:ResponseActor {name: '종합사령실(대구지하철공사)'}), (b:ResponseAction {name: '초동 대응조치'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '화재경보를 오작동으로 판단·안일 대처, 확인 절차 없이 전체호출로 주의운전만 지시, 적절한 대응조치 미실시', phase: 'response', effectiveness: 'Low', evidence: '종합사령실 근무자의 경우, 화재경보가 울렸는데도 이를 운전사령에게 통보해 주지 않고... 평소에 자주 일어나는 오작동일 것으로 판단하고 안일하게 대처한', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0383'};
MATCH (a:ResponseAction {name: '1080호 승객 대피 조치'}), (b:Damage {name: '대구지하철 화재 인명피해'}) MERGE (a)-[r:MITIGATES]->(b) SET r += {effectiveness: 'Low', reason: '대피시기 지연으로 희생자 증가', timing: '초동 단계', evidence: '계속 출발을 시도함으로 대피시기를 지연시켜 희생자가 증가되었다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0384'};
MATCH (a:ResponseActor {name: '대구소방본부 119종합상황실'}), (b:ResponseAction {name: '상황전파 및 협조'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '10여 차례 119신고 추가 접수에도 현장상황 파악·전파 노력 미흡, 출입문 개방·대피방법 미안내', phase: 'response', effectiveness: 'Low', timing: '09:54:40 최초접보 후 09:59~10:30', evidence: '소방본부 119종합상황실에서는 2월 18일 09:54:40경 중앙로역 화재사고를 최초로 접보한 후... 10여 차례에 걸쳐 119신고를 추가로 받았으나... 적극적인 상황전파 노력이 미흡하였다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0385'};
MATCH (a:ResponseAction {name: '상황전파 및 협조'}), (b:Damage {name: '대구지하철 화재 인명피해'}) MERGE (a)-[r:MITIGATES]->(b) SET r += {effectiveness: 'Low', reason: '부서간·기관간 화재 상황정보 미전달로 화재초기 30여분 화재진압·인명구조 효과적 수행 실패', mechanism: '유관기관 무선채널 상이, 연락관 미파견', evidence: '부서간, 기관간 화재 상황정보가 제대로 전달되지 않아 화재발생 초기에 화재진압과 인명구조활동을 효과적으로 수행하지 못하는 결과를 가져왔다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0386'};
MATCH (a:RiskFactor {name: '지하철공사 안전교육·전담조직 미비'}), (b:ResponseAction {name: '초동 대응조치'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {mechanism: '직원 위기대처능력 부족으로 초동대처 실패', probability: 'High', reason: '안전시스템 미구축', evidence: '지하철공사에서는... 1999년 자체 교육원을 폐지하였고, 안전이나 사고예방, 비상사태 발생시의 조치 등에 대한 교육훈련을 제대로 실시하지 못하였으며... 안전관리 전담부서가 별도로 조직되어 있지 않는 등', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0387'};
MATCH (a:RiskFactor {name: '역사 배연설비 미비'}), (b:Damage {name: '대구지하철 화재 인명피해'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {mechanism: '배연용량 부족으로 피난로에 연기 가득차 피난 곤란', effectiveness: 'High', evidence: '배연용량이 부족하여 발생된 연기가 계단을 통해 위충의 대합실로 이동하고... 피난로에 연기가 가득 차 있어 피난이 곤란하였던 것으로 추정된다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0388'};
MATCH (a:RiskFactor {name: '승강장 스프링클러 미설치'}), (b:Damage {name: '대구지하철 화재 인명피해'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {mechanism: '승강장 화재진압·냉각·피난보조 수단 부재', effectiveness: 'Med', evidence: '지하 3층 승강장은 소방법에 규정한 설치대상에서 제외되어 있으며, 살수시 고압 전차선과 접촉우려 등으로 스프링클러가 설치되어 있지 않았다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0389'};
MATCH (a:RiskFactor {name: '비상유도등 기능 한계'}), (b:Damage {name: '대구지하철 화재 인명피해'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {mechanism: '유도등 기능 상실로 피난로 방향 식별 불가', effectiveness: 'Med', evidence: '대형 화재시 발생된 다량의 연기와 유독가스의 농도가 짙어지면서 상대적으로 조도가 떨어져 유도등이 제 기능을 발휘하지 못하며, 화재확대로 열의 발생이 많아지면 유도등과 배선이 소손되어 점등을 유지하지 못한다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0390'};
MATCH (a:RiskFactor {name: '무선통신망 한계'}), (b:Event {name: '1080호 전동차 출발 불능·승객 고립'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {mechanism: '1080호 기관사-종합사령실 통화 불가로 신속대처 실패, 대피시간 지연', effectiveness: 'High', evidence: '1080호 전동차가 중앙로역에 진입하면서 종합사령실에 통화시도를 하였지만, 종합사령실은 다른 열차와 통화하고 있어 통화하지 못하였고... 종합사령실과 기관사는 신속히 대처하지 못하고 대피시간을 지연시켰다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0391'};
MATCH (a:RiskFactor {name: '비상전력 확보시스템 미비'}), (b:Event {name: '중앙로역 일대 정전'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {mechanism: '정전시 비상전력 부재로 인명피해 가중', probability: 'High', specialNote: '많은 인명피해 발생의 또 하나의 원인으로 지적', evidence: '전원차단에 따른 비상전력 확보시스템이 마련되어 있지 않은 것이 많은 인명피해가 발생한 또 하나의 원인으로 지적되고 있으나', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0392'};
MATCH (a:Event {name: '현장지휘체계 혼선'}), (b:Damage {name: '대구지하철 화재 인명피해'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {mechanism: '지휘체계 혼선으로 사고수습 차질', effectiveness: 'High', evidence: '소방, 군부대, 경찰, 자원봉사자 등에 대한 통합 지휘체계도 제대로 가동되지 않아 역할분담이나 책임한계가 분명하지 않았으며, 이러한 현장지휘체계 혼선은 사고수습에 있어 큰 문제점으로 지적되었다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0393'};
MATCH (a:RiskFactor {name: '인명구조체계 미흡'}), (b:Damage {name: '대구지하철 화재 인명피해'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {mechanism: '구조대원 부족·진입곤란으로 화재초기 대량 인명피해 대응 실패', effectiveness: 'High', evidence: '소방본부 산하에 6개 구조대 84명의 구조대원이 있었지만 화재발생 직후 10분 이내 투입된 구조대는 인근지역의 3개 구조대(북부·중부·서부) 뿐이었으며... 화재초기 대량 인명피해 발생에 따른 구조대원의 부족현상이 일시적으로 나타나기도 하였다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0394'};
MATCH (a:ResponseAction {name: '안전관리 체계 정비 및 교육훈련 강화'}), (b:Resilience {name: '위기대처능력'}) MERGE (a)-[r:BUILDS]->(b) SET r += {effectiveness: 'Med', phase: 'prevention', reason: '지속적 교육훈련으로 위기대처능력 확보', evidence: '평상시 훈련을 통해 습득한 위기대처 능력은 예기치 못한 상황이 발생되었을 때 그 효과가 나타난다... 안전관리 체계를 정비하는 등 사고 예방시스템을 구축하여야 할 것이다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0395'};
MATCH (a:Event {name: '대구지하철 중앙로역 화재(2003)'}), (b:Context {name: '2003-02-18 09:54:40 (119 최초접보)'}) MERGE (a)-[r:OCCURS_AT]->(b) SET r += {role: '최초 접보 시각', evidence: '소방본부 119종합상황실에서는 2월 18일 09:54:40경 중앙로역 화재사고를 최초로 접보한 후', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0396'};
MATCH (a:ResponseAction {name: '사고관련 사법처리'}), (b:Event {name: '대구지하철 중앙로역 화재(2003)'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {phase: 'recovery', specialNote: '방화범 김대한은 04.8.30 진주의료원에서 지병으로 사망', evidence: '사고관련 사법처리자 현황... 방화범 김대한 무기징역... ※ 무기징역을 선고받고 진주교도소에 수감 중이던 방화범 김대한(58세)은 04. 8. 30(월) 09:10경 진주의료원에서 지병인 정신질환 및 뇌졸중 후유증으로 사망하였음', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0397'};
MATCH (a:ResponseActor {name: '추모사업추진위원회'}), (b:ResponseAction {name: '추모사업 추진'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', actionType: '추모사업', evidence: '당초 10명이던 추모사업추진위원회를... 총 16명으로 위원회를 운영하게 되었다... 3. 추모사업 추진 가. 추모묘역 조성', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0398'};
MATCH (a:ResponseAction {name: '시민 안전테마파크 건립'}), (b:Resilience {name: '시민 재난대처능력'}) MERGE (a)-[r:BUILDS]->(b) SET r += {effectiveness: 'Med', phase: 'prevention', reason: '체험위주 안전교육으로 초기 대처능력 향상, 대형사고 확대 방지', evidence: '각종 재해 재난발생시 초기 대처능력을 향상시켜 대형사고로 확대되는 것을 방지하고, 안전문화 정착과 안전사고율을 저하시키는 효과를 유발할 것으로 분석되었다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0399'};
MATCH (a:Event {name: '상인동 도시가스 폭발사고(1995)'}), (b:Damage {name: '상인동 가스폭발 피해(1995)'}) MERGE (a)-[r:CAUSES]->(b) SET r += {scale: '대형', directCause: '도시가스 폭발', evidence: '약 40분후인 07:52경 원인불명의 화인으로 도시가스가 폭발하는 사고가 발생하여 사망 101명, 부상 202명, 건물 346건, 차량 150대 등 막대한 인명과 재산피해가 발생하였다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0400'};
MATCH (a:Event {name: '삼풍백화점 붕괴사고(1995)'}), (b:Damage {name: '삼풍백화점 붕괴 피해(1995)'}) MERGE (a)-[r:CAUSES]->(b) SET r += {scale: '대형', directCause: '건물 붕괴', evidence: '총체적인 부실로 인하여 붕괴되는 사고가 발생하여 사망 502명, 부상 937명 등 총1,439명의 인명피해와 막대한 재산피해가 발생하였다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0401'};
MATCH (a:Event {name: '대구 지하철 중앙로역 화재(2003)'}), (b:Event {name: '농연·유독가스 지상 배출'}) MERGE (a)-[r:TRIGGERS]->(b) SET r += {mechanism: '농연·유독가스·열기가 계단을 통해 지상으로 배출', consequence: '구조대원 지하3층 진입 곤란', evidence: '화재당시 농연 및 유독가스와 열기가 계단을 통하여 지상으로 배출됨으로 화재진압 및 구조대원이 전동차가 있는 지하3층 승강장까지 진입하는데 상당한 곤란을 겪었다.', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0402'};
MATCH (a:Event {name: '농연·유독가스 지상 배출'}), (b:ResponseAction {name: '지하3층 승강장 인명구조 진입'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {reason: '농연·유독가스·열기로 지하3층 승강장 진입 곤란', specialNote: '구조대 진입 방해 요인', evidence: '화재진압 및 구조대원이 전동차가 있는 지하3층 승강장까지 진입하는데 상당한 곤란을 겪었다.', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0403'};
MATCH (a:ResponseActor {name: '소방본부 구조대'}), (b:ResponseAction {name: '지하3층 승강장 인명구조 진입'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '투입 구조대원 부족, 화재초기 인근 3개 구조대만 10분내 투입, 나머지는 10분 경과 후 도착', consequence: '화재초기 대량 인명피해 발생에 따른 구조대원 부족 현상', effectiveness: 'Low', evidence: '화재발생 직후 10분 이내 투입된 구조대는 인근지역의 3개 구조대(북부·중부·서부) 뿐이었으며, 나머지 구조대는 ... 10분이 경과해서야 도착할 수 있었다. 이로 인해 화재초기 대량 인명피해 발생에 따른 구조대원의 부족현상이 일시적으로 나타나기도 하였다.', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0404'};
MATCH (a:RiskFactor {name: '구조대원 부족'}), (b:Damage {name: '대구 지하철 중앙로역 화재 인명피해'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {mechanism: '화재초기 위험지점에만 우선 투입 가능, 심층부 구조 지연', probability: 'High', evidence: '투입될 구조대원의 부족으로 화재발생 초기에는 ... 가장 위험한 특정지점 또는 요구조자가 많을 것으로 예상되는 지점에 우선적으로 투입할 수 밖에 없었으며', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0405'};
MATCH (a:ResponseAction {name: '응급의료체계'}), (b:Event {name: '대구 지하철 중앙로역 화재(2003)'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {reason: '일시에 많은 환자 발생', effectiveness: 'Low', specialNote: '전담인력·장비 부족, 중증도 분류 시간 부족', evidence: '응급의료체계의 경우 일시에 많은 환자가 발생함으로써 전담인력•장비의 부족과 신속한 응급처치 및 이송이 곤란하였고', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0406'};
MATCH (a:RiskFactor {name: '응급의료 통신체계 미일원화'}), (b:Damage {name: '응급처치 미흡(사상자 인근병원 집중)'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {mechanism: '의료기관별 수용실태 집계 혼선, 인근병원 사상자 집중', probability: 'Med', evidence: '응급의료에 관한 통신체계가 일원화되어 있지 않고 ... 의료기관별 수용실태를 집계하는데 혼선을 초래하게 되었다.', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0407'};
MATCH (a:RiskFactor {name: '구조장비 부족'}), (b:ResponseAction {name: '지하3층 승강장 인명구조 진입'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {mechanism: '지하 심층부 구조장비 이송·구조활동 제약', probability: 'High', specialNote: '지하화재 적합 구조장비 부재로 진압 완료 후에야 수습 참여', evidence: '공기호흡기의 용량과 예비용기가 부족하였으며, 연기투시기•라이프라인 등은 농연•고열속에서 성능상의 한계 등으로 구조활동에 제약을 가져왔다.', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0408'};
MATCH (a:RiskFactor {name: '교통체증'}), (b:ResponseAction {name: '지하3층 승강장 인명구조 진입'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {mechanism: '현장까지 구조장비 수송 지연', probability: 'Med', evidence: '예비로 보유하고 있는 장비를 현장까지 수송하기 위해서는 교통체증 등의 장애요인과 마주쳐야 했으며', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0409'};
MATCH (a:RiskFactor {name: '지하 다중이용시설 소방안전기준 취약'}), (b:Event {name: '대구 지하철 중앙로역 화재(2003)'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {mechanism: '지하공간 다중이용시설 재난예방 기준 미흡', probability: 'High', evidence: '지하 건축물의 재난예방을 위한 기준, 특히 지하철 역사와 같이 지하공간의 다중이용시설에 대한 기준들이 매우 취약한 것으로 나타났다. ... 건축허가 동의대상에서 제외됨으로써 소방안전에 대한 검토가 이루어지지 않았으며', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0410'};
MATCH (a:RiskFactor {name: '전동차 붙박이창(강화유리)'}), (b:Event {name: '승객 고립'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {mechanism: '탈출로 확보 어려움으로 고립 심화', probability: 'High', evidence: '전동차내에 설치된 붙박이창(강화유리)으로 인해 고열•유독가스의 배출이 어려웠고, 파괴 등에 의한 탈출로 확보가 쉽지 않았다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0411'};
MATCH (a:ResponseAction {name: '사고현장 관리 미흡'}), (b:Event {name: '대구 지하철 중앙로역 화재(2003)'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {effectiveness: 'Low', reason: '유가족 불신 초래', consequence: '상당기간 사고수습 진통', evidence: '사고 초기 사고현장 관리가 미흡하여 대구시가 유가족들로부터 불신을 받음에 따라 상당기간 사고수습에 진통을 겪는 원인이 되었다.', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0412'};
MATCH (a:ResponseActor {name: '국립과학수사연구소'}), (b:ResponseAction {name: '1차 합동 현장감식'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {timing: '2003-02-18 20:30~', composition: '검찰 2명, 국과수 12명, 경찰 12명', role: '검찰지휘 1차 합동 현장감식', evidence: '2월 18일 사고 당일 20:30경 국립과학수사연구소의 법의감정팀 및 물리분석팀이 사고현장에 도착하면서부터 검찰지휘로 1차 합동 현장감식(검찰 2명, 국립과학수사연구소 12명, 경찰 12명)이 이루어졌다.', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0413'};
MATCH (a:ResponseAction {name: '사고 전동차 월배차량기지 이동'}), (b:Event {name: '대구 지하철 중앙로역 화재(2003)'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {timing: '2003-02-18 22:00~2003-02-19 01:00', reason: '전동차 내부 사체수습·감식 위해', evidence: '사고 당일 22:00경 1080호 전동차의 견인이 시작되었고, 그 다음날인 2월 19일 01:00경에는 1079호 전동차의 견인이 마무리되었다.', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0414'};
MATCH (a:ResponseActor {name: '대구지방경찰청'}), (b:ResponseAction {name: '사고현장 1차 수색'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {timing: '2003-02-19 01:00', composition: '기동대원 23명 + 중부경찰서 1개 중대 100여명', consequence: '사체·유류품 전혀 미발견', evidence: '전동차 견인 직후인 2월 19일 0100경 기동대원 23명을 동원하여 사고현장을 수색하였고, 중부경찰서에서도 ... 100여명을 동원하여 ... 추가 수색하였으나, 피해자의 사체나 유류품을 전혀 발견하지 못하였다.', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0415'};
MATCH (a:ResponseActor {name: '대구지하철공사'}), (b:ResponseAction {name: '사고현장 잔재물 정리·수거작업'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {timing: '2003-02-19 11:30~17:00', composition: '작업준비팀 20여명 + 육군 OO사단 병력 200여명', detail: '긴급 안전진단 후 잔재물 정리·수거, 안심차량기지 야적장 보관', evidence: '2월 19일 11:30경부터 지하철공사에서는 안전진단팀을 투입하여 ... 긴급 안전진단을 실시하였고, 13:00경부터 17:00까지는 작업준비팀(20여명)은 육군 OO사단 소속 병력 200여명을 지원받아 사고 현장에 대한 잔재물 정리 및 수거 작업을 실시하였으며', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0416'};
MATCH (a:ResponseActor {name: '육군 OO사단'}), (b:ResponseActor {name: '대구지하철공사'}) MERGE (a)-[r:COORDINATES_WITH]->(b) SET r += {role: '병력 200여명 지원', timing: '2003-02-19', evidence: '작업준비팀(20여명)은 육군 OO사단 소속 병력 200여명을 지원받아 사고 현장에 대한 잔재물 정리 및 수거 작업을 실시하였으며', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0417'};
MATCH (a:ResponseAction {name: '사고현장 잔재물 정리·수거작업'}), (b:Damage {name: '현장훼손·증거인멸 논란'}) MERGE (a)-[r:CAUSES]->(b) SET r += {directCause: '잔재물 조기 수거로 시신편·유류품 잔존', mechanism: '2월23일 실종자 가족이 뼈조각 5~6개·유류품 발견 → 재감식 요구', consequence: '현장훼손·증거인멸 논란', evidence: '2월 23일 02:00경 일부 실종자 가족이 ... 뼈조각으로 추정되는 물체 5~6개와 유류품 ... 발견함에 따라 ... 현장훼손에 대한 관계기관간 책임 논란이 일어나면서 여론이 악화되어 지하철공사사장과 대구시장이 검찰의 수사를 받는 상황까지 이르게 되었다.', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0418'};
MATCH (a:ResponseAction {name: '사고현장 잔재물 재감식'}), (b:Damage {name: '시신편·유류품 추가 발견'}) MERGE (a)-[r:CAUSES]->(b) SET r += {consequence: '시신편·유류품 추가 발견', evidence: '2월 25일 안심차량기지에 보관하고 있던 사고현장 잔재물에 대한 대대적인 재감식에서도 뼈조각 등 시신편 14점과 안경, 모자 등 유류품 169점이 추가로 발견되었다.', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0419'};
MATCH (a:Damage {name: '현장훼손·증거인멸 논란'}), (b:Damage {name: '유가족 불신·사고수습 장기화'}) MERGE (a)-[r:CAUSES]->(b) SET r += {mechanism: '유가족 불신, 대화 단절, 갈등 심화', consequence: '사고수습 원만 진행 불가', evidence: '대구시가 상당기간 실종자 가족 등 유가족들로부터 불신을 받음에 따라 대화가 단절되고 갈등이 심화되는 등 ... 사고수습을 원만히 이끌어가지 못하는 매우 어려운 상황에 놓이게 되었다.', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0420'};
MATCH (a:RiskFactor {name: '사고수습대책위원회 미운영'}), (b:Damage {name: '유가족 불신·사고수습 장기화'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {mechanism: '피해자 무리한 요구 수용, 합리적 의사결정 실패, 시행착오', probability: 'High', specialNote: '감금·강압하 합의서 서명 등 독자적 의사결정·번복', evidence: '「사고수습대책위원회」를 운영하지 아니하고 사고 당사자의 위치에 있는 대구시 공무원들에 의해 주요 의사결정이 이루어짐에 따라 피해자들의 무리한 요구사항을 수용하는 등 합리적인 의사결정을 하지 못하는 등 시행착오를 겪었다.', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0421'};
MATCH (a:RiskFactor {name: '사고대책본부 3교대 근무체제'}), (b:Damage {name: '유가족 불신·사고수습 장기화'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {mechanism: '유가족 요구사항 인계인수 미흡, 업무처리 지연', probability: 'Med', specialNote: '실종신고자 619명, 신원확인 불가 시신 다수의 특수사고', evidence: '사고대책본부는 ... 각 부서에서 차출되어 온 직원들이 근무하는 체제로 운영되어 소속감이나 책임감 결여될 수 밖에 없었고, ... 3교대 근무방식으로 운영함에 따라 업무의 연속성이 결여되는 등 효율적으로 운영되지 못하였다.', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0422'};
MATCH (a:Damage {name: '실종신고'}), (b:Context {name: '사고수습 장기화 맥락'}) MERGE (a)-[r:QUANTIFIED_BY]->(b) SET r += {detail: '실종자 확인·사망자 신원확인·시신인도 난항으로 사고수습 장기화', evidence: '지하철 화재사고의 경우 실종신고자가 619명에 이르고, 고도로 탄화되어 신원을 확인할 수 없는 시신이 많이 발생된 특수한 사고였으며', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0423'};
MATCH (a:RiskFactor {name: '손해사정업체 난립'}), (b:Damage {name: '손해보상 협상 지연·유가족 고통'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {mechanism: '보상기준 결정·협상 지연, 유가족 단체 분리 후 가압류 분쟁', probability: 'Med', evidence: '사고초기 손해사정인들이 손해사정업체로 선정되기 위하여 지나친 경쟁양상을 보임으로써 손해보상업무 추진에 지장을 초래하였다. ... 보상기준 결정을 위한 유가족 대표와의 협상이 지연되는 원인으로 작용', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0424'};
MATCH (a:RiskFactor {name: '복수 손해사정인 선임'}), (b:Damage {name: '손해사정 수수료 부담 가중'}) MERGE (a)-[r:CAUSES]->(b) SET r += {directCause: '평가수수료·검증수수료 이중 부담', mechanism: '총 손해사정액 64,332,669천원 대비 수수료 2,881,070천원(평균 4.5%)', evidence: '총 손해사정액은 검증액 기준으로 64,332,669천원인데 비해 수수료 지출액은 2,881,070천원으로서 평균 4.5%의 높은 수수료를 부담한 것으로 나타났다.', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0425'};
MATCH (a:RiskFactor {name: '보상액 산정기준 미흡'}), (b:Damage {name: '보상 재사정·형평성 논란'}) MERGE (a)-[r:CAUSES]->(b) SET r += {directCause: '직접피해 무관 간접 영업손실 포함 손해사정', consequence: '재사정·시행착오', evidence: '손해사정인이 자의적으로 판단하여 직접피해와 관련이 없는 간접 영업손실 부문을 포함하여 손해사정을 함으로써 재사정을 하게 되는 등 시행착오를 겪었다.', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0426'};
MATCH (a:ResponseAction {name: '사망자 장례지원'}), (b:Event {name: '대구 지하철 중앙로역 화재(2003)'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {effectiveness: 'Med', specialNote: '변형 시신 일반관 입관 불가로 긴급 특수관 제작, 시신변형 예측 실패', evidence: '사망자별 장례지원반을 편성하여 ... 장례절차 전반에 대해 사전 면담을 실시하고 ... 그러나 ... 변형된 시신이 있는데도 불구하고 시신입관을 위한 관을 모두 일반관으로 주문도록 하는 등 화재사고의 특성을 무시한 획일적인 조사로 ... 긴급히 특수관을 제작하여 장례를 치르기도 하는 등', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0427'};
MATCH (a:ResponseActor {name: '대구광역시'}), (b:ResponseAction {name: '피해업체 금융지원'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', detail: '경영안정자금·창업경쟁력강화자금, 대출금리 4.5% 중 4% 이자보전', specialNote: '간접 영업손실 지원기준 애매로 항의·민원, 무이자·무담보 요구 갈등', evidence: '대구시에서는 ... 정책자금인 경영안정자금과 창업 및 경쟁력 강화자금을 마련하여 ... 지원대책을 수립하여 시행하였으나 ... 시중은행 대출금리 4.5%를 적용하여 ... 대구시에서 4%의 이자를 보전하여 주는 방식으로 지원하고 있으나', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0428'};
MATCH (a:ResponseAction {name: '지하철 화재사고 자원봉사활동'}), (b:Event {name: '대구 지하철 중앙로역 화재(2003)'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {effectiveness: 'Med', specialNote: '초기 안내·배치 전담팀 부재, 수요-공급 불일치로 무질서', evidence: '사상 최대의 자원봉사활동은 민간단체 차원에서 자발적으로 이루어졌으며 ... 유가족들의 편의 제공을 위한 급식 및 간식 지원, 생필품 지원 등을 위한 활동이 이루어진 것이 특색이다.', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0429'};
MATCH (a:ResponseActor {name: '건설교통부'}), (b:ResponseAction {name: '도시철도종합안전대책'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'prevention', timing: '2003-03~06', composition: '전문가 26명(대학교수·철도기술연구원·운영기관·철도청·소방서 등)', detail: '안전실태 조사·내장재 화재시험·국내외 자문·공청회(6/25) 거쳐 38개 중장기 개선과제', evidence: '건설교통부에서는 ... 26명의 전문가를 중심으로 「지하철안전기획단」을 구성하여 ... 38개 중장기 개선과제로 구성된 도시철도종합안전대책을 마련하였다.', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0430'};
MATCH (a:ResponseAction {name: '도시철도종합안전대책'}), (b:ManmadeHazard {name: '도시철도 차량·화재·설비사고'}) MERGE (a)-[r:PREVENTS]->(b) SET r += {objective: '5년내 사고발생률 30% 감축, 주행 100만km당 차량·화재·설비사고 0.3→0.2건, 차량·설비·화재사고 사망자 제로화', amount: 1065400000000, unit: '원(2003~2007 총투입)', detail: '2003년 1,468억원, 2004년 2,068억원, 2007년까지 총 1조 654억원', evidence: '향후 5년 이내 사고발생률을 30% 감축하고, ... 사망자 발생을 제로화 한다는 목표아래 ... 2003년에 1,468억원을 투입하였고, 2004년도에 2,068억원을 투입하는 등 2007년까지 총 1조 654억원을 투입하여 모두 완료할 계획', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0431'};
MATCH (a:ResponseAction {name: '전동차 내장재 교체 사업'}), (b:Event {name: '농연·유독가스 지상 배출'}) MERGE (a)-[r:PREVENTS]->(b) SET r += {mechanism: '불연·연소가스 무독성으로 화재확산·유독가스 발생 억제', effectiveness: 'High', evidence: '내장재는 불에 잘 타지 않고 연소가스의 독성이 인체에 치명적이지 않도록 알루미늄, 스테인레스 등 금속성 재질의 내장재로 계약을 체결했고 ... 철도청과 대구지하철공사에서는 실제 전동차에 신나 4리터를 연소시키는 화재시연회를 개최하여 새로운 내장재의 불연성을 입증한 바 있다.', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0432'};
MATCH (a:Resilience {name: '지능형 제연설비·유독가스 배출설비'}), (b:Damage {name: '대구 지하철 중앙로역 화재 인명피해'}) MERGE (a)-[r:OFFSETS]->(b) SET r += {mechanism: '유독가스 배출방향 제어로 승객 대피 용이, 연기확산 지연', effectiveness: 'High', evidence: '화재발생장소에 따라 유독가스 배출방향을 조절하여 승객의 대피를 용이하게 하는 지능형 제연설비와 연기확산을 지연하는 제연경계벽도 설치하고 있다.', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0433'};
MATCH (a:Resilience {name: '정전대비 소화설비(상수도 직결·유도등 1시간)'}), (b:Damage {name: '대구 지하철 중앙로역 화재 인명피해'}) MERGE (a)-[r:OFFSETS]->(b) SET r += {mechanism: '정전시에도 소화·대피유도 가능', effectiveness: 'High', specialNote: '원 사고시 정전·소화설비 미작동 보완', evidence: '정전시에 옥내소화전과 스프링클러의 소화용 펌프가 작동하지 않는 문제점을 해소하기 위해 상수도에 소화전을 직결하고 있으며, 유도등과 비상조명등의 지속시간을 20분에서 1시간으로 상향 조정중이다.', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0434'};
MATCH (a:ResponseAction {name: '전동차 출입문 수동개방장치·승객 비상행동요령 교육'}), (b:Event {name: '승객 고립'}) MERGE (a)-[r:PREVENTS]->(b) SET r += {mechanism: '출입문 수동개방으로 탈출로 확보, 승객 자력 대피 능력 강화', effectiveness: 'Med', evidence: '차량내 소화기를 종전 1개에서 2개이상 비치하고, 소화기 사용법 및 출입문 비상개방탈출 등 승객탈출시 필요한 안내표지를 축광식으로 개선 완료하였다. ... 전동차 출입문 수동개방 등 비상시 행동요령에 대한 교육도 실시하고 있다.', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0435'};
MATCH (a:ResponseAction {name: '철도안전법 제정'}), (b:Resilience {name: '비상대응 매뉴얼·합동모의훈련 체계'}) MERGE (a)-[r:BUILDS]->(b) SET r += {objective: '기관사면허제·운전사령 자격강화·전문기관 위탁교육으로 직원 위기대처능력 강화', evidence: '이를 위해 철도안전법이 제정되어 2005년 1월 1일부터 시행되고 있다. 이 법에는 철도안전종합계획, 종합안전심사제, 비상대응계획, 경찰 소방•군부대와의 합동 모의훈련에 대한 근거조항을 담고 있다. ... 각 운영기관은 화재, 독가스 살포 등 발생 가능한 시나리오별로 비상대응 매뉴얼을 만들었으며', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0436'};
MATCH (a:Resilience {name: '승강장 추락방지시설(안전펜스·스크린도어)'}), (b:Damage {name: '승강장 추락 피해'}) MERGE (a)-[r:OFFSETS]->(b) SET r += {mechanism: '승강장 추락 방지', effectiveness: 'High', evidence: '안전펜스는 2004년에 혼잡역사, 환승역 등 위험도가 높은 154개 승강장에 우선 설치한다. ... 스크린도어 시설은 ... 71개 신규역사에 도입된다.', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0437'};
MATCH (a:Resilience {name: '다자간 디지털 무선통신망(TRS)·승객용 비상인터폰'}), (b:Damage {name: '유가족 불신·사고수습 장기화'}) MERGE (a)-[r:OFFSETS]->(b) SET r += {mechanism: '비상시 다자간 통신·승객-기관사 양방향 통화로 대응 신속화', effectiveness: 'Med', specialNote: '원 사고시 통신체계 미흡 보완', evidence: '비상시 다자간 통화가 자유로운 디지털 무선통신망(TRS)을 구축중에 있으며 양방향 통화가 가능한 승객용 비상인터폰을 전동차와 승강장에 설치하고 있다.', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0438'};
MATCH (a:ResponseAction {name: '대구지하철 종합안전개선대책'}), (b:ManmadeHazard {name: '도시철도 차량·화재·설비사고'}) MERGE (a)-[r:PREVENTS]->(b) SET r += {objective: '시설개선·전기통신개선·차량개선 등 분야별 안전개선', effectiveness: 'Med', evidence: '건설교통부에서 시달된 「도시철도종합안전대책」에 의거 지하철 종합안전개선대책을 수립하여 추진하고 있다. ... 계 ... 66,005 ... 75건', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0439'};
MATCH (a:ResponseAction {name: '전동차 내장재 교체 사업'}), (b:RiskFactor {name: '전동차 가연성 내장재'}) MERGE (a)-[r:MITIGATES]->(b) SET r += {effectiveness: 'High', mechanism: '강화된 연소성 시험기준 적용으로 가연성 저감', evidence: '강화된 시험기준에는 산소지수, 화염전파, 연기밀도, 독성지수가 추가되고, 통과수준은 선진국의 기준을 준용토록 하였다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0440'};
MATCH (a:RiskFactor {name: '비상통신수단(비상벨·인터폰) 미흡'}), (b:Event {name: '대구 지하철 중앙로역 화재(2003)'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {mechanism: '비상시 신속한 상황전파 곤란', probability: 'Med', evidence: '비상벨은 경보음만 발령하는 한계가 있고 인터폰 또한 성능이 낮은 것은 물론 ... 설치위치도 ... 185cm 높이에 설치되어 있어 비상시 접근성도 좋지 않았다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0441'};
MATCH (a:ResponseAction {name: '전동차 객실 통신시스템 개선(비상인터폰)'}), (b:RiskFactor {name: '비상통신수단(비상벨·인터폰) 미흡'}) MERGE (a)-[r:MITIGATES]->(b) SET r += {effectiveness: 'Med', mechanism: '신속한 상황전파·통화 활용도 제고', evidence: '비상사태 발생시 신속한 상황전파를 위하여 ... 비상인터폰을 설치하도록 기준을 강화 ... 종합사령실로 자동전환이 되도록 하되, 그 시간도 최대 10초이내로 설정', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0442'};
MATCH (a:RiskFactor {name: '정전·농연시 소화기 위치 식별곤란'}), (b:Event {name: '대구 지하철 중앙로역 화재(2003)'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {mechanism: '정전·화재 농연 상황에서 소화기 식별·이용 곤란', probability: 'Med', evidence: '소화기 설치위치 안내명판이 축광식으로 되어 있지 않아 정전 및 화재 발생시 농연으로 인하여 소화기 설치 위치 식별이 곤란하였다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0443'};
MATCH (a:ResponseAction {name: '수동식 소화기 증설 및 축광 명판 개선'}), (b:RiskFactor {name: '정전·농연시 소화기 위치 식별곤란'}) MERGE (a)-[r:MITIGATES]->(b) SET r += {effectiveness: 'Med', mechanism: '정전·농연시 소화기 식별·활용도 제고', evidence: '소화기 안내명판을 축광식으로 제작하며, 소화기 보관함 형태를 통일 ... 충전압력계가 달린 성능이 우수한 ABC급 수동식 소화기를 비치', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0444'};
MATCH (a:RiskFactor {name: '출입문 수동개방장치 접근·식별 곤란'}), (b:Event {name: '대구 지하철 중앙로역 화재(2003)'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {mechanism: '정전 상황에서 출입문 수동개방 곤란으로 탈출 지연', probability: 'High', specialNote: '대구 화재 당시 출입문 잠김·고립이 대량 사망의 핵심 기제', evidence: '수동개방장치의 위치에 대한 구체적 기준이 없어 ... 안내표지판도 비상시 전등이 꺼진 상황에서는 식별이 불가능하여 사고발생시 안내효과를 기대하기가 어려웠다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0445'};
MATCH (a:ResponseAction {name: '수동개방장치 위치·표지판 개선'}), (b:RiskFactor {name: '출입문 수동개방장치 접근·식별 곤란'}) MERGE (a)-[r:MITIGATES]->(b) SET r += {effectiveness: 'Med', mechanism: '정전시 수동개방장치 접근·식별 개선으로 탈출 용이', evidence: '안내표지판은 출입구 측벽 120~160cm의 높이로 부착하되 ... 외부개방장치는 레일상면 126~150cm 사이 외측벽에 설치하고, 내부개방장치는 승객 의자 밑에 설치', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0446'};
MATCH (a:ResponseAction {name: '직원용 응급·구조장비 비치'}), (b:Resilience {name: '지하역사·전동차 구조장비 역량'}) MERGE (a)-[r:BUILDS]->(b) SET r += {effectiveness: 'Med', role: '비상시 인명구조 역량 확보', evidence: '지하역사 역무실에는 공기흡입기, 메가폰, 손전등 각 2개 이상, 들것 1개 이상, 방독면은 일일 근무자수 이상을 비치', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0447'};
MATCH (a:ResponseActor {name: '대구도시철도공사'}), (b:ResponseAction {name: '지하철2호선 전동차 제작(화재안전 강화)'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'prevention', legalBasis: '국제입찰(조달청)', dateTime: '2001-12-06', evidence: '지하철2호선에 투입될 전동차 168량(6량×28개 편성)은 국제입찰(조달청)을 통하여 2001년 12월 6일 (주)로템과 구매계약을(금액 147,090백만원) 체결', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0448'};
MATCH (a:ResponseAction {name: '지하철2호선 전동차 화재안전 내장재 보강'}), (b:RiskFactor {name: '전동차 가연성 내장재'}) MERGE (a)-[r:MITIGATES]->(b) SET r += {effectiveness: 'High', mechanism: '선진국 수준 안전기준 적용으로 화재 안전성 강화', evidence: '당초사양/개선적용 ... 내장판 페놀계하니컴 BS6853, 단열재 글라스울 NFPA, 바닥판 염화비닐→합성고무 ... 의자 ... 안티반달쿠션 2,755 ... 통로연결막 ... 3,528 ... 화재감지기 655 ... 객실전광판 LED표시기 1,411', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0449'};
MATCH (a:RiskFactor {name: '열차 무선통신체계 부재(외부기관 연계)'}), (b:Event {name: '대구 지하철 중앙로역 화재(2003)'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {mechanism: '다수 통화수요·외부기관 연계 불가로 위급상황 대처 실패', probability: 'Med', evidence: '기존 열차 무선통신시스템이 1주파수에 1채널만 가능 ... 외부기관과의 연계된 비상무선 통신 체계가 없어 위급한 상황에 대처하지 못했다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0450'};
MATCH (a:ResponseAction {name: '전동차 무선통신시스템 구축(TRS방식)'}), (b:RiskFactor {name: '열차 무선통신체계 부재(외부기관 연계)'}) MERGE (a)-[r:MITIGATES]->(b) SET r += {effectiveness: 'Med', mechanism: '외부기관 연계 비상통신으로 위급상황 대처력 확보', evidence: 'TRS방식의 무선통신시스템을 구축하여 국가지휘통신망과도 연계될 수 있도록 개선', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0451'};
MATCH (a:ResponseAction {name: '열차방호기능(자동정지시스템) 확대'}), (b:Event {name: '인접열차 진입에 의한 후속사고'}) MERGE (a)-[r:PREVENTS]->(b) SET r += {effectiveness: 'Med', mechanism: '선행 사고 발생시 인접열차 자동정지로 2차 사고 차단', specialNote: 'cascading 후속사고(인접열차 진입) 차단 목적', evidence: '후속사고를 방지하기 위해 일정거리 이내의 다른 열차를 자동으로 정지시키는 열차 방호기능 ... 열차 자동정지시스템을 설치', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0452'};
MATCH (a:RiskFactor {name: '화재시 정전·대피로 미확보'}), (b:Event {name: '대구 지하철 중앙로역 화재(2003)'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {mechanism: '정전·농연시 대피로 식별 불가로 고립·인명피해 확대', probability: 'High', evidence: '화재 등 정전시 ... 축광형 유도타일 설치 대피로 확보(29개역) ; 화재시 승강장 하부 배기휀을 활용하여 연기 배기', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0453'};
MATCH (a:ResponseAction {name: '축광형 유도타일·피난유도등 설치'}), (b:RiskFactor {name: '화재시 정전·대피로 미확보'}) MERGE (a)-[r:MITIGATES]->(b) SET r += {effectiveness: 'Med', mechanism: '정전·농연시 대피로 식별 확보', evidence: '화재 등 정전시 축광형 유도타일 설치 대피로 확보(29개역) ; 피난구유도등 보완 및 증설(86개소)', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0454'};
MATCH (a:ResponseAction {name: '승강장 하부 배기휀 운용개선·제연설비 개선'}), (b:Event {name: '대구 지하철 중앙로역 화재(2003)'}) MERGE (a)-[r:MITIGATES]->(b) SET r += {effectiveness: 'Med', mechanism: '유독가스·연기 배출로 질식피해 완화', specialNote: '대구 화재 사망의 주원인이 유독가스', evidence: '화재시 승강장 하부 배기휀을 활용하여 연기 배기 ; 제연경계벽 설치 ... 제연송풍기 개선 ... 제연시스템 개선', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0455'};
MATCH (a:ResponseAction {name: 'CCTV·화재수신반 연계운용'}), (b:Event {name: '대구 지하철 중앙로역 화재(2003)'}) MERGE (a)-[r:MITIGATES]->(b) SET r += {effectiveness: 'Med', mechanism: '화재 감지시 개집표기 자동개방으로 신속 대피 지원', evidence: 'CCTV와 화재수신반 연계운용 화재시 개집표기 되어 자동 개방 ; 화재수신반과 CCTV, 승강설비 연동', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0456'};
MATCH (a:ResponseAction {name: '터널·역사 화재탐지·소방설비 보강'}), (b:Event {name: '대구 지하철 중앙로역 화재(2003)'}) MERGE (a)-[r:MITIGATES]->(b) SET r += {effectiveness: 'Med', mechanism: '조기 화재탐지·소화수 확보로 초기진화 강화', evidence: '터널내 연결송수관설비 설치 ... 역사화재탐지설비 개선 지하역사에 적합한 감지기로 교체', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0457'};
MATCH (a:ResponseAction {name: '본선 터널내 비상조명등·대피로 확보'}), (b:RiskFactor {name: '화재시 정전·대피로 미확보'}) MERGE (a)-[r:MITIGATES]->(b) SET r += {effectiveness: 'Med', mechanism: '정전·농연시 터널 대피로 조명 확보', evidence: '본선 터널내 비상 조명등 설치(751개) ... 터널구간 대피로 확보 ; 승강장에서 선로출입 계단 경사로 완화', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0458'};
MATCH (a:ResponseAction {name: '변전소 화재시 전원 자동차단 회로개선'}), (b:Event {name: '중앙로역 일대 정전'}) MERGE (a)-[r:PREVENTS]->(b) SET r += {effectiveness: 'Med', mechanism: '변전소 화재시 전원 자동차단·케이블 연소차단으로 2차 화재·정전 확산 방지', evidence: '변전소 화재시 전원이 자동으로 차단되도록 케어회로 보완 ; 전력케이블 방화도료 ... 공동구 1개소, 변전소 4개소, 전기실 38개소', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0459'};
MATCH (a:ResponseActor {name: '대구도시철도공사'}), (b:ResponseAction {name: '도시철도종합안전대책'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', dateTime: '2004-12-31 기준', detail: '총 75건 추진(완료 39, 추진중 13, 향후 23)', evidence: '3. 세부 추진실적 가. 총괄 ... 계 75 ... 차량 개선 9 ... 시설개선 21 ... 전기통신개선 29 ... 인적제도개선 16', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0460'};
MATCH (a:Event {name: '1080호 전동차 화재'}), (b:Damage {name: '중앙로역 화재 인명피해'}) MERGE (a)-[r:CAUSES]->(b) SET r += {mechanism: '전동차 전소로 다수 사망', specialNote: '전소된 전동차내 신원 미확인 시신 128구 수습', evidence: '전소된 전동차내 신원 미확인 시신 128구 수습', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0461'};
MATCH (a:Event {name: '대구 지하철 중앙로역 화재(2003)'}), (b:Event {name: '지하철 전구간 운행중단'}) MERGE (a)-[r:TRIGGERS_SECONDARY]->(b) SET r += {mechanism: '전구간 안전상 운행 중단', timing: '2003-02-18 10:17', evidence: '지하철공사 전구간 지하철 운행중단(10:17)', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0462'};
MATCH (a:Event {name: '대구 지하철 중앙로역 화재(2003)'}), (b:Facility {name: '중앙로역'}) MERGE (a)-[r:OCCURS_AT]->(b) SET r += {evidence: '지하철 중앙로역 전동차 화재사고 발생(09:53경)', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0463'};
MATCH (a:ResponseActor {name: '대구시 사고대책본부'}), (b:Event {name: '대구 지하철 중앙로역 화재(2003)'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {phase: 'response', role: '사고 수습 총괄', timing: '2003-02-18', evidence: '대구시 사고수습대책본부(본부장 : 시장) 설치 : 6개반 205명', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0464'};
MATCH (a:ResponseActor {name: '중앙특별지원단'}), (b:Event {name: '대구 지하철 중앙로역 화재(2003)'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {phase: 'response', role: '중앙정부 차원 수습 총괄', timing: '2003-03-01', evidence: '대구지하철화재사고수습 중앙특별지원단 설치 • 운영(11:30) ... 단장 : 행정자치부 소청심사위원장 김중량', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0465'};
MATCH (a:ResponseActor {name: '국립과학수사연구소 집단사망자관리단(KDMORT)'}), (b:ResponseAction {name: '사망자 시신수습·신원확인'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', role: '시신 수습·신원확인 감정', location: '월배차량기지', evidence: '국과수 집단사망자관리단(단장 이원태, 46명) 파견 ... 시신수습 작업', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0466'};
MATCH (a:ResponseActor {name: '대구지방경찰청 수사본부'}), (b:ResponseAction {name: '화재사고 수사·감식'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', role: '사고 원인·책임 수사', detail: '지하철공사 종합사령실 압수수색 등', evidence: '중부경찰서에 수사본부 설치 ... 1차 현장검증 및 감식 실시(20:30~23:30)', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0467'};
MATCH (a:ResponseAction {name: '특별재난지역 선포'}), (b:Event {name: '대구 지하철 중앙로역 화재(2003)'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {phase: 'recovery', role: '국가 차원 지원근거 마련', timing: '2003-02-19', evidence: '중앙로역 일원을 특별재난지역으로 선포(16:30, 대통령공고 제177호)', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0468'};
MATCH (a:ResponseAction {name: '중앙로역 구조물 정밀안전진단'}), (b:Event {name: '중앙로역 구조물 붕괴위험'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {phase: 'recovery', role: '붕괴위험 상부구간 구조 안전 확보', effectiveness: 'High', evidence: '붕괴위험 상부구간(서울은행~아카데미극장) 차량운행 전면 통제 ... 지하3층 기둥부분 가시설보강 공사 완료후 통행재개', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0469'};
MATCH (a:ResponseAction {name: '중앙로역 재하시험'}), (b:Event {name: '중앙로역 구조물 붕괴위험'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {phase: 'recovery', role: '기둥보강 후 구조안전 검증', effectiveness: 'High', consequence: '지하3층 28개소 기둥보강으로 중요구조체 안전 이상 없음', evidence: '시험결과 : 중앙로역 지하 3층에 28개소의 기둥보강으로 중요구조체의 안전에는 이상이 없음', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0470'};
MATCH (a:ResponseAction {name: '피해자 금융·생활 지원'}), (b:Damage {name: '중앙로역 화재 인명피해'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {phase: 'recovery', role: '피해자·유가족 재정 구호', evidence: '사망자 위로금 및 장제비 지원 : 378백만원(54명) ... 부상자 위로금 ... 610백만원(1인당 5백만원)', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0471'};
MATCH (a:ResponseAction {name: '전동차 무인운전구간 비상통과 규정개정'}), (b:Event {name: '대구 지하철 중앙로역 화재(2003)'}) MERGE (a)-[r:MODIFIES_RISK_OF]->(b) SET r += {phase: 'prevention', role: '비상시 정차 회피로 고립 위험 저감', effectiveness: 'Med', evidence: '자동운전구간 기관사 비상시 통과 운전할 수 있도록 규정개정', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0472'};
MATCH (a:ResponseAction {name: '역사내 화재시 안내방송 자동송출 체계'}), (b:Resilience {name: '비상안내방송 체계'}) MERGE (a)-[r:BUILDS]->(b) SET r += {phase: 'preparedness', role: '비상시 승객 대피안내 역량 강화', evidence: '역사내 화재시 안내 방송 자동송출 ... 유형별 안내방송 녹음 테이프 비치(화재, 침수 독가스, 지진, 터널붕괴)', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0473'};
MATCH (a:ResponseAction {name: '통신기계실 무정전장치 증설'}), (b:Resilience {name: '비상 통신 지속 역량'}) MERGE (a)-[r:BUILDS]->(b) SET r += {phase: 'mitigation', role: '정전 시 통신 지속 역량 확보', effectiveness: 'Med', evidence: '정전시 교환설비 및 전송설비기능 3시간 이상 확보(30개 역) ... 통신기계실 무정전장치 증설', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0474'};
MATCH (a:ResponseAction {name: '지하철 운전분야 직원 특별교육'}), (b:Resilience {name: '운영인력 비상대응 역량'}) MERGE (a)-[r:BUILDS]->(b) SET r += {phase: 'preparedness', role: '기관사 비상대응 역량 강화', evidence: '지하철 운전분야 직원(175명) 특별교육(2. 26~2. 28)', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0475'};
MATCH (a:ResponseAction {name: '윤진태 대구지하철공사 사장 해임'}), (b:Event {name: '대구 지하철 중앙로역 화재(2003)'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {phase: 'recovery', role: '사고 책임 인사조치', evidence: '윤진태 대구지하철공사 사장 해임 ... 김영창 대구시 종합건설본부장이 지하철공사 사장에 취임', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0476'};
MATCH (a:ResponseAction {name: '중앙로역 지상부 도로 교통통제'}), (b:Event {name: '중앙로역 구조물 붕괴위험'}) MERGE (a)-[r:MITIGATES]->(b) SET r += {phase: 'response', role: '붕괴위험 구간 지상 하중 차단', effectiveness: 'Med', evidence: '중앙로역 지상부 도로 전면 교통통제 ... 제한대상 : 모든 차량(긴급 및 상가 영업차량 제외)', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0477'};
MATCH (a:ResponseAction {name: '무료 셔틀버스 운행'}), (b:Event {name: '지하철 전구간 운행중단'}) MERGE (a)-[r:MITIGATES]->(b) SET r += {phase: 'response', role: '운행중단 교통서비스 공백 완화', effectiveness: 'Med', evidence: '지하철 운행중단구간 무료 셔틀버스 운행(3. 8부터) ... 차량 30대 투입, 3~6분 간격으로 왕복 운행', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0478'};
MATCH (a:Event {name: '지하철 전구간 운행중단'}), (b:Damage {name: '지하철 교통서비스 중단 피해'}) MERGE (a)-[r:CAUSES]->(b) SET r += {category: 'service', mechanism: '노선 운행 중지로 시민 교통서비스 중단', evidence: '운행 중지구간 : 명덕~신천(6개역, 4.8km)', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0479'};
MATCH (a:ResponseAction {name: '소방·경찰 지하철 탑승 순찰'}), (b:ManmadeHazard {name: '방화범 김대한'}) MERGE (a)-[r:PREVENTS]->(b) SET r += {phase: 'preparedness', role: '재발 방지·유사시 대응 홍보', effectiveness: 'Med', evidence: '소방: 경찰인력 지하철 탑승 순찰(3. 8~3. 31) ... 2인 1개조로 전동차 순찰 및 유사시 대응 방법 홍보', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0480'};
MATCH (a:ResponseActor {name: '대구지하철공사'}), (b:ResponseAction {name: '중앙로역 교통통제 및 안전보강공사'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', timing: '2003-03~04', duration: '여러 차례', detail: '외관조사·비파괴시험·정밀안전진단, 환풍기 가동, 코어 채취 등', evidence: '중앙로역 안전보강 공사(09:00~19:00) ... 정밀안전진단(외관조사, 비파괴시험), 계측기 설치 등', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0481'};
MATCH (a:ResponseActor {name: '한국시설안전기술공단'}), (b:ResponseAction {name: '중앙로역 구조물 정밀안전진단'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', timing: '2003-05-11~2003-07-21', objective: '중앙로역 시설물 안전상태 진단', evidence: '정밀안전진단 실시 - 기간: 5.11~7.21 - 진단기관: 한국시설안전기술공단; 중앙로역 안전진단용 코어 채취', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0482'};
MATCH (a:ResponseActor {name: '대구지하철화재사건 특별수사본부'}), (b:ResponseAction {name: '지하철참사 원인규명 및 책임자 수사'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', objective: '참사 원인규명 및 책임자 처벌', evidence: '대구지하철화재사건 특별수사본부 발족(3.19~4.23) - 조직: 본부장(대검찰청 강력부장)...', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0483'};
MATCH (a:ResponseAction {name: '실종자 인정사망 심사'}), (b:Damage {name: '대구 지하철 참사 인명피해'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {role: '사망자 신원·법적지위 확정', consequence: '다수 실종자를 인정사망으로 결정', evidence: '64명 인정사망 결정; 심사후 사망인정 35건, 심사제외(생존) 4건; 미확인 실종자 24명', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0484'};
MATCH (a:ResponseActor {name: '국립과학수사연구소'}), (b:ResponseAction {name: '국과수 신원확인작업'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', timing: '2003-04-12 종료 / 4.16~4.19 재개', location: '월배차량기지', objective: '희생자 신원확인 및 시신 일괄인도 준비', evidence: '국과수 신원확인작업 재개 - 기간: 4.16~4.19(월배차량기지); 국과수 신원확인 종료(4.12)', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0485'};
MATCH (a:ResponseActor {name: '대구시 사고대책본부'}), (b:ResponseAction {name: '사고수습대책본부 조직개편'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', timing: '2003-04-17, 4.30 조직개편', detail: '10개반 248명 → 6개반 7개팀 214명 → 6개반 1개팀 87명, 3교대→상시근무 전환', evidence: '대구시 사고수습대책본부 조직개편 - 10개반 248명 > 6개반 7개팀 214명; 6개반 7개팀 214명 -> 6개반 1개팀 87명', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0486'};
MATCH (a:ResponseActor {name: '고건 국무총리'}), (b:ResponseAction {name: '국무총리 주재 대구현지 관계장관회의'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', timing: '2003-03-20', location: '대구시청', detail: '관계장관회의 주재 및 유가족 대표 면담', evidence: '국무총리주재 대구현지 관계장관회의 개최(08:30~09:30) ... 참석: 27명; 국무총리와 유가족 대표 면담', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0487'};
MATCH (a:ResponseActor {name: '중앙정부'}), (b:ResponseAction {name: '특별재난지역 피해복구 중앙지원예산'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', timing: '2003-04-01 국무회의 의결', legalBasis: '재난관리법 제52조 및 예산회계법 제39조', amount: 30162686, unit: '천원', evidence: '특별재난지역 피해복구 중앙지원예산 확정(국무회의 의결) - 확정금액: 30,162,686천원(일반회계 목적예비비) ... 관련법령: 재난관리법 제52조 및 예산회계법 제39조', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0488'};
MATCH (a:ResponseAction {name: '전동차 내장재 교체 사업'}), (b:Event {name: '전동차 화재 확산'}) MERGE (a)-[r:PREVENTS]->(b) SET r += {effectiveness: 'High', reason: '기존 가연성 내장재가 유독가스 다량 발생·화재 급속 확산의 핵심 요인이었음', specialNote: '재발방지 핵심 대책', evidence: '중앙정부가 지하철 전동차 객실내장재를 불연성 자재로 교체; 전동차 불연성 내장재 개조경비: 16,991,486원', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0489'};
MATCH (a:ResponseActor {name: '대구시의회'}), (b:ResponseAction {name: '지하철화재사고피해보상에관한조례'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', timing: '2003-05-22 의결, 5.30 공포예정', reference: '제121회 임시회', objective: '피해 보상 법적근거 마련', evidence: '시의회 임시회(제121회) 지하철화재사고피해보상에관한조례안 의결 - 조례안 공포 예정일: 5.30 ... 보상금 등의 지급근거 마련', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0490'};
MATCH (a:ResponseAction {name: '지하철화재사고피해보상에관한조례'}), (b:Damage {name: '대구 지하철 참사 인명피해'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {role: '법적 보상근거 제공', consequence: '사망자·부상자·피해상인 보상 추진 기반 마련', evidence: '지하철화재사고피해보상에관한조례안 의결 ... 보상금 등의 지급근거 마련; 보상심의위원회의 구성', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0491'};
MATCH (a:Event {name: '지하철 전구간 운행중단'}), (b:Damage {name: '중앙로역 인근 상가 영업피해'}) MERGE (a)-[r:CAUSES]->(b) SET r += {mechanism: '운행중단·교통통제로 인근 상권 영업 마비', scale: '중앙로·동성로 인근 상가 다수', evidence: '영업피해로 따른 영업손실 보상; 지하철 운행중단으로 인한 영업손실 보상; 영업 등 간접피해 보상관련 회의', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0492'};
MATCH (a:Damage {name: '대구 지하철 참사 인명피해'}), (b:Context {name: '지하철참사 국민성금'}) MERGE (a)-[r:QUANTIFIED_BY]->(b) SET r += {role: '국민성금 규모', evidence: '지하철참사 국민성금 전달(14:00) - 금액: 65,660백만원 - 성금전달: 재해구호협회장->대구광역시장', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0493'};
MATCH (a:ResponseActor {name: '재정경제부'}), (b:ResponseAction {name: '피해상인 금융·세제지원'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', timing: '2003-04-25', objective: '피해상인 금융·세제지원', evidence: '지하철참사 피해상인과 현지간담회 ... 주관: 재정경제부 ... 피해상인 금융·세제지원 방안 협의 등', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0494'};
MATCH (a:ResponseAction {name: '피해상인 금융·세제지원'}), (b:Damage {name: '중앙로역 인근 상가 영업피해'}) MERGE (a)-[r:MITIGATES]->(b) SET r += {role: '경제피해 완화', effectiveness: 'Med', evidence: '피해상인 금융·세제지원 방안 협의; 영업손실보상 관련 사례설명', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0495'};
MATCH (a:ResponseActor {name: '추모사업추진위원회'}), (b:ResponseAction {name: '추모공원 조성사업'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', timing: '2003-05~', objective: '추모공원(추모탑·안전교육관·묘역) 조성', evidence: '추모사업추진위원회 구성 - 위원위촉: 10명 ... 추모공원 조성내용은 추모탑, 안전교육장, 묘역 등으로 함; 추모공원 조성기한은 3년 2개월내', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0496'};
MATCH (a:RiskFactor {name: '수창공원 추모공원 조성'}), (b:Event {name: '추모공원 조성 관련 사회갈등'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {reason: '인근 주민 조성반대 집회·결의문 채택, 중구청 농성 등 사회적 갈등 유발', probability: 'High', evidence: '수창추모공원 조성반대 주민집회; 대구시 중구의회에서 수창공원 예정지에 ... 묘역 조성을 반대한다는 결의문 채택; 희생자대책위원회 중구청 방문 농성', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0497'};
MATCH (a:Event {name: '추모공원 조성 관련 사회갈등'}), (b:Damage {name: '중구청 농성 중 교통사고 부상'}) MERGE (a)-[r:CAUSES]->(b) SET r += {mechanism: '자원봉사차량의 경찰기동대 돌진', timing: '2003-04-08 16:14', evidence: '지하철 희생자 유가족 교통사고 야기(16:14) ... 피해내용: 경찰기동대 대원 3명 부상 ... 경비중이던 기동중대원을 향해 돌진하여 사고 유발', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0498'};
MATCH (a:ResponseActor {name: '대구광역시'}), (b:ResponseAction {name: '중앙로역 지상도로 차량통행 재개'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', timing: '2003-04-10 00:00', detail: '안전펜스 철거(아카데미극장~하나은행), 시내버스 19개 노선 426대 정상운행 환원', evidence: '중앙로역 지상도로 차량통행 재개(00:00) - 19개 노선 426대 시내버스 정상운행(우회노선 환원); 안전펜스 철거(23:30)', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0499'};
MATCH (a:ResponseAction {name: '중앙로역 공기질 측정검사'}), (b:Event {name: '전동차 화재 확산'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {role: '화재 잔류 유해물질 점검', objective: '공기질 안전 확인 후 통행재개 판단', evidence: '중앙로역 공기질 측정검사 ... 내용: 다이옥신 등 유해물질 측정', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0500'};
MATCH (a:ResponseAction {name: '지하철1호선 종합안전점검'}), (b:RiskFactor {name: '지하철 화재 재발 위험'}) MERGE (a)-[r:PREVENTS]->(b) SET r += {effectiveness: 'Med', reason: '지하철 시스템 전반 안전상태 점검으로 재발 위험 저감', phase: 'prevention', evidence: '지하철1호선 종합안전점검 관련회의 ... 점검항목 및 점검단 구성 등; 지하철 1호선 종합안전점검관련 회의 ... 전문가 14, 참관인 6', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0501'};
MATCH (a:ResponseAction {name: '지하철 통신기계실 무정전전원장치(UPS) 점검'}), (b:RiskFactor {name: '지하철 화재 재발 위험'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {role: '화재시 정전·통신두절 재발 방지 점검', specialNote: '화재 당시 정전·통신 문제 관련 후속 점검', evidence: '지하철 통신기계실 무정전전원장치 점검(3.26~3.30) - 대상: 기지 및 역사 통신기계실; 통신장비 불안정에 따른 전화 및 FAX 점검', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0502'};
MATCH (a:ResponseAction {name: '대구지하철참사 사망자 보상협상'}), (b:Damage {name: '대구 지하철 참사 인명피해'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {role: '사망자 손해배상 산정', consequence: '사정 및 검증 시안 8개항 타결', evidence: '대구지하철참사 사망자 보상관련 제2차 협상 ... 합의사항: 사정 및 검증 시안 8개항 타결; 일용임금의 가동일수는 25일, 기술직종사자 22일', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0503'};
MATCH (a:ResponseAction {name: '사망자 유가족 생활안정자금 대부'}), (b:Damage {name: '대구 지하철 참사 인명피해'}) MERGE (a)-[r:MITIGATES]->(b) SET r += {role: '유가족 경제적 충격 완화', effectiveness: 'Med', evidence: '사망자 유가족에 대한 생활안전자금 대부시행', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0504'};
MATCH (a:ResponseAction {name: '대구지하철참사 백서발간'}), (b:Resilience {name: '재난 기록·학습 역량'}) MERGE (a)-[r:BUILDS]->(b) SET r += {role: '교훈 기록을 통한 학습 역량 구축', effectiveness: 'Med', evidence: '대구지하철참사 백서발간 설명회 ... 주최: 경북대 도시환경설비연구실 방재팀(설명자: 건축학부 홍원화 교수); 백서발간에 따른 조사 연구자료 협조요청', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0505'};
MATCH (a:Event {name: '대구 지하철 중앙로역 화재(2003)'}), (b:Damage {name: '대구 지하철 화재 사망자(희생자 명단)'}) MERGE (a)-[r:CAUSES]->(b) SET r += {role: '최종 인명피해 집계', phase: 'response', evidence: '총사망자 : 192명(신원 확인 185, 신원 미확인 6, 인정사망 1)', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0506'};
MATCH (a:Damage {name: '대구 지하철 화재 사망자(희생자 명단)'}), (b:Context {name: '사망자 시신인도 현황(2003-06-30)'}) MERGE (a)-[r:QUANTIFIED_BY]->(b) SET r += {detail: '시신인도 현황', dateTime: '2003-06-30', evidence: '시신인도 : 183명(장례 176, 재안치 7) · 미신청 2명 · 사망자 신원확인 및 시신인도(6.27~7.1) 월배차량기지 현장', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0507'};
