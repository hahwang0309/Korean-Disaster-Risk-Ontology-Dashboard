MATCH (a:ResponseAction {name: '지하철참사 피해 보상'}), (b:Context {name: '사망자 특별위로금 기준(221백만원/인)'}) MERGE (a)-[r:QUANTIFIED_BY]->(b) SET r += {detail: '사망자 특별위로금 단가', dateTime: '2003-07-31', evidence: '사망자 특별위로금 : 1인당 221백만원 · 부상자 특별위로금 : 노동능력상실률에 따라 차등 지급', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0510'};
MATCH (a:ResponseActor {name: '중앙안전대책위원회'}), (b:ResponseAction {name: '지하철참사 수습대책비 확정'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', actionType: '수습대책비 확정', dateTime: '2003-08-19', evidence: '수습대책비 확정 : 총액 1,605억원(중앙정부지원금 1,147억원, 대구시부담금 458억원)', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0511'};
MATCH (a:ResponseActor {name: '대구광역시'}), (b:ResponseAction {name: '중앙로역 시설물 복구공사'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', actionType: '시설물 복구공사', duration: '2003-07-10 착공 ~ 2003-12-30 완료', evidence: '지하철 중앙로역 시설물 복구공사 착공 - 공사기간 : 7.10~12.30(6개월) - 공사내용 : 토목, 건축·설비, 전기·통신 등', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0512'};
MATCH (a:ResponseAction {name: '중앙로역 시설물 복구공사'}), (b:Resilience {name: '중앙로역 운행 정상화'}) MERGE (a)-[r:BUILDS]->(b) SET r += {effectiveness: 'High', consequence: '중앙로역 정상운영 회복', evidence: '시설복구공사 진척에 따라 중앙로역 열차 무정차 통과 운행(05:20) · 12.31 지하철 중앙로역 정상운영(05:00)', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0513'};
MATCH (a:ResponseActor {name: '한국시설안전기술공단'}), (b:ResponseAction {name: '지하철 1호선 정밀안전진단'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'preparedness', actionType: '정밀안전진단', duration: '2003-05-11 ~ 2003-07-21', evidence: '정밀안전진단 완료 - 기간 : 5.11~7.21 - 진단기관 : 한국시설안전기술공단', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0514'};
MATCH (a:ResponseAction {name: '지하철 1호선 정밀안전진단'}), (b:Resilience {name: '지하철 운영 안전관리 역량'}) MERGE (a)-[r:BUILDS]->(b) SET r += {effectiveness: 'Med', reason: '재발방지를 위한 안전역량 강화', evidence: '지하철 1호선 종합안전점검 및 중앙로역 ... · 지하철화재 실제 종합소방훈련', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0515'};
MATCH (a:ResponseActor {name: '대구지하철공사'}), (b:ResponseAction {name: '지하철화재 종합소방훈련'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'preparedness', actionType: '종합소방훈련', dateTime: '2003-06-14', evidence: '지하철화재 실제 종합소방훈련(13:50~14:25) - 참여인원 : 452명(공사 127, 유관기관 125, 일반인 200) - 내용 : 1단계(열차 화재발생), 2단계(사고열차 화재 확산), 3단계(유관기관 조치)', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0516'};
MATCH (a:ResponseAction {name: '지하철화재 종합소방훈련'}), (b:Resilience {name: '지하철 운영 안전관리 역량'}) MERGE (a)-[r:BUILDS]->(b) SET r += {effectiveness: 'Med', reason: '화재발생·확산·유관기관 조치 단계별 대응 숙달', evidence: '1단계(열차 화재발생), 2단계(사고열차 화재 확산), 3단계(유관기관 조치)', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0517'};
MATCH (a:ResponseActor {name: '정부 관계부처(국무총리실 조정관 주재)'}), (b:ResponseAction {name: '정부 지원대책 및 도시철도 안전종합대책'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', actionType: '지원대책 수립', evidence: '국무총리실 조정관 주재 정부 관계부처 지원방안 협의 ... 정부 지원대책과 도시철도 안전종합대책(건교부) · 예산 지원대책(행자부, 기획예산처) · 부상자에 대한 치료 등 지원대책(보건복지부)', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0518'};
MATCH (a:ResponseActor {name: '대구광역시'}), (b:ResponseAction {name: '추모공원 조성사업'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', actionType: '추모공원 조성', evidence: '추모사업은 추모공원(위령탑, 안전교육관, 묘역) 조성과 추모벽 설치 및 기념(복지)재단 설립 · 추모공원 조성 위치는 수성구 삼덕동 118-1번지 일원 · 사업기간은 3년 2개월', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0519'};
MATCH (a:ResponseActor {name: '대구지하철참사 희생자대책위원회'}), (b:ResponseAction {name: '지하철안전관련 대정부 정책건의'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', actionType: '대정부 정책건의', dateTime: '2003-06-12', evidence: '희생자대책위 대정부 건의문 전달 - 건의내용 : 지하철안전관련 대정부 정책건의서 - 조치 : 청와대 관계관에게 건의문 전달', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0520'};
MATCH (a:ResponseActor {name: '경북대학교 연구진'}), (b:ResponseAction {name: '부상자 만성후유증관리 연구용역'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', actionType: '만성후유증 연구용역', duration: '3년간 추적조사', evidence: '부상자 상해에 대한 3년간 추적조사를 수행하여 추후 부상자의 만성후유증 치료비 지원에 필요한 근거자료 활용', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0521'};
MATCH (a:Damage {name: '대구 지하철 화재 사망자(희생자 명단)'}), (b:Population {name: '대구 지하철 화재 이용객(승객)'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {role: '피해 대상 인구 집단', reason: '피해자가 대구 전역 및 경북·경남·울산·충남·서울 등 광역에 거주 — 출퇴근·통학 시간대 다수 이용객 피해 시사', evidence: '주소 컬럼이 대구 각 구·군뿐 아니라 \'경상북도 상주시\', \'경상남도 마산시\', \'울산광역시 중구\', \'충청남도 천안시\', \'서울특별시 강남구\' 등 광역에 분포', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0522'};
MATCH (a:Damage {name: '대구 지하철 화재 사망자(희생자 명단)'}), (b:Context {name: '희생자 명단 기재항목(성명·주소·직업·나이·성별)'}) MERGE (a)-[r:QUANTIFIED_BY]->(b) SET r += {role: '명단 집계 근거', detail: '개인별 식별정보(성명·연령·직업)로 사망자 신원이 기록됨', evidence: '표 헤더 반복: \'번호 / 성명 / 주소 / 나이 / 직업 / 성별\', 나이 예: 13(중학생)~77(무직), 직업 예: \'초등학생\', \'대학 2\', \'버스기사\', \'세무사\'', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0523'};
MATCH (a:Event {name: '대구 지하철 중앙로역 화재(2003)'}), (b:Event {name: '지하공간 유독가스 충만'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {mechanism: '화재 연소로 유독가스 발생', spreadRisk: 'High', specialNote: '밀폐된 지하공간에서 유독가스 충만', evidence: '칠흑같은 어둠속에서 매캐한 유독가스에 가슴을 쥐어뜯으며 숨졌을 피해자', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0524'};
MATCH (a:Event {name: '지하공간 유독가스 충만'}), (b:Damage {name: '대구 지하철 화재 사망 피해'}) MERGE (a)-[r:CAUSES]->(b) SET r += {directCause: '유독가스 질식', mechanism: '유독가스 흡입에 의한 질식사', specialNote: '피해자의 절규 \'아빠, 뜨거워 죽겠어요, 살려주세요\'', evidence: '칠흑같은 어둠속에서 매캐한 유독가스에 가슴을 쥐어뜯으며 숨졌을 피해자 / 향후 사고 관련 유해가스에 의해 발생할 수 있는 모든 종류의 암과 경피증 등 난치성질환', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0525'};
MATCH (a:Event {name: '지하공간 유독가스 충만'}), (b:Damage {name: '유해가스 노출 후유 난치성질환(암·경피증)'}) MERGE (a)-[r:TRIGGERS_SECONDARY]->(b) SET r += {timing: '사고 이후 장기', mechanism: '유해가스 노출에 의한 만성 후유증', specialNote: '암·경피증 등 난치성질환 발생 우려로 치료비 조성 합의', evidence: '본사고 관련 유해가스에 의해 발생할 수 있는 모든 종류의 암과 경피증 등 난치성질환에 대한 치료비를 중앙부처 예산으로 조성하기 위해 공동 노력', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0526'};
MATCH (a:ResponseAction {name: '피해자 보상금 지급'}), (b:Other {name: '대구광역시지하철화재사고피해보상에관한조례'}) MERGE (a)-[r:GUIDED_BY]->(b) SET r += {reference: '제4조', specialNote: '보상금 지급의 근거 조례', evidence: '관련 법규 대구광역시지하철화재사고피해보상에관한조례 제4조', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0527'};
MATCH (a:ResponseActor {name: '대구광역시지하철참사보상심의위원회'}), (b:ResponseAction {name: '피해자 보상금 지급'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', actionType: '심의·의결', specialNote: '사망자·부상자·물적피해자 보상금 심의조서 의결', evidence: '보상심의위원회의 심의를 거쳐 \'을\'에게 지급 / 대구광역시지하철참사보상심의위원회 위원장', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0528'};
MATCH (a:ResponseActor {name: '대구광역시'}), (b:ResponseAction {name: '손해사정 및 검증 업무'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', actionType: '손해사정·검증 위탁', specialNote: '손해사정인·검증손해사정인 협약 체결로 배상액 산정', evidence: '사망자 손해사정업무 협약서 / 희생자 검증손해사정업무 협약서 / 부상자 손해조사 및 손해액 사정업무에 대한 협약서 (보수 4.5%, 2.85%, 1.48%)', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0529'};
MATCH (a:ResponseAction {name: '국민성금 특별위로금 배분'}), (b:Damage {name: '대구 지하철 화재 사망 피해'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {phase: 'recovery', specialNote: '국민성금을 재원으로 한 위로 보상', evidence: '특별위로금 배분은 사망자 1인당 지급한 특별위로금 일금 221백만원을 기준으로 부상의 정도에 따라 차등 지급', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0530'};
MATCH (a:ResponseActor {name: '대구광역시 사고대책본부 유족대책반'}), (b:ResponseAction {name: '사망자 장례지원'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', actionType: '장례지원', amount: 700, unit: '만원', specialNote: '사망자 1인당 장례경비 700만원(장제비 600, 위로금 100)', evidence: '사망자 1인당 장례경비 700만원(장제비 600, 위로금100)을 장례일정 확정시 유가족에게 직접 전달 / 화장장 및 공설묘지, 납골당 이용시 무료로 지원', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0531'};
MATCH (a:ResponseActor {name: '한울인봉사단'}), (b:ResponseAction {name: '유가족 한방의료봉사'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', actionType: '한방의료봉사', duration: '2003.2.25~3.17(21일간)', specialNote: '유가족 500여명에게 1천여만원 상당 의료봉사', evidence: '2월 25일부터 3월 17일(21일간)까지 전국에서 한울인 한의사 50여명, 자원봉사자 650여명은 유가족 500여명에게 ... 1천여만원 상당의 의료물품으로 의료봉사를 실시', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0532'};
MATCH (a:Event {name: '대구 지하철 중앙로역 화재(2003)'}), (b:Event {name: '유독가스·농연 확산'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {mechanism: '화재 연소로 유독가스 발생', spreadRisk: 'High', timing: '화재 직후', evidence: '수많은 선량한 사람들의 숨통을 죄이던 유독가스의 매캐한 내음 … 중앙로역에서 반월당까지는 검은 연기와 매캐한 냄새', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0533'};
MATCH (a:RiskFactor {name: '지하 밀폐구조(지하철 화재 취약성)'}), (b:Damage {name: '대구 지하철 화재 인명피해'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'High', mechanism: '밀폐 지하공간이 유독가스 농축·대피 지연을 유발', evidence: '시커먼 연기가 지하도를 통해 연통을 가득 메우며 솟아나고 있었고, 유독성 가스 때문에 숨이 막혔고 … 앞도 잘 보이지 않는 상황', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0534'};
MATCH (a:RiskFactor {name: '안전 불감증'}), (b:Event {name: '대구 지하철 중앙로역 화재(2003)'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'High', reason: '조금만 신경 쓰면 미연에 방지할 수 있는 사고를 안전불감증이 큰 사고로 키움', evidence: '조금만 신경을 더 쓰면 미연에 방지할 수 있는 사고들이 무관심과 설마하는 안전 불감증에 의해 큰 사고로 이어져 … 우리 모두가 총체적인 안전불감증의 원인을 다시 한번 곱씹어 본다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0535'};
MATCH (a:RiskFactor {name: '대구 연쇄 재난 이력'}), (b:Event {name: '대구 지하철 중앙로역 화재(2003)'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'Med', reason: '동일 지역에서 반복되는 대형 안전사고 패턴', specialNote: '1995/2000/2003 반복 발생 — 지역적 재난 취약성', evidence: '지하철사고 이번이 세 번째, … 1995년 상인동 가스폭발사고, 2000년 신남네거리 붕괴사고, 2003년 지하철방화 화재사고', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0536'};
MATCH (a:ResponseActor {name: '소방·119 구조대원'}), (b:ResponseAction {name: '중앙로역 화재 인명구조 작업'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', timing: '사고 직후~수일간', evidence: '소방구조대원들은 사력을 다해 구조작업에 … 이미 소방관 아저씨들은 … 산소마스크와 중장비를 갖추고 들어갔다 나오기를 반복', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0537'};
MATCH (a:ResponseActor {name: '대한적십자사 봉사회'}), (b:ResponseAction {name: '적십자 급식·구호 봉사활동'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', timing: '사고 당일 비상소집~약 두 달', evidence: '적십자 급식차량을 이용하여 급식봉사활동을 실시 … 많을 때는 약 3,000명분의 식사 … 무료건강상담센터를 마련 … 혈액형 검사를 해 주었다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0538'};
MATCH (a:ResponseActor {name: '심리상담 자원봉사단'}), (b:ResponseAction {name: '유가족·부상자 심리상담 봉사'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', objective: '외상후 스트레스·우울증 등 심리적 응급처치', evidence: '심리적 응급처치를 위한 위기상담 … 특히 염려되는 점은 심각한 외상성 스트레스 증세와 우울증세 … 약물상담과 각종 심리치료를 전문가들이 직접 분담', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0539'};
MATCH (a:Resilience {name: '재해구호훈련'}), (b:Damage {name: '대구 지하철 화재 인명피해'}) MERGE (a)-[r:OFFSETS]->(b) SET r += {effectiveness: 'Med', mechanism: '사전 훈련된 구호 대응이 피해자 고통·2차 피해를 완화', evidence: '재해구호 훈련이 평소에 잘 되어 있어 우리 봉사원은 늦어도 4시간 정도면 급식준비까지 모든 것이 완료된다 … 평소에 이런 위기상황에 대비해왔기 때문', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0540'};
MATCH (a:Event {name: '대구 지하철 중앙로역 화재(2003)'}), (b:Context {name: '사고 발생시간(2003-02-18 09:53)'}) MERGE (a)-[r:OCCURS_AT]->(b) SET r += {timing: '발생 시각', evidence: '2003년 2월 18일 화요일 아침 9시 53분 … 화재장소가 중구소재 중앙로역', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0541'};
MATCH (a:RiskFactor {name: '지하 밀폐구조(지하철 화재 취약성)'}), (b:Damage {name: '중앙로역 화재 인명피해'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {probability: 'High', reason: '밀폐공간으로 가스 배출 지연, 사고 후에도 매캐한 냄새 장기 잔류', mechanism: '유독가스 농도 상승', evidence: '입구에 닿는 순간 남아 있는 유독가스로 숨을 쉴 수가 없었다 / 아직도 매캐한 냄새가 가시지 않아 숨쉬기가 불편했지만', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0542'};
MATCH (a:RiskFactor {name: '대피·안전 교육 미흡'}), (b:Damage {name: '중앙로역 화재 인명피해'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {probability: 'Med', reason: '화재시 대피 교육을 받지 못해 피해 확대', mechanism: '대피 실패', evidence: '우리나라 사람들이 화재시 대피 교육을 해보지 못해서인가? / 이번 지하철 참사가 대피 교육도 미흡했지만', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0543'};
MATCH (a:Event {name: '대구 지하철 중앙로역 화재(2003)'}), (b:Event {name: '중앙로역 붕괴 위험'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {probability: 'Med', mechanism: '화재 열손상으로 역사 구조물 붕괴 위험 발생', timing: '사고 후', evidence: '붕괴 위험이 있어서 더 이상 내려가지 못한다고 / 중앙로역 입구를 봉쇄하기 시작했다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0544'};
MATCH (a:ResponseActor {name: '119구조대'}), (b:ResponseAction {name: '지하층 인명구조활동'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', effectiveness: 'High', timing: '사고 당일', specialNote: '유독가스·연기 속 필사적 구조', evidence: '한사람이라도 더 구조하고자 애쓰는 119구조대원들의 필사적인 구조활동이 한창 전개되고 있었다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0545'};
MATCH (a:ResponseAction {name: '지하층 인명구조활동'}), (b:Event {name: '대구 지하철 중앙로역 화재(2003)'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {phase: 'response', timing: '사고 당일', evidence: '막 중앙로역에 도착했을 때, 소방차 앰뷸런스, 119구조대 등 구조를 위한 차량들로 도로는 혼잡했으며', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0546'};
MATCH (a:ResponseActor {name: '대구시 사고대책본부'}), (b:ResponseAction {name: '대구시 사고대책본부 설치'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', timing: '사고 당일~', location: '대구 시민회관', evidence: '사고대책본부가 설치된 시민회관 / 합동분향소가 시민회관에 마련된다는 소식 / 대책본부 내에 조의금 접수처 개설', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0547'};
MATCH (a:ResponseActor {name: '민간 자원봉사단체'}), (b:ResponseAction {name: '유가족 구호·무료급식 봉사'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', effectiveness: 'High', timing: '사고 이튿날~약 2개월', specialNote: '24시간 주야 교대 봉사', evidence: '민간단체의 자원봉사는 사고수습에 큰 힘이 되었다 / 30여개의 단체들이 참여해 식사와 커피·녹차, 생필품 등을 제공', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0548'};
MATCH (a:ResponseAction {name: '유가족 구호·무료급식 봉사'}), (b:Damage {name: '중앙로역 화재 인명피해'}) MERGE (a)-[r:MITIGATES]->(b) SET r += {phase: 'response', effectiveness: 'Med', reason: '유가족 정서·생활 피해 완화, 직접적 인명피해는 회복 불가', timing: '사고 수습기', evidence: '유가족과 관계자들에게 따뜻한 위로가 되었다 / 그분들의 아픔을 조금이라도 덜어 줄 수만 있다면', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0549'};
MATCH (a:RiskFactor {name: '민관 합동 재난구조 시스템 부재'}), (b:Damage {name: '중앙로역 화재 인명피해'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {probability: 'Med', reason: '재난구조 시스템 미작동으로 체계적 지원 미흡, 봉사단체 난립으로 혼잡 초래', mechanism: '수습 비효율', evidence: '민관 합동으로 구성된 재난구조 시스템이 제대로 작용하지 않아 좀더 체계적인 지원이 되지 못했다 / 각 단체에서의 봉사팀 난립은 오히려 혼잡스러움을 초래', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0550'};
MATCH (a:ResponseActor {name: '대구시 사고대책본부'}), (b:ResponseAction {name: '유가족 사망자 인정·합의 지연 대응'}) MERGE (a)-[r:FAILS]->(b) SET r += {phase: 'response', effectiveness: 'Low', reason: '유가족 사망자 인정 지연·합의 지연으로 유가족에게 2차 상처', specialNote: '수습 후속처리 미흡', evidence: '사망자로 인정도 못 받고 제사를 지내라고 했던 당국 / 유족들과 대책본부의 긴장감은 고조되고 / 이번 지하철 참사가 ... 사고 후 뒤처리에도 미흡했다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0551'};
MATCH (a:RiskFactor {name: '전동차 내장재(가연성 합성수지)'}), (b:Event {name: '1079호 전동차 화재'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {mechanism: '가연성 내장재가 불길을 순식간에 전동차 전체로 확산', effectiveness: 'High', spreadRisk: 'High', evidence: '우리나라 지하철 객차는 온통 가연성 물질로 꾸며져 있다. 시트는 물론이고 천장 손잡이에서 도료에 이르기까지 가연성 물질 일색 … 방염 처리된 재료를 사용하는 것과 대비', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0552'};
MATCH (a:Event {name: '1079호 전동차 화재'}), (b:Event {name: '1080호 전동차 연소(맞은편 전동차 옮아붙음)'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {mechanism: '선로 간 거리 1m 미만, 달아오른 객차 불꽃이 건너편 전동차 도료로 옮겨붙음', spreadRisk: 'High', timing: '9시56분쯤 반대편 차로 도착', evidence: '맞은편 전동차에 옮아붙어 객차12량 전소 … 선로 사이 1m 안돼 삽시간에 옮겨붙어 … 9시56분쯤 반대편 차로의 중앙로역에 대곡 방향 열차가 도착, 피해가 더 커졌다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0553'};
MATCH (a:RiskFactor {name: '지하 밀폐 갱도 구조(선로 간격 1m 미만)'}), (b:Event {name: '1080호 전동차 연소(맞은편 전동차 옮아붙음)'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {mechanism: '근접 선로로 불길이 맞은편 전동차에 쉽게 전파', spreadRisk: 'High', evidence: '선로의 전동차 도료로 옮겨 붙는 것은 너무 손쉬운 상황이었다 … 동차와의 거리도 1m가 채 안됐다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0554'};
MATCH (a:ResponseActor {name: '1080호 전동차 기관사 최상열'}), (b:ResponseAction {name: '상행 전동차 정차·문개방 지연 대응'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '사령실로부터 정차 통보·지령 못 받아 차량을 세움, 사고 상황 파악 위해 5분 대기 후 문 열어줌', consequence: '승객 대피 지연으로 더 큰 피해', timing: '화재 발생 후', evidence: '맞은편 전동차의 기관사는 사고 상황을 파악하기 위해 5분을 기다렸다가 문을 열어줘, 승객들의 대피가 늦어져 처음 불이 난 전동차보다 더 큰 피해를 낳았다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0555'};
MATCH (a:ResponseActor {name: '종합사령실(대구지하철공사)'}), (b:ResponseAction {name: '화재 통보·정차 지령 미전달'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '상행선 전동차에 화재 정차 통보·지령 미전달(3~4분 시간 여유 있었음)', consequence: '상행 전동차가 불구덩이 역사로 진입, 사상자 증가', mechanism: '역사 화재 발생 보고를 즉각 상부에 안 함', evidence: '상행선 전동차는 사령실로부터 아무런 정보나 지령도 받지 못했고 결과적으로 승객들을 불구덩이로 이끌었다 … 최소한 3~4분의 시간적 여유가 있었던 셈', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0556'};
MATCH (a:Event {name: '중앙로역 정전(2003 대구지하철)'}), (b:Event {name: '승객 대피 혼란·고립(2003 대구지하철)'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {mechanism: '암흑 속 승객들이 출입구로 한꺼번에 몰려 아비규환', spreadRisk: 'High', evidence: '승객돌이 서로 출입구를 먼저 빠져 나오려고 아우성을 지르는 등 아비규환으로 변했다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0557'};
MATCH (a:Event {name: '유독가스 확산(2003 대구지하철)'}), (b:Damage {name: '대구지하철 화재 인명피해'}) MERGE (a)-[r:CAUSES]->(b) SET r += {mechanism: '유독가스 질식으로 다수 승객 의식불명·사망', scale: '대형', evidence: '이 날 오후 11시 현재 적어도 승객 122여명이 사망하고 138명이 부상, 85명이 실종된 것으로 추정되는 대참사', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0558'};
MATCH (a:Event {name: '1079호 전동차 화재'}), (b:Event {name: '중앙로역 기계실 작업자·승객 고립(2003)'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {mechanism: '기계실 작업인부 및 고립자에 연기 차단으로 구조 접근 곤란', spreadRisk: 'High', evidence: '중앙로역 기계실 내에 작업인부 6명 등 12명이 고립돼 있고 전동차 안에도 승객들이 일부 남아 있으나, 연기때문에 구조대 접근이 이뤄지지 않아', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0559'};
MATCH (a:ResponseActor {name: '북부소방서 구조대(황윤찬 소방위)'}), (b:ResponseAction {name: '중앙로역 인명구조 활동(소방·직원)'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', timing: '2003-02-18 10시께', effectiveness: 'High', detail: '자신의 산소호흡기를 빼내 실신자 입에 물려 구출, 수십명 구조', evidence: '대구 북부소방서 구조대장 황윤찬(44) 소방위를 비롯한 구조대원 7명은 … 자신의 산소 호흡기를 빼내 … 쓰러진 이들의 입에 물렸다 … 수십명의 고귀한 목숨을 구해냈다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0560'};
MATCH (a:ResponseActor {name: '지하철 직원 장대성·김상만'}), (b:ResponseAction {name: '중앙로역 인명구조 활동(소방·직원)'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', consequence: '끝내 못 빠져나오고 주검으로 발견', timing: '사고 발생 직후', detail: '유독가스가 방화벽 친 사무실까지 엄습', evidence: '차량정비공 장씨와 김씨는 … 마지막까지 승객구조에 나섰던 두 직원은 끝내 주검으로 발견됐다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0561'};
MATCH (a:Event {name: '1079호 전동차 화재'}), (b:Damage {name: '전동차 객차 12량 전소'}) MERGE (a)-[r:CAUSES]->(b) SET r += {mechanism: '상·하행 객차 12량 전소', scale: '대형', timing: '발생 3시간반 만 진화(오후 1시30분경)', evidence: '불은 3시간반 만에 상·하행 전동차 객차 12량을 모두 태우고 이날 오후 1시30분쯤 진화됐으며', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0562'};
MATCH (a:Population {name: '주변 승객(전동차 내)'}), (b:ResponseAction {name: '방화 저지 시도'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'prevention', effectiveness: 'Low', reason: '라이터 켜려는 김씨를 제지했으나 전동차 멈추는 순간 발화', evidence: '김씨가 라이터를 자꾸 켜려고 해 주변 승객들이 달려들어 제지했으나 전동차가 멈춰서는 순간 불이 났다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0563'};
MATCH (a:ResponseActor {name: '대구광역시'}), (b:ResponseAction {name: '대구시 사고대책본부 설치'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', timing: '사고 직후', detail: '시청 2층 밀라노 프로젝트 사무실에 상황실 설치, 긴급 간부회의 소집', evidence: '대구시는 시청 2층 밀라노 프로젝트 사무실에 상황실을 설치, 사고 수습에 들어갔다 … 김기옥 행정부시장을 사고대책본부장으로 임명', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0564'};
MATCH (a:ResponseActor {name: '노무현 대통령 당선자'}), (b:ResponseAction {name: '전국 지하철 안전점검'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'prevention', detail: '전국 지하철 안전점검 실시, 대구 우선 안전진단, 재난방지대책기구 설치 약속', evidence: '노무현 대통령 당선자는 … 전국의 지하철 안전 진단을 … 대구를 가장 먼저 안전 진단할 것 … 재난방지대책기구를 설치하겠다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0565'};
MATCH (a:RiskFactor {name: '전동차 비상장치·방재 체계 미비'}), (b:Damage {name: '대구지하철 화재 인명피해'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {mechanism: '초기 대처·대피 실패로 인명피해 확대', effectiveness: 'High', evidence: '인명구조 비상장치 미비 … 엉성한 방재 체계 … 비상상황에 대처하는 체계가 미흡했기 때문이라는 것이 안전 관계자들의 분석', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0566'};
MATCH (a:RiskFactor {name: '대구지하철 안전불감증·반복 사고 이력'}), (b:Event {name: '1079호 전동차 화재'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {reason: '반복된 대형사고와 안전불감증이 참사 규모를 키움', probability: 'Med', evidence: '지금까지 지하철과 관련해 사망자가 발생한 9건의 굵직굵직한 사고 중 4건이 대구지하철에 집중 … 95년엔 가스폭발 101명 사망 … 초기 대처를 제대로 하지 못해 인명피해가 커졌다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0567'};
MATCH (a:Event {name: '1079호 전동차 화재'}), (b:Event {name: '1080호 전동차 중앙로역 진입·정차'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {mechanism: '맞은편 1080호 전동차가 화재 중인 중앙로역으로 진입', directCause: '사령실이 1080호를 진입하도록 함', spreadRisk: 'High', specialNote: '사령실이 1080호 전동차를 사고가 난 중앙로역으로 진입토록 함', evidence: '사령실이 1080호 전동차를 사고가 난 중앙로역으로 진입토록 한 사실', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0568'};
MATCH (a:Event {name: '1080호 전동차 중앙로역 진입·정차'}), (b:Event {name: '1080호 전동차 출입문 잠김'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {mechanism: '1080호 정차 즉시 모두 문이 열려 일부 승객 대피 뒤 문이 잠김', directCause: '정차 후 출입문 잠김', spreadRisk: 'High', evidence: '2대가 정차 즉시 모두 문이 열려 일부 수객이 대피한 뒤 문이 잠긴 것으로', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0569'};
MATCH (a:Event {name: '승객 고립'}), (b:Damage {name: '대구 지하철 참사 인명피해'}) MERGE (a)-[r:CAUSES]->(b) SET r += {directCause: '고온·유독연기 속 대피 불가', mechanism: '1천도 이상 고온에서 장시간 노출, 검게 타버린 상태', scale: '대규모', evidence: '희생자들이 1천도 이상 고온에서 3시간이상 갇혀 있었고 / 검게 타버린 상태였다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0570'};
MATCH (a:Damage {name: '대구 지하철 참사 인명피해'}), (b:Context {name: '실종자 통계(2003-02-25)'}) MERGE (a)-[r:QUANTIFIED_BY]->(b) SET r += {timing: '2003-02-25 기준', detail: '신고된 실종자 571명 중 신원확인 54명, 미확인 실종자 320명', evidence: '현재까지 신고된 실종자는 571명. 원이 확인된 54명 / 미확인 실종자는 320명으로', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0571'};
MATCH (a:Event {name: '1080호 진입 차단 실패'}), (b:Damage {name: '대구 지하철 참사 인명피해'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {mechanism: '대피 시기 상실로 인명피해 확대', scale: '절반 이상', reason: '결정적인 대피 시기를 놓침', evidence: '결정적인 대피 시기를 놓친 것으로 드러났다 / 진입을 막았다면 인명피해는 절반 이상 줄일 수 있었을 것', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0572'};
MATCH (a:ResponseActor {name: '대구지방경찰청'}), (b:ResponseAction {name: '사령실·기관사 과실 수사'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', timing: '2003-02-20', detail: '사고 전동차 관계자 등 108명 조사, 기관사·사령실 직원 10여명 교신내용 분석', evidence: '대구지방경찰청은 사고 전동차 관계자 등 108명에 대해 조사를 벌인 / 사령실·기관사 10여명 조사', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0573'};
MATCH (a:ResponseActor {name: '노무현 대통령 당선자'}), (b:ResponseAction {name: '재난관리기구 설치'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'preparedness', timing: '2003-02-20', objective: '각종 재난 대처 위한 상설기구 설치', evidence: '각종 재난에 대처하기 위해 재난관리기구를 조속히 설치 하겠다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0574'};
MATCH (a:ResponseActor {name: '대구시 사고대책본부'}), (b:ResponseAction {name: '유가족·부상자 성금 지원'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', timing: '2003-02-25 기준', detail: '성금·성품 접수 및 유가족·부상자 지원', evidence: '성금 기탁액이 200억원을 넘어서는 / 화재사고대책본부에는 희생자 유가족 및 부상자를 돕기 위한 성금', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0575'};
MATCH (a:ResponseAction {name: '유가족·부상자 성금 지원'}), (b:Context {name: '성금 접수 현황(2003-02-25)'}) MERGE (a)-[r:QUANTIFIED_BY]->(b) SET r += {timing: '2003-02-25 오전 기준', detail: '성금 1972건 209억4300만원, 성품 94건', evidence: '성금 1972건 209억 4300만원과 / 성품 94건 / 객 4만3118명이 분향', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0576'};
MATCH (a:ResponseActor {name: '대구시 자원봉사센터'}), (b:ResponseAction {name: '지하철 화재사고 자원봉사활동'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', detail: '하루 1만1천여명분 식사 준비, 하역·청소·상담·통신지원', scale: '200여개 단체 연인원 6천여명', evidence: '지금까지 200여개 단체 연인원 6천여명 / 하루 1만명 식사준비 상담·통신 등 지원', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0577'};
MATCH (a:RiskFactor {name: '신원확인 곤란(고열·연기)'}), (b:Event {name: '인정사망 절차 난항'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {mechanism: '신원확인 곤란으로 사망 인정 절차 장기화·법정분쟁', reason: '민법상 실종선고는 1년 소요', evidence: '신원확인이 어려운 실종자들의 / 인정사망 여부를 둘러싸고 법정공방 등 난항이 예상', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0578'};
MATCH (a:ResponseActor {name: '대구시 사고대책본부'}), (b:ResponseAction {name: '인정사망제도 적용'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', actionType: '제도 적용', objective: '신원확인 곤란 실종자를 사망자로 인정', evidence: '인정사망제를 추진하기 위해 / 인정사망은 삼풍배화점 참사 때 30여명, 대한항공기 괌 참사 때 50여명에게 적용', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0579'};
MATCH (a:ResponseActor {name: '고건 국무총리'}), (b:ResponseAction {name: '정부 특별지원대책반 구성'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', timing: '2003-02-27', detail: '차관급/1급 공무원 단장의 정부 특별지원대책반 구성·대구 상주', evidence: '중앙정부 차원의 특별지원대책반을 구성, 대구에 상주시키겠다 / 차관급이나 1급 공무원을 단장으로', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0580'};
MATCH (a:ResponseActor {name: '실종자가족대책위원회'}), (b:ResponseAction {name: '별도 정부 대책본부 요구'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', timing: '2003-02-25 이후', detail: '조해녕 대구시장 퇴진 및 중앙정부 대책본부 마련 요구, 대통령 탄원서 제출', evidence: '대책본부의 무성의에 항의하며 조해녕 대구시장의 퇴진과 중앙정부 차원의 대책본부 마련을 요구 / 대화가 이틀째 끊겼다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0581'};
MATCH (a:ManmadeHazard {name: '대구 지하철 중앙로역 방화'}), (b:Event {name: '대구지하철 화재참사(2003)'}) MERGE (a)-[r:TRIGGERS]->(b) SET r += {scale: '대참사', probability: 'High', mechanism: '방화가 화재로 발현', specialNote: '어이없는 방화가 유례없는 대참사로 이어짐', evidence: '어이없는 방화가 유례없는 대참사로 이어진 대구지하철방화사건', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0582'};
MATCH (a:Event {name: '대구지하철 화재참사(2003)'}), (b:Damage {name: '대구 지하철 참사 인명피해'}) MERGE (a)-[r:CAUSES]->(b) SET r += {directCause: '화재·유독가스', specialNote: '수백명의 무고한 희생자', evidence: '7일 현재 이번 참사로 생사가 확인되지 않고 있는 실종자는 모두 248명이다 / 현재까지 확인되지 않은 시신 222구', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0583'};
MATCH (a:Event {name: '대구지하철 화재참사(2003)'}), (b:Context {name: '사고 발생시간(2003-02-18 09:53)'}) MERGE (a)-[r:OCCURS_AT]->(b) SET r += {role: '발생일', evidence: '지난달 18일 참사 직후 지하철화재사고대책본부', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0584'};
MATCH (a:RiskFactor {name: '조기훼손에 취약한 사고현장(중앙로역)'}), (b:Event {name: '사고현장 조기훼손(증거인멸 논란)'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'High', mechanism: '물청소·잔재물 수거로 증거 소실 위험 증대', specialNote: '유류품·유해 잿더미가 신원확인 단서', evidence: '유해 잿더미가 사고 전동차를 옮기는 도중 날아가고 쓰레기더미에서 희생자들의 유류품은 물론 사체 일부가 발굴되는 등 부작용이 속출', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0585'};
MATCH (a:RiskFactor {name: '복구·발전 우선 논리(원인규명·책임자처벌 회피)'}), (b:Event {name: '사고현장 조기훼손(증거인멸 논란)'}) MERGE (a)-[r:TRIGGERS]->(b) SET r += {probability: 'High', mechanism: '지하철 운행 중단 시 국가신인도 악영향 우려로 서둘러 청소', reason: 'U대회 성공개최·대구발전 명분', evidence: '대구시의 한 고위공무원은 사고현장을 청소했고...지하철 운행을 중단하면 국가신인도에까지 악영향을 미친다며 서둘러 사고현장을 청소', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0586'};
MATCH (a:Event {name: '사고현장 조기훼손(증거인멸 논란)'}), (b:Damage {name: '신원확인 단서 훼손 피해'}) MERGE (a)-[r:CAUSES]->(b) SET r += {directCause: '유류품·유해 소실', specialNote: '신원확인 중요 단서 훼손', evidence: '신원 확인에 중요한 단서가 될 유해 잿더미가 사고 전동차를...옮기는 도중 날아가고...사체 일부가 발굴되는 등 부작용이 속출', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0587'};
MATCH (a:ResponseActor {name: '대구지검'}), (b:ResponseAction {name: '참사 진상규명 수사'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', objective: '사고원인·책임소재 규명, 증거인멸·은폐 여부 수사', timing: '2003-02~03', evidence: '검찰이 대구지하철화재참사 수사전면에 나섰다 / 관련자들의 과실 유무, 범행의 조직적 은폐 여부에 대한 철저한 진상 규명', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0588'};
MATCH (a:ResponseActor {name: '검찰총장(김각영)'}), (b:ResponseActor {name: '수사지휘본부'}) MERGE (a)-[r:COMMANDS]->(b) SET r += {role: '특별지시', objective: '수사지휘본부 설치 지시', timing: '2003-02-28', evidence: '대구지검은 28일 김각영 검찰총장의 특별지시에 따라 임안식 2차장검사를 본부장으로 하는 수사지휘본부를 설치', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0589'};
MATCH (a:ResponseActor {name: '수사지휘본부'}), (b:ResponseAction {name: '현장훼손 책임소재 수사'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', objective: '현장 조기훼손 책임소재·관계기관 협의 여부 조사', measures: '물청소 지시 여부·증거인멸 고의성 수사, 1079호 기관사 영장 재신청', evidence: '검찰이 대구지하철 참사현장의 조기훼손에 대한 책임소재를 가리기 위한 수사에 본격 착수 / 물 청소 등 현장 조기복구에 대해 관계기관간의 협의가 있었는지 여부', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0590'};
MATCH (a:ResponseActor {name: '대구지하철참사 시민사회단체대책위원회'}), (b:ResponseAction {name: '현장보존 진정서 제출 및 책임자 고발'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', objective: '현장보존 및 책임자 처벌 요구', timing: '2003-03-04', evidence: '시민사회단체 대책위원회가 지하철 참사와 관련해 현장보존진정서를 대구지방법원에 제출 / 조해녕 대구시장을 비롯 대구시 고위책임자들을 업무상 과실 혐의로 고발할 방침', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0591'};
MATCH (a:ResponseActor {name: '대구시 사고대책본부'}), (b:ResponseAction {name: '현장 조기복구 조치'}) MERGE (a)-[r:FAILS]->(b) SET r += {phase: 'response', reason: '현장 조기복구로 증거 훼손 초래', specialNote: '물청소·전동차 월배차량기지 이동으로 증거인멸 고의성 논란', evidence: '조 시장이 지하철 참사의 중요한 증거인 중앙로역에 대한 청소작업과 사고 전동차를 월배차량기지로 옮긴 것은 증거인멸의 고의성이 높다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0592'};
MATCH (a:ResponseActor {name: '중앙특별지원단'}), (b:ResponseActor {name: '실종자가족대책위원회'}) MERGE (a)-[r:COORDINATES_WITH]->(b) SET r += {role: '인정사망심사위 구성 합의', timing: '2003-03-07', detail: '실종자대책위 입장 대폭 수용', evidence: '대구지하철 사고수습 중앙특별지원단과 대구지하철참사 실종자가족 대책위원회는 7일...인정사망심사위 구성과 관련 2차 협의', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0593'};
MATCH (a:ResponseActor {name: '중앙특별지원단'}), (b:ResponseActor {name: '인정사망심사위원회'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', objective: '실종자 조기 사망인정', timing: '2003-03-08 발족, 03-10 첫 회의', evidence: '인정사망심사위원회가 8일 발족된다 / 위원장 1명 포함해 위원 14명 등 총 15명으로...중앙지원단 추천 7명, 실종자대책위 추천 7명으로 5대5 구성', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0594'};
MATCH (a:ResponseActor {name: '실종자가족대책위원회'}), (b:ResponseAction {name: '포괄 인정제 요구'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', objective: '확인 전 실종자 우선 인정(포괄 인정제) 요구', reason: '사실확인 곤란·가족 명예', evidence: '인정 후 확인을 원칙으로 하는 포괄 인정제를 요구하고 있어 인정사망심사위원회 구성이 쉽지 않을 전망', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0595'};
MATCH (a:Population {name: '실종자 가족'}), (b:Damage {name: '실종자 가족 2차 피해(노숙·건강 악화)'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {role: '장기 노숙·피로 누적이 2차 피해 확대', mechanism: '냉기·악몽·감기 등 건강 악화', evidence: '실종자 가족들이 18일째 가족들을 애타게 찾으려고...낮과 밤을 보내고 있다 / 실종자 가족들이 한방치료를 받고 있다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0596'};
MATCH (a:ResponseActor {name: '자원봉사자'}), (b:ResponseAction {name: '지하철 화재사고 자원봉사활동'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', objective: '부상자 구호·유가족 급식·생필품 제공', effectiveness: 'High', evidence: '4일 현재 봉사활동에 참가한 자원봉사자는 모두 615개 단체에 1만3천600여명 / 무료 급식은 물론 담요와 속옷 등 생필품 제공', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0597'};
MATCH (a:ResponseAction {name: '전국민·기업·언론사 성금모금'}), (b:Damage {name: '대구 지하철 참사 인명피해'}) MERGE (a)-[r:MITIGATES]->(b) SET r += {phase: 'recovery', effectiveness: 'Med', role: '경제적 피해 완화·유가족 위로금', evidence: '18일만에 모인 성금 총액은 480억원(중앙재해구호협회 집계액) / 사고보상금액과는 별도로 사망자와 실종자 유가족들에게 특별위로금 형식으로 지급', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0598'};
MATCH (a:RiskFactor {name: '대구시 지하철 재정 압박·안전투자 후순위'}), (b:Event {name: '대구지하철 화재참사(2003)'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {probability: 'Med', mechanism: '재정난으로 안전설비 투자 우선순위 밀림', reason: '지하철 건설을 정부가 맡지 않아 무리한 건설', evidence: '재정이 열악한 대구시가 지하철을 무리하게 건설하다보니 값싼 전동차를 구입할 수밖에 없었고 안전시설 설치도 부족 / 안전설비 투자가 우선 순위에서 밀릴 수밖에 없는 실정', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0599'};
MATCH (a:Resilience {name: '지하철 국가 건설·운영(한국지하철공사 설립)'}), (b:RiskFactor {name: '대구시 지하철 재정 압박·안전투자 후순위'}) MERGE (a)-[r:OFFSETS]->(b) SET r += {role: '재정난으로 인한 안전투자 부족 위험 완화', effectiveness: 'Med', reason: '국가가 맡아 안전 담보', evidence: '지하철을 국가가 맡지않고서는 전동차 개체, 1호선 복구 등 무엇하나 제대로 하지 못한다 / 정부가 맡아야 안전을 담보할 수 있다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0600'};
MATCH (a:ResponseAction {name: '지하철 운행 즉시 재개'}), (b:Event {name: '사고현장 조기훼손(증거인멸 논란)'}) MERGE (a)-[r:MODIFIES_RISK_OF]->(b) SET r += {role: '복구 우선 기조 강화로 현장훼손 위험 증대', effectiveness: 'Low', specialNote: '안전대책 없는 운행에 비난', evidence: '사고 다음날부터 지하철 운행이 재개되는 등 이해하기 어려울 정도 / 안전대책없는 지하철 운행에 대해 비난이 쏟아지는데도', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0601'};
MATCH (a:Event {name: '대구지하철 방화참사(2003)'}), (b:Damage {name: '대구 지하철 참사 인명피해'}) MERGE (a)-[r:CAUSES]->(b) SET r += {role: '인명피해', directCause: '방화로 인한 화재 및 유독가스', evidence: '지난달 18일 지하철 화재로 344명의 사상자를 냈던 중앙로역.', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0602'};
MATCH (a:Event {name: '대구지하철 방화참사(2003)'}), (b:Damage {name: '대구지하철 방화참사 사망자(271명 인정)'}) MERGE (a)-[r:CAUSES]->(b) SET r += {role: '사망', specialNote: '신원확인 사망자 49명 + 미확인 실종자 222명 등 271명 사망 인정', evidence: '신원이 확인된 사망자 49명과 기확인 실종자 222명 등 271명을 사망자로 인정하고 특별위로금을...', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0603'};
MATCH (a:Event {name: '대구지하철 방화참사(2003)'}), (b:Damage {name: '1080호 전동차 내 유해(149구)'}) MERGE (a)-[r:CAUSES]->(b) SET r += {role: '유해 발견', specialNote: '1080호 전동차 내 유해 149구 발견', evidence: '는 발견된 유해 149구의 유전자 1차 감식이 완료될 수 있을 것... 14일께 1080호내 사체 142구...', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0604'};
MATCH (a:ManmadeHazard {name: '방화(대구지하철)'}), (b:Event {name: '대구지하철 방화참사(2003)'}) MERGE (a)-[r:TRIGGERS]->(b) SET r += {role: '발화 원인', probability: 'High', directCause: '방화', evidence: '어이없는 방화가 유례없는 대참사로 이어진 대구지하철방화사건', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0605'};
MATCH (a:RiskFactor {name: '전동차 가연성 내장재'}), (b:Event {name: '대구지하철 방화참사(2003)'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {role: '피해 증폭 요인', probability: 'High', mechanism: '가연성 내장재 연소로 화재 확산·유독가스', evidence: '전동차 내장재를 불연재로 전면 교체하고... 2호선 전동차의 내장재 차 내장판은 불연재로 시공하고 있지만 의자·바닥재·연결막은 1호선 전동차와 비슷한 수준... 화재에 여전히 취약', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0606'};
MATCH (a:RiskFactor {name: '전동차 내장재(가연성 합성수지)'}), (b:Event {name: '지하철 화재 사건(일반)'}) MERGE (a)-[r:PRECONDITIONS]->(b) SET r += {role: '잠재 화재위험', probability: 'Med', specialNote: '안전성 보강에 150억원 필요', evidence: '2호선 전동차의 내장재... 의자·바닥재·연결막은 1호선 전동차와 비슷한 수준... 도록 설계돼 있어 화재에 여전히 취약하다... 안전성을 높일 수 있으나 이에 필요한 150억원...', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0607'};
MATCH (a:RiskFactor {name: '전동차 불량자재 납품 의혹'}), (b:Event {name: '대구지하철 방화참사(2003)'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {role: '잠재 위험요인', probability: 'Low', specialNote: '바닥재·FRP 내장재 샘플 불량여부 검사 진행', reason: '납품과정 리베이트 의혹', evidence: '전동차 제작 과정에서의 불량 자재 납품 등 비리여부에 대해 수사력을 집중... 정품이 아닌 비품으로 대신할 가능성... 불량자재 납품을 대가로 리베이트', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0608'};
MATCH (a:RiskFactor {name: '대구지하철 운영 재정악화'}), (b:Event {name: '지하철 화재 사건(일반)'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {role: '구조적 위험요인', probability: 'Med', mechanism: '운영적자 가중으로 안전성 투자 불가', evidence: '지하철 부채는... 1조3천316억원으로 시 전체 부채 2조8천876억원의 46%를 차지... 운임 현실화율... 17.6%에 불과... 시민 안전이 위협받는 상황이 닥친', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0609'};
MATCH (a:Facility {name: '중앙로역'}), (b:Damage {name: '대구 지하철 참사 인명피해'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {role: '밀폐 지하구조로 피해 증폭', specialNote: '지하 역사 화재현장', evidence: '지난달 18일 지하철 화재로 344명의 사상자를 냈던 중앙로역... 그을음 진 매캐한 지하철역 안에서', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0610'};
MATCH (a:ResponseAction {name: '재해구호협회·사고대책본부 성금모금'}), (b:Event {name: '대구지하철 방화참사(2003)'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {role: '피해자 경제지원', effectiveness: 'High', specialNote: '18일만에 480억원, 19일간 500억 육박', evidence: '참사로 이어진 대구지하철방화사건... 뜨거운 성금 행렬로 이어졌다... 18일만에 모인 성금 총액은 480억원', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0611'};
MATCH (a:ResponseAction {name: '재해구호협회·사고대책본부 성금모금'}), (b:Context {name: '대구지하철 참사 국민성금(480억원)'}) MERGE (a)-[r:QUANTIFIED_BY]->(b) SET r += {role: '모금 실적', evidence: '18일만에 모인 성금 총액은 480억원(중앙재해구호협회 집계액)... 언론사 기탁분... 197억여원이며... 상인동 가스폭발사고 시 성금 192억원에 비해 단 기간에 2.5배', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0612'};
MATCH (a:ResponseAction {name: '재해구호협회·사고대책본부 성금모금'}), (b:Context {name: '참사 보상 필요액(687억여원)'}) MERGE (a)-[r:QUANTIFIED_BY]->(b) SET r += {role: '필요 보상액 추계', evidence: '할 경우 사망자 598억9천100만원, 부상자 88억4천500만원 등 687억여원이 필요하다고... 사망자 2억2천100만원씩, 부상자 (145명) 6천100만원씩', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0613'};
MATCH (a:ResponseActor {name: '대구시 사고대책본부'}), (b:ResponseAction {name: '성금 한도 증액·기간 연장 건의'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '모금 한도·기간 연장 건의', phase: 'recovery', evidence: '한도액을 현행 500억원에서 700억원으로 상향 조정해 줄 것과 모금 기간도... 이달말까지 연장... 재해구호협회에 요청... 한도도 500억원에서 700억원으로 증액', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0614'};
MATCH (a:ResponseAction {name: '실종자 인정사망 심사'}), (b:Context {name: '인정사망자 첫 결정(64명)'}) MERGE (a)-[r:QUANTIFIED_BY]->(b) SET r += {role: '4차 회의 판정 결과', timing: '2003-03-21', evidence: '인정사망 심사위(위원장 김준곤 변호사)는 21일 4차 회의에서 사체 신원이 확정된 확정사망자 12명을 제외한 64명을 인정사망자로 합의', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0615'};
MATCH (a:ResponseAction {name: '경찰 전동차 납품비리 수사'}), (b:Event {name: '대구지하철 방화참사(2003)'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {role: '원인규명·책임자 처벌', effectiveness: 'Med', reason: '공소시효 문제(형법 7년 경과, 특경법 적용시 10년)', evidence: '경찰이 2차 수사를 진행... 전동차 제작 과정에서의 불량 자재 납품 등 비리여부에 대해 수사력을 집중... \'특별수사팀\'을 구성하고 실사작업에 착수', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0616'};
MATCH (a:ResponseAction {name: '전동차 불연재 전면교체 요구'}), (b:Event {name: '지하철 화재 사건(일반)'}) MERGE (a)-[r:PREVENTS]->(b) SET r += {role: '재발 방지 대책', effectiveness: 'High', timing: '3월 중 착수 요구', evidence: '대구 지하철 전동차를 즉시 불연재 전동차로 전면 교체하고 안전관리, 대피장치 등의 시설보완작업도 3월 중 착수할 것을 요구', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0617'};
MATCH (a:ResponseActor {name: '대구광역시'}), (b:ResponseAction {name: '지하철 국가공사화(한국지하철공사 설립) 추진'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '지하철 국가공사화 정부이관 요청', phase: 'recovery', objective: '재정난 해소 및 안전 운영', evidence: '정부가 가칭 『한국지하철공사』를 설립해 대구지하철의 건설·운영 주체가 돼줘야 한다... 중앙정부가 대구지하철의 건설·운영을 맡아 주도록 공식 요청', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0618'};
MATCH (a:ResponseActor {name: '노무현 대통령 당선자'}), (b:ResponseAction {name: '대구 관계장관회의·지역경제 회생대책'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '관계장관회의·지역경제 회생대책', phase: 'recovery', timing: '2003-03-20 대구시청', evidence: '정부는 20일 대구시청에서 고건 총리가 주재한 \'대구U대회 및 밀라노 프로젝트 대책회의\'에서... 정부, 지역경제 회생... 경제관련 장관회의', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0619'};
MATCH (a:ResponseActor {name: '실종자가족 대책위·시민단체'}), (b:ResponseAction {name: '유가족·시민단체 항의집회(시청앞)'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '사고수습 요구·항의집회', phase: 'recovery', timing: '2003-03-20', evidence: '희생자자가족대책위와 시민사회단체대책위 관계자 등 100여명이 대구시청 앞에서 조해녕 대구시장 사퇴 및 구속수사를 촉구하는 항의 집회... 수백개의 계란을 던졌으며', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0620'};
MATCH (a:ResponseActor {name: '전국궤도노동조합'}), (b:ResponseAction {name: '전국궤도노동자 추모대회·안전요구'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '안전대책 요구 추모대회', phase: 'recovery', timing: '2003-03-19', evidence: '전국궤도노동조합 소속 조합원 700여명이 중앙로역 앞 도로에서... 추모대회... 전동차 내장재를 불연재로 전면 교체하고 대피가 용이하도록 역사의 구조도 개선해야 한다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0621'};
MATCH (a:Damage {name: '신원미확인 사체 인수방법 갈등'}), (b:Context {name: '사체인수 투표 결과'}) MERGE (a)-[r:QUANTIFIED_BY]->(b) SET r += {role: '유족 투표 결과', evidence: '투표 참여자 148명 가운데 53%인 79명이 사체 일괄인수 및 합동장례식을 희망... 46%인 68명은 신원이 확인되는대로 개별적으로 사체를 인수받은 뒤', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0622'};
MATCH (a:Damage {name: '중앙로역 인근 상가 영업피해'}), (b:Context {name: '상가번영회 주민수호대회'}) MERGE (a)-[r:QUANTIFIED_BY]->(b) SET r += {role: '2차 피해 양상', specialNote: '추모집회 금지 요구로 희생자가족대책위와 충돌', evidence: '차량 통제와 잦은 희생자 추모행사 등으로 생계를 위한 영업활동에 막대한 지장이 초래돼... 피해지역 상가 영업손실 보상 등을 요구하는 \'상가 및 주민 수호대회\'', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0623'};
MATCH (a:ResponseAction {name: '중앙로역 안전보강 작업'}), (b:Event {name: '대구지하철 방화참사(2003)'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {role: '사고 현장 시설 복구·보강', phase: 'recovery', evidence: '한국시설안전기술공단 관계자들이 12일 오후 대구지하철 중앙로역에 대한 안전보강 작업을 하고 있다.', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0624'};
MATCH (a:Event {name: '대구 지하철 중앙로역 화재(2003)'}), (b:Event {name: '1080호 전동차 인명피해 확대(2003)'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {probability: 'High', mechanism: '1079호 화재가 마주오던 1080호 전동차로 옮겨붙고 대응 미비로 피해 확대', timing: '화재 직후', evidence: '1080호 전동차의 인명 피해를 키운 혐의 / 화재 당시 중앙로역 긴급 대응 미비', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0625'};
MATCH (a:Event {name: '전동차 단전(2003)'}), (b:Event {name: '1080호 전동차 인명피해 확대(2003)'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {probability: 'High', mechanism: '전력 차단 후 긴급대응을 하지 않아 1080호 전동차 승객 피난 실패', directCause: '전력 차단 후 긴급대응 미비', evidence: '전력 차단 후 긴급대응을 않아 1080호 전동차의 인명 피해를 키운 혐의 / 전동차 단전과 관련해 업무상 과실치사상', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0626'};
MATCH (a:Event {name: '1080호 전동차 인명피해 확대(2003)'}), (b:Damage {name: '대구 지하철 화재 인명피해'}) MERGE (a)-[r:CAUSES]->(b) SET r += {scale: '대형', mechanism: '전동차 내 승객 사망', evidence: '지하철 화재로 344명의 사상자를 냈던 중앙로역 / 국과수가 수습한 142구의 시신', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0627'};
MATCH (a:Damage {name: '대구 지하철 화재 인명피해'}), (b:Context {name: '시신 수습·인도 현황(2003-04-28)'}) MERGE (a)-[r:QUANTIFIED_BY]->(b) SET r += {detail: '수습 시신 142구 중 개별 인도 61구, 신원미확인 6구, 잔여 75구', evidence: '국과수가 수습한 142구의 시신 가운데 유가족들에게 개별 인도된 시신 수는 61구 / 신원을 확인하지 못한 시신 6구를 제외한 75구의 시신이 남게 된다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0628'};
MATCH (a:Event {name: '중앙로역 화재 후 교통통제(2003)'}), (b:Damage {name: '중앙로 상권 영업피해'}) MERGE (a)-[r:CAUSES]->(b) SET r += {scale: '대형', mechanism: '교통통제로 인근 상권 매출 급감', evidence: '지하철 참사 이후 매출액이 절반 이하로 줄었다 / 영화관람객도 70% 감소 / 관람객은 12만명이었는데 올해 같은 기간 관람객은 3만6000명으로 떨어졌다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0629'};
MATCH (a:ResponseAction {name: '자원봉사단체 식사·구호 제공'}), (b:Damage {name: '대구 지하철 화재 인명피해'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {effectiveness: 'High', scale: '대형', detail: '참여 인원 누계 2만2천여명, 초기 60여개 단체', evidence: '식사제공 등 참사수습 2만여명 활동 / 참사 초기엔 60개가 넘는 단체가 자발적으로 식사 제공과 청소 / 한달이상 지속', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0630'};
MATCH (a:ResponseActor {name: '자원봉사단체(대구 지하철 화재)'}), (b:ResponseAction {name: '자원봉사단체 식사·구호 제공'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '구호 주체', phase: 'response', evidence: '삼성사회봉사단, KT대구본부봉사단, 대한적십자사 대구지사봉사단 / 17개 단체에서 230여명이 다양한 봉사활동', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0631'};
MATCH (a:ResponseAction {name: '중앙로역 차량통행 재개(2003-04-10)'}), (b:Damage {name: '중앙로 상권 영업피해'}) MERGE (a)-[r:MITIGATES]->(b) SET r += {effectiveness: 'Med', reason: '교통통제로 인한 상권 영업피해 완화 목적', detail: '일부 회복세, 지하철 정차는 11월에야 재개 예정', evidence: '교통이 통제됐던 중앙로역 일대의 차량통행이 지난 10일 재개됐다 / 차량통행 재개로 일부 회복세', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0632'};
MATCH (a:ResponseAction {name: '중앙로역 구조물 정밀안전진단'}), (b:Event {name: '대구 지하철 중앙로역 화재(2003)'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {effectiveness: 'Low', reason: '유가족 반대로 수차례 무산', timing: '2003-04-26~27 무산', evidence: '중앙로역 지하 3층에 대한 정밀안전진단이 유가족들의 반대로 또 다시 무산됐다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0633'};
MATCH (a:ResponseActor {name: '대구지하철공사'}), (b:ResponseAction {name: '중앙로역 구조물 정밀안전진단'}) MERGE (a)-[r:FAILS]->(b) SET r += {reason: '유가족 합동장례 요구·반대 농성으로 진입 저지', timing: '2003-04-26~27', consequence: '안전진단 미실시, 8월 전동차 무정차 통과 일정 변경 불가피', evidence: '정밀안전진단이 유가족들의 반대로 또 다시 무산됐다 / 유가족들의 반대로 안전진단이 실시되지 못했다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0634'};
MATCH (a:ResponseActor {name: '대검 특별수사본부'}), (b:ResponseAction {name: '현장훼손 책임소재 수사'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '수사 주체', phase: 'recovery', objective: '현장훼손·증거인멸 진상규명', evidence: '대검 특별수사본부는 현장훼손과 관련 조해녕 대구시장을 무혐의 처분하고 윤진태 전 대구지하철공사 사장을 불구속 기소 / 전동차 단전과 관련해 업무상 과실치사상 혐의로 입건됐던 5명을 무혐의 처분', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0635'};
MATCH (a:Event {name: '현장훼손(증거인멸)'}), (b:Damage {name: '참사 수습 혼란·진상규명 차질'}) MERGE (a)-[r:CAUSES]->(b) SET r += {scale: '대형', mechanism: '참사 수습 혼란 및 진상규명 곤란', evidence: '대구지하철 참사 수습을 혼란에 빠뜨렸던 현장 훼손 관련 수사 / 무수한 의혹만 남겨버렸다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0636'};
MATCH (a:ResponseAction {name: '추모묘지공원 조성(수창공원)'}), (b:Damage {name: '대구 지하철 화재 인명피해'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {effectiveness: 'Low', reason: '현행법(인가 500m 이내 묘지 금지)·주민 반발·재정난으로 난항', phase: 'recovery', evidence: '대구지하철참사 희생자 추모묘지공원 조성 / 토지 및 건물 보상비는 425억원 / 242ml에 609억원을 들여 2~3년내 완공', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0637'};
MATCH (a:RiskFactor {name: '지하 밀폐구조(지하철 화재 취약성)'}), (b:Damage {name: '대구 지하철 화재 인명피해'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {probability: 'High', mechanism: '지하 밀폐·정전 환경에서 승객 피난 실패로 사망 증가', evidence: '암흑 속 절규 / 단전, 화재 당시 중앙로역 긴급 대응 미비 관련자 / 그을음 진 매캐한 지하철역 안', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0638'};
MATCH (a:ManmadeHazard {name: '대구 지하철 방화'}), (b:Event {name: '대구 지하철 1079호 전동차 화재'}) MERGE (a)-[r:TRIGGERS]->(b) SET r += {scale: '대형', probability: 'High', mechanism: '전동차 내장재에 점화', directCause: '방화', evidence: '200여명의 요원으로 수사본부를 설치한 경찰은 방화범 김대한(56)씨, 1080호 기관사 최상열(38)씨 등 대구지하철공사 직원 8명', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0639'};
MATCH (a:Event {name: '대구 지하철 1079호 전동차 화재'}), (b:Event {name: '대구 지하철 참사'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {mechanism: '가연성 불량 내장재가 화재를 확대·유독가스 발생 증대', reason: '불연성 FRP 대신 가연성 수지 사용', effectiveness: 'High', specialNote: '불량내장재가 대형참사로 이어지게 함', evidence: '대구지하철 방화사건이 대형참사로 이어지게 한 전동차 불량내장재 납품업자들이 철퇴를 맞았다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0640'};
MATCH (a:RiskFactor {name: '전동차 불량 내장재(가연성 FRP)'}), (b:Event {name: '대구 지하철 참사'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {mechanism: '가연성 내장재로 화재 급속 확산 및 유독가스 다량 발생', probability: 'High', reason: '난연성 수지 의무 미준수', specialNote: '방화를 대형참사로 비화시킨 핵심 위험요인', evidence: '난연성 수지만을 사용, 불연성 FRP를 제작해야 하는데도 불구하고 값싼 일반수지인 불포화 폴리에스테르를 50% 가량 섞은 가연성 수지를 사용한 불량 FRP를 제작, 납품', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0641'};
MATCH (a:Event {name: '대구 지하철 1079호 전동차 화재'}), (b:Damage {name: '대구 지하철 참사 인명피해'}) MERGE (a)-[r:CAUSES]->(b) SET r += {scale: '대형', directCause: '화재·유독가스로 인한 인명피해', specialNote: '최종 집계 인명피해', evidence: '참사 사상자는 사망 192명(인정사망 1명 포함), 부상 147명 등 339명으로 집계됐다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0642'};
MATCH (a:Damage {name: '대구 지하철 참사 인명피해'}), (b:Context {name: '사망자 신원확인 현황(2003-05-27)'}) MERGE (a)-[r:QUANTIFIED_BY]->(b) SET r += {detail: '사망자 신원 구성 내역', evidence: '사망자는 당초 신원 확인자 49명, 전동차내에서 수습된 시신 142명으로 전동차내에서 수습된 시신 가운데 6명(DNA 확인 미신고 3명, 신원확인불능 3명)은 신원확인이 되지 않고 있는 상태다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0643'};
MATCH (a:Damage {name: '대구 지하철 화재 부상 피해'}), (b:Context {name: '부상자 치료 현황(2003-05-27)'}) MERGE (a)-[r:QUANTIFIED_BY]->(b) SET r += {detail: '부상자 치료 현황', evidence: '부상자는 147명 가운데 138명이 퇴원했고 9명은 현재 동산병원 등 4개병원에 입원 치료중이다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0644'};
MATCH (a:ResponseActor {name: '방화범 김대한(56)'}), (b:ManmadeHazard {name: '대구 지하철 방화'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {role: '형사 입건 대상', phase: 'response', specialNote: '현주건조물방화 등 혐의로 구속·기소', evidence: '경찰은 방화범 김대한(56)씨...등 모두 12명을 구속하고', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0645'};
MATCH (a:ResponseActor {name: '대구지방경찰청 수사본부'}), (b:ResponseAction {name: '참사 수사 및 형사 입건'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', actionType: '수사·입건', detail: '방화범·전동차 기관사 등 대구지하철공사 직원 8명, 불량제품 납품 0정밀 대표 등 12명 구속, 윤모씨 등 12명 불구속 입건', evidence: '방화범 김대한(56)씨, 1080호 기관사 최상열(38)씨 등 대구지하철공사 직원 8명, 불량제품을 납품한 0정밀 대표 전모(65)씨 등 모두 12명을 구속하고 대구지하철공사 전 사장 윤모(62)씨 등 12명을 불구속 입건했다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0646'};
MATCH (a:ResponseActor {name: '1080호 전동차 기관사 최상열'}), (b:ResponseAction {name: '참사 현장 초동 대응'}) MERGE (a)-[r:FAILS]->(b) SET r += {phase: 'response', reason: '업무상 과실치사상 혐의 적용', specialNote: '1080호 진입·대응 관련 직원 과실', evidence: '방화 피고인 김씨를 비롯해 사고 전동차 기관사 등 업무상 과실치사상 협의가 적용된 대구지하철공사 직원 8명 등 9명에 대한 첫 공판이 지난 19일 대구지법에서 열린', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0647'};
MATCH (a:ResponseActor {name: '불량 내장재 납품업자(0정밀·0사)'}), (b:ResponseAction {name: '전동차 안전 내장재 공급'}) MERGE (a)-[r:FAILS]->(b) SET r += {phase: 'prevention', reason: '정품 견본으로 수주 후 불량품 납품, 원가절감 위해 가연성 수지 사용', specialNote: '안전자재 공급 의무 위반', evidence: '이들은 대구지하철 전동차 216량의 내장재를 모두 불량품으로 제작, 원청 업체인 H중공업에 납품해...특정경제범죄 가중처벌법상 사기 혐의로 구속했다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0648'};
MATCH (a:ResponseActor {name: '대구시 사고대책본부'}), (b:ResponseAction {name: '사망자 특별위로금 지급'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'recovery', actionType: '사망자 보상금 지급', detail: '국민성금 656억6000만원으로 특별위로금 지급', evidence: '사고대책본부는 이 성금으로 상인동 가스폭발사고(1인당 1억7000만원), 삼풍백화점붕괴사고(1억7000만원) 등의 보상기준을 참고해...사망자 특별위로금을 지급할 계획이다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0649'};
MATCH (a:Resilience {name: '국민성금(재해구호 성금)'}), (b:Damage {name: '대구 지하철 참사 인명피해'}) MERGE (a)-[r:OFFSETS]->(b) SET r += {effectiveness: 'Med', mechanism: '유가족·부상자 위로금·보상금 재원으로 경제적 피해 완충', evidence: '전국재해구호협회 등에 기탁돼 지난 20일 재해구호협회로부터 대구시가 인수한 국민성금 656억6000만원을 특별위로금으로 지급받게 된다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0650'};
MATCH (a:Resilience {name: '대구지하철공사 배상책임보험(지방재정공제회)'}), (b:Damage {name: '대구 지하철 참사 인명피해'}) MERGE (a)-[r:OFFSETS]->(b) SET r += {effectiveness: 'Low', mechanism: '배상책임보험으로 피해보상 일부 충당', specialNote: '1인당 한도 4000만원으로 제한적', evidence: '대구지하철공사가 지방재정공제회에 가입한 배상책임보험도 사고당 보상한도 10억원, 1인당 보상한도 4000만원으로 이에 준하는 보상을 받게 된다', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0651'};
MATCH (a:Event {name: '신원확인 지연·시신 냉동보관'}), (b:Damage {name: '합동장례 장기 지연 피해'}) MERGE (a)-[r:CAUSES]->(b) SET r += {directCause: '신원확인 지연·장례 갈등으로 장례식 장기 지연', specialNote: '2차적 사회적 피해(장례 파행)', evidence: '대구지하철 참사 사망자 192명에 대한 합동영결식이 사고 발생 131일만에 거행됐다 / 안심기지창에 냉동 보관중이던 희생자들', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0652'};
MATCH (a:Event {name: '추모공원 부지 갈등'}), (b:Damage {name: '참사 수습 지연 피해'}) MERGE (a)-[r:CAUSES]->(b) SET r += {directCause: '부지 선정 갈등으로 추모사업·장례 수습 지연', specialNote: '2차 사회갈등 피해', evidence: '추모공원 조성을 둘러 싼 희생자 대책위와 대구시의 갈등이 합동 장례식의 파행으로 이어질 조짐이다...새로 결정되는 후보지마다 반대의견이 속출', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0653'};
MATCH (a:ResponseAction {name: '추모공원·위령탑·안전교육관 조성'}), (b:Resilience {name: '지하철 안전교육 역량'}) MERGE (a)-[r:BUILDS]->(b) SET r += {phase: 'recovery', effectiveness: 'Med', mechanism: '안전교육관 통한 재발방지 교육 역량 구축', evidence: '추모공원에는 안전교육관이 필수이고 안전교육관이 제 기능을 하기 위해서는 묘역과 함께 있어야 하기 때문에...위령탑과 안전교육관 등 추모공원을 조성해 줄 것을 요구', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0654'};
MATCH (a:ResponseActor {name: '이영탁 국무조정실장(고건 총리 대신)'}), (b:ResponseAction {name: '안전한 지하철 구축·현장대응 강화 다짐'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'prevention', actionType: '재발방지 다짐', specialNote: '철저한 원인규명·안전 최우선 국정 운영 선언', evidence: '철저한 원인 규명을 통해 앞으로는 안전한 지하철을 구축할 것...앞으로는 현장 대응 능력의 대폭강화와 안전을 최우선 할 것', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0655'};
MATCH (a:Event {name: '대구 지하철 참사'}), (b:Context {name: '사고 발생시간(2003-02-18 09:53)'}) MERGE (a)-[r:OCCURS_AT]->(b) SET r += {detail: '발생 일시·장소', evidence: '2•18 대구지하철 참사가 28일로 발생 100일을 맞았으나 / 검은 연기가 가득했던 2월 18일', sourceDoc: '대구 지하철 중앙로역 화재사고 백서 (대구시, 2005)', tripleId: 'T0656'};
