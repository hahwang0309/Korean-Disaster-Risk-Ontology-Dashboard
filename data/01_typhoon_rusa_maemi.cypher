MATCH (a:Resilience {name: '감염병 차단 (전염병 미발생)'}), (b:Damage {name: '전염병 발생 피해'}) MERGE (a)-[r:OFFSETS]->(b) SET r += {effectiveness: 'High', reason: '예방접종·방역활동으로 2차 피해(전염병) 차단', evidence: '의료 사각지역의 어려운 여건속에서도 단 한 건의 전염병도 발생되지 않았다', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0180'};
MATCH (a:ResponseActor {name: '강릉아산병원·동인병원·강릉의료원·강릉국군병원'}), (b:ResponseAction {name: '이재민 수용시설 순회 의료지원'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '이재민 수용시설·침수지역 순회 의료지원', phase: 'response', timing: '2002-09-02부터 10일간', evidence: '관내 종합병원인 강릉아산병원, 동인병원, 강릉의료원과 강릉국군병원에서는 9월 2일부터 10일간 이재민 수용시설과 침수지역을 순회하면서 의료 지원', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0181'};
MATCH (a:ResponseActor {name: '강릉시의사회'}), (b:ResponseAction {name: '남산초교 이재민 수용시설 주야간 진료'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '남산초등학교 이재민 수용시설 주야간 진료', phase: 'response', timing: '2002-09-03 ~ 2002-09-18', location: '내곡·노암동', evidence: '강릉시의사회에서는 수해 피해가 많은 내곡·노암동 지역 주민을 위하여 남산초등학교의 이재민 수용시설을 9월 3일부터 9월 18일까지 주야간 진료를 실시', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0182'};
MATCH (a:ResponseAction {name: '구호물품 지원 (식품·취사·의류)'}), (b:Population {name: '이재민'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {phase: 'response', mechanism: '이재민 대상 생필품 지원', evidence: '구호물품지원 〇식품류 ... 생수(박스) 7,079 빵(개) 28,117 ... 〇의류 등 모포(장) 3,720 의류(점) 46,366', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0183'};
MATCH (a:Event {name: '오봉댐 원수관 유실'}), (b:Event {name: '시 전역 단수 사태'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {mechanism: '원수관 유실로 정수 공급 차단', timing: '태풍 직후', evidence: '오봉댐 원수관 유실로 시전역 단수 사태가 발생되어 수인성 전염병 발생환경에 곧바로 노출', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0184'};
MATCH (a:Event {name: '시 전역 단수 사태'}), (b:RiskFactor {name: '수인성 전염병 발생위험'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {mechanism: '수인성 전염병 발생환경 노출', spreadRisk: 'High', evidence: '단수 사태가 발생되어 수인성 전염병 발생환경에 곧바로 노출되었다', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0185'};
MATCH (a:Population {name: '이재민 23,384명(7,155세대)'}), (b:RiskFactor {name: '질병노출 취약 여건'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {mechanism: '다수인 집단생활로 질병노출 취약', phase: 'response', evidence: '7,155 세대 23,384 명의 이재민이 발생하여 다수인의 집단생활 및 집단급식 등 열악한 환경으로 인하여 질병노출에 취약한 여건', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0186'};
MATCH (a:ResponseActor {name: '강릉시 보건소 방역기동반'}), (b:ResponseAction {name: '집중 방역소독'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '방역소독 주체', phase: 'recovery', duration: '9월1일~', evidence: '9 월 1 일부터 보건소장을 총괄로 방역기동반을 3 개반 15 명으로 편성하여 침수지역, 축사시설, 쓰레기 야적장 등을 중심으로 집중 방역소독을 실시', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0187'};
MATCH (a:ResponseAction {name: '방역소독 실적(9.1~11.30)'}), (b:RiskFactor {name: '수인성 전염병 발생위험'}) MERGE (a)-[r:MITIGATES]->(b) SET r += {effectiveness: 'High', mechanism: '전염병 발생예방', scale: '소독인력 3,592명', evidence: '방역약품 사용 및 소독 실적 (9. 1 ~ 11. 30) 계 17,338.5 ... 전염병 발생예방에 주력', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0188'};
MATCH (a:Resilience {name: '전염성질환자 미발생'}), (b:RiskFactor {name: '수인성 전염병 발생위험'}) MERGE (a)-[r:OFFSETS]->(b) SET r += {effectiveness: 'High', reason: '환경위생 조화', evidence: '전염성질환자는 발생하지 않았으며, 이는 주민의 보건 위생관념의 향상과 음식물 끓여먹기, 철저한 방역소독으로 인한 환경위생의 조화가 잘 이루어진 결과', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0189'};
MATCH (a:Event {name: '급성 출혈성 결막염 확산'}), (b:ResponseAction {name: '급성 출혈성 결막염 방역조치 및 안과 모니터링'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {phase: 'response', scale: '7개 안과 모니터 확인', evidence: '급성 출혈성결막염 확산에 따른 방역조치 및 7 개안과 모니터 확인', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0190'};
MATCH (a:ResponseActor {name: '강릉시'}), (b:ResponseAction {name: '장티푸스 예방접종'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '예방접종 주체', phase: 'preparedness', scale: '29,350명 예상, 약품 3,000명분', evidence: '제 1 군인 장티푸스 예방접종 계획 수립하여 29,350 명을 무료예방 접종을 예상', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0191'};
MATCH (a:Damage {name: '사천 강릉공원묘원 묘지 유실'}), (b:RiskFactor {name: '수인성 전염병 발생위험'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {mechanism: '사체 방치 악취·해충 발생', spreadRisk: 'High', evidence: '사천 공원묘원의 묘지 약 800 기가 유실되어 많은 사체가 넓은 지역으로 방치되어 ... 악취와 해충으로 중점 방역소독 실시', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0192'};
MATCH (a:ResponseAction {name: '비상급수(소방차)'}), (b:Event {name: '시 전역 단수 사태'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {phase: 'recovery', reason: '단수 사태 대응', evidence: '비상급수: 소방차 482 대 6,810 톤(1 일 48 대) 공급', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0193'};
MATCH (a:Damage {name: '홍제정수장 도수관로 유실'}), (b:Event {name: '상수도 단수'}) MERGE (a)-[r:CAUSES]->(b) SET r += {directCause: '태풍 루사 침수', phase: 'damage', evidence: '홍제정수장도수관로 유실 ... 피해액： 259 백만원 ... 응급복구완료 -원수통수 : 9. 3(14:30)', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0194'};
MATCH (a:Damage {name: '상수도 배수관 유실(28개소)'}), (b:Event {name: '급수 차질'}) MERGE (a)-[r:CAUSES]->(b) SET r += {directCause: '태풍 루사', phase: 'damage', evidence: '상수도 배수관리 유실 -개소수 : 28 개소 ... -피해액: L=1,154 백만원', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0195'};
MATCH (a:Damage {name: '수해쓰레기 발생'}), (b:ResponseAction {name: '수해쓰레기 처리 및 매립장 조기건립'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {phase: 'recovery', scale: '장비 2,246대, 인력 12,325명 동원', evidence: '수해쓰레기: 45,000 톤 발생(해안 23,000 톤) - 장비 2,246 대, 인력 12,325 명 동원 처리', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0196'};
MATCH (a:Damage {name: '강릉 하수/분뇨처리시설 침수'}), (b:ResponseAction {name: '하수/분뇨처리시설 조기복구'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {phase: 'recovery', timing: '75일이내(2.5개월) 공기단축', detail: '전기수전설비(22,900V/2,500Kw) 우선복구', evidence: '침수: 2002. 8. 31(지금까지 가동 불능: 피해액 5,918 백만원) ... 정상운영을 위한 최우선 설비 및 공기단축: 75 일이내(2.5 개월)', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0197'};
MATCH (a:Event {name: '동해고속도로 1,2터널 입구 산사태'}), (b:Damage {name: '고속도로 통행 차질'}) MERGE (a)-[r:CAUSES]->(b) SET r += {directCause: '산사태 발생', phase: 'damage', evidence: '동해고속도로 1,2 터널 산사태 발생 ... 응급복구완료 · 상하행 통행(9. 1 일)', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0198'};
MATCH (a:Damage {name: '영동선 철도 유실'}), (b:Event {name: '강릉~동해 철도 교통통제'}) MERGE (a)-[r:CAUSES]->(b) SET r += {directCause: '태풍 루사 침수·유실', phase: 'damage', evidence: '영동선 철도 유실(600m)(K-18 전투비행장앞) ... 응급복구중 (※ 10 월초완료예정) · 교통통제(강릉~동해)', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0199'};
MATCH (a:Damage {name: '농어촌도로(시외곽) 유실·붕괴'}), (b:ResponseAction {name: '도로·교량 응급복구'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {phase: 'recovery', evidence: '72 개 노선 360km 중 - 유실 및 붕괴: 158km - 교량 유실: 15 개소 ... 소규모시설 응급복구 완료', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0200'};
MATCH (a:Damage {name: '유실·침수차량 발생'}), (b:ResponseAction {name: '태풍피해차량 말소·견인'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {phase: 'recovery', scale: '지원인력 3개반 8명', evidence: '유실 및침수차량 발생 ... 태풍피해차량 말소 -1,196 대(침수말소 1,045, 기타 151) ... 견인실적: 147 대', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0201'};
MATCH (a:Event {name: '정전(배전장비 8,903본)'}), (b:Damage {name: '전기 공급 중단'}) MERGE (a)-[r:CAUSES]->(b) SET r += {directCause: '태풍 루사', scale: '47,383호 정전', phase: 'damage', evidence: '전기 · 배전장비： 8,903 본 · 정전호수: 47,383 호 · 복구호수: 47,383(100%) 한국전력', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0202'};
MATCH (a:ResponseActor {name: '한국전력(한전 강릉지사)'}), (b:ResponseAction {name: '전기(배전장비·정전) 복구'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '전기 복구 주체', phase: 'recovery', effectiveness: 'High', evidence: '전기 · 복구：8,903(100%) · 복구호수: 47,383(100%) 한국전력', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0203'};
MATCH (a:Event {name: '일반전화 선로두절·정전장애'}), (b:Damage {name: '통신 두절'}) MERGE (a)-[r:CAUSES]->(b) SET r += {directCause: '선로두절·정전', scale: '13,808회선 두절', phase: 'damage', evidence: '일반전화 -관내, 관외, 인터넷 등 - 선로두절，정전장애 -13,808 회선 두절 · 13,808 회선 복구완료', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0204'};
MATCH (a:ResponseActor {name: '한국통신(KT)'}), (b:ResponseAction {name: '통신회선(13,808회선)·이동통신 복구'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '통신회선 복구 주체', phase: 'recovery', specialNote: 'KT 복구가 늦어져 읍면동 피해상황 전파에 어려움', evidence: '13,808 회선 복구완료 ... 이동통신(3 사 145 개소) · 복구완료 ... KT 복구가 늦어져 읍면동 피해상황, 전파에 어려움', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0205'};
MATCH (a:Event {name: '행정통신망 장애(KT 선로 유실)'}), (b:Damage {name: '행정통신 두절(피해상황 전파 곤란)'}) MERGE (a)-[r:CAUSES]->(b) SET r += {directCause: 'KT 선로 유실', phase: 'damage', timing: '8.31 17:30 장애시작', evidence: '행정통신망 장애시작 (원인 : KT 선로 유실) ... 9 월 18 일 행정통신시설 완전복구(정상 작동)', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0206'};
MATCH (a:Event {name: '강릉↔정선 광케이블 유실'}), (b:ResponseAction {name: '회선 이원화 데이콤 우회구축'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {phase: 'recovery', mechanism: '회선 이원화로 데이콤회선 우회구축', kind: 'buffering', evidence: '원인: 강릉 ↔ 정선 간 광케이블 유실 ... 복구: 회선의 이원화로 데이콤회선 우회구축', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0207'};
MATCH (a:Resilience {name: '회선 이원화 우회망'}), (b:Damage {name: '행정통신 두절(피해상황 전파 곤란)'}) MERGE (a)-[r:OFFSETS]->(b) SET r += {effectiveness: 'Med', reason: '유선망 두절 대체', evidence: '복구: 회선의 이원화로 데이콤회선 우회구축 ... 유선망 두절시 자체행정무선망을 이용한 방법', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0208'};
MATCH (a:RiskFactor {name: '무인국사 예비전원 부재'}), (b:Damage {name: '행정통신 복구 지연'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {mechanism: '장시간 정전시 예비전원 차단으로 복구 지연', probability: 'High', evidence: '정전이 장시간 지속됨에 따라 무인국사의 예비전원마저 차단됨 (별도 안정적이고 지속적인 전원공급시설을 미보유 → 발전기 등)', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0209'};
MATCH (a:ResponseActor {name: 'SK텔레콤 강릉지점'}), (b:ResponseAction {name: '휴대폰 지원(고립마을 통신지원)'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '휴대이동통신 단말기 지원', phase: 'recovery', evidence: '지원업체: SK 텔레콤 강릉지점 - 지원물품: 휴대폰 12 대(15 일간 공공요금 무료)', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0210'};
