MATCH (a:ResponseActor {name: '강릉시 재해대책본부'}), (b:ResponseActor {name: '강릉지방기상청·한국전력공사 강릉지사·관할군부대·경찰서'}) MERGE (a)-[r:COORDINATES_WITH]->(b) SET r += {role: '유관기관 공조체제', mechanism: '관할경찰서·군부대장 통보, 합동근무요원 파견요청', evidence: '필요시 강릉지방기상청, 한국전력공사강릉지사. 관할군부대 등 관련기관 파견요청 ... 관할경찰서, 시·군 지역 군부대장에 통보', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0021'};
MATCH (a:ResponseActor {name: '강릉시장(시·군 재해대책본부장)'}), (b:ResponseActor {name: '강원도재해대책본부'}) MERGE (a)-[r:BELONGS_TO]->(b) SET r += {role: '보고체계 상급기관', reportingMechanism: '재해상황·응급조치 내용 보고', evidence: '시장은 재해의 상황과 응급조치의 내용을 강원도재해대책본부장에게 보고', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0022'};
MATCH (a:ResponseActor {name: '읍·면·동장'}), (b:ResponseActor {name: '강릉시장(시·군 재해대책본부장)'}) MERGE (a)-[r:BELONGS_TO]->(b) SET r += {role: '보고체계 상급기관', timing: '재해발생 즉시', evidence: '읍·면·동장은 그 관할구역 내에 재해가 발생하였을 때에는 지체 없이 그 재해의 상황과 응급조치의 내용을 시장에게 보고', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0023'};
MATCH (a:ResponseActor {name: '강릉시 재해대책본부'}), (b:ResponseAction {name: '인명구조대 편성운영'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'preparedness', objective: '신속 대처', scale: '시군단위 20~30명', evidence: '주요 하천의 홍수범람지역, 인구밀집지역, 상습침수지역, 홍수시 고립지역 → 시군단위 20~30명의 인명구조대 편성 운영', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0024'};
MATCH (a:ResponseAction {name: '재해위험지구 주민대피계획'}), (b:Resilience {name: '주민대피 수용역량'}) MERGE (a)-[r:BUILDS]->(b) SET r += {kind: 'buffering', mechanism: '대피로·수용시설 사전 지정', evidence: '▣ 재해위험지구별 주민대피계획 ... 137세대 6개소 ... 수용인원 539명 ... 영진지구/뒷불지구/강문지구/낙풍지구', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0025'};
MATCH (a:ResponseAction {name: '강릉시 재해보고체제'}), (b:Resilience {name: '방재조직 효율적 운영역량'}) MERGE (a)-[r:BUILDS]->(b) SET r += {kind: 'recovery', mechanism: '재해보고체제 전산화', evidence: '재해보고체제의 전산화로 방재조직의 효율적 운영 ... 일일보고 정기보고: 1일 4회 보고 (08:00, 12:00, 17:00, 21:00)', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0026'};
MATCH (a:ResponseActor {name: '강릉시'}), (b:ResponseAction {name: '재해위험지구별 주민대피계획 수립'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'preparedness', role: '재해위험지구 관리 주체', evidence: '재해위험지구별 주민대피계획 ... 137 세대 6 개소 수용인원 539 명', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0027'};
MATCH (a:ResponseAction {name: '재해위험지구별 주민대피계획'}), (b:RiskFactor {name: '상습침수 위험'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {phase: 'preparedness', timing: '사전', evidence: '상습침수(2 등급) ... 영진지구 뒷불지구 강문지구', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0028'};
MATCH (a:Region {name: '영진지구'}), (b:Region {name: '연곡면'}) MERGE (a)-[r:LOCATED_IN]->(b) SET r += {shelter: '강원도립대학', evidence: '상습침수(2 등급) ... 영진지구 ... 연곡면 ... 강원도립대학 ... 영진 2 리', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0029'};
MATCH (a:Region {name: '낙풍지구'}), (b:Region {name: '옥계면'}) MERGE (a)-[r:LOCATED_IN]->(b) SET r += {shelter: '옥계초등학교', evidence: '상습침수(1 등급) ... 낙풍지구 ... 옥계면 낙풍리 일원 ... 옥계초등학교', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0030'};
MATCH (a:Region {name: '남산지구'}), (b:RiskFactor {name: '붕괴위험'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {phase: 'preparedness', evidence: '붕괴위험(2 등급) ... 남산지구 ... 남산주택가 내곡 1 통 ... 남산초등학교', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0031'};
MATCH (a:Region {name: '주문진지구'}), (b:RiskFactor {name: '붕괴위험'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {phase: 'preparedness', evidence: '붕괴위험(1 등급) ... 주문진지구 ... 주문진읍 주문 12 리 ... 주영초등학교', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0032'};
MATCH (a:ResponseActor {name: '인명구조 단체'}), (b:ResponseAction {name: '인명구조 활동'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', role: '인명구조', evidence: '인명구조 단체현황 ... 동원가능인원 계 ... 400', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0033'};
MATCH (a:ResponseActor {name: '해병전우회'}), (b:ResponseAction {name: '인명구조 활동'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', role: '인명구조', evidence: '해병전우회 옥천동 265 번지 최삼순 300', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0034'};
MATCH (a:ResponseActor {name: '산악구조대'}), (b:ResponseAction {name: '인명구조 활동'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', role: '산악 인명구조', evidence: '산악구조대 연곡면삼산 2 리 (청학산장) 김영복 7', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0035'};
MATCH (a:ResponseActor {name: '강원도수중협회'}), (b:ResponseAction {name: '수난구조 활동'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', role: '수난구조', evidence: '강원도수중협회 교 2 동 산 11 안택열 38', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0036'};
MATCH (a:ResponseAction {name: '경계구역 설정운용'}), (b:Damage {name: '산간계곡·하천변 인명피해'}) MERGE (a)-[r:PREVENTS]->(b) SET r += {phase: 'prevention', effectiveness: 'Med', mechanism: '행락객·주민 사전 대피', evidence: '경계구역 설정운용 ... 산간계곡, 하천변 유원지, 재해위험지구 등에서 빈발하는 인명피해 예방', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0037'};
MATCH (a:Region {name: '사근진 경계구역'}), (b:RiskFactor {name: '해일로 인한 인명피해·가옥침수'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {phase: 'preparedness', measure: '기상특보 발표시 감시공무원 배치', evidence: '현황: 2 개소(사근진 지구) → \'97. 6. 15 부터 ... 위치: 강릉시 안현동 3/4 사근진 해수욕장 ... 위험요인: 해일로 인한 인명피해, 가옥침수 예상지역', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0038'};
MATCH (a:Facility {name: '우량관측시설 자동화시스템'}), (b:Resilience {name: '방재 모니터링 역량'}) MERGE (a)-[r:BUILDS]->(b) SET r += {phase: 'preparedness', evidence: '우량관측시설 자동화시스템의 지속적보완 및 관리 → 8 개소', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0039'};
MATCH (a:Facility {name: '수위관측시설 자동화시스템'}), (b:Resilience {name: '방재 모니터링 역량'}) MERGE (a)-[r:BUILDS]->(b) SET r += {phase: 'preparedness', evidence: '수위관측시설 자동화시스템 구축 → 1 개소(연곡면 행신교)', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0040'};
MATCH (a:ResponseAction {name: '재해위험지구 일원화 관리'}), (b:Other {name: '자연재해대책법 제26조 및 동시행령 제27조'}) MERGE (a)-[r:GUIDED_BY]->(b) SET r += {reason: '법적 근거', evidence: '자연재해대책법 제 26 조 및 동시행령 제 27 조 ... 지구별 선정범위는 발생가능성, 발생주기, 지역형태 등을 감안 1~3 등급으로 구분관리', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0041'};
MATCH (a:Region {name: '재해위험지구 1등급'}), (b:RiskFactor {name: '상습침수·붕괴위험'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {phase: 'preparedness', monitoringFrequency: '수시', evidence: '1 등급(수시감시: 시장) → 옥계면 낙풍지구외 1 개소(상습침수 1, 붕괴위험 1)', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0042'};
MATCH (a:Region {name: '재해위험지구 2등급'}), (b:RiskFactor {name: '상습침수·붕괴위험'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {phase: 'preparedness', monitoringFrequency: '수시', evidence: '2 등급(수시감시: 시장) → 경포동 사근진지구외 4 개소(상습침수 3, 붕괴위험 1)', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0043'};
MATCH (a:ResponseAction {name: '방재시설물 개·보수'}), (b:RiskFactor {name: '방재시설물 붕괴·기능저하 위험'}) MERGE (a)-[r:MODIFIES_RISK_OF]->(b) SET r += {phase: 'mitigation', effectiveness: 'Med', mechanism: '노후·취약 시설물 사전 보수', evidence: '옹벽, 축대, 도로, 교량, 저수지, 소류지 등 재해위험 요인이 있는 시설물을 대상으로 매년 초 일제조사를 실시하여 우기 전(5.20)까지 개 · 보수 완료', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0044'};
MATCH (a:ResponseAction {name: '하천 제방 개·보수'}), (b:RiskFactor {name: '제방 붕괴 위험'}) MERGE (a)-[r:MODIFIES_RISK_OF]->(b) SET r += {phase: 'mitigation', mechanism: '제방 보강 및 통수단면 확보', evidence: '하천: 붕괴 예상 제방 개 · 보수, 유수소통 지장물 제거', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0045'};
MATCH (a:ResponseAction {name: '대규모 건설공사장 특별관리'}), (b:RiskFactor {name: '공사장 토사유출·하류 피해'}) MERGE (a)-[r:PREVENTS]->(b) SET r += {phase: 'prevention', mechanism: '토사유출·배수 관리 사전 조치', evidence: '골프장 조성, 고속도로, 댐건설, 택지조성, 기타 50억 이상 대규모 건설공사 장과 자연재해로 인하여 피해발생 우려 ... 하류지역 토사유출을 위한 충분한 침사지 설치', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0046'};
MATCH (a:ResponseActor {name: '강릉시 재해대책본부'}), (b:ResponseAction {name: '예비특보시 비상근무'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'preparedness', trigger: '예비특보 발령시', role: '비상근무 및 정보전파', evidence: '예비특보시 조치사항 〇 재해대책본부 비상근무 실시 〇 유관기관에 정보 전파', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0047'};
MATCH (a:ResponseActor {name: '강릉시 재해대책본부'}), (b:ResponseAction {name: '경보시 재해대비 조치'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {phase: 'response', trigger: '경보 발령시', role: '비상근무체제 강화 및 대피·구조 총괄', evidence: '경보시 재해대비 사전조치사항 ... 재해위험지구, 산사태 위험지역 주민대피 〇 인명구조 활동 실시 〇 사망자 및 부상자에 대한 의료조치 〇 이재민 구호 및 수용 실시', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0048'};
MATCH (a:Context {name: '호우주의보'}), (b:ResponseAction {name: '호우주의보 국민행동요령'}) MERGE (a)-[r:UNDER_CONDITION]->(b) SET r += {timing: '발령시', trigger: '호우 위험', evidence: '호우주의보： 24 시간 강우량이 80 ㎜이상 예상될 때 ... 저지대, 상습침수지역 등 재해 위험지구주민대피', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0049'};
