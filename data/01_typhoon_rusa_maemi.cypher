MATCH (a:Event {name: '강릉지역 집중호우'}), (b:Damage {name: '태풍 루사 강릉지역 농경지 피해'}) MERGE (a)-[r:CAUSES]->(b) SET r += {directCause: '침수·유실', scale: '광범위', evidence: '○ 농경지 3,46Ua (전 1,567 /답 1,894) ○ 농작물 5,476/ia', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0237'};
MATCH (a:Event {name: '강릉지역 집중호우'}), (b:Damage {name: '태풍 루사 강릉지역 공공시설 피해'}) MERGE (a)-[r:CAUSES]->(b) SET r += {directCause: '도로·하천·수리시설 유실 및 파손', scale: '1,141개소 공공시설', evidence: '○ 공공시설 1,141 개소 ... 623,533 백만원 ▶기타(농어촌도로 등) 198 개소 188,309 백만원', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0238'};
MATCH (a:Event {name: '강릉지역 집중호우'}), (b:Damage {name: '태풍 루사 강릉지역 총 수해 피해액'}) MERGE (a)-[r:CAUSES]->(b) SET r += {directCause: '수해 총피해액 집계', scale: '거의 1조원', evidence: '우리시의 태풍피해액은 지금까지 잠정적으로 3 천 39 억 5 천 6 백여만원으로 추계되고 있습니다 ... 거의 1 조원에 달하는 엄청난 피해를 가져왔다.', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0239'};
MATCH (a:Facility {name: '장현저수지'}), (b:Damage {name: '신석동 일대 가옥 유실·침수 피해'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {mechanism: '제방 취약으로 범람 시 하류 가옥 피해 증폭', reason: '제방 20m 붕괴로 급류 발생', evidence: '장현 저수지가 범람하면서 제방 20m 가 붕괴돼 순식간에 신석동 일대 20 여 가구가 물에 휩쓸리고', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0240'};
MATCH (a:ResponseAction {name: '긴급대피방송 및 사이렌 발령'}), (b:Event {name: '장현저수지 수위 상승 및 범람'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {timing: '저수지 범람 직전', role: '주민 경보·대피 유도', evidence: '장현 저수지의 수위가 상승해 인근마을에는 긴급대피방송과 함께 싸이렌 소리는 강릉 전역에 울려 퍼졌다.', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0241'};
MATCH (a:ResponseActor {name: '공무원·군인·소방대원'}), (b:ResponseAction {name: '인근주민 긴급 대피·구조'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '인근주민 약 2천명 긴급 대피·구조보트 활용', phase: 'response', evidence: '공무원과 군인, 소방대원들은 인근주민 2 천여명을 긴급히 대피시키고 ... 노인들은 구조보트를 이용해 안전한 곳으로 옮기기도 했다.', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0242'};
MATCH (a:ResponseAction {name: '오봉댐 원수관 복구공사'}), (b:Event {name: '오봉댐 원수관 파열·강릉 전역 단수'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {role: '급수 복구', timing: '복구 초기', evidence: '우선 시급한 급수난을 위해 오봉댐 원수관 공사는 야간에도 계속되고', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0243'};
MATCH (a:ResponseAction {name: '소방차·헬기 동원 식수·구호품 공급'}), (b:Event {name: '오봉댐 원수관 파열·강릉 전역 단수'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {role: '고립·단수 대응', scale: '소방차 115대, 헬기 6대', evidence: '소방차 115 대가 동원돼 지역민들에게 식수를 공급하고 ... 소방헬기와 산림청, 군 헬기 등 6 대가 동원돼 고립 된 마을에 ... 구호품, 유류, 사료 등이 전달됐다.', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0244'};
MATCH (a:ResponseAction {name: '읍면동별 방역작업'}), (b:RiskFactor {name: '태풍 후 전염병 발생 위험'}) MERGE (a)-[r:PREVENTS]->(b) SET r += {role: '2차 보건 피해 예방', effectiveness: 'Med', evidence: '태풍으로 인한 전염병 발생을 막기 위해 각 읍면동별로 일제히 방역작업이 시작됐고', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0245'};
MATCH (a:ResponseAction {name: '민관군 합동 복구작업'}), (b:Event {name: '강릉 저지대 침수'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {role: '응급복구', effectiveness: 'High', evidence: '주민과 공무원, 군인, 자원봉사자들이 하나가 돼 침수가옥과 중앙시장에 양수기를 동원한 물 빼기 작업을 시작으로 ... 3〜4 일이 지나면서 집집마다 물이 나오고 전기가 들어오고', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0246'};
MATCH (a:ResponseActor {name: '제1야전군 장병'}), (b:ResponseAction {name: '민관군 합동 복구작업'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '재해 응급복구 선봉', effectiveness: 'High', specialNote: '군민일체 명제 아래 투입', evidence: '1 군사 장병들을 ... 태풍 루사 피해복구에 투입 ... 재해 응급복구가 훨씬 앞당겨진 것은 주지의 사실입니다.', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0247'};
MATCH (a:ResponseActor {name: '행정자치부'}), (b:ResponseAction {name: '태풍 루사 피해 합동조사반 운영'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '합동조사반 파견 및 피해조사', timing: '2002-09-05~09-11', evidence: '행정자치부에서는 태풍 피해로 인한 특별재해지역을 결정하기 위하여 합동조사반을 현지에 파견하여 피해조사를 하게 됩니다 ... 조사기간: 2002. 9. 5 - 9. 11 (7 일간) 조사방법: 현지전수조사', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0248'};
MATCH (a:ResponseActor {name: '대통령 김대중'}), (b:ResponseAction {name: '태풍 루사 특별재해지역 선포'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '특별재해지역 선포', timing: '2002-09-16 20:00', specialNote: '대통령 공고 제173호, 자연재해대책법 제62조의2 근거', evidence: '● 특별재해지역 선포 2002.9.16. 20:00 선포 【대통령 공고 제 173 호】 ... 자연재해대책법 제 62 조의 2 ... 에 의하여 제 15 호 태풍 「루사』 피해에 의한 특별재해지역을 ... 선포한다.', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0249'};
MATCH (a:ResponseAction {name: '태풍 루사 특별재해지역 선포'}), (b:Other {name: '자연재해대책법 제62조의2 및 동법시행령 제57조'}) MERGE (a)-[r:GUIDED_BY]->(b) SET r += {role: '법적 근거', reason: '특별재해지역 지정의 법령 근거', evidence: '자연재해대책법 제 62 조의 2 및 부칙 제 2 항, 동법시행령 제 57 조의 규정에 의하여', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0250'};
MATCH (a:NaturalHazard {name: '2002년 제15호 태풍 루사(RUSA)'}), (b:Damage {name: '태풍 루사 전국 재산피해'}) MERGE (a)-[r:CAUSES]->(b) SET r += {directCause: '전국 재산피해·이재민 발생', scale: '전국 5조4,697억원', evidence: '2002. 8. 30-9. 1 기간 중 제 15 호 태풍 「루사」로 인하여 전국에 걸쳐 5 조 4,697 억원(잠정)의 재산피해(이중사유시설 피해액 1 조 297 억원)와 55,000 여명의 이재민 발생', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0251'};
MATCH (a:ResponseActor {name: '강릉시'}), (b:ResponseAction {name: '수해 복구 예산 확보 및 항구복구 사업'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '수해복구 예산 확보·집행', scale: '총사업비 9,730억원', evidence: '【총사업비: 9,730 억원】 o 강릉시 집행(11 개분야) : 6,151 억원 o 유관기관 집행(9 개기관) : 3，140 억원 ... o 구호 및 생계지원비: 439 억원', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0252'};
MATCH (a:ResponseAction {name: '모든 시설물 안전기준 강화'}), (b:NaturalHazard {name: '2002년 제15호 태풍 루사(RUSA)'}) MERGE (a)-[r:PREVENTS]->(b) SET r += {role: '재난 재발 방지', effectiveness: 'Med', specialNote: '조기 주민대피 미흡에 대한 반성 포함', evidence: '이제 우리시에서는 모든 시설물의 안전기준을 한층 더 강화해 나감으로써, 다시는 이러한 재해가 발생하지 않도록 재난방지에 최선을 다해나가겠습니다.', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0253'};
MATCH (a:RiskFactor {name: '조기 주민대피 미흡'}), (b:Damage {name: '태풍 루사 강릉지역 인명피해'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {role: '인명피해 증가 요인', probability: 'High', evidence: '이러한 기상이변이 사전에 예측되어 주민대피가 좀 더 일찍 이루어졌더라면 하는 아쉬움도 있습니다.', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0254'};
MATCH (a:Other {name: '강원도 자연순응 산간계곡형 복구지침'}), (b:ResponseAction {name: '강릉 수해 항구복구 사업'}) MERGE (a)-[r:GUIDED_BY]->(b) SET r += {role: '복구방법 근거', reason: '자연생태·경관 고려 복구 원칙', evidence: '복구방법은 자연본래의 형상에 순응하고 ... 「강원도 자연순응 산간계곡형 복구지침」에 의거 복구', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0255'};
MATCH (a:ResponseAction {name: '장마기·집중호우 대비 2차 피해 예방대책'}), (b:RiskFactor {name: '도로 2차 붕괴위험'}) MERGE (a)-[r:PREVENTS]->(b) SET r += {role: '2차 피해 예방', effectiveness: 'Med', timing: '장마기·우기 대비', evidence: 'o 장마기 대비 2 차 피해 예방대책 강구 ... 집중호우 시 하천 통수단면 및 준설, 사토장 확보 등 수방대책 추진 ... 도로는 곳곳이 유실돼 2 차 붕괴위험에 노출돼 있었다.', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0256'};
MATCH (a:RiskFactor {name: '단기간 항구개량복구 부실시공'}), (b:ResponseAction {name: '강릉 수해 항구복구 사업'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {role: '복구품질 저하 위험', probability: 'Med', evidence: '단기간의 항구 개량복구 공사로 인한 부실시공 방지 대책을 강구할 것과', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0257'};
MATCH (a:ResponseActor {name: '태풍 루사 피해복구대책 특별위원회'}), (b:ResponseAction {name: '강릉 수해 항구복구 사업'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '복구 점검·감독 및 시정개선 촉구', phase: 'recovery', evidence: '제 15 호 태풍 루사 피해복구대책특별위원회 구성 ... 피해상황 및 복구 추진상황 종합 확인 ... 문제요인에 대한 시정 및 개선대책 강구', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0258'};
MATCH (a:NaturalHazard {name: '2003년 제14호 태풍 매미'}), (b:Damage {name: '태풍 매미 강릉지역 피해'}) MERGE (a)-[r:CAUSES]->(b) SET r += {directCause: '침수·시설 파손', scale: '루사 대비 소규모', evidence: '● 태풍 「매미」 피해현황 조사결과 ○ 인명피해 4 명 (사망 2, 실종 1，부상 1) ○ 이재민 353 세대 1，292 명 ○ 공공시설 936 개소 2,032 억원', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0259'};
MATCH (a:Population {name: '고립된 산간마을 주민'}), (b:Context {name: '다리 끊김·도로 유실로 고립된 산마을'}) MERGE (a)-[r:LOCATED_IN]->(b) SET r += {role: '노출 인구 소재지', evidence: '다리가 끊기고 길이 유실되어 고립된 산마을까지 ... 마을과 마을을 잇는 다리가 끊겨 고립된 마을', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0260'};
MATCH (a:ResponseAction {name: '이재민 임시거처 제공(마을회관·학교·컨테이너집)'}), (b:Damage {name: '신석동 일대 가옥 유실·침수 피해'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {role: '이재민 구호', scale: '3,900여명', evidence: '각 읍면동 마을회관과 학교 등 27 개소에 3,900 여명의 수재민이 대피해 있었다 ... 장현저수지 붕괴로 마을이 사라져 집을 잃은 주민들에게 컨테이너집이 설치되고는 있지만', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0261'};
MATCH (a:Event {name: '강릉지역 극한강우(태풍 루사)'}), (b:Damage {name: '강릉지역 홍수피해'}) MERGE (a)-[r:CAUSES]->(b) SET r += {directCause: '설계강우량 크게 초과', scale: '사상최대', specialNote: '불가항력적 요소가 큼', mechanism: '하천·상수도·도로 측구가 설계강우량 초과 홍수 감당 불가', evidence: '강릉지역은 24시간 강우량이 최고 944.5mm를 기록하였으며 1시간 최대 강우량도 113.5mm로서 강릉지역 홍수의 가장 큰 원인', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0262'};
MATCH (a:RiskFactor {name: '유목(流木) 대량 유입'}), (b:Event {name: '제방 범람 및 붕괴'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {mechanism: '교량에 걸려 통수단면 축소·수위 급증', consequence: '제방 범람·붕괴·유실', probability: 'High', evidence: '유목은 하천에 설치된 교량에 걸려 교량 위쪽부근의 수위가 급증, 제방이 범람하였다', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0263'};
MATCH (a:Event {name: '강릉지역 대형 산불'}), (b:RiskFactor {name: '유목(流木) 대량 유입'}) MERGE (a)-[r:TRIGGERS_SECONDARY]->(b) SET r += {mechanism: '벌채·간벌 방치목이 호우 시 유목으로 유실', timing: '후속 호우 시', evidence: '강릉지역의 대형 산불이 발생한 지역 계곡부에 벌채, 간벌 등에 의해 방치된 나무들과...산사태에 의해 붕괴된 사면에서 유실된 나무들이 토사와 함께 하천으로 대량 유입', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0264'};
MATCH (a:RiskFactor {name: '저수지 측구여수로 형식'}), (b:Event {name: '강릉지역 저수지 붕괴'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {reason: '태풍 루사 홍수량 감당 불가', consequence: '하류지역 막대한 피해 유발 가능', probability: 'High', specialNote: '재해가중요인', evidence: '여수로는 측구여수로 형식으로서 과도한 홍수량에는 적합하지 못한...설계안전도를 높이지 못한 것이 강릉지역 저수지 붕괴에 따른 재해가중요인', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0265'};
MATCH (a:Event {name: '동해안 고파고(하구 수면상승)'}), (b:Damage {name: '하구·경포호 침수피해'}) MERGE (a)-[r:AMPLIFIES]->(b) SET r += {mechanism: '홍수량 해양 유출 저해→호수 범람', consequence: '경포호 최대 2m 이상 침수심', timing: '하천 홍수피해 극심 시점', evidence: '하구지역에서 상당한 수면상승이 발생...경포호 지역은...호수를 범람함에 따라 최대 2m 이상 침수심을 기록', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0266'};
MATCH (a:Event {name: '토사·수목 해양 유입'}), (b:Damage {name: '연근해 수산업·생태계 피해'}) MERGE (a)-[r:CAUSES]->(b) SET r += {mechanism: '토사 퇴적→플랑크톤 번식 방해→생태계 변화', consequence: '물고기 소멸·수산업 피해', scale: '동해안 연안 및 해저 대부분 오염', evidence: '토사는 바다 밑에 퇴적되어 폴랑크톤의 번식을 방해하여 생태계의 변화로 인해 연근해에 물고기가 사라져 수산업에 상당한 피해', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0267'};
MATCH (a:RiskFactor {name: '홍수 저류기능 시설·면적 절대 부족'}), (b:Damage {name: '강릉지역 홍수피해'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {reason: '기상학적 요인 이외의 피해 원인', probability: 'High', evidence: '기상학적 요인이외의 피해 원인...홍수 시 저류 기능을 할 시설 및 면적의 절대 부족', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0268'};
MATCH (a:RiskFactor {name: '하천부지 인위적 변경·부적절한 하천시설 건설'}), (b:Event {name: '제방 범람 및 붕괴'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {reason: '순리에 어긋난 하천시설물', consequence: '제방 붕괴 직접 피해요인', probability: 'High', evidence: '순리에 어긋나게 설치된 하천시설물은...물길을 가로막아 하천수의 월류를 초래하여 제방이 붕괴되는 직접적인 피해요인', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0269'};
MATCH (a:RiskFactor {name: '도심 배수·유수지·하수관거 통수능 부족'}), (b:Event {name: '도심 내수 침수'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {reason: '기상학적 요인 이외 피해 원인', probability: 'High', evidence: '도심지 내수 침수 처리를 위한 배수 시설 미비...도심 유수지 부족 및 하수관거의 통수능 부족', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0270'};
MATCH (a:ResponseAction {name: '유목차단 스크린댐·토사유출 저감 사방댐 설치'}), (b:RiskFactor {name: '유목(流木) 대량 유입'}) MERGE (a)-[r:MITIGATES]->(b) SET r += {effectiveness: 'Med', reason: '하천 본류 유목 유입 방지', phase: 'prevention', evidence: '산사태 다발지역에 대해서는 하천 본류로 유목이 유입되지 않도록 유목 차단을 위한 스크린 댐이나 사방댐을 계곡에 설치하여야 한다', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0271'};
MATCH (a:ResponseAction {name: '교량 개선(교각 제거·경간 확대·내진보강)'}), (b:Event {name: '교량 파괴 및 제방 월류'}) MERGE (a)-[r:PREVENTS]->(b) SET r += {reason: '유목 걸림·교량 파괴 방지', effectiveness: 'Med', directCause: 'T형 교각 수압 좌굴', evidence: '교량은 설계 시 교각을 없애거나, 경간을 넓혀 유목과 같은 장애물이 차단되어 흐름을 방해하지 않도록 설계되어야한다...T형 교각보다...새로운 설계방식이 보완 도입', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0272'};
MATCH (a:ResponseAction {name: '하천준설 및 유로재조정'}), (b:Damage {name: '하폭축소로 인한 도로·제방·농경지 유실'}) MERGE (a)-[r:MITIGATES]->(b) SET r += {reason: '하폭축소로 인한 유실 방지', effectiveness: 'Med', phase: 'recovery', evidence: '하천의 흐름이 바뀌어 직강화 된...하천구간에서는 하폭축소로 인하여 도로, 제방, 농경지 등이 유실...자연 본래의 물길을 따라 하천폭을 최대한 넓게', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0273'};
MATCH (a:ResponseAction {name: '국가 안전관리 시스템·통합지휘본부 구축'}), (b:Event {name: '다기관 대응 혼란(경찰·군·민방위·자원봉사자)'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {reason: '기관간 지휘체계 혼란 방지', effectiveness: 'High', specialNote: '신속성·상호협력·일사불란한 지휘통솔이 핵심', evidence: '여러 기관으로부터의 인원을 일사불란하게 통솔할 수 있는 통합지휘본부의 역할이 매우 중요', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0274'};
MATCH (a:ResponseAction {name: '인명구조 작업'}), (b:Damage {name: '강릉지역 홍수피해'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {reason: '수해 국지적 급작 발생', effectiveness: 'Low', specialNote: '광역·지구단위 구조구난 전문기관 양성 필요', evidence: '인명구조 작업은...신속하고 안전하게...전문인력과 구조장비가 필요한 분야...광역단위 또는 지구단위로...구조구난 전문기관을 양성', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0275'};
MATCH (a:Resilience {name: '비상연락망(무전기·수신호) 확보'}), (b:Damage {name: '고립지역 구조·구호 지연 피해'}) MERGE (a)-[r:OFFSETS]->(b) SET r += {reason: '교통·통신·전기 두절 고립 대비', effectiveness: 'Med', specialNote: '주민대피 비상연락 미비 문제 보완', evidence: '기존 도보, 유선전화, 휴대전화 등의 통신망을 대체할 수 있는 비상연락망(무전기, 수신호 등) 확보가 우선적으로 고려', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0276'};
MATCH (a:Event {name: '교통·통신·전기 두절'}), (b:Damage {name: '산간오지 마을 고립'}) MERGE (a)-[r:CAUSES]->(b) SET r += {mechanism: '육상 접근로 두절로 구호품 전달 불가', consequence: '산간오지 마을 고립', specialNote: '헬기공수·고무보트 수상보급 필요', evidence: '교통과 통신, 전기마저 두절된 상황은 외부세계와의 완전한 고립을 의미...고립된 지역은 구조・구호요청, 생필품 조달 등이 일시 또는 상당기간 불가능', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0277'};
MATCH (a:ResponseAction {name: '긴급구호물품 선취득·복구장비 불시동원 지정'}), (b:Damage {name: '이재민 발생'}) MERGE (a)-[r:MITIGATES]->(b) SET r += {reason: '초기피해 최소화', effectiveness: 'Med', phase: 'preparedness', evidence: '예측 불가한 재난에 대비하여 긴급동원할 복구장비의 불시동원 지정과 긴급구호물품(의류, 식품 등)의 선취득(외상구매) 거래처 지정', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0278'};
MATCH (a:ResponseAction {name: '고립지역 해소 및 교통소통 확보'}), (b:Event {name: '도로 두절·고립'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {reason: '산사태·유실로 도로 두절', effectiveness: 'Med', timing: '재해발생 후 시급', evidence: '고립지역을 해소하고 구호물품이 도착할 수 있도록...교통소통이 매우 중요...장비 등의 진입로가 최우선적으로 확보되어야', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0279'};
MATCH (a:ResponseAction {name: '이재민 지원(컨테이너하우스·구호품)'}), (b:Damage {name: '이재민 발생'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {reason: '거주지 상실 이재민', effectiveness: 'High', actor: '강릉시', evidence: '강릉시에서는 컨테이너하우스 600여등을 긴급 지원하여 이재민 1,698명을 입주시키고 싱크대, 냉장고...공급하며 이재민들의 불편을 다소 해소', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0280'};
MATCH (a:ResponseActor {name: '강릉시'}), (b:ResponseAction {name: '이재민 지원(컨테이너하우스·구호품)'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '이재민 구호 주체', phase: 'recovery', evidence: '강릉시에서는 컨테이너하우스 600여등을 긴급 지원하여 이재민 1,698명을 입주', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0281'};
MATCH (a:ResponseAction {name: '철저한 위생관리·방역소독·보건교육'}), (b:Event {name: '수인성전염병(2차 재난)'}) MERGE (a)-[r:PREVENTS]->(b) SET r += {reason: '수인성전염병 발생 우려 열악 환경', effectiveness: 'High', consequence: '장티푸스·세균성이질 단 한건도 발생 안함', spreadRisk: 'High', evidence: '장티푸스, 세균성이질 등 수인성 전염병이 단 한건도 발생되지 않은 점은 초동대처를 능동적으로 수행...철저한 위생관리 및 환경조성...보건교육', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0282'};
MATCH (a:ResponseAction {name: '최소부락단위 응급의료체계 구축'}), (b:Resilience {name: '오지지역 응급의료 회복역량'}) MERGE (a)-[r:BUILDS]->(b) SET r += {reason: '고립지역 의료지원 운송수단 부족', effectiveness: 'Med', phase: 'preparedness', evidence: '최소부락단위 응급의료체계를 구축하여야 하며, 이를 위한 혈압계, 혈당측정기 등 기본필요장비와 응급약품 및 방역 소독약품을 리별로 확보', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0283'};
MATCH (a:RiskFactor {name: '사유시설 복구비 지원기준 불명확·형평성 논란'}), (b:Damage {name: '복구비 지원 혼란'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {reason: '복구사업비 지원 적용 혼란', effectiveness: 'Low', phase: 'recovery', evidence: '사유시설은 시설물의 종류와 규모에 따라 지원기준이 각기 상이하여 적용에 상당한 혼란이 있으며, 지원기준의 형평성에 대한 논란이 많은 분야', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0284'};
MATCH (a:ResponseAction {name: '하천제방 개량복구(원인 근본 차단)'}), (b:Event {name: '제방 피해 재발(악순환)'}) MERGE (a)-[r:MITIGATES]->(b) SET r += {reason: '원상복구 시 피해 재발', effectiveness: 'High', phase: 'recovery', specialNote: '방재관리 기초시설', evidence: '원상으로 복구된 제방은 수년 내에 피해가 재발하는 악순환...수해원인을 근본적으로 차단할 수 있는 방안의 시행이 필요...개량복구로 추진되어야', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0285'};
MATCH (a:RiskFactor {name: '잦은 집중호우(루사·매미·메기 반복)'}), (b:Damage {name: '도심 재침수 피해'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {reason: '기후변화에 의한 잦은 집중호우', probability: 'High', specialNote: '과거 통계 기반 하수시설 무용', evidence: '태풍으로 인한 집중호우가 자주 반복하여 앞으로도 재침수가 있을 것으로 예상...기후변화에 의한 잦은 집중호우에 대비한 노선이 검토', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0286'};
MATCH (a:ResponseAction {name: '침수지역 대책사업(펌프장·관로확장·암거연장)'}), (b:Damage {name: '도심 재침수 피해'}) MERGE (a)-[r:PREVENTS]->(b) SET r += {reason: '상습 재침수 영구 대비', effectiveness: 'High', consequence: '태풍 메기 시 동해상사 주변 한 건물도 침수 안됨', evidence: '환경부와 행정자치부로부터 12,850백만원의 복구비를 지원...이러한 시설로 2004년 8월에 발생한 태풍메기의 엄청난 시우량에도 동해상사주변은 한 건물도 침수되지 않았다', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0287'};
MATCH (a:Event {name: '남대천 수위상승 역류현상'}), (b:Damage {name: '구 공설운동장·주택가 침수'}) MERGE (a)-[r:CAUSES]->(b) SET r += {mechanism: '하수관로 역류→배수 불가→장시간 침수', consequence: '운동장 전체 저류지화', evidence: '남대천 수위상승에 의하여 남대천으로부터 역류현상이 발생하여 하천수가 하수맨홀로 용출되어 범람...운동장전체가 저류지가 되어 장시간 침수', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0288'};
MATCH (a:RiskFactor {name: '전답(저류조 역할) 소실'}), (b:Damage {name: '구 공설운동장·주택가 침수'}) MERGE (a)-[r:INCREASES_RISK_OF]->(b) SET r += {reason: '저류조 역할 전답 소실로 우수 일시 유출', probability: 'High', evidence: '유산~내곡간 도로개설과 한라아파트 등의 건설로 저류조 역할을 하던 전답이 없어져 일시에 많은 우수가 유출되어...침수현상이 발생', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0289'};
MATCH (a:ResponseAction {name: '주택복구'}), (b:Damage {name: '주택피해'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {phase: 'recovery', effectiveness: 'Med', specialNote: '피해조사·대상자 선정 혼란, 컨테이너 난립 도시경관 훼손', evidence: '주택복구...복구동수 8,051동...복구금액 39,106백만원...피해동수 8,051동...피해액 30,869백만원', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0290'};
MATCH (a:ResponseAction {name: '농작물·농경지 복구'}), (b:Damage {name: '농경지·농업시설 피해'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {phase: 'recovery', effectiveness: 'Med', specialNote: '복구비 산정단가·지원비율 낮아 복구포기 다수', evidence: '피해농경지 3,461㏊에 대하여...2,647㏊에 대하여 복구를 완료...675㏊에 81백만원의 농약대...4,109㏊에 5,661백만원의 대파대', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0291'};
MATCH (a:ResponseAction {name: '태풍피해주택 신축 자매결연 지원'}), (b:Population {name: '거처 상실 피해주민'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {phase: 'recovery', effectiveness: 'High', role: '주거안정 도모', actor: '강릉시 공무원', evidence: '신축복구대상자와 공무원 간에 1:1 자매결연을 맺어 거처를 잃은 피해주민들에게 복구지침 및 지원기준을 상세히 안내...주거안정을 도모', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0292'};
MATCH (a:ResponseAction {name: '관광지 피해복구·쓰레기 수거'}), (b:Damage {name: '관광지 피해'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {phase: 'recovery', effectiveness: 'High', reason: '해변 백사장 나무·폐기물 자연경관 훼손', evidence: '태풍 루사에 위한 관광지 피해는 총 33건에 814,000천원...경포해변을 시작으로...쓰레기 수거작업...원상복구를 완료', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0293'};
MATCH (a:ResponseAction {name: '관광객 유치 마케팅(보은세일·특별열차·현지홍보)'}), (b:Damage {name: '지역경제 침체(관광객 감소)'}) MERGE (a)-[r:RESPONDS_TO]->(b) SET r += {phase: 'recovery', effectiveness: 'High', reason: '수해 이후 지역경기 침체 장기화', role: '지역경제 활성화', evidence: '수해발생 이후 발길이 끊겨 지역경기 침체가 장기화...관광객 유치를 통한 지역경제 활성화...10월 31일자 관광객 이동현황은 총 17,713,524명으로서...32%정도 증가', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0294'};
MATCH (a:Other {name: '강원도 자연순응 산간계곡형 복구지침'}), (b:ResponseAction {name: '수해복구사업(항구복구)'}) MERGE (a)-[r:GUIDED_BY]->(b) SET r += {role: '복구방법 근거 지침', phase: 'recovery', evidence: '복구방법은 자연본래의 형상에 순응하고...「강원도 자연순응 산간계곡형 복구지침」에 의거 복구', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0295'};
MATCH (a:ResponseActor {name: '강원도'}), (b:ResponseActor {name: '강릉시'}) MERGE (a)-[r:COMMANDS]->(b) SET r += {role: '재침수방지 공사 기한 지시(6월 30일 전 완공)', phase: 'recovery', evidence: '강원도에서는 어떠한 일이 있더라도 재침수방지를 위하여 6월 30일전에 공사를 완공하도록 지시', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0296'};
MATCH (a:ResponseActor {name: '자원봉사자'}), (b:ResponseAction {name: '사유시설·농축산물 수작업 복구'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '수작업 복구 지원', phase: 'recovery', specialNote: '침수주택정리·청소·빨래·잔해물 정리·농작물복구', evidence: '사유시설과 농축산물은 대부분 수작업...많은 인력이 필요하다. 자원봉사자들의 적극적인 참여와 관심이 요구', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0297'};
MATCH (a:ResponseActor {name: '대한적십자사'}), (b:ResponseActor {name: '강릉시'}) MERGE (a)-[r:COORDINATES_WITH]->(b) SET r += {role: '구호물자 협업 공급', phase: 'recovery', evidence: '이재민에게 지급한 각종구호품은 대한적십자사, 전국재해대책협의회, 공공단체 구호물자와...민간단체(개인)의 재해의연성품으로 충당', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0298'};
MATCH (a:ResponseActor {name: '육군 제1901부대'}), (b:ResponseAction {name: '수해복구사업(항구복구)'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '수해복구 인력 지원', phase: 'recovery', evidence: '수해복구에 적극 협조해 주신 육군 제1901부대 장병', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0299'};
