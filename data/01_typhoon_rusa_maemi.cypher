MATCH (a:ResponseActor {name: '한국통신(KT) 강릉지사'}), (b:ResponseAction {name: '피해주민 전화기 무료배부'}) MERGE (a)-[r:PERFORMS]->(b) SET r += {role: '피해주민 전화기 무료배부', phase: 'recovery', evidence: '피해주민전화기 무료배부 ... 한국통신(KT) 강릉지사/ 1,700 대 ... 삼성전자 / 384 대', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0212'};
