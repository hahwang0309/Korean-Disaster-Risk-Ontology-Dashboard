MATCH (a:Event {name: '강릉지역 집중호우'}), (b:Context {name: '2002-08-31 1일 강수량 870.5mm'}) MERGE (a)-[r:OCCURS_AT]->(b) SET r += {timing: '2002-08-31 새벽 5시 시작', evidence: '한 시간에 내린 비의 양이 100.5mm，1 일 강우량은 898mm 였습니다. 연간 강수량이 1,300~1,400mm 라는 점을 감안하면 폭우의 위력을 짐작하실 수 있을 것입니다.', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0223'};
MATCH (a:Event {name: '강릉지역 집중호우'}), (b:Event {name: '강릉 저지대 침수'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {mechanism: '저지대 우수 집중으로 침수 발생', phase: '1차 연쇄', evidence: '동해상사에서 포남시장 사거리 등 강릉지역의 저지대 곳곳에 침수피해가 발생했다. 순식간에 가슴까지 물이 차올랐고 ... 수천대의 차량들이 물에 잠겼고', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0224'};
MATCH (a:Event {name: '강릉지역 집중호우'}), (b:Event {name: '남대천 범람'}) MERGE (a)-[r:CASCADES_INTO]->(b) SET r += {mechanism: '하천 유량 급증으로 범람', phase: '1차 연쇄', evidence: '강릉의 젖줄인 남대천도 이 비에 범람해 어디가 주차장이고, 어디가 하천인지… 차량들이 물에 마구 뒤엉켜 있었다.', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0225'};
MATCH (a:Event {name: '강릉지역 집중호우'}), (b:Event {name: '산사태로 인한 도로 유실·매몰'}) MERGE (a)-[r:TRIGGERS_SECONDARY]->(b) SET r += {mechanism: '강우로 인한 사면 붕괴', phase: '2차촉발', evidence: '동해고속도로를 비롯한 35 번국도 등 강릉을 연결하는 도로들이 유실되거나 갑작스런 산사태로 인해 이곳을 지나던 차량들이 매몰되는 사고가 발생했다.', sourceDoc: '수해백서_루사매미(강릉시 2005)', tripleId: 'T0226'};
